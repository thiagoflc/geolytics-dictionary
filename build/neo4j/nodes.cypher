MERGE (n_gso_Reverse_Fault:GSOClass {id: 'gso_Reverse_Fault'})
  ON CREATE SET n_gso_Reverse_Fault += {id: 'gso_Reverse_Fault', gso_class: 'Reverse_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Reverse_Fault', pref_label_en: 'reverse fault', definition_en_canonical: 'Fault with dip-parallel displacement component of slip vector more than 10 times the strike-parallel component of the slip vector at at least one location along the mapped trace of the fault, and the fault dips consistently in the same direction with the hanging wall displaced up relative to the footwall over at least half the mapped trace of the fault.', parents: ['gsfa:Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Reverse_Fault += {id: 'gso_Reverse_Fault', gso_class: 'Reverse_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Reverse_Fault', pref_label_en: 'reverse fault', definition_en_canonical: 'Fault with dip-parallel displacement component of slip vector more than 10 times the strike-parallel component of the slip vector at at least one location along the mapped trace of the fault, and the fault dips consistently in the same direction with the hanging wall displaced up relative to the footwall over at least half the mapped trace of the fault.', parents: ['gsfa:Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Reverse_Sinistral:GSOClass {id: 'gso_Reverse_Sinistral'})
  ON CREATE SET n_gso_Reverse_Sinistral += {id: 'gso_Reverse_Sinistral', gso_class: 'Reverse_Sinistral', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Reverse_Sinistral', pref_label_en: 'reverse sinistral', definition_en_canonical: 'The movement sense includes both reverse and sinistral components.', parents: ['gsfa:Reverse', 'gsfa:Sinistral'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Reverse_Sinistral += {id: 'gso_Reverse_Sinistral', gso_class: 'Reverse_Sinistral', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Reverse_Sinistral', pref_label_en: 'reverse sinistral', definition_en_canonical: 'The movement sense includes both reverse and sinistral components.', parents: ['gsfa:Reverse', 'gsfa:Sinistral'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Right_Normal_Fault:GSOClass {id: 'gso_Right_Normal_Fault'})
  ON CREATE SET n_gso_Right_Normal_Fault += {id: 'gso_Right_Normal_Fault', gso_class: 'Right_Normal_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Right_Normal_Fault', pref_label_en: 'right normal fault', definition_en_canonical: 'High angle fault with slip vector that has ratio of strike-parallel to dip-parallel displacement between 10 to 1 and 1 to 10 at at least one location along the mapped trace, with right-lateral strike-parallel component and normal dip-parallel component of slip over at least half the mapped trace of the fault', parents: ['gsfa:Oblique_Slip_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Right_Normal_Fault += {id: 'gso_Right_Normal_Fault', gso_class: 'Right_Normal_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Right_Normal_Fault', pref_label_en: 'right normal fault', definition_en_canonical: 'High angle fault with slip vector that has ratio of strike-parallel to dip-parallel displacement between 10 to 1 and 1 to 10 at at least one location along the mapped trace, with right-lateral strike-parallel component and normal dip-parallel component of slip over at least half the mapped trace of the fault', parents: ['gsfa:Oblique_Slip_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Right_Reverse_Fault:GSOClass {id: 'gso_Right_Reverse_Fault'})
  ON CREATE SET n_gso_Right_Reverse_Fault += {id: 'gso_Right_Reverse_Fault', gso_class: 'Right_Reverse_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Right_Reverse_Fault', pref_label_en: 'right reverse fault', definition_en_canonical: 'High angle fault with slip vector that has ratio of strike-parallel to dip-parallel displacement between 10 to 1 and 1 to 10 at at least one location along the mapped trace, with a right-lateral strike-parallel component and reverse dip-parallel component of slip over at least half the mapped trace of the fault.', parents: ['gsfa:Oblique_Slip_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Right_Reverse_Fault += {id: 'gso_Right_Reverse_Fault', gso_class: 'Right_Reverse_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Right_Reverse_Fault', pref_label_en: 'right reverse fault', definition_en_canonical: 'High angle fault with slip vector that has ratio of strike-parallel to dip-parallel displacement between 10 to 1 and 1 to 10 at at least one location along the mapped trace, with a right-lateral strike-parallel component and reverse dip-parallel component of slip over at least half the mapped trace of the fault.', parents: ['gsfa:Oblique_Slip_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Scissor_Fault:GSOClass {id: 'gso_Scissor_Fault'})
  ON CREATE SET n_gso_Scissor_Fault += {id: 'gso_Scissor_Fault', gso_class: 'Scissor_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Scissor_Fault', pref_label_en: 'scissor fault', definition_en_canonical: 'A fault on which there is increasing offset or separation along the strike from an initial point of no offset, with the opposite sense of offset in the opposite direction.', parents: ['gsfa:Fault'], sources: ['Neuendorf et al 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Scissor_Fault += {id: 'gso_Scissor_Fault', gso_class: 'Scissor_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Scissor_Fault', pref_label_en: 'scissor fault', definition_en_canonical: 'A fault on which there is increasing offset or separation along the strike from an initial point of no offset, with the opposite sense of offset in the opposite direction.', parents: ['gsfa:Fault'], sources: ['Neuendorf et al 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Scissor_Movement:GSOClass {id: 'gso_Scissor_Movement'})
  ON CREATE SET n_gso_Scissor_Movement += {id: 'gso_Scissor_Movement', gso_class: 'Scissor_Movement', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Scissor_Movement', pref_label_en: 'scissor', definition_en_canonical: 'A fault on which there is increasing offset or separation along the strike from an initial point of no offset, with reverse offset in the opposite direction.', parents: ['gsfa:Fault_Movement_Sense'], sources: ['Neuendorf et al 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Scissor_Movement += {id: 'gso_Scissor_Movement', gso_class: 'Scissor_Movement', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Scissor_Movement', pref_label_en: 'scissor', definition_en_canonical: 'A fault on which there is increasing offset or separation along the strike from an initial point of no offset, with reverse offset in the opposite direction.', parents: ['gsfa:Fault_Movement_Sense'], sources: ['Neuendorf et al 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Sinistral:GSOClass {id: 'gso_Sinistral'})
  ON CREATE SET n_gso_Sinistral += {id: 'gso_Sinistral', gso_class: 'Sinistral', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Sinistral', pref_label_en: 'sinistral', definition_en_canonical: 'In plan view the side opposite the observer is displaced to the left.', parents: ['gsfa:Fault_Movement_Sense'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
