MERGE (n_gso_intersection_lineation:GSOClass {id: 'gso_intersection_lineation'})
  ON CREATE SET n_gso_intersection_lineation += {id: 'gso_intersection_lineation', gso_class: 'intersection_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/intersection_lineation', pref_label_en: 'intersection lineation', definition_en_canonical: 'A lineation produced by the intersection of two planar fabrics.', parents: ['gsos:Lineation'], sources: ['Neuendorf et al 2005, CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_intersection_lineation += {id: 'gso_intersection_lineation', gso_class: 'intersection_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/intersection_lineation', pref_label_en: 'intersection lineation', definition_en_canonical: 'A lineation produced by the intersection of two planar fabrics.', parents: ['gsos:Lineation'], sources: ['Neuendorf et al 2005, CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_mineral_lineation:GSOClass {id: 'gso_mineral_lineation'})
  ON CREATE SET n_gso_mineral_lineation += {id: 'gso_mineral_lineation', gso_class: 'mineral_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/mineral_lineation', pref_label_en: 'mineral lineation', definition_en_canonical: 'Lineation defined by alignment of elongate crystals that have a prismatic crystal habit or of monomineralic grain aggregates.', parents: ['gsol:particle_shape_lineation'], sources: ['Neuendorf et al 2005, CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
