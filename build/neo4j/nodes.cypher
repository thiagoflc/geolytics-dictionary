MERGE (n_gso_Sinistral_Strike_Slip_Fault:GSOClass {id: 'gso_Sinistral_Strike_Slip_Fault'})
  ON CREATE SET n_gso_Sinistral_Strike_Slip_Fault += {id: 'gso_Sinistral_Strike_Slip_Fault', gso_class: 'Sinistral_Strike_Slip_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Sinistral_Strike_Slip_Fault', pref_label_en: 'sinistral strike slip fault', definition_en_canonical: 'Fault with left-lateral strike-parallel displacement component of slip vector more than 10 times the dip-parallel component of the slip vector at at least one location along the fault, and left-lateral displacement over more than half the mapped trace of the fault.', parents: ['gsfa:Strike_Slip_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Sinistral_Strike_Slip_Fault += {id: 'gso_Sinistral_Strike_Slip_Fault', gso_class: 'Sinistral_Strike_Slip_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Sinistral_Strike_Slip_Fault', pref_label_en: 'sinistral strike slip fault', definition_en_canonical: 'Fault with left-lateral strike-parallel displacement component of slip vector more than 10 times the dip-parallel component of the slip vector at at least one location along the fault, and left-lateral displacement over more than half the mapped trace of the fault.', parents: ['gsfa:Strike_Slip_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

