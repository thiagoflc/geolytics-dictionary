MERGE (n_gso_Low_Angle_Normal_Fault:GSOClass {id: 'gso_Low_Angle_Normal_Fault'})
  ON CREATE SET n_gso_Low_Angle_Normal_Fault += {id: 'gso_Low_Angle_Normal_Fault', gso_class: 'Low_Angle_Normal_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Low_Angle_Normal_Fault', pref_label_en: 'low angle normal fault', definition_en_canonical: 'Fault that dips less than 45 degrees over more than half of the recognized extent of the fault with the hanging wall displaced from a structurally higher position relative to footwall rocks.', parents: ['gsfa:Low_Angle_Fault', 'gsfa:Normal_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
