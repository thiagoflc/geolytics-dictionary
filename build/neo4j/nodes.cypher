MERGE (n_well_activity_phase_type:Entity:Operational {id: 'well-activity-phase-type'})
  ON CREATE SET n_well_activity_phase_type += {id: 'well-activity-phase-type', label: 'Fase da Atividade do Poço', label_en: 'Well Activity Phase Type', type: 'operational', definition: 'Marcos-chave em um programa de atividade de poço, geralmente baseados nas seções principais do poço ou em trabalhos não relacionados ao poço. (OSDU canonical: Key milestones in a well activity program, usually based on the major sections of the well or non well-related work.)', osdu_kind: 'opendes:osdu:reference-data--WellActivityPhaseType:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}
  ON MATCH SET n_well_activity_phase_type += {id: 'well-activity-phase-type', label: 'Fase da Atividade do Poço', label_en: 'Well Activity Phase Type', type: 'operational', definition: 'Marcos-chave em um programa de atividade de poço, geralmente baseados nas seções principais do poço ou em trabalhos não relacionados ao poço. (OSDU canonical: Key milestones in a well activity program, usually based on the major sections of the well or non well-related work.)', osdu_kind: 'opendes:osdu:reference-data--WellActivityPhaseType:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}

MERGE (n_drilling_reason_type:Entity:Operational {id: 'drilling-reason-type'})
  ON CREATE SET n_drilling_reason_type += {id: 'drilling-reason-type', label: 'Tipo de Razão de Perfuração', label_en: 'Drilling Reason Type', type: 'operational', definition: 'Usado para descrever o tipo de razão (motivo) de perfuração — explica por que um poço foi perfurado (exploratório, delimitatório, produtor, injetor, etc.). (OSDU canonical: Used to describe the type of drilling reasons.)', osdu_kind: 'opendes:osdu:reference-data--DrillingReasonType:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}
