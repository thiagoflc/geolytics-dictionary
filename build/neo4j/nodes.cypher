  ON CREATE SET n_gso_Transform_Fault += {id: 'gso_Transform_Fault', gso_class: 'Transform_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Transform_Fault', pref_label_en: 'transform', definition_en_canonical: 'A variety of strike-slip fault along which the displacement suddenly stops or changes form, typically associated with mid-ocean ridges.', parents: ['gsfa:Strike_Slip_Fault'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
