  ON MATCH SET n_correlacao_oleo_rocha += {id: 'correlacao-oleo-rocha', label: 'Correlação Óleo-Rocha', label_en: 'Oil-Source Correlation', type: 'analytical', definition: 'Análise que associa hidrocarbonetos produzidos à rocha geradora de origem via assinatura de biomarcadores e isótopos. M7 C107.', geocoverage: ['layer6'], sources: ['GEOQWIN']}

MERGE (n_litologia:Entity:Analytical {id: 'litologia'})
  ON CREATE SET n_litologia += {id: 'litologia', label: 'Litologia', label_en: 'Lithology', type: 'analytical', definition: 'Classificação composicional da rocha. Pode ser inferida por ML (RockFinder/GDA). NÃO confundir com formação (FOR ≠ ROC em PetroGold). M8 C201.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Lithology', osdu_kind: 'opendes:osdu:reference-data--LithologyType:1.0.0', owl_uri: 'https://w3id.org/osdu#LithologyType', geocoverage: ['layer1', 'layer2', 'layer3', 'layer4', 'layer6'], sources: ['GDA / RockFinder']}
  ON MATCH SET n_litologia += {id: 'litologia', label: 'Litologia', label_en: 'Lithology', type: 'analytical', definition: 'Classificação composicional da rocha. Pode ser inferida por ML (RockFinder/GDA). NÃO confundir com formação (FOR ≠ ROC em PetroGold). M8 C201.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Lithology', osdu_kind: 'opendes:osdu:reference-data--LithologyType:1.0.0', owl_uri: 'https://w3id.org/osdu#LithologyType', geocoverage: ['layer1', 'layer2', 'layer3', 'layer4', 'layer6'], sources: ['GDA / RockFinder']}

MERGE (n_facies_sedimentar:Entity:Analytical {id: 'facies-sedimentar'})
  ON CREATE SET n_facies_sedimentar += {id: 'facies-sedimentar', label: 'Fácies Sedimentar', label_en: 'Sedimentary Facies', type: 'analytical', definition: 'Unidade rochosa com características físicas e biológicas distintas — base de classificação de reservatório. M8 C203.', geocoverage: ['layer2', 'layer6'], sources: ['Petrobras / GeoCore']}
  ON MATCH SET n_facies_sedimentar += {id: 'facies-sedimentar', label: 'Fácies Sedimentar', label_en: 'Sedimentary Facies', type: 'analytical', definition: 'Unidade rochosa com características físicas e biológicas distintas — base de classificação de reservatório. M8 C203.', geocoverage: ['layer2', 'layer6'], sources: ['Petrobras / GeoCore']}

MERGE (n_modelo_petrofisico:Entity:Analytical {id: 'modelo-petrofisico'})
  ON CREATE SET n_modelo_petrofisico += {id: 'modelo-petrofisico', label: 'Modelo Petrofísico', label_en: 'Petrophysical Model', type: 'analytical', definition: 'Integra perfis (Den, Neu, Son, NMR) para calcular φ, k, Sw via equação de Archie. M8 C208.', geocoverage: ['layer6'], sources: ['GDA']}
  ON MATCH SET n_modelo_petrofisico += {id: 'modelo-petrofisico', label: 'Modelo Petrofísico', label_en: 'Petrophysical Model', type: 'analytical', definition: 'Integra perfis (Den, Neu, Son, NMR) para calcular φ, k, Sw via equação de Archie. M8 C208.', geocoverage: ['layer6'], sources: ['GDA']}

MERGE (n_campo_tensional:Entity:Analytical {id: 'campo-tensional'})
  ON CREATE SET n_campo_tensional += {id: 'campo-tensional', label: 'Campo Tensional', label_en: 'In-Situ Stress Field', type: 'analytical', definition: 'Conjunto Sv (vertical), SHmax (horizontal máximo), Shmin (horizontal mínimo). Base do modelo geomecânico. M9 C303.', geocoverage: ['layer6'], sources: ['GEOMECBR / GERESIM']}
  ON MATCH SET n_campo_tensional += {id: 'campo-tensional', label: 'Campo Tensional', label_en: 'In-Situ Stress Field', type: 'analytical', definition: 'Conjunto Sv (vertical), SHmax (horizontal máximo), Shmin (horizontal mínimo). Base do modelo geomecânico. M9 C303.', geocoverage: ['layer6'], sources: ['GEOMECBR / GERESIM']}

MERGE (n_janela_lama:Entity:Analytical {id: 'janela-lama'})
  ON CREATE SET n_janela_lama += {id: 'janela-lama', label: 'Janela de Lama', label_en: 'Mud Weight Window', type: 'analytical', definition: 'Intervalo seguro de peso de lama: limite inferior=colapso (breakout), limite superior=fratura (perda circulação). NÃO confundir com Janela de Geração (Ro%). M9 C309.', geocoverage: ['layer6'], sources: ['GEOMECBR']}
  ON MATCH SET n_janela_lama += {id: 'janela-lama', label: 'Janela de Lama', label_en: 'Mud Weight Window', type: 'analytical', definition: 'Intervalo seguro de peso de lama: limite inferior=colapso (breakout), limite superior=fratura (perda circulação). NÃO confundir com Janela de Geração (Ro%). M9 C309.', geocoverage: ['layer6'], sources: ['GEOMECBR']}

MERGE (n_ocorrencia_geomec:Entity:Analytical {id: 'ocorrencia-geomec'})
  ON CREATE SET n_ocorrencia_geomec += {id: 'ocorrencia-geomec', label: 'Ocorrência Geomecânica', label_en: 'Geomechanical Event', type: 'analytical', definition: 'Eventos: breakouts, kick zones, lost circulation, stuck pipe. Indicadores de problemas operacionais. M9 C317.', geocoverage: ['layer6'], sources: ['GEOMECBR / Petrobras']}
  ON MATCH SET n_ocorrencia_geomec += {id: 'ocorrencia-geomec', label: 'Ocorrência Geomecânica', label_en: 'Geomechanical Event', type: 'analytical', definition: 'Eventos: breakouts, kick zones, lost circulation, stuck pipe. Indicadores de problemas operacionais. M9 C317.', geocoverage: ['layer6'], sources: ['GEOMECBR / Petrobras']}

MERGE (n_potencial_selante:Entity:Analytical {id: 'potencial-selante'})
  ON CREATE SET n_potencial_selante += {id: 'potencial-selante', label: 'Potencial Selante', label_en: 'Fault Sealing Potential', type: 'analytical', definition: 'Capacidade de falha reter HC — calculado por SGR (Shale Gouge Ratio), CSP e SSF no TrapTester. SGR > 18–20% = potencial selante. M9 C313.', geocoverage: ['layer6'], sources: ['TrapTester / Badley']}
  ON MATCH SET n_potencial_selante += {id: 'potencial-selante', label: 'Potencial Selante', label_en: 'Fault Sealing Potential', type: 'analytical', definition: 'Capacidade de falha reter HC — calculado por SGR (Shale Gouge Ratio), CSP e SSF no TrapTester. SGR > 18–20% = potencial selante. M9 C313.', geocoverage: ['layer6'], sources: ['TrapTester / Badley']}

MERGE (n_amostra_fluido:Entity:Analytical {id: 'amostra-fluido'})
  ON CREATE SET n_amostra_fluido += {id: 'amostra-fluido', label: 'Amostra de Fluido', label_en: 'Fluid Sample', type: 'analytical', definition: 'Amostra de óleo/gás/água coletada para análise laboratorial. M10 CL_AMOSTRA.', osdu_kind: 'opendes:osdu:master-data--Sample:1.0.0', owl_uri: 'https://w3id.org/osdu#RockSample', geocoverage: ['layer4', 'layer6'], sources: ['LIMS Sample Manager']}
  ON MATCH SET n_amostra_fluido += {id: 'amostra-fluido', label: 'Amostra de Fluido', label_en: 'Fluid Sample', type: 'analytical', definition: 'Amostra de óleo/gás/água coletada para análise laboratorial. M10 CL_AMOSTRA.', osdu_kind: 'opendes:osdu:master-data--Sample:1.0.0', owl_uri: 'https://w3id.org/osdu#RockSample', geocoverage: ['layer4', 'layer6'], sources: ['LIMS Sample Manager']}

MERGE (n_pvt:Entity:Analytical {id: 'pvt'})
  ON CREATE SET n_pvt += {id: 'pvt', label: 'PVT', label_en: 'PVT Analysis', type: 'analytical', definition: 'Ensaios pressão-volume-temperatura: Flash, ECC, Liberação Diferencial, Viscosidade. Sistema SIRR (35 campos com completude documentada). M10 CL_PVT.', osdu_kind: 'opendes:osdu:work-product-component--WellborePressure:1.0.0', geocoverage: ['layer4', 'layer6'], sources: ['SIRR']}
  ON MATCH SET n_pvt += {id: 'pvt', label: 'PVT', label_en: 'PVT Analysis', type: 'analytical', definition: 'Ensaios pressão-volume-temperatura: Flash, ECC, Liberação Diferencial, Viscosidade. Sistema SIRR (35 campos com completude documentada). M10 CL_PVT.', osdu_kind: 'opendes:osdu:work-product-component--WellborePressure:1.0.0', geocoverage: ['layer4', 'layer6'], sources: ['SIRR']}

MERGE (n_classe_fluido:Entity:Analytical {id: 'classe-fluido'})
  ON CREATE SET n_classe_fluido += {id: 'classe-fluido', label: 'Classe de Fluido', label_en: 'Fluid Class', type: 'analytical', definition: 'Classificação operacional: black oil, óleo volátil, condensado, gás úmido, gás seco. Critérios: API e RGO. Sistema AIDA. M10 CL_CLASS_FLUIDO.', osdu_kind: 'opendes:osdu:reference-data--FluidType:1.0.0', owl_uri: 'https://w3id.org/osdu#FluidType', geocoverage: ['layer4', 'layer6'], sources: ['AIDA']}
  ON MATCH SET n_classe_fluido += {id: 'classe-fluido', label: 'Classe de Fluido', label_en: 'Fluid Class', type: 'analytical', definition: 'Classificação operacional: black oil, óleo volátil, condensado, gás úmido, gás seco. Critérios: API e RGO. Sistema AIDA. M10 CL_CLASS_FLUIDO.', osdu_kind: 'opendes:osdu:reference-data--FluidType:1.0.0', owl_uri: 'https://w3id.org/osdu#FluidType', geocoverage: ['layer4', 'layer6'], sources: ['AIDA']}

MERGE (n_gc_ms:Entity:Analytical {id: 'gc-ms'})
  ON CREATE SET n_gc_ms += {id: 'gc-ms', label: 'GC-MS', label_en: 'GC-MS SIM', type: 'analytical', definition: 'Cromatografia gasosa com espectrometria de massas para biomarcadores (Pr/Ph, hopanos, esteranos). M10 CL_GC_MS.', geocoverage: ['layer6'], sources: ['GEOQWIN']}
  ON MATCH SET n_gc_ms += {id: 'gc-ms', label: 'GC-MS', label_en: 'GC-MS SIM', type: 'analytical', definition: 'Cromatografia gasosa com espectrometria de massas para biomarcadores (Pr/Ph, hopanos, esteranos). M10 CL_GC_MS.', geocoverage: ['layer6'], sources: ['GEOQWIN']}

MERGE (n_sara:Entity:Analytical {id: 'sara'})
  ON CREATE SET n_sara += {id: 'sara', label: 'SARA', label_en: 'SARA', type: 'analytical', definition: 'Saturados/Aromáticos/Resinas/Asfaltenos — fracionamento do óleo bruto. Correlaciona com viscosidade e risco de deposição. M10 CL_SARA.', geocoverage: ['layer6'], sources: ['GEOQWIN']}
  ON MATCH SET n_sara += {id: 'sara', label: 'SARA', label_en: 'SARA', type: 'analytical', definition: 'Saturados/Aromáticos/Resinas/Asfaltenos — fracionamento do óleo bruto. Correlaciona com viscosidade e risco de deposição. M10 CL_SARA.', geocoverage: ['layer6'], sources: ['GEOQWIN']}

MERGE (n_wellbore:Entity:Operational {id: 'wellbore'})
  ON CREATE SET n_wellbore += {id: 'wellbore', label: 'Trecho Perfurado', label_en: 'Wellbore', type: 'operational', definition: 'Trecho físico perfurado de um poço. Um poço ANP (registro superficial + legal) pode ter múltiplos wellbores em caso de sidetrack ou completação multilateral. Na prática, 1 poço ANP sem sidetrack = 1 wellbore. OSDU separa formalmente Well (registro de superfície) de Wellbore (trecho perfurado físico). O número ANP POCO_NUM corresponde ao Well.WellID no OSDU; o wellbore é gerado automaticamente.', osdu_kind: 'opendes:osdu:master-data--Wellbore:1.0.0', owl_uri: 'https://w3id.org/osdu#Wellbore', geocoverage: ['layer2', 'layer3', 'layer4'], sources: ['ANP/BDP + OSDU master-data--Wellbore']}
  ON MATCH SET n_wellbore += {id: 'wellbore', label: 'Trecho Perfurado', label_en: 'Wellbore', type: 'operational', definition: 'Trecho físico perfurado de um poço. Um poço ANP (registro superficial + legal) pode ter múltiplos wellbores em caso de sidetrack ou completação multilateral. Na prática, 1 poço ANP sem sidetrack = 1 wellbore. OSDU separa formalmente Well (registro de superfície) de Wellbore (trecho perfurado físico). O número ANP POCO_NUM corresponde ao Well.WellID no OSDU; o wellbore é gerado automaticamente.', osdu_kind: 'opendes:osdu:master-data--Wellbore:1.0.0', owl_uri: 'https://w3id.org/osdu#Wellbore', geocoverage: ['layer2', 'layer3', 'layer4'], sources: ['ANP/BDP + OSDU master-data--Wellbore']}

MERGE (n_topo_formacional:Entity:Analytical {id: 'topo-formacional'})
  ON CREATE SET n_topo_formacional += {id: 'topo-formacional', label: 'Topo Formacional', label_en: 'Formation Top / Wellbore Marker', type: 'analytical', definition: 'Pick da profundidade (em MD — Measured Depth — e TVD — True Vertical Depth) em que o wellbore intercepta o topo de uma formação geológica. Dado fundamental em correlações estratigráficas entre poços e na construção de modelos de reservatórios 3D. Exemplo: Topo da Formação Barra Velha no poço 1-RJS-702-RJ a MD=4220m / TVD=4105m.', osdu_kind: 'opendes:osdu:work-product-component--WellboreMarker:1.0.0', owl_uri: 'https://w3id.org/osdu#WellboreMarkerSet', geocoverage: ['layer2', 'layer3', 'layer4'], sources: ['Relatórios de completação / OSDU WellboreMarker']}
  ON MATCH SET n_topo_formacional += {id: 'topo-formacional', label: 'Topo Formacional', label_en: 'Formation Top / Wellbore Marker', type: 'analytical', definition: 'Pick da profundidade (em MD — Measured Depth — e TVD — True Vertical Depth) em que o wellbore intercepta o topo de uma formação geológica. Dado fundamental em correlações estratigráficas entre poços e na construção de modelos de reservatórios 3D. Exemplo: Topo da Formação Barra Velha no poço 1-RJS-702-RJ a MD=4220m / TVD=4105m.', osdu_kind: 'opendes:osdu:work-product-component--WellboreMarker:1.0.0', owl_uri: 'https://w3id.org/osdu#WellboreMarkerSet', geocoverage: ['layer2', 'layer3', 'layer4'], sources: ['Relatórios de completação / OSDU WellboreMarker']}

MERGE (n_trajetoria_poco:Entity:Analytical {id: 'trajetoria-poco'})
  ON CREATE SET n_trajetoria_poco += {id: 'trajetoria-poco', label: 'Trajetória do Poço', label_en: 'Wellbore Trajectory', type: 'analytical', definition: 'Survey direcional do wellbore: sequência de medições de profundidade (MD), inclinação e azimute ao longo do trecho perfurado. Permite calcular a posição 3D real do poço (TVD, offsets Norte/Sul/Leste/Oeste). Diferencia poços verticais (inclinação ≈ 0°) de poços direcionais (inclinação > 30°) e poços horizontais (inclinação ≈ 90°). Essencial para visualização 3D de poços offshore e para o cálculo correto de pressão hidrostática.', osdu_kind: 'opendes:osdu:work-product-component--WellboreTrajectory:1.0.0', owl_uri: 'https://w3id.org/osdu#WellboreTrajectory', geocoverage: ['layer3', 'layer4'], sources: ['Relatórios de completação / OSDU WellboreTrajectory']}
  ON MATCH SET n_trajetoria_poco += {id: 'trajetoria-poco', label: 'Trajetória do Poço', label_en: 'Wellbore Trajectory', type: 'analytical', definition: 'Survey direcional do wellbore: sequência de medições de profundidade (MD), inclinação e azimute ao longo do trecho perfurado. Permite calcular a posição 3D real do poço (TVD, offsets Norte/Sul/Leste/Oeste). Diferencia poços verticais (inclinação ≈ 0°) de poços direcionais (inclinação > 30°) e poços horizontais (inclinação ≈ 90°). Essencial para visualização 3D de poços offshore e para o cálculo correto de pressão hidrostática.', osdu_kind: 'opendes:osdu:work-product-component--WellboreTrajectory:1.0.0', owl_uri: 'https://w3id.org/osdu#WellboreTrajectory', geocoverage: ['layer3', 'layer4'], sources: ['Relatórios de completação / OSDU WellboreTrajectory']}

MERGE (n_completacao:Entity:Operational {id: 'completacao'})
  ON CREATE SET n_completacao += {id: 'completacao', label: 'Completação', label_en: 'Well Completion', type: 'operational', definition: 'Conjunto de operações e equipamentos instalados no poço após a perfuração para viabilizar a produção segura: revestimento de produção, tubing (coluna de produção), packers, válvulas de subsuperfície (DHSV), perforações (canhoneio) das zonas produtoras e árvore de natal. No OSDU corresponde a master-data--WellboreCompletion, vinculado ao Wellbore. Tipos: completação seca (dry tree, plataforma fixa), molhada (subsea com ANM) ou inteligente (smart well — múltiplas zonas controladas).', osdu_kind: 'opendes:osdu:master-data--WellboreCompletion:1.0.0', geocoverage: ['layer2', 'layer3', 'layer4'], sources: ['O3PO (UFRGS) / OSDU master-data--WellboreCompletion']}
  ON MATCH SET n_completacao += {id: 'completacao', label: 'Completação', label_en: 'Well Completion', type: 'operational', definition: 'Conjunto de operações e equipamentos instalados no poço após a perfuração para viabilizar a produção segura: revestimento de produção, tubing (coluna de produção), packers, válvulas de subsuperfície (DHSV), perforações (canhoneio) das zonas produtoras e árvore de natal. No OSDU corresponde a master-data--WellboreCompletion, vinculado ao Wellbore. Tipos: completação seca (dry tree, plataforma fixa), molhada (subsea com ANM) ou inteligente (smart well — múltiplas zonas controladas).', osdu_kind: 'opendes:osdu:master-data--WellboreCompletion:1.0.0', geocoverage: ['layer2', 'layer3', 'layer4'], sources: ['O3PO (UFRGS) / OSDU master-data--WellboreCompletion']}

MERGE (n_unidade_medida:Entity:Instrument {id: 'unidade-medida'})
  ON CREATE SET n_unidade_medida += {id: 'unidade-medida', label: 'Unidade de Medida', label_en: 'Unit of Measure', type: 'instrument', definition: 'Vocabulário controlado de unidades de medida usadas nos dados de subsuperfície. Crítico para interoperabilidade entre sistemas: ANP/Petrobras usa SI (metros, MPa, m³/d) enquanto dados legados e internacionais frequentemente usam sistema imperial (ft, psi, bbl/d). O mD (miliDarcy) é um caso especial — unidade do sistema CGS-Gaussian amplamente usada em petrofísica. A conversão de unidades sem referência ao vocabulário OSDU é fonte frequente de erros em integração de dados.', osdu_kind: 'opendes:osdu:reference-data--UnitOfMeasure:1.0.0', owl_uri: 'https://w3id.org/osdu#UnitOfMeasure', geocoverage: ['layer2', 'layer3', 'layer4'], sources: ['OSDU reference-data--UnitOfMeasure / BIPM SI / API standards']}
  ON MATCH SET n_unidade_medida += {id: 'unidade-medida', label: 'Unidade de Medida', label_en: 'Unit of Measure', type: 'instrument', definition: 'Vocabulário controlado de unidades de medida usadas nos dados de subsuperfície. Crítico para interoperabilidade entre sistemas: ANP/Petrobras usa SI (metros, MPa, m³/d) enquanto dados legados e internacionais frequentemente usam sistema imperial (ft, psi, bbl/d). O mD (miliDarcy) é um caso especial — unidade do sistema CGS-Gaussian amplamente usada em petrofísica. A conversão de unidades sem referência ao vocabulário OSDU é fonte frequente de erros em integração de dados.', osdu_kind: 'opendes:osdu:reference-data--UnitOfMeasure:1.0.0', owl_uri: 'https://w3id.org/osdu#UnitOfMeasure', geocoverage: ['layer2', 'layer3', 'layer4'], sources: ['OSDU reference-data--UnitOfMeasure / BIPM SI / API standards']}

MERGE (n_activity_plan:Entity:Operational {id: 'activity-plan'})
  ON CREATE SET n_activity_plan += {id: 'activity-plan', label: 'Plano de Atividade', label_en: 'Activity Plan', type: 'operational', definition: 'Informações sobre uma série de atividades planejadas — agrupa passos, responsáveis e marcos de uma campanha operacional. (OSDU canonical: Information about a series of planned activities.)', osdu_kind: 'opendes:osdu:master-data--ActivityPlan:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}
  ON MATCH SET n_activity_plan += {id: 'activity-plan', label: 'Plano de Atividade', label_en: 'Activity Plan', type: 'operational', definition: 'Informações sobre uma série de atividades planejadas — agrupa passos, responsáveis e marcos de uma campanha operacional. (OSDU canonical: Information about a series of planned activities.)', osdu_kind: 'opendes:osdu:master-data--ActivityPlan:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}

MERGE (n_activity_template:Entity:Operational {id: 'activity-template'})
  ON CREATE SET n_activity_template += {id: 'activity-template', label: 'Template de Atividade', label_en: 'Activity Template', type: 'operational', definition: 'Descrição de um tipo de atividade, por exemplo, um passo (work-step) reutilizável dentro de um workflow operacional. (OSDU canonical: Description of one type of activity, e.g., a work-step in a workflow.)', osdu_kind: 'opendes:osdu:master-data--ActivityTemplate:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}
  ON MATCH SET n_activity_template += {id: 'activity-template', label: 'Template de Atividade', label_en: 'Activity Template', type: 'operational', definition: 'Descrição de um tipo de atividade, por exemplo, um passo (work-step) reutilizável dentro de um workflow operacional. (OSDU canonical: Description of one type of activity, e.g., a work-step in a workflow.)', osdu_kind: 'opendes:osdu:master-data--ActivityTemplate:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}

MERGE (n_well_activity_program:Entity:Operational {id: 'well-activity-program'})
  ON CREATE SET n_well_activity_program += {id: 'well-activity-program', label: 'Programa de Atividade de Poço', label_en: 'Well Activity Program', type: 'operational', definition: 'Descrição completa do Programa de Atividades para um poço (ou conjunto de poços e/ou wellbores), cobrindo objetivos, fases e procedimentos. (OSDU canonical: A complete description of an Activity Program for a unique or a set of Well(s) and/or Wellbore(s).)', osdu_kind: 'opendes:osdu:master-data--WellActivityProgram:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}
  ON MATCH SET n_well_activity_program += {id: 'well-activity-program', label: 'Programa de Atividade de Poço', label_en: 'Well Activity Program', type: 'operational', definition: 'Descrição completa do Programa de Atividades para um poço (ou conjunto de poços e/ou wellbores), cobrindo objetivos, fases e procedimentos. (OSDU canonical: A complete description of an Activity Program for a unique or a set of Well(s) and/or Wellbore(s).)', osdu_kind: 'opendes:osdu:master-data--WellActivityProgram:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}

MERGE (n_casing_design:Entity:Equipment {id: 'casing-design'})
  ON CREATE SET n_casing_design += {id: 'casing-design', label: 'Desenho de Revestimento', label_en: 'Casing Design', type: 'equipment', definition: 'Projeto de revestimento (casing) de um poço, descrevendo seções, diâmetros, graus de aço, conexões e profundidades planejadas. (OSDU canonical: The design of the Casing in a wellbore.)', osdu_kind: 'opendes:osdu:master-data--CasingDesign:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}
  ON MATCH SET n_casing_design += {id: 'casing-design', label: 'Desenho de Revestimento', label_en: 'Casing Design', type: 'equipment', definition: 'Projeto de revestimento (casing) de um poço, descrevendo seções, diâmetros, graus de aço, conexões e profundidades planejadas. (OSDU canonical: The design of the Casing in a wellbore.)', osdu_kind: 'opendes:osdu:master-data--CasingDesign:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}

MERGE (n_core_sample:Entity:Analytical {id: 'core-sample'})
