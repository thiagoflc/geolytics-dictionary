MERGE (n_gso_Igneous_Intrusive_Contact:GSOClass {id: 'gso_Igneous_Intrusive_Contact'})
  ON CREATE SET n_gso_Igneous_Intrusive_Contact += {id: 'gso_Igneous_Intrusive_Contact', gso_class: 'Igneous_Intrusive_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Igneous_Intrusive_Contact', pref_label_en: 'igneous intrusive contact', definition_en_canonical: 'An intrusive contact between a younger igneous rock and an older, pre-existing geological unit into which it has been intruded.', parents: ['gscn:Lithogenetic_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Igneous_Intrusive_Contact += {id: 'gso_Igneous_Intrusive_Contact', gso_class: 'Igneous_Intrusive_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Igneous_Intrusive_Contact', pref_label_en: 'igneous intrusive contact', definition_en_canonical: 'An intrusive contact between a younger igneous rock and an older, pre-existing geological unit into which it has been intruded.', parents: ['gscn:Lithogenetic_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Igneous_Phase_Contact:GSOClass {id: 'gso_Igneous_Phase_Contact'})
  ON CREATE SET n_gso_Igneous_Phase_Contact += {id: 'gso_Igneous_Phase_Contact', gso_class: 'Igneous_Phase_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Igneous_Phase_Contact', pref_label_en: 'igneous phase contact', definition_en_canonical: 'A lithogenetic contact separating lithologically distinct phases of a single intrusive body. Does not denote nature of contact (intrusive or gradation).', parents: ['gscn:Lithogenetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Igneous_Phase_Contact += {id: 'gso_Igneous_Phase_Contact', gso_class: 'Igneous_Phase_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Igneous_Phase_Contact', pref_label_en: 'igneous phase contact', definition_en_canonical: 'A lithogenetic contact separating lithologically distinct phases of a single intrusive body. Does not denote nature of contact (intrusive or gradation).', parents: ['gscn:Lithogenetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

