MERGE (n_gso_Normal_Dextral:GSOClass {id: 'gso_Normal_Dextral'})
  ON CREATE SET n_gso_Normal_Dextral += {id: 'gso_Normal_Dextral', gso_class: 'Normal_Dextral', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Normal_Dextral', pref_label_en: 'normal dextral', definition_en_canonical: 'The movement sense includes both normal and dextral components.', parents: ['gsfa:Dextral', 'gsfa:Normal'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
