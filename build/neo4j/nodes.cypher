MERGE (n_gso_Normal:GSOClass {id: 'gso_Normal'})
  ON CREATE SET n_gso_Normal += {id: 'gso_Normal', gso_class: 'Normal', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Normal', pref_label_en: 'normal', definition_en_canonical: 'The hanging wall has been displaced down relative to the footwall, dip of fault usually 45-90 degrees.', parents: ['gsfa:Fault_Movement_Sense'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
