MERGE (n_gso_Magnetic_Contact:GSOClass {id: 'gso_Magnetic_Contact'})
  ON CREATE SET n_gso_Magnetic_Contact += {id: 'gso_Magnetic_Contact', gso_class: 'Magnetic_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Magnetic_Contact', pref_label_en: 'magnetic contact', definition_en_canonical: 'A geophysical contact separating bodies of material distinguished based on properties related to magnetic fields.', parents: ['gscn:Geophysical_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Magnetic_Contact += {id: 'gso_Magnetic_Contact', gso_class: 'Magnetic_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Magnetic_Contact', pref_label_en: 'magnetic contact', definition_en_canonical: 'A geophysical contact separating bodies of material distinguished based on properties related to magnetic fields.', parents: ['gscn:Geophysical_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

