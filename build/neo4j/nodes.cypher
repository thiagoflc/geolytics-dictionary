MERGE (n_gso_Dextral:GSOClass {id: 'gso_Dextral'})
  ON CREATE SET n_gso_Dextral += {id: 'gso_Dextral', gso_class: 'Dextral', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Dextral', pref_label_en: 'dextral', pref_label_fr: 'dextre', definition_en_canonical: 'In plan view, the side opposite the observer is displaced to the right.', parents: ['gsfa:Fault_Movement_Sense'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Dextral += {id: 'gso_Dextral', gso_class: 'Dextral', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Dextral', pref_label_en: 'dextral', pref_label_fr: 'dextre', definition_en_canonical: 'In plan view, the side opposite the observer is displaced to the right.', parents: ['gsfa:Fault_Movement_Sense'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Dextral_Strike_Slip_Fault:GSOClass {id: 'gso_Dextral_Strike_Slip_Fault'})
  ON CREATE SET n_gso_Dextral_Strike_Slip_Fault += {id: 'gso_Dextral_Strike_Slip_Fault', gso_class: 'Dextral_Strike_Slip_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Dextral_Strike_Slip_Fault', pref_label_en: 'dextral strike slip fault', definition_en_canonical: 'Fault with right-lateral strike-parallel displacement component of slip vector more than 10 times the dip-parallel component of the slip vector at at least one location along the fault, and right-lateral displacement over more than half the mapped trace of the fault.', parents: ['gsfa:Strike_Slip_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Dextral_Strike_Slip_Fault += {id: 'gso_Dextral_Strike_Slip_Fault', gso_class: 'Dextral_Strike_Slip_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Dextral_Strike_Slip_Fault', pref_label_en: 'dextral strike slip fault', definition_en_canonical: 'Fault with right-lateral strike-parallel displacement component of slip vector more than 10 times the dip-parallel component of the slip vector at at least one location along the fault, and right-lateral displacement over more than half the mapped trace of the fault.', parents: ['gsfa:Strike_Slip_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Dip_Separation:GSOClass {id: 'gso_Dip_Separation'})
  ON CREATE SET n_gso_Dip_Separation += {id: 'gso_Dip_Separation', gso_class: 'Dip_Separation', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Dip_Separation', pref_label_en: 'dip separation sense', definition_en_canonical: 'A fault along which there is some separation parallel to the dip of the fault.', parents: ['gsfa:Fault_Separation'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Dip_Separation += {id: 'gso_Dip_Separation', gso_class: 'Dip_Separation', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Dip_Separation', pref_label_en: 'dip separation sense', definition_en_canonical: 'A fault along which there is some separation parallel to the dip of the fault.', parents: ['gsfa:Fault_Separation'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Dip_Slip:GSOClass {id: 'gso_Dip_Slip'})
  ON CREATE SET n_gso_Dip_Slip += {id: 'gso_Dip_Slip', gso_class: 'Dip_Slip', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Dip_Slip', pref_label_en: 'dip slip', definition_en_canonical: 'The net slip of the fault lies in the dip direction of the fault.', parents: ['gsfa:Fault_Slip'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Dip_Slip += {id: 'gso_Dip_Slip', gso_class: 'Dip_Slip', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Dip_Slip', pref_label_en: 'dip slip', definition_en_canonical: 'The net slip of the fault lies in the dip direction of the fault.', parents: ['gsfa:Fault_Slip'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Ductile_Shear_Zone:GSOClass {id: 'gso_Ductile_Shear_Zone'})
  ON CREATE SET n_gso_Ductile_Shear_Zone += {id: 'gso_Ductile_Shear_Zone', gso_class: 'Ductile_Shear_Zone', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Ductile_Shear_Zone', pref_label_en: 'Ductile Shear Zone', definition_en_canonical: 'a broadly planar zone of shear displacement within which deformation has occurred without loss of material continuity', parents: ['gsfa:Fault_Zone'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Ductile_Shear_Zone += {id: 'gso_Ductile_Shear_Zone', gso_class: 'Ductile_Shear_Zone', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Ductile_Shear_Zone', pref_label_en: 'Ductile Shear Zone', definition_en_canonical: 'a broadly planar zone of shear displacement within which deformation has occurred without loss of material continuity', parents: ['gsfa:Fault_Zone'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Extraction:GSOClass {id: 'gso_Extraction'})
  ON CREATE SET n_gso_Extraction += {id: 'gso_Extraction', gso_class: 'Extraction', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Extraction', pref_label_en: 'extraction', definition_en_canonical: 'Displacement across a fault is substantially in the direction perpendicular to the fault. The fault-parallel displacement is effectively zero.', parents: ['gsfa:Fault_Movement_Sense'], sources: ['Froitzheim, N., Pleuger, J. & Nagel, T.J., 2006. Extraction faults. Journal of Structural Geology v28, pp. 1388-1395.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Extraction += {id: 'gso_Extraction', gso_class: 'Extraction', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Extraction', pref_label_en: 'extraction', definition_en_canonical: 'Displacement across a fault is substantially in the direction perpendicular to the fault. The fault-parallel displacement is effectively zero.', parents: ['gsfa:Fault_Movement_Sense'], sources: ['Froitzheim, N., Pleuger, J. & Nagel, T.J., 2006. Extraction faults. Journal of Structural Geology v28, pp. 1388-1395.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Extraction_Fault:GSOClass {id: 'gso_Extraction_Fault'})
  ON CREATE SET n_gso_Extraction_Fault += {id: 'gso_Extraction_Fault', gso_class: 'Extraction_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Extraction_Fault', pref_label_en: 'extraction fault', definition_en_canonical: 'A fault whose two sides have approached each other substantially in the direction perpendicular to the fault.', parents: ['gsfa:Fault'], sources: ['Froitzheim, N., Pleuger, J. & Nagel, T.J., 2006. Extraction faults. Journal of Structural Geology v28, pp. 1388-1395.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Extraction_Fault += {id: 'gso_Extraction_Fault', gso_class: 'Extraction_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Extraction_Fault', pref_label_en: 'extraction fault', definition_en_canonical: 'A fault whose two sides have approached each other substantially in the direction perpendicular to the fault.', parents: ['gsfa:Fault'], sources: ['Froitzheim, N., Pleuger, J. & Nagel, T.J., 2006. Extraction faults. Journal of Structural Geology v28, pp. 1388-1395.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Fault:GSOClass {id: 'gso_Fault'})
  ON CREATE SET n_gso_Fault += {id: 'gso_Fault', gso_class: 'Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault', pref_label_en: 'Fault', definition_en_canonical: 'A discrete surface, or zone of discrete surfaces, with some thickness, separating two rock masses across which one mass has slid past the other and characterized by brittle deformation.', parents: ['gsos:Fracture'], sources: ['this vocabulary'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Fault += {id: 'gso_Fault', gso_class: 'Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault', pref_label_en: 'Fault', definition_en_canonical: 'A discrete surface, or zone of discrete surfaces, with some thickness, separating two rock masses across which one mass has slid past the other and characterized by brittle deformation.', parents: ['gsos:Fracture'], sources: ['this vocabulary'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Fault_Movement_Magnitude:GSOClass {id: 'gso_Fault_Movement_Magnitude'})
  ON CREATE SET n_gso_Fault_Movement_Magnitude += {id: 'gso_Fault_Movement_Magnitude', gso_class: 'Fault_Movement_Magnitude', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault_Movement_Magnitude', pref_label_en: 'Displacement magnitude', definition_en_canonical: 'magnitude of slip or separation', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Fault_Movement_Magnitude += {id: 'gso_Fault_Movement_Magnitude', gso_class: 'Fault_Movement_Magnitude', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault_Movement_Magnitude', pref_label_en: 'Displacement magnitude', definition_en_canonical: 'magnitude of slip or separation', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Fault_Movement_Sense:GSOClass {id: 'gso_Fault_Movement_Sense'})
  ON CREATE SET n_gso_Fault_Movement_Sense += {id: 'gso_Fault_Movement_Sense', gso_class: 'Fault_Movement_Sense', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault_Movement_Sense', pref_label_en: 'Fault movement sense ', definition_en_canonical: 'Quality that specifies the relative sense of displacement (right, left, up, down) between rocks on opposites of a fault.', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Fault_Movement_Sense += {id: 'gso_Fault_Movement_Sense', gso_class: 'Fault_Movement_Sense', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault_Movement_Sense', pref_label_en: 'Fault movement sense ', definition_en_canonical: 'Quality that specifies the relative sense of displacement (right, left, up, down) between rocks on opposites of a fault.', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Fault_Movement_Vector:GSOClass {id: 'gso_Fault_Movement_Vector'})
  ON CREATE SET n_gso_Fault_Movement_Vector += {id: 'gso_Fault_Movement_Vector', gso_class: 'Fault_Movement_Vector', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault_Movement_Vector', pref_label_en: 'Movement Vector', definition_en_canonical: 'Slip vector linking piercing point on opposite sides of fault, or separation vector linking offset surface along fault trace.', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Fault_Movement_Vector += {id: 'gso_Fault_Movement_Vector', gso_class: 'Fault_Movement_Vector', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault_Movement_Vector', pref_label_en: 'Movement Vector', definition_en_canonical: 'Slip vector linking piercing point on opposite sides of fault, or separation vector linking offset surface along fault trace.', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Fault_Separation:GSOClass {id: 'gso_Fault_Separation'})
  ON CREATE SET n_gso_Fault_Separation += {id: 'gso_Fault_Separation', gso_class: 'Fault_Separation', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault_Separation', pref_label_en: 'Separation', definition_en_canonical: 'a vector (magnitude and orientation) specifying the distance between the intersection of a surface on opposite sides of a displacment surface. In 3-D is the projection of a vector normal to the displaced surface into the displacment surface, but might also be specified as offset of the intersection of displacement surface and marker surface in some other profile view (e.g. horizontal/map view, or a cross section)', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Fault_Separation += {id: 'gso_Fault_Separation', gso_class: 'Fault_Separation', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault_Separation', pref_label_en: 'Separation', definition_en_canonical: 'a vector (magnitude and orientation) specifying the distance between the intersection of a surface on opposite sides of a displacment surface. In 3-D is the projection of a vector normal to the displaced surface into the displacment surface, but might also be specified as offset of the intersection of displacement surface and marker surface in some other profile view (e.g. horizontal/map view, or a cross section)', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Fault_Slip:GSOClass {id: 'gso_Fault_Slip'})
  ON CREATE SET n_gso_Fault_Slip += {id: 'gso_Fault_Slip', gso_class: 'Fault_Slip', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault_Slip', pref_label_en: 'Slip', definition_en_canonical: 'a vector (magnitude and orientation) that links a peircing point on opposite sides of a displacement surface.', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Fault_Slip += {id: 'gso_Fault_Slip', gso_class: 'Fault_Slip', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault_Slip', pref_label_en: 'Slip', definition_en_canonical: 'a vector (magnitude and orientation) that links a peircing point on opposite sides of a displacement surface.', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Fault_Zone:GSOClass {id: 'gso_Fault_Zone'})
  ON CREATE SET n_gso_Fault_Zone += {id: 'gso_Fault_Zone', gso_class: 'Fault_Zone', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault_Zone', pref_label_en: 'Fault Zone ', definition_en_canonical: 'A material spatial feature that contains one or more fault surfaces as well as deformed rocks related to the faults located between and adjacent to the fault traces', parents: ['gsoc:Material_Feature'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Fault_Zone += {id: 'gso_Fault_Zone', gso_class: 'Fault_Zone', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Fault_Zone', pref_label_en: 'Fault Zone ', definition_en_canonical: 'A material spatial feature that contains one or more fault surfaces as well as deformed rocks related to the faults located between and adjacent to the fault traces', parents: ['gsoc:Material_Feature'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Generic_Decollement_Fault:GSOClass {id: 'gso_Generic_Decollement_Fault'})
  ON CREATE SET n_gso_Generic_Decollement_Fault += {id: 'gso_Generic_Decollement_Fault', gso_class: 'Generic_Decollement_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Generic_Decollement_Fault', pref_label_en: 'generic decollement', pref_label_fr: 'decollement', definition_en_canonical: 'A large-displacement (kilometers or tens of kilometers) shallowly dipping to subhorizontal fault or shear zone.', parents: ['gsfa:Low_Angle_Fault'], sources: ['Neuendorf et al. 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Generic_Decollement_Fault += {id: 'gso_Generic_Decollement_Fault', gso_class: 'Generic_Decollement_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Generic_Decollement_Fault', pref_label_en: 'generic decollement', pref_label_fr: 'decollement', definition_en_canonical: 'A large-displacement (kilometers or tens of kilometers) shallowly dipping to subhorizontal fault or shear zone.', parents: ['gsfa:Low_Angle_Fault'], sources: ['Neuendorf et al. 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_High_Angle_Fault:GSOClass {id: 'gso_High_Angle_Fault'})
  ON CREATE SET n_gso_High_Angle_Fault += {id: 'gso_High_Angle_Fault', gso_class: 'High_Angle_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/High_Angle_Fault', pref_label_en: 'high angle fault', definition_en_canonical: 'Fault that dips at least 45 degrees over more than half of its recognized extent, for which slip or separation is not explicitly specified.', parents: ['gsfa:Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_High_Angle_Fault += {id: 'gso_High_Angle_Fault', gso_class: 'High_Angle_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/High_Angle_Fault', pref_label_en: 'high angle fault', definition_en_canonical: 'Fault that dips at least 45 degrees over more than half of its recognized extent, for which slip or separation is not explicitly specified.', parents: ['gsfa:Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_High_Angle_Normal_Fault:GSOClass {id: 'gso_High_Angle_Normal_Fault'})
  ON CREATE SET n_gso_High_Angle_Normal_Fault += {id: 'gso_High_Angle_Normal_Fault', gso_class: 'High_Angle_Normal_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/High_Angle_Normal_Fault', pref_label_en: 'high angle normal fault', definition_en_canonical: 'Fault that dips at least 45 degrees over more than half of the recognized extent of the fault with the hanging wall displaced from a structurally higher position relative to footwall rocks.', parents: ['gsfa:High_Angle_Fault', 'gsfa:Normal_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_High_Angle_Normal_Fault += {id: 'gso_High_Angle_Normal_Fault', gso_class: 'High_Angle_Normal_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/High_Angle_Normal_Fault', pref_label_en: 'high angle normal fault', definition_en_canonical: 'Fault that dips at least 45 degrees over more than half of the recognized extent of the fault with the hanging wall displaced from a structurally higher position relative to footwall rocks.', parents: ['gsfa:High_Angle_Fault', 'gsfa:Normal_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_High_Angle_Reverse_Fault:GSOClass {id: 'gso_High_Angle_Reverse_Fault'})
  ON CREATE SET n_gso_High_Angle_Reverse_Fault += {id: 'gso_High_Angle_Reverse_Fault', gso_class: 'High_Angle_Reverse_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/High_Angle_Reverse_Fault', pref_label_en: 'high angle reverse', definition_en_canonical: 'Reverse fault that dips at least 45 degrees over more than half of its recognized extent, for which slip or separation is not explicitly specified.', parents: ['gsfa:High_Angle_Fault', 'gsfa:Reverse_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
