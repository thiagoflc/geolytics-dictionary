  ON CREATE SET n_geo_political_entity += {id: 'geo-political-entity', label: 'Entidade Geopolítica', label_en: 'Geo Political Entity', type: 'actor', definition: 'Área geográfica nomeada definida e administrada por uma entidade oficial — país, estado, bloco, área especial. (OSDU canonical: A named geographical area which is defined and administered by an official entity.)', osdu_kind: 'opendes:osdu:master-data--GeoPoliticalEntity:1.0.0', geocoverage: ['layer1'], sources: ['Accenture/OSDU OWL']}
