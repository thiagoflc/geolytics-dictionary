MERGE (n_facility_type:Entity:Equipment {id: 'facility-type'})
  ON CREATE SET n_facility_type += {id: 'facility-type', label: 'Tipo de Instalação', label_en: 'Facility Type', type: 'equipment', definition: 'Identifica e descreve o tipo de instalação. Uma facility é um agrupamento de equipamentos em um sítio geográfico específico, usado em atividades energéticas como exploração, extração, geração, armazenamento, processamento, descarte, suprimento ou transferência. Pode ser de superfície ou subsuperfície. (OSDU canonical: Used to identify and describe the type of facility.)', osdu_kind: 'opendes:osdu:reference-data--FacilityType:1.0.0', geocoverage: ['layer1'], sources: ['Accenture/OSDU OWL']}
  ON MATCH SET n_facility_type += {id: 'facility-type', label: 'Tipo de Instalação', label_en: 'Facility Type', type: 'equipment', definition: 'Identifica e descreve o tipo de instalação. Uma facility é um agrupamento de equipamentos em um sítio geográfico específico, usado em atividades energéticas como exploração, extração, geração, armazenamento, processamento, descarte, suprimento ou transferência. Pode ser de superfície ou subsuperfície. (OSDU canonical: Used to identify and describe the type of facility.)', osdu_kind: 'opendes:osdu:reference-data--FacilityType:1.0.0', geocoverage: ['layer1'], sources: ['Accenture/OSDU OWL']}

