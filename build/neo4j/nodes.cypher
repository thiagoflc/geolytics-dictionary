  ON MATCH SET n_gso_Normal_Sinistral += {id: 'gso_Normal_Sinistral', gso_class: 'Normal_Sinistral', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Normal_Sinistral', pref_label_en: 'normal sinistral', definition_en_canonical: 'The movement sense includes both normal and sinistral components.', parents: ['gsfa:Normal', 'gsfa:Sinistral'], sources: ['GGIC vocabularies working group (Australia)'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

MERGE (n_gso_Oblique_Slip:GSOClass {id: 'gso_Oblique_Slip'})
  ON CREATE SET n_gso_Oblique_Slip += {id: 'gso_Oblique_Slip', gso_class: 'Oblique_Slip', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Oblique_Slip', pref_label_en: 'oblique slip', definition_en_canonical: 'The net slip of the fault lies between the strike and dip directions of the fault, the slip vector rakes between 10 and 80 degrees in the plane of the fault.', parents: ['gsfa:Fault_Slip'], sources: ['GGIC vocabularies working group (Australia), SMR'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
  ON MATCH SET n_gso_Oblique_Slip += {id: 'gso_Oblique_Slip', gso_class: 'Oblique_Slip', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Oblique_Slip', pref_label_en: 'oblique slip', definition_en_canonical: 'The net slip of the fault lies between the strike and dip directions of the fault, the slip vector rakes between 10 and 80 degrees in the plane of the fault.', parents: ['gsfa:Fault_Slip'], sources: ['GGIC vocabularies working group (Australia), SMR'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}

