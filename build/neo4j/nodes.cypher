  ON MATCH SET n_gso_Anticline += {id: 'gso_Anticline', gso_class: 'Anticline', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Anticline', pref_label_en: 'Anticline ', definition_en_canonical: 'A fold whose core contains the stratigraphically older rocks', parents: ['gsfd:Fold'], sources: ['https://inspire.ec.europa.eu/codelist/FoldProfileTypeValue/anticline'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Antiform:GSOClass {id: 'gso_Antiform'})
  ON CREATE SET n_gso_Antiform += {id: 'gso_Antiform', gso_class: 'Antiform', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Antiform', pref_label_en: 'Antiform', definition_en_canonical: 'A convex-upward, concave downward fold.', parents: ['gsfd:Fold'], sources: ['https://inspire.ec.europa.eu/codelist/FoldProfileTypeValue/antiform'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Antiform += {id: 'gso_Antiform', gso_class: 'Antiform', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Antiform', pref_label_en: 'Antiform', definition_en_canonical: 'A convex-upward, concave downward fold.', parents: ['gsfd:Fold'], sources: ['https://inspire.ec.europa.eu/codelist/FoldProfileTypeValue/antiform'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Chevron_Fold:GSOClass {id: 'gso_Chevron_Fold'})
  ON CREATE SET n_gso_Chevron_Fold += {id: 'gso_Chevron_Fold', gso_class: 'Chevron_Fold', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Chevron_Fold', pref_label_en: 'Chevron Fold ', definition_en_canonical: 'A fold with straight limbs and sharp hinges. Well developed, these folds develop repeated set of v-shaped beds.  Inter-limb angles are generally 60 degrees or less. Chevron folding preferentially occurs in well bedded units where  bedding regularly alternates between contrasting competences.', parents: ['gsfd:Fold'], sources: ['http://www.geologyin.com/2015/02/types-of-folds-with-photos.html'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Chevron_Fold += {id: 'gso_Chevron_Fold', gso_class: 'Chevron_Fold', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Chevron_Fold', pref_label_en: 'Chevron Fold ', definition_en_canonical: 'A fold with straight limbs and sharp hinges. Well developed, these folds develop repeated set of v-shaped beds.  Inter-limb angles are generally 60 degrees or less. Chevron folding preferentially occurs in well bedded units where  bedding regularly alternates between contrasting competences.', parents: ['gsfd:Fold'], sources: ['http://www.geologyin.com/2015/02/types-of-folds-with-photos.html'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Fold:GSOClass {id: 'gso_Fold'})
  ON CREATE SET n_gso_Fold += {id: 'gso_Fold', gso_class: 'Fold', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold', pref_label_en: 'Fold', definition_en_canonical: 'A curve or bend of a planar structure, such as rock strata, bedding planes, foliation or cleavage. A fold is usually the product of deformation, involving the compression of strata, but may include primary structures, as its definition is descriptive, not genetic. (Neuendorf et al., 2011).', parents: ['gsoc:Nonphysical_Morphologic_Feature', 'gsog:Geologic_Structure'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Fold += {id: 'gso_Fold', gso_class: 'Fold', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold', pref_label_en: 'Fold', definition_en_canonical: 'A curve or bend of a planar structure, such as rock strata, bedding planes, foliation or cleavage. A fold is usually the product of deformation, involving the compression of strata, but may include primary structures, as its definition is descriptive, not genetic. (Neuendorf et al., 2011).', parents: ['gsoc:Nonphysical_Morphologic_Feature', 'gsog:Geologic_Structure'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Fold_Amplitude:GSOClass {id: 'gso_Fold_Amplitude'})
  ON CREATE SET n_gso_Fold_Amplitude += {id: 'gso_Fold_Amplitude', gso_class: 'Fold_Amplitude', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Amplitude', pref_label_en: 'Fold Amplitude', definition_en_canonical: 'the length of half the distance from the crest of a fold to the adjacent troughs. ', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Fold_Amplitude += {id: 'gso_Fold_Amplitude', gso_class: 'Fold_Amplitude', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Amplitude', pref_label_en: 'Fold Amplitude', definition_en_canonical: 'the length of half the distance from the crest of a fold to the adjacent troughs. ', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Fold_Axial_Surface:GSOClass {id: 'gso_Fold_Axial_Surface'})
  ON CREATE SET n_gso_Fold_Axial_Surface += {id: 'gso_Fold_Axial_Surface', gso_class: 'Fold_Axial_Surface', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Axial_Surface', pref_label_en: 'Fold axial surface', definition_en_canonical: 'Abstract surface that bisects the limbs of a fold or is the normal to a surface defined by the poles to the folded surface (typically visualized on a stereonet).  The axial surface of a particular fold may be located based on observations of the folded geologic structure, but in general it has no direct physical manifestation. Contrast with hinge surface, which is defined as the surface containing a set of hinge lines in the stack of folded surfaces defining a fold structure.  As a geologic surface, the axial surface has geometric properties, including orientation, which may be specified by observations at one or more locations, or generalized using terminology (upright, inclined, reclined, recumbent, overturned). (revised from GeoSciML 3.2)', parents: ['gsoc:Low_Dimension_Feature'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Fold_Axial_Surface += {id: 'gso_Fold_Axial_Surface', gso_class: 'Fold_Axial_Surface', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Axial_Surface', pref_label_en: 'Fold axial surface', definition_en_canonical: 'Abstract surface that bisects the limbs of a fold or is the normal to a surface defined by the poles to the folded surface (typically visualized on a stereonet).  The axial surface of a particular fold may be located based on observations of the folded geologic structure, but in general it has no direct physical manifestation. Contrast with hinge surface, which is defined as the surface containing a set of hinge lines in the stack of folded surfaces defining a fold structure.  As a geologic surface, the axial surface has geometric properties, including orientation, which may be specified by observations at one or more locations, or generalized using terminology (upright, inclined, reclined, recumbent, overturned). (revised from GeoSciML 3.2)', parents: ['gsoc:Low_Dimension_Feature'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Fold_Hinge:GSOClass {id: 'gso_Fold_Hinge'})
  ON CREATE SET n_gso_Fold_Hinge += {id: 'gso_Fold_Hinge', gso_class: 'Fold_Hinge', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Hinge', pref_label_en: 'Fold Hinge', definition_en_canonical: 'the line linking points of maximum curvature on a folded surface (http://www.geosci.usyd.edu.au/users/prey/Teaching/Geos-2123/Folds/Sld22.html). A low-dimensional feature', parents: ['gsoc:Low_Dimension_Feature'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Fold_Hinge += {id: 'gso_Fold_Hinge', gso_class: 'Fold_Hinge', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Hinge', pref_label_en: 'Fold Hinge', definition_en_canonical: 'the line linking points of maximum curvature on a folded surface (http://www.geosci.usyd.edu.au/users/prey/Teaching/Geos-2123/Folds/Sld22.html). A low-dimensional feature', parents: ['gsoc:Low_Dimension_Feature'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Fold_Hinge_Surface:GSOClass {id: 'gso_Fold_Hinge_Surface'})
  ON CREATE SET n_gso_Fold_Hinge_Surface += {id: 'gso_Fold_Hinge_Surface', gso_class: 'Fold_Hinge_Surface', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Hinge_Surface', pref_label_en: 'Fold - Hinge surface', definition_en_canonical: 'Surface that contains the hinge lines in a stack of folded layers', parents: ['gsoc:Low_Dimension_Feature'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Fold_Hinge_Surface += {id: 'gso_Fold_Hinge_Surface', gso_class: 'Fold_Hinge_Surface', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Hinge_Surface', pref_label_en: 'Fold - Hinge surface', definition_en_canonical: 'Surface that contains the hinge lines in a stack of folded layers', parents: ['gsoc:Low_Dimension_Feature'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Fold_InterLimb_Angle:GSOClass {id: 'gso_Fold_InterLimb_Angle'})
  ON CREATE SET n_gso_Fold_InterLimb_Angle += {id: 'gso_Fold_InterLimb_Angle', gso_class: 'Fold_InterLimb_Angle', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_InterLimb_Angle', pref_label_en: 'Fold limb shape', definition_en_canonical: 'The angle between adjacent limbs of a fold, normally determined by drawing tangents to the fold limbs at the inflection points.', parents: ['gsoc:Physical_Quality'], sources: ['Neuendorf et al., 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Fold_InterLimb_Angle += {id: 'gso_Fold_InterLimb_Angle', gso_class: 'Fold_InterLimb_Angle', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_InterLimb_Angle', pref_label_en: 'Fold limb shape', definition_en_canonical: 'The angle between adjacent limbs of a fold, normally determined by drawing tangents to the fold limbs at the inflection points.', parents: ['gsoc:Physical_Quality'], sources: ['Neuendorf et al., 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Fold_Limb:GSOClass {id: 'gso_Fold_Limb'})
  ON CREATE SET n_gso_Fold_Limb += {id: 'gso_Fold_Limb', gso_class: 'Fold_Limb', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Limb', pref_label_en: 'Fold Limb', definition_en_canonical: 'The generally planar region of a fold which lies between two adjacent hinge lines and is confined between the zones of maximum curvature. A role played by some layered rock reated to the adjacent fold hinges.  Not necessarily a feature', parents: ['gsoc:Nonphysical_Morphologic_Feature', 'gsog:Geologic_Structure'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Fold_Limb += {id: 'gso_Fold_Limb', gso_class: 'Fold_Limb', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Limb', pref_label_en: 'Fold Limb', definition_en_canonical: 'The generally planar region of a fold which lies between two adjacent hinge lines and is confined between the zones of maximum curvature. A role played by some layered rock reated to the adjacent fold hinges.  Not necessarily a feature', parents: ['gsoc:Nonphysical_Morphologic_Feature', 'gsog:Geologic_Structure'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Fold_Limb_Shape:GSOClass {id: 'gso_Fold_Limb_Shape'})
  ON CREATE SET n_gso_Fold_Limb_Shape += {id: 'gso_Fold_Limb_Shape', gso_class: 'Fold_Limb_Shape', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Limb_Shape', pref_label_en: 'Fold limb shape', definition_en_canonical: 'Straight vs curved limbs, eg kink, chevron, sinusoidal, box', parents: ['gsoc:Shape'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Fold_Limb_Shape += {id: 'gso_Fold_Limb_Shape', gso_class: 'Fold_Limb_Shape', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Limb_Shape', pref_label_en: 'Fold limb shape', definition_en_canonical: 'Straight vs curved limbs, eg kink, chevron, sinusoidal, box', parents: ['gsoc:Shape'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Fold_Span:GSOClass {id: 'gso_Fold_Span'})
  ON CREATE SET n_gso_Fold_Span += {id: 'gso_Fold_Span', gso_class: 'Fold_Span', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Span', pref_label_en: 'Fold span', definition_en_canonical: 'linear distance between inflection points in a single fold (GeoSciML v3.2)', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Fold_Span += {id: 'gso_Fold_Span', gso_class: 'Fold_Span', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Span', pref_label_en: 'Fold span', definition_en_canonical: 'linear distance between inflection points in a single fold (GeoSciML v3.2)', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Fold_Symmetry:GSOClass {id: 'gso_Fold_Symmetry'})
  ON CREATE SET n_gso_Fold_Symmetry += {id: 'gso_Fold_Symmetry', gso_class: 'Fold_Symmetry', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Symmetry', pref_label_en: 'Fold symmetry', definition_en_canonical: 'Concordance or discordance of bisecting surface and axial surface, or ratio of length of limbs. Folded surface may have asymmetry defined by limb length ratio if inflection points are defined. Definition based on bisecting surface/axial surface angle depends on having multiple surfaces defined such that the axial surface may be identified. (symmetric, assymetric)', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Fold_Symmetry += {id: 'gso_Fold_Symmetry', gso_class: 'Fold_Symmetry', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Symmetry', pref_label_en: 'Fold symmetry', definition_en_canonical: 'Concordance or discordance of bisecting surface and axial surface, or ratio of length of limbs. Folded surface may have asymmetry defined by limb length ratio if inflection points are defined. Definition based on bisecting surface/axial surface angle depends on having multiple surfaces defined such that the axial surface may be identified. (symmetric, assymetric)', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Fold_System:GSOClass {id: 'gso_Fold_System'})
  ON CREATE SET n_gso_Fold_System += {id: 'gso_Fold_System', gso_class: 'Fold_System', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_System', pref_label_en: 'Fold System', definition_en_canonical: 'A collection of congruent folds  (axis and axial surface are parallel) produced by the same tectonic event. Sometimes referred to as a \\', parents: ['gsoc:Inherant_Feature', 'gsog:Geologic_Structure'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Fold_System += {id: 'gso_Fold_System', gso_class: 'Fold_System', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_System', pref_label_en: 'Fold System', definition_en_canonical: 'A collection of congruent folds  (axis and axial surface are parallel) produced by the same tectonic event. Sometimes referred to as a \\', parents: ['gsoc:Inherant_Feature', 'gsog:Geologic_Structure'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Fold_Wavelength:GSOClass {id: 'gso_Fold_Wavelength'})
  ON CREATE SET n_gso_Fold_Wavelength += {id: 'gso_Fold_Wavelength', gso_class: 'Fold_Wavelength', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Wavelength', pref_label_en: 'Fold wavelength', definition_en_canonical: 'The distance between adjacent crest or trough of  a single fold, or the average distance between adjacent crests or troughs in a fold system. ', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Fold_Wavelength += {id: 'gso_Fold_Wavelength', gso_class: 'Fold_Wavelength', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Fold_Wavelength', pref_label_en: 'Fold wavelength', definition_en_canonical: 'The distance between adjacent crest or trough of  a single fold, or the average distance between adjacent crests or troughs in a fold system. ', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Hinge_Line_Curvature:GSOClass {id: 'gso_Hinge_Line_Curvature'})
  ON CREATE SET n_gso_Hinge_Line_Curvature += {id: 'gso_Hinge_Line_Curvature', gso_class: 'Hinge_Line_Curvature', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Hinge_Line_Curvature', pref_label_en: 'Fold hinge line curvature', definition_en_canonical: 'Variation in orientation of fold hinge along trend of fold, distinguish sheath from cylindrical folds. Specify with terminology eg sheath, dome, basin, cylindrical.', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Hinge_Line_Curvature += {id: 'gso_Hinge_Line_Curvature', gso_class: 'Hinge_Line_Curvature', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Hinge_Line_Curvature', pref_label_en: 'Fold hinge line curvature', definition_en_canonical: 'Variation in orientation of fold hinge along trend of fold, distinguish sheath from cylindrical folds. Specify with terminology eg sheath, dome, basin, cylindrical.', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Hinge_Shape:GSOClass {id: 'gso_Hinge_Shape'})
  ON CREATE SET n_gso_Hinge_Shape += {id: 'gso_Hinge_Shape', gso_class: 'Hinge_Shape', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Hinge_Shape', pref_label_en: 'Fold hinge shape', definition_en_canonical: 'Rounded vs. angular hinge zones; has to do with the proportion of the wavelength that is considered part of hinge', parents: ['gsoc:Shape'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Hinge_Shape += {id: 'gso_Hinge_Shape', gso_class: 'Hinge_Shape', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Hinge_Shape', pref_label_en: 'Fold hinge shape', definition_en_canonical: 'Rounded vs. angular hinge zones; has to do with the proportion of the wavelength that is considered part of hinge', parents: ['gsoc:Shape'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Is_Periodic:GSOClass {id: 'gso_Is_Periodic'})
  ON CREATE SET n_gso_Is_Periodic += {id: 'gso_Is_Periodic', gso_class: 'Is_Periodic', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Is_Periodic', pref_label_en: 'Folds are periodic', definition_en_canonical: 'boolean value, true if wavelength of folds in a fold system is approximately the same', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Is_Periodic += {id: 'gso_Is_Periodic', gso_class: 'Is_Periodic', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Is_Periodic', pref_label_en: 'Folds are periodic', definition_en_canonical: 'boolean value, true if wavelength of folds in a fold system is approximately the same', parents: ['gsoc:Physical_Quality'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Monocline:GSOClass {id: 'gso_Monocline'})
  ON CREATE SET n_gso_Monocline += {id: 'gso_Monocline', gso_class: 'Monocline', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Monocline', pref_label_en: 'Monocline ', definition_en_canonical: 'step-like fold in rock strata consisting of a zone of steeper dip within an otherwise horizontal or gently-dipping sequence.', parents: ['gsfd:Fold'], sources: ['https://en.wikipedia.org/wiki/Monocline'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Monocline += {id: 'gso_Monocline', gso_class: 'Monocline', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Monocline', pref_label_en: 'Monocline ', definition_en_canonical: 'step-like fold in rock strata consisting of a zone of steeper dip within an otherwise horizontal or gently-dipping sequence.', parents: ['gsfd:Fold'], sources: ['https://en.wikipedia.org/wiki/Monocline'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Neutral_Fold:GSOClass {id: 'gso_Neutral_Fold'})
  ON CREATE SET n_gso_Neutral_Fold += {id: 'gso_Neutral_Fold', gso_class: 'Neutral_Fold', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Neutral_Fold', pref_label_en: 'Neutral Fold ', definition_en_canonical: 'A fold which closes laterally and is therefore neither antiformal nor synformal.  ', parents: ['gsfd:Fold'], sources: ['https://www.encyclopedia.com/science/dictionaries-thesauruses-pictures-and-press-releases/neutral-fold'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Neutral_Fold += {id: 'gso_Neutral_Fold', gso_class: 'Neutral_Fold', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Neutral_Fold', pref_label_en: 'Neutral Fold ', definition_en_canonical: 'A fold which closes laterally and is therefore neither antiformal nor synformal.  ', parents: ['gsfd:Fold'], sources: ['https://www.encyclopedia.com/science/dictionaries-thesauruses-pictures-and-press-releases/neutral-fold'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Ptygmatic_Fold:GSOClass {id: 'gso_Ptygmatic_Fold'})
  ON CREATE SET n_gso_Ptygmatic_Fold += {id: 'gso_Ptygmatic_Fold', gso_class: 'Ptygmatic_Fold', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Ptygmatic_Fold', pref_label_en: 'Ptygmatic Fold ', definition_en_canonical: 'Chaotic and highly sinuous fold typically in an isolated layer within a more homogeneous rock body. Typical of sedimentary slump folding and veins or dikes in medium to high-grade metamorphic rocks', parents: ['gsfd:Fold'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Ptygmatic_Fold += {id: 'gso_Ptygmatic_Fold', gso_class: 'Ptygmatic_Fold', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Ptygmatic_Fold', pref_label_en: 'Ptygmatic Fold ', definition_en_canonical: 'Chaotic and highly sinuous fold typically in an isolated layer within a more homogeneous rock body. Typical of sedimentary slump folding and veins or dikes in medium to high-grade metamorphic rocks', parents: ['gsfd:Fold'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Recumbent:GSOClass {id: 'gso_Recumbent'})
  ON CREATE SET n_gso_Recumbent += {id: 'gso_Recumbent', gso_class: 'Recumbent', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Recumbent', pref_label_en: 'Recumbent ', definition_en_canonical: 'Surface dips between 0 and 10 degrees; typically used to describe orientation of fold hing surface or axial surface, use equivalent term \'Horizontal inclination\' for other geologic surfaces.', parents: ['gsgq:Plane_Orientation'], sources: ['Fleuty (1964) Folds classification.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Recumbent += {id: 'gso_Recumbent', gso_class: 'Recumbent', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Recumbent', pref_label_en: 'Recumbent ', definition_en_canonical: 'Surface dips between 0 and 10 degrees; typically used to describe orientation of fold hing surface or axial surface, use equivalent term \'Horizontal inclination\' for other geologic surfaces.', parents: ['gsgq:Plane_Orientation'], sources: ['Fleuty (1964) Folds classification.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Recumbent_Fold:GSOClass {id: 'gso_Recumbent_Fold'})
  ON CREATE SET n_gso_Recumbent_Fold += {id: 'gso_Recumbent_Fold', gso_class: 'Recumbent_Fold', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Recumbent_Fold', pref_label_en: 'Recumbent Fold ', definition_en_canonical: 'A fold that has an essentially horizontal axial plane.', parents: ['gsfd:Neutral_Fold'], sources: ['Fleuty (1964) Folds classification.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Recumbent_Fold += {id: 'gso_Recumbent_Fold', gso_class: 'Recumbent_Fold', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Recumbent_Fold', pref_label_en: 'Recumbent Fold ', definition_en_canonical: 'A fold that has an essentially horizontal axial plane.', parents: ['gsfd:Neutral_Fold'], sources: ['Fleuty (1964) Folds classification.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Syncline:GSOClass {id: 'gso_Syncline'})
  ON CREATE SET n_gso_Syncline += {id: 'gso_Syncline', gso_class: 'Syncline', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Syncline', pref_label_en: 'Syncline ', definition_en_canonical: 'A fold of which the core contains the stratigraphically younger rocks', parents: ['gsfd:Fold'], sources: ['https://inspire.ec.europa.eu/codelist/FoldProfileTypeValue/syncline'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Syncline += {id: 'gso_Syncline', gso_class: 'Syncline', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Syncline', pref_label_en: 'Syncline ', definition_en_canonical: 'A fold of which the core contains the stratigraphically younger rocks', parents: ['gsfd:Fold'], sources: ['https://inspire.ec.europa.eu/codelist/FoldProfileTypeValue/syncline'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Synform:GSOClass {id: 'gso_Synform'})
  ON CREATE SET n_gso_Synform += {id: 'gso_Synform', gso_class: 'Synform', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Synform', pref_label_en: 'Synform', definition_en_canonical: 'A convex-downward, concave upward fold.', parents: ['gsfd:Fold'], sources: ['based on https://inspire.ec.europa.eu/codelist/FoldProfileTypeValue/antiform'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Synform += {id: 'gso_Synform', gso_class: 'Synform', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Synform', pref_label_en: 'Synform', definition_en_canonical: 'A convex-downward, concave upward fold.', parents: ['gsfd:Fold'], sources: ['based on https://inspire.ec.europa.eu/codelist/FoldProfileTypeValue/antiform'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Upright_Inclination:GSOClass {id: 'gso_Upright_Inclination'})
  ON CREATE SET n_gso_Upright_Inclination += {id: 'gso_Upright_Inclination', gso_class: 'Upright_Inclination', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Upright_Inclination', pref_label_en: 'Upright Inclination', definition_en_canonical: 'Surface dips between 80 and 90 degrees, used to describe orientation of fold hinge surface or axial surface;  use equivalent term \'Vertical inclination\' for other geologic surfaces.', parents: ['gsgq:Plane_Orientation'], sources: ['Fleuty (1964) Folds classification.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Upright_Inclination += {id: 'gso_Upright_Inclination', gso_class: 'Upright_Inclination', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Upright_Inclination', pref_label_en: 'Upright Inclination', definition_en_canonical: 'Surface dips between 80 and 90 degrees, used to describe orientation of fold hinge surface or axial surface;  use equivalent term \'Vertical inclination\' for other geologic surfaces.', parents: ['gsgq:Plane_Orientation'], sources: ['Fleuty (1964) Folds classification.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_Vertical_Fold:GSOClass {id: 'gso_Vertical_Fold'})
  ON CREATE SET n_gso_Vertical_Fold += {id: 'gso_Vertical_Fold', gso_class: 'Vertical_Fold', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Vertical_Fold', pref_label_en: 'Vertical Fold ', definition_en_canonical: 'A fold for which the fold axis is vertical and axial surface is upright.', parents: ['gsfd:Neutral_Fold'], sources: ['Fleuty (1964) Folds classification.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}
  ON MATCH SET n_gso_Vertical_Fold += {id: 'gso_Vertical_Fold', gso_class: 'Vertical_Fold', owl_uri: 'https://w3id.org/gso/1.0/geologicfold/Vertical_Fold', pref_label_en: 'Vertical Fold ', definition_en_canonical: 'A fold for which the fold axis is vertical and axial surface is upright.', parents: ['gsfd:Neutral_Fold'], sources: ['Fleuty (1964) Folds classification.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-folds'}

MERGE (n_gso_anastomosing_spaced_cleavage:GSOClass {id: 'gso_anastomosing_spaced_cleavage'})
  ON CREATE SET n_gso_anastomosing_spaced_cleavage += {id: 'gso_anastomosing_spaced_cleavage', gso_class: 'anastomosing_spaced_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/anastomosing_spaced_cleavage', pref_label_en: 'anastomosing spaced cleavage', definition_en_canonical: 'spaced cleavage domains branch and rejoin, creating lens-shaped microlithons.', parents: ['gsfo:spaced_cleavage'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_anastomosing_spaced_cleavage += {id: 'gso_anastomosing_spaced_cleavage', gso_class: 'anastomosing_spaced_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/anastomosing_spaced_cleavage', pref_label_en: 'anastomosing spaced cleavage', definition_en_canonical: 'spaced cleavage domains branch and rejoin, creating lens-shaped microlithons.', parents: ['gsfo:spaced_cleavage'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_bedding_fabric:GSOClass {id: 'gso_bedding_fabric'})
  ON CREATE SET n_gso_bedding_fabric += {id: 'gso_bedding_fabric', gso_class: 'bedding_fabric', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/bedding_fabric', pref_label_en: 'bedding', definition_en_canonical: 'Fabric defined by textural or mineralogic variations in sediment produced by depositional processes. May be manifested by lamination structure within the sediment, or by layering in which the individual layers (beds) are bounded by discontinuities related to events in the depositional history.', parents: ['gsfo:primary_foliation'], sources: ['NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  SLTTs 2004, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_bedding_fabric += {id: 'gso_bedding_fabric', gso_class: 'bedding_fabric', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/bedding_fabric', pref_label_en: 'bedding', definition_en_canonical: 'Fabric defined by textural or mineralogic variations in sediment produced by depositional processes. May be manifested by lamination structure within the sediment, or by layering in which the individual layers (beds) are bounded by discontinuities related to events in the depositional history.', parents: ['gsfo:primary_foliation'], sources: ['NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  SLTTs 2004, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_bedding_lamination_structure:GSOClass {id: 'gso_bedding_lamination_structure'})
  ON CREATE SET n_gso_bedding_lamination_structure += {id: 'gso_bedding_lamination_structure', gso_class: 'bedding_lamination_structure', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/bedding_lamination_structure', pref_label_en: 'bedding lamination structure', definition_en_canonical: 'A surface internal to the containing sediment mass defined by textural or mineralogical variation, produced by sediment deposition process, and reflecting the orientation of the original depositional surface. Syn Laminated structure (NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  SLTTs 2004).', parents: ['gsfo:bedding_fabric'], sources: ['NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  SLTTs 2004'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_bedding_lamination_structure += {id: 'gso_bedding_lamination_structure', gso_class: 'bedding_lamination_structure', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/bedding_lamination_structure', pref_label_en: 'bedding lamination structure', definition_en_canonical: 'A surface internal to the containing sediment mass defined by textural or mineralogical variation, produced by sediment deposition process, and reflecting the orientation of the original depositional surface. Syn Laminated structure (NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  SLTTs 2004).', parents: ['gsfo:bedding_fabric'], sources: ['NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  SLTTs 2004'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_c_fabric:GSOClass {id: 'gso_c_fabric'})
  ON CREATE SET n_gso_c_fabric += {id: 'gso_c_fabric', gso_class: 'c_fabric', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/c_fabric', pref_label_en: 'c fabric', definition_en_canonical: 'Ductile shear banding foliation defined by spaced, discrete planar zones of high strain less than 1mm thick. Commonly associated with a particle flattening (\'S\') fabric to form a mylonitic foliation.', parents: ['gsfo:ductile_shear_banding_foliation'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_c_fabric += {id: 'gso_c_fabric', gso_class: 'c_fabric', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/c_fabric', pref_label_en: 'c fabric', definition_en_canonical: 'Ductile shear banding foliation defined by spaced, discrete planar zones of high strain less than 1mm thick. Commonly associated with a particle flattening (\'S\') fabric to form a mylonitic foliation.', parents: ['gsfo:ductile_shear_banding_foliation'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_cleavage:GSOClass {id: 'gso_cleavage'})
  ON CREATE SET n_gso_cleavage += {id: 'gso_cleavage', gso_class: 'cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/cleavage', pref_label_en: 'cleavage', definition_en_canonical: 'A tectonic foliation in a rock characterized by a tendency for the rock to split along a regular set of parallel or sub-parallel closely spaced surfaces. Cleavage is a more general term than schistosity because schistosity need not be present in order for a rock to display cleavage. Cleavage domains or parting surfaces are not spaced more than 5 cm apart on average (Borradaille et al., 1982)', parents: ['gsfo:tectonic_foliation'], sources: ['Brodie, Kate, Fettes, Douglas, and Harte, Ben, 2007, Structural terms including fault rock terms, in Fettes, D., and Desmons, J., Metamorphic rocks-A classification and Glossary of Terms: Cambridge, UK, Cambridge University Press, p. 24-31.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_cleavage += {id: 'gso_cleavage', gso_class: 'cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/cleavage', pref_label_en: 'cleavage', definition_en_canonical: 'A tectonic foliation in a rock characterized by a tendency for the rock to split along a regular set of parallel or sub-parallel closely spaced surfaces. Cleavage is a more general term than schistosity because schistosity need not be present in order for a rock to display cleavage. Cleavage domains or parting surfaces are not spaced more than 5 cm apart on average (Borradaille et al., 1982)', parents: ['gsfo:tectonic_foliation'], sources: ['Brodie, Kate, Fettes, Douglas, and Harte, Ben, 2007, Structural terms including fault rock terms, in Fettes, D., and Desmons, J., Metamorphic rocks-A classification and Glossary of Terms: Cambridge, UK, Cambridge University Press, p. 24-31.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_cleavage_parallel_to_bedding:GSOClass {id: 'gso_cleavage_parallel_to_bedding'})
  ON CREATE SET n_gso_cleavage_parallel_to_bedding += {id: 'gso_cleavage_parallel_to_bedding', gso_class: 'cleavage_parallel_to_bedding', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/cleavage_parallel_to_bedding', pref_label_en: 'cleavage parallel to bedding', definition_en_canonical: 'Composite fabric in which a cleavage is developed parallel to bedding.', parents: ['gsfo:cleavage', 'gsfo:compound_foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_cleavage_parallel_to_bedding += {id: 'gso_cleavage_parallel_to_bedding', gso_class: 'cleavage_parallel_to_bedding', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/cleavage_parallel_to_bedding', pref_label_en: 'cleavage parallel to bedding', definition_en_canonical: 'Composite fabric in which a cleavage is developed parallel to bedding.', parents: ['gsfo:cleavage', 'gsfo:compound_foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_close_joints:GSOClass {id: 'gso_close_joints'})
  ON CREATE SET n_gso_close_joints += {id: 'gso_close_joints', gso_class: 'close_joints', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/close_joints', pref_label_en: 'close joints', definition_en_canonical: 'Foliation defined by parting surfaces (cleavage domains) that have no apparent thickness, are spaced between 5 cm and 25 cm, and do not crenulate an older foliation. Fabric intermediate between typical cleavage and joints. Parting surfaces are regularly spaced, and penetrative on a 1-10 m scale. 5 cm upper limit on spacing of \'cleavage domains\' in a \'cleavage \'fabric is suggested by Borradaile et al. [1982].', parents: ['gsfo:cleavage', 'gsfo:joint_fabric'], sources: ['Borradaile et al. 1982, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_close_joints += {id: 'gso_close_joints', gso_class: 'close_joints', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/close_joints', pref_label_en: 'close joints', definition_en_canonical: 'Foliation defined by parting surfaces (cleavage domains) that have no apparent thickness, are spaced between 5 cm and 25 cm, and do not crenulate an older foliation. Fabric intermediate between typical cleavage and joints. Parting surfaces are regularly spaced, and penetrative on a 1-10 m scale. 5 cm upper limit on spacing of \'cleavage domains\' in a \'cleavage \'fabric is suggested by Borradaile et al. [1982].', parents: ['gsfo:cleavage', 'gsfo:joint_fabric'], sources: ['Borradaile et al. 1982, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_comb_layering:GSOClass {id: 'gso_comb_layering'})
  ON CREATE SET n_gso_comb_layering += {id: 'gso_comb_layering', gso_class: 'comb_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/comb_layering', pref_label_en: 'comb layering', definition_en_canonical: 'Layering fabric defined by layers that have internal comb structure. Layer boundaries are the termination surfaces for the constituent crystals.', parents: ['gsfo:layering'], sources: ['Neuendorf et al. 2005, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_comb_layering += {id: 'gso_comb_layering', gso_class: 'comb_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/comb_layering', pref_label_en: 'comb layering', definition_en_canonical: 'Layering fabric defined by layers that have internal comb structure. Layer boundaries are the termination surfaces for the constituent crystals.', parents: ['gsfo:layering'], sources: ['Neuendorf et al. 2005, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_compositional_layering:GSOClass {id: 'gso_compositional_layering'})
  ON CREATE SET n_gso_compositional_layering += {id: 'gso_compositional_layering', gso_class: 'compositional_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/compositional_layering', pref_label_en: 'compositional layering', definition_en_canonical: 'Layering fabric defined by layers that have different mineralogic composition.', parents: ['gsfo:layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03, submitted by British Antarctic Survey'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_compositional_layering += {id: 'gso_compositional_layering', gso_class: 'compositional_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/compositional_layering', pref_label_en: 'compositional layering', definition_en_canonical: 'Layering fabric defined by layers that have different mineralogic composition.', parents: ['gsfo:layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03, submitted by British Antarctic Survey'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_compound_foliation:GSOClass {id: 'gso_compound_foliation'})
  ON CREATE SET n_gso_compound_foliation += {id: 'gso_compound_foliation', gso_class: 'compound_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/compound_foliation', pref_label_en: 'compound foliation', definition_en_canonical: 'Foliation that includes fabric elements indicating classification with foliation types of different genetic origin, e.g. cleavage parallel to bedding is a compound fabric with a sedimentary foliation and a tectonic foliation. No connotation of genetic origin of fabric elements.', parents: ['gsos:Foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_compound_foliation += {id: 'gso_compound_foliation', gso_class: 'compound_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/compound_foliation', pref_label_en: 'compound foliation', definition_en_canonical: 'Foliation that includes fabric elements indicating classification with foliation types of different genetic origin, e.g. cleavage parallel to bedding is a compound fabric with a sedimentary foliation and a tectonic foliation. No connotation of genetic origin of fabric elements.', parents: ['gsos:Foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_compound_metamorphic_foliation:GSOClass {id: 'gso_compound_metamorphic_foliation'})
  ON CREATE SET n_gso_compound_metamorphic_foliation += {id: 'gso_compound_metamorphic_foliation', gso_class: 'compound_metamorphic_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/compound_metamorphic_foliation', pref_label_en: 'compound metamorphic foliation', definition_en_canonical: 'A compound foliation in which the constituent fabric elements are of metamorphic origin.', parents: ['gsfo:compound_foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_compound_metamorphic_foliation += {id: 'gso_compound_metamorphic_foliation', gso_class: 'compound_metamorphic_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/compound_metamorphic_foliation', pref_label_en: 'compound metamorphic foliation', definition_en_canonical: 'A compound foliation in which the constituent fabric elements are of metamorphic origin.', parents: ['gsfo:compound_foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_continuous_cleavage:GSOClass {id: 'gso_continuous_cleavage'})
  ON CREATE SET n_gso_continuous_cleavage += {id: 'gso_continuous_cleavage', gso_class: 'continuous_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/continuous_cleavage', pref_label_en: 'continuous cleavage', definition_en_canonical: 'A cleavage that is statistically homogeneous down to the scale of individual mineral grains.', parents: ['gsfo:cleavage'], sources: ['Borradaile et al 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_continuous_cleavage += {id: 'gso_continuous_cleavage', gso_class: 'continuous_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/continuous_cleavage', pref_label_en: 'continuous cleavage', definition_en_canonical: 'A cleavage that is statistically homogeneous down to the scale of individual mineral grains.', parents: ['gsfo:cleavage'], sources: ['Borradaile et al 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_continuous_crenulation_cleavage:GSOClass {id: 'gso_continuous_crenulation_cleavage'})
  ON CREATE SET n_gso_continuous_crenulation_cleavage += {id: 'gso_continuous_crenulation_cleavage', gso_class: 'continuous_crenulation_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/continuous_crenulation_cleavage', pref_label_en: 'continuous crenulation cleavage', definition_en_canonical: 'Cleavage defined by long, thin limbs of crenulation folds of pre-existing foliation, in which the boundaries between cleavage domains and lithons are gradational. Both the crenulation foliation and the crenulated (older) foliation are easily visible. Grades to spaced crenulation cleavage as boundaries of cleavage domains become sharp, and to schistosity or compositional layering as the crenulation foliation obscures the crenulated foliation to become the dominant fabric in the rock. In many rocks with continuous crenulation cleavage, the tendency to part along the cleavage may be weak, thus the rock may not technically meet the definition of \'cleavage as used in CGI foliationtype SKOS vocabulary 2018-08-03.', parents: ['gsfo:continuous_cleavage', 'gsfo:crenulation_cleavage'], sources: ['Borradaile et al 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_continuous_crenulation_cleavage += {id: 'gso_continuous_crenulation_cleavage', gso_class: 'continuous_crenulation_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/continuous_crenulation_cleavage', pref_label_en: 'continuous crenulation cleavage', definition_en_canonical: 'Cleavage defined by long, thin limbs of crenulation folds of pre-existing foliation, in which the boundaries between cleavage domains and lithons are gradational. Both the crenulation foliation and the crenulated (older) foliation are easily visible. Grades to spaced crenulation cleavage as boundaries of cleavage domains become sharp, and to schistosity or compositional layering as the crenulation foliation obscures the crenulated foliation to become the dominant fabric in the rock. In many rocks with continuous crenulation cleavage, the tendency to part along the cleavage may be weak, thus the rock may not technically meet the definition of \'cleavage as used in CGI foliationtype SKOS vocabulary 2018-08-03.', parents: ['gsfo:continuous_cleavage', 'gsfo:crenulation_cleavage'], sources: ['Borradaile et al 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_crenulation_cleavage:GSOClass {id: 'gso_crenulation_cleavage'})
  ON CREATE SET n_gso_crenulation_cleavage += {id: 'gso_crenulation_cleavage', gso_class: 'crenulation_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/crenulation_cleavage', pref_label_en: 'crenulation cleavage', definition_en_canonical: 'Cleavage that is overprinted on an older foliation that is folded to some degree in association with development of the younger cleavage. Cleavage domains commonly associated with long limbs of crenulation folds, and hinge surfaces of folds are roughly parallel. Wavelength of crenulation folds is less than or equal to 1 cm. Cleavage defined by limbs of microfolds coincident with zones of mineral differentiation', parents: ['gsfo:cleavage'], sources: ['Brodie, Kate, Fettes, Douglas, and Harte, Ben, 2007, Structural terms including fault rock terms, in Fettes, D., and Desmons, J., Metamorphic rocks-A classification and Glossary of Terms: Cambridge, UK, Cambridge University Press, p. 24-31.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_crenulation_cleavage += {id: 'gso_crenulation_cleavage', gso_class: 'crenulation_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/crenulation_cleavage', pref_label_en: 'crenulation cleavage', definition_en_canonical: 'Cleavage that is overprinted on an older foliation that is folded to some degree in association with development of the younger cleavage. Cleavage domains commonly associated with long limbs of crenulation folds, and hinge surfaces of folds are roughly parallel. Wavelength of crenulation folds is less than or equal to 1 cm. Cleavage defined by limbs of microfolds coincident with zones of mineral differentiation', parents: ['gsfo:cleavage'], sources: ['Brodie, Kate, Fettes, Douglas, and Harte, Ben, 2007, Structural terms including fault rock terms, in Fettes, D., and Desmons, J., Metamorphic rocks-A classification and Glossary of Terms: Cambridge, UK, Cambridge University Press, p. 24-31.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_crude_or_indistinct_bedding:GSOClass {id: 'gso_crude_or_indistinct_bedding'})
  ON CREATE SET n_gso_crude_or_indistinct_bedding += {id: 'gso_crude_or_indistinct_bedding', gso_class: 'crude_or_indistinct_bedding', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/crude_or_indistinct_bedding', pref_label_en: 'crude or indistinct bedding', definition_en_canonical: 'Bedding defined by surfaces that are not distinct, e.g. by gradational grain size variations.', parents: ['gsfo:bedding_fabric'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_crude_or_indistinct_bedding += {id: 'gso_crude_or_indistinct_bedding', gso_class: 'crude_or_indistinct_bedding', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/crude_or_indistinct_bedding', pref_label_en: 'crude or indistinct bedding', definition_en_canonical: 'Bedding defined by surfaces that are not distinct, e.g. by gradational grain size variations.', parents: ['gsfo:bedding_fabric'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_cryptomicrobial_lamination:GSOClass {id: 'gso_cryptomicrobial_lamination'})
  ON CREATE SET n_gso_cryptomicrobial_lamination += {id: 'gso_cryptomicrobial_lamination', gso_class: 'cryptomicrobial_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/cryptomicrobial_lamination', pref_label_en: 'cryptomicrobial lamination', definition_en_canonical: 'Fabric defined by fine laminae formed by the trapping of grains and lime precipitation in a microbial mat.', parents: ['gsfo:bedding_lamination_structure'], sources: ['GGIPAC'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_cryptomicrobial_lamination += {id: 'gso_cryptomicrobial_lamination', gso_class: 'cryptomicrobial_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/cryptomicrobial_lamination', pref_label_en: 'cryptomicrobial lamination', definition_en_canonical: 'Fabric defined by fine laminae formed by the trapping of grains and lime precipitation in a microbial mat.', parents: ['gsfo:bedding_lamination_structure'], sources: ['GGIPAC'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_cumulate_layering:GSOClass {id: 'gso_cumulate_layering'})
  ON CREATE SET n_gso_cumulate_layering += {id: 'gso_cumulate_layering', gso_class: 'cumulate_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/cumulate_layering', pref_label_en: 'cumulate layering', definition_en_canonical: 'Layering in igneous rocks in which layers are characterized by variation in relative proportion of magmatically crystallized minerals. Typically a pattern of mineralogical variation will be repeated many times in a vertical section with layers of relatively consistent thickness. See photos in Best [1982] p. 176-177. Gravity-stratified layers typically have mafic minerals at the base and plagioclase at the top and are interpreted to form by crystal settling in magma.', parents: ['gsfo:igneous_layering'], sources: ['Carmichael et al 1974, Best 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_cumulate_layering += {id: 'gso_cumulate_layering', gso_class: 'cumulate_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/cumulate_layering', pref_label_en: 'cumulate layering', definition_en_canonical: 'Layering in igneous rocks in which layers are characterized by variation in relative proportion of magmatically crystallized minerals. Typically a pattern of mineralogical variation will be repeated many times in a vertical section with layers of relatively consistent thickness. See photos in Best [1982] p. 176-177. Gravity-stratified layers typically have mafic minerals at the base and plagioclase at the top and are interpreted to form by crystal settling in magma.', parents: ['gsfo:igneous_layering'], sources: ['Carmichael et al 1974, Best 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_discrete_cleavage:GSOClass {id: 'gso_discrete_cleavage'})
  ON CREATE SET n_gso_discrete_cleavage += {id: 'gso_discrete_cleavage', gso_class: 'discrete_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/discrete_cleavage', pref_label_en: 'discrete cleavage', definition_en_canonical: 'Spaced cleavage in which cleavage domains have sharply defined edges.', parents: ['gsfo:spaced_cleavage'], sources: ['Borradaile et al., 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_discrete_cleavage += {id: 'gso_discrete_cleavage', gso_class: 'discrete_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/discrete_cleavage', pref_label_en: 'discrete cleavage', definition_en_canonical: 'Spaced cleavage in which cleavage domains have sharply defined edges.', parents: ['gsfo:spaced_cleavage'], sources: ['Borradaile et al., 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_discrete_crenulation_cleavage:GSOClass {id: 'gso_discrete_crenulation_cleavage'})
  ON CREATE SET n_gso_discrete_crenulation_cleavage += {id: 'gso_discrete_crenulation_cleavage', gso_class: 'discrete_crenulation_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/discrete_crenulation_cleavage', pref_label_en: 'discrete crenulation cleavage', definition_en_canonical: 'Crenulation cleavage in which the cleavage domains have discrete boundaries. Amplitude of crenulation folds tends to be small.', parents: ['gsfo:crenulation_cleavage', 'gsfo:spaced_cleavage'], sources: ['Borradaile et al 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_discrete_crenulation_cleavage += {id: 'gso_discrete_crenulation_cleavage', gso_class: 'discrete_crenulation_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/discrete_crenulation_cleavage', pref_label_en: 'discrete crenulation cleavage', definition_en_canonical: 'Crenulation cleavage in which the cleavage domains have discrete boundaries. Amplitude of crenulation folds tends to be small.', parents: ['gsfo:crenulation_cleavage', 'gsfo:spaced_cleavage'], sources: ['Borradaile et al 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_discrete_disjunct_spaced_cleavage:GSOClass {id: 'gso_discrete_disjunct_spaced_cleavage'})
  ON CREATE SET n_gso_discrete_disjunct_spaced_cleavage += {id: 'gso_discrete_disjunct_spaced_cleavage', gso_class: 'discrete_disjunct_spaced_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/discrete_disjunct_spaced_cleavage', pref_label_en: 'discrete disjunct spaced cleavage', definition_en_canonical: 'Disjunct spaced cleavage defined by discrete cleavage surfaces, typically in low-grade clastic rocks. Syn. Fracture cleavage.', parents: ['gsfo:spaced_cleavage'], sources: ['Neuendorf et al. 2005, Borradaile et al. 1982.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_discrete_disjunct_spaced_cleavage += {id: 'gso_discrete_disjunct_spaced_cleavage', gso_class: 'discrete_disjunct_spaced_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/discrete_disjunct_spaced_cleavage', pref_label_en: 'discrete disjunct spaced cleavage', definition_en_canonical: 'Disjunct spaced cleavage defined by discrete cleavage surfaces, typically in low-grade clastic rocks. Syn. Fracture cleavage.', parents: ['gsfo:spaced_cleavage'], sources: ['Neuendorf et al. 2005, Borradaile et al. 1982.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_disjunctive_cleavage:GSOClass {id: 'gso_disjunctive_cleavage'})
  ON CREATE SET n_gso_disjunctive_cleavage += {id: 'gso_disjunctive_cleavage', gso_class: 'disjunctive_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/disjunctive_cleavage', pref_label_en: 'disjunctive cleavage', definition_en_canonical: 'A spaced cleavage independent of any pre-existing mineral orientation, cleavage in which there is no systematic relationship between a pre-existing preferred orientation and the superimposed cleavage. (Borradaile et al., 1982)', parents: ['gsfo:cleavage'], sources: ['Borradaile et al. 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_disjunctive_cleavage += {id: 'gso_disjunctive_cleavage', gso_class: 'disjunctive_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/disjunctive_cleavage', pref_label_en: 'disjunctive cleavage', definition_en_canonical: 'A spaced cleavage independent of any pre-existing mineral orientation, cleavage in which there is no systematic relationship between a pre-existing preferred orientation and the superimposed cleavage. (Borradaile et al., 1982)', parents: ['gsfo:cleavage'], sources: ['Borradaile et al. 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_domainal_cleavage:GSOClass {id: 'gso_domainal_cleavage'})
  ON CREATE SET n_gso_domainal_cleavage += {id: 'gso_domainal_cleavage', gso_class: 'domainal_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/domainal_cleavage', pref_label_en: 'domainal cleavage', definition_en_canonical: 'Fabric in which domains of more strongly developed (closely spaced) cleavage are separated by lenses of weakly or non-cleaved rock. Typically observed on outcrop scale and used for geologic unit description', parents: ['gsfo:cleavage'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_domainal_cleavage += {id: 'gso_domainal_cleavage', gso_class: 'domainal_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/domainal_cleavage', pref_label_en: 'domainal cleavage', definition_en_canonical: 'Fabric in which domains of more strongly developed (closely spaced) cleavage are separated by lenses of weakly or non-cleaved rock. Typically observed on outcrop scale and used for geologic unit description', parents: ['gsfo:cleavage'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_ductile_shear_banding_foliation:GSOClass {id: 'gso_ductile_shear_banding_foliation'})
  ON CREATE SET n_gso_ductile_shear_banding_foliation += {id: 'gso_ductile_shear_banding_foliation', gso_class: 'ductile_shear_banding_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/ductile_shear_banding_foliation', pref_label_en: 'ductile shear banding foliation', definition_en_canonical: 'Foliation defined by regularly spaced ductile shear bands at the scale of descripiton.', parents: ['gsfo:tectonic_foliation'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_ductile_shear_banding_foliation += {id: 'gso_ductile_shear_banding_foliation', gso_class: 'ductile_shear_banding_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/ductile_shear_banding_foliation', pref_label_en: 'ductile shear banding foliation', definition_en_canonical: 'Foliation defined by regularly spaced ductile shear bands at the scale of descripiton.', parents: ['gsfo:tectonic_foliation'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_eutaxitic_foliation:GSOClass {id: 'gso_eutaxitic_foliation'})
  ON CREATE SET n_gso_eutaxitic_foliation += {id: 'gso_eutaxitic_foliation', gso_class: 'eutaxitic_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/eutaxitic_foliation', pref_label_en: 'eutaxitic foliation', definition_en_canonical: 'Foliation defined by flattened pumice clasts or glass shards, aligned elongate lithic fragments, variations in composition, vesicularity, crystallinity, grain size, spherulite and lithophysae abundance, or the degree of devitrification in a welded tuff. This term denotes interpretation that foliation formed during compaction and welding of tuff.', parents: ['gsfo:primary_igneous_foliation'], sources: ['Neuendorf et al. 2005, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_eutaxitic_foliation += {id: 'gso_eutaxitic_foliation', gso_class: 'eutaxitic_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/eutaxitic_foliation', pref_label_en: 'eutaxitic foliation', definition_en_canonical: 'Foliation defined by flattened pumice clasts or glass shards, aligned elongate lithic fragments, variations in composition, vesicularity, crystallinity, grain size, spherulite and lithophysae abundance, or the degree of devitrification in a welded tuff. This term denotes interpretation that foliation formed during compaction and welding of tuff.', parents: ['gsfo:primary_igneous_foliation'], sources: ['Neuendorf et al. 2005, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_fissile_lamination:GSOClass {id: 'gso_fissile_lamination'})
  ON CREATE SET n_gso_fissile_lamination += {id: 'gso_fissile_lamination', gso_class: 'fissile_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/fissile_lamination', pref_label_en: 'fissile lamination', definition_en_canonical: 'Diffuse to distinct lamination in mudstones and mud, defined by the alignment of clay minerals. Lacks distinct very-fine scale layering and repetition of couplets that characterize varves. Essentially a continuous cleavage parallel to bedding, but considered a sedimentary structure related to sediment compaction during diagenesis.', parents: ['gsfo:bedding_lamination_structure'], sources: ['NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  SLTTs 2004, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_fissile_lamination += {id: 'gso_fissile_lamination', gso_class: 'fissile_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/fissile_lamination', pref_label_en: 'fissile lamination', definition_en_canonical: 'Diffuse to distinct lamination in mudstones and mud, defined by the alignment of clay minerals. Lacks distinct very-fine scale layering and repetition of couplets that characterize varves. Essentially a continuous cleavage parallel to bedding, but considered a sedimentary structure related to sediment compaction during diagenesis.', parents: ['gsfo:bedding_lamination_structure'], sources: ['NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  SLTTs 2004, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_flaser_structure:GSOClass {id: 'gso_flaser_structure'})
  ON CREATE SET n_gso_flaser_structure += {id: 'gso_flaser_structure', gso_class: 'flaser_structure', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/flaser_structure', pref_label_en: 'flaser structure', definition_en_canonical: 'Tectonic foliation defined by lenses and layers of original or relatively unaltered granular minerals surrounded by a matrix of highly sheared and crushed material. No connotation of metamorphic grade.', parents: ['gsfo:tectonic_foliation'], sources: ['Neuendorf et al. 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_flaser_structure += {id: 'gso_flaser_structure', gso_class: 'flaser_structure', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/flaser_structure', pref_label_en: 'flaser structure', definition_en_canonical: 'Tectonic foliation defined by lenses and layers of original or relatively unaltered granular minerals surrounded by a matrix of highly sheared and crushed material. No connotation of metamorphic grade.', parents: ['gsfo:tectonic_foliation'], sources: ['Neuendorf et al. 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_flow_layering:GSOClass {id: 'gso_flow_layering'})
  ON CREATE SET n_gso_flow_layering += {id: 'gso_flow_layering', gso_class: 'flow_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/flow_layering', pref_label_en: 'flow layering', definition_en_canonical: 'Layering produced by flow of magma, lava, or diapiric flow of sedimentary rock. Distinction from eutaxitic foliation may be difficult.', parents: ['gsfo:layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_flow_layering += {id: 'gso_flow_layering', gso_class: 'flow_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/flow_layering', pref_label_en: 'flow layering', definition_en_canonical: 'Layering produced by flow of magma, lava, or diapiric flow of sedimentary rock. Distinction from eutaxitic foliation may be difficult.', parents: ['gsfo:layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_generic_mylonitic_foliation:GSOClass {id: 'gso_generic_mylonitic_foliation'})
  ON CREATE SET n_gso_generic_mylonitic_foliation += {id: 'gso_generic_mylonitic_foliation', gso_class: 'generic_mylonitic_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/generic_mylonitic_foliation', pref_label_en: 'generic mylonitic foliation', definition_en_canonical: 'Foliation defined by the shapes of deformed mineral grains or grain aggregates having aspect ratios greater than 1.5:1, greater than 10 percent of the rock is composed of \'matrix\' showing evidence of tectonic reduction in grain size, and the foliation and matrix are interpreted to be the product of continuous, crystal-plastic deformation processes. Generic class is used when data are insufficient to determine classification to protomylontic, mylonite, or ultramylonitc foliation, or to specify that any sort of mylontic foliation may be present.', parents: ['gsfo:tectonic_foliation'], sources: ['NADM metamorphic rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixB/appendixB.pdf) SLTTm1.0 2004'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_generic_mylonitic_foliation += {id: 'gso_generic_mylonitic_foliation', gso_class: 'generic_mylonitic_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/generic_mylonitic_foliation', pref_label_en: 'generic mylonitic foliation', definition_en_canonical: 'Foliation defined by the shapes of deformed mineral grains or grain aggregates having aspect ratios greater than 1.5:1, greater than 10 percent of the rock is composed of \'matrix\' showing evidence of tectonic reduction in grain size, and the foliation and matrix are interpreted to be the product of continuous, crystal-plastic deformation processes. Generic class is used when data are insufficient to determine classification to protomylontic, mylonite, or ultramylonitc foliation, or to specify that any sort of mylontic foliation may be present.', parents: ['gsfo:tectonic_foliation'], sources: ['NADM metamorphic rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixB/appendixB.pdf) SLTTm1.0 2004'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_gneissic_layering:GSOClass {id: 'gso_gneissic_layering'})
  ON CREATE SET n_gso_gneissic_layering += {id: 'gso_gneissic_layering', gso_class: 'gneissic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/gneissic_layering', pref_label_en: 'gneissic layering', definition_en_canonical: 'Compositional layering in a metamorphic rock, syn. gneissic banding', parents: ['gsfo:metamorphic_layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_gneissic_layering += {id: 'gso_gneissic_layering', gso_class: 'gneissic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/gneissic_layering', pref_label_en: 'gneissic layering', definition_en_canonical: 'Compositional layering in a metamorphic rock, syn. gneissic banding', parents: ['gsfo:metamorphic_layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_grain_shape_foliation:GSOClass {id: 'gso_grain_shape_foliation'})
  ON CREATE SET n_gso_grain_shape_foliation += {id: 'gso_grain_shape_foliation', gso_class: 'grain_shape_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/grain_shape_foliation', pref_label_en: 'grain shape foliation', definition_en_canonical: 'Foliation defined by the alignment of oblate particles, which may be detrital grains, crystals, or crystalline grain aggregates.', parents: ['gsos:Foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_grain_shape_foliation += {id: 'gso_grain_shape_foliation', gso_class: 'grain_shape_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/grain_shape_foliation', pref_label_en: 'grain shape foliation', definition_en_canonical: 'Foliation defined by the alignment of oblate particles, which may be detrital grains, crystals, or crystalline grain aggregates.', parents: ['gsos:Foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_igneous_flow_foliation:GSOClass {id: 'gso_igneous_flow_foliation'})
  ON CREATE SET n_gso_igneous_flow_foliation += {id: 'gso_igneous_flow_foliation', gso_class: 'igneous_flow_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/igneous_flow_foliation', pref_label_en: 'igneous flow foliation', definition_en_canonical: 'Foliation interpreted to be due to flow in a body of magma or lava. Includes flow banding in lava, and foliation defined by aligned crystals in a phaneritic igneous rock..', parents: ['gsfo:primary_igneous_foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_igneous_flow_foliation += {id: 'gso_igneous_flow_foliation', gso_class: 'igneous_flow_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/igneous_flow_foliation', pref_label_en: 'igneous flow foliation', definition_en_canonical: 'Foliation interpreted to be due to flow in a body of magma or lava. Includes flow banding in lava, and foliation defined by aligned crystals in a phaneritic igneous rock..', parents: ['gsfo:primary_igneous_foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_igneous_lamination:GSOClass {id: 'gso_igneous_lamination'})
  ON CREATE SET n_gso_igneous_lamination += {id: 'gso_igneous_lamination', gso_class: 'igneous_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/igneous_lamination', pref_label_en: 'igneous lamination', definition_en_canonical: 'Foliation defined by surfaces of textural or mineralogical variation formed by igneous processes. If the lamination surfaces are regularly spaced, they may be used to define layers.', parents: ['gsfo:igneous_layering', 'gsfo:primary_igneous_foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_igneous_lamination += {id: 'gso_igneous_lamination', gso_class: 'igneous_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/igneous_lamination', pref_label_en: 'igneous lamination', definition_en_canonical: 'Foliation defined by surfaces of textural or mineralogical variation formed by igneous processes. If the lamination surfaces are regularly spaced, they may be used to define layers.', parents: ['gsfo:igneous_layering', 'gsfo:primary_igneous_foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_igneous_layering:GSOClass {id: 'gso_igneous_layering'})
  ON CREATE SET n_gso_igneous_layering += {id: 'gso_igneous_layering', gso_class: 'igneous_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/igneous_layering', pref_label_en: 'igneous layering', definition_en_canonical: 'Layering that is the product of processes operating in magma or lava. syn. magmatic layering', parents: ['gsfo:layering', 'gsfo:primary_igneous_foliation'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_igneous_layering += {id: 'gso_igneous_layering', gso_class: 'igneous_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/igneous_layering', pref_label_en: 'igneous layering', definition_en_canonical: 'Layering that is the product of processes operating in magma or lava. syn. magmatic layering', parents: ['gsfo:layering', 'gsfo:primary_igneous_foliation'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_igneous_textural_layering:GSOClass {id: 'gso_igneous_textural_layering'})
  ON CREATE SET n_gso_igneous_textural_layering += {id: 'gso_igneous_textural_layering', gso_class: 'igneous_textural_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/igneous_textural_layering', pref_label_en: 'igneous textural layering', definition_en_canonical: 'Layering defined by grain size/ grain shape variations resulting from crystallization processes in igneous rock, most commonly observed in pegmatite/aplite dikes or bodies, and in Laramide leucogranites of Wilderness suite in Arizona.', parents: ['gsfo:igneous_layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_igneous_textural_layering += {id: 'gso_igneous_textural_layering', gso_class: 'igneous_textural_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/igneous_textural_layering', pref_label_en: 'igneous textural layering', definition_en_canonical: 'Layering defined by grain size/ grain shape variations resulting from crystallization processes in igneous rock, most commonly observed in pegmatite/aplite dikes or bodies, and in Laramide leucogranites of Wilderness suite in Arizona.', parents: ['gsfo:igneous_layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_imbricated_clast_fabric:GSOClass {id: 'gso_imbricated_clast_fabric'})
  ON CREATE SET n_gso_imbricated_clast_fabric += {id: 'gso_imbricated_clast_fabric', gso_class: 'imbricated_clast_fabric', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/imbricated_clast_fabric', pref_label_en: 'imbricated clast fabric', definition_en_canonical: 'Fabric defined by long axis of tabular clasts stacked like shingles to define a surface that makes a small angle with the bedding surface. A depositional fabric formed by disk-shaped or elongate pebbles all tilted in the same direction, flat sides commonly dip upstream', parents: ['gsfo:grain_shape_foliation', 'gsfo:primary_foliation'], sources: ['based on Neuendorf et al 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_imbricated_clast_fabric += {id: 'gso_imbricated_clast_fabric', gso_class: 'imbricated_clast_fabric', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/imbricated_clast_fabric', pref_label_en: 'imbricated clast fabric', definition_en_canonical: 'Fabric defined by long axis of tabular clasts stacked like shingles to define a surface that makes a small angle with the bedding surface. A depositional fabric formed by disk-shaped or elongate pebbles all tilted in the same direction, flat sides commonly dip upstream', parents: ['gsfo:grain_shape_foliation', 'gsfo:primary_foliation'], sources: ['based on Neuendorf et al 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_impersistent_lamination:GSOClass {id: 'gso_impersistent_lamination'})
  ON CREATE SET n_gso_impersistent_lamination += {id: 'gso_impersistent_lamination', gso_class: 'impersistent_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/impersistent_lamination', pref_label_en: 'impersistent lamination', definition_en_canonical: 'Lamination defined by discontinuous surfaces', parents: ['gsfo:bedding_lamination_structure'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_impersistent_lamination += {id: 'gso_impersistent_lamination', gso_class: 'impersistent_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/impersistent_lamination', pref_label_en: 'impersistent lamination', definition_en_canonical: 'Lamination defined by discontinuous surfaces', parents: ['gsfo:bedding_lamination_structure'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_irregular_lamination:GSOClass {id: 'gso_irregular_lamination'})
  ON CREATE SET n_gso_irregular_lamination += {id: 'gso_irregular_lamination', gso_class: 'irregular_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/irregular_lamination', pref_label_en: 'irregular lamination', definition_en_canonical: 'Lamination fabric in which individual lamina or groups of lamina are warped in an irregular fashion, like a flattened peice of crumpled paper. A crude planar orientation is discernible.', parents: ['gsfo:bedding_lamination_structure'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_irregular_lamination += {id: 'gso_irregular_lamination', gso_class: 'irregular_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/irregular_lamination', pref_label_en: 'irregular lamination', definition_en_canonical: 'Lamination fabric in which individual lamina or groups of lamina are warped in an irregular fashion, like a flattened peice of crumpled paper. A crude planar orientation is discernible.', parents: ['gsfo:bedding_lamination_structure'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_joint_fabric:GSOClass {id: 'gso_joint_fabric'})
  ON CREATE SET n_gso_joint_fabric += {id: 'gso_joint_fabric', gso_class: 'joint_fabric', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/joint_fabric', pref_label_en: 'joint fabric', definition_en_canonical: 'Fabric defined by parting surfaces in rock that occur in crudely parallel orientation, spaced greater than 5 cm on average if in a very regular joint set. Spacing is more variable and alignment of surfaces is cruder that cleavage. Typically applies to geologic unit description.', parents: ['gsos:Foliation'], sources: ['Borradaile et al 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_joint_fabric += {id: 'gso_joint_fabric', gso_class: 'joint_fabric', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/joint_fabric', pref_label_en: 'joint fabric', definition_en_canonical: 'Fabric defined by parting surfaces in rock that occur in crudely parallel orientation, spaced greater than 5 cm on average if in a very regular joint set. Spacing is more variable and alignment of surfaces is cruder that cleavage. Typically applies to geologic unit description.', parents: ['gsos:Foliation'], sources: ['Borradaile et al 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_laminated_metamorphic_layering:GSOClass {id: 'gso_laminated_metamorphic_layering'})
  ON CREATE SET n_gso_laminated_metamorphic_layering += {id: 'gso_laminated_metamorphic_layering', gso_class: 'laminated_metamorphic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/laminated_metamorphic_layering', pref_label_en: 'laminated metamorphic layering', definition_en_canonical: 'Metamorphic layering in which the layers are less than 1 cm thick. See Weiss, L.E. [1972] plate 36 or Borraidaile et al [1982] plate 137A B (page 331), plate140A (page 337) for examples.', parents: ['gsfo:metamorphic_layering'], sources: ['Weiss 1972, Borradaile et al 1982, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_laminated_metamorphic_layering += {id: 'gso_laminated_metamorphic_layering', gso_class: 'laminated_metamorphic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/laminated_metamorphic_layering', pref_label_en: 'laminated metamorphic layering', definition_en_canonical: 'Metamorphic layering in which the layers are less than 1 cm thick. See Weiss, L.E. [1972] plate 36 or Borraidaile et al [1982] plate 137A B (page 331), plate140A (page 337) for examples.', parents: ['gsfo:metamorphic_layering'], sources: ['Weiss 1972, Borradaile et al 1982, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_lava_flow_banding:GSOClass {id: 'gso_lava_flow_banding'})
  ON CREATE SET n_gso_lava_flow_banding += {id: 'gso_lava_flow_banding', gso_class: 'lava_flow_banding', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/lava_flow_banding', pref_label_en: 'lava flow banding', definition_en_canonical: 'Layering formed by laminar lava flow, defined by variations in composition, vesicularity, crystallinity, grainsize, spherulite and lithophysae abundance, degree of devitrification, colour, and/or parting surfaces, syn. flow lamination, flow banding', parents: ['gsfo:flow_layering', 'gsfo:igneous_layering'], sources: ['GGIPAC, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_lava_flow_banding += {id: 'gso_lava_flow_banding', gso_class: 'lava_flow_banding', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/lava_flow_banding', pref_label_en: 'lava flow banding', definition_en_canonical: 'Layering formed by laminar lava flow, defined by variations in composition, vesicularity, crystallinity, grainsize, spherulite and lithophysae abundance, degree of devitrification, colour, and/or parting surfaces, syn. flow lamination, flow banding', parents: ['gsfo:flow_layering', 'gsfo:igneous_layering'], sources: ['GGIPAC, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_layered_mylonitic_foliation:GSOClass {id: 'gso_layered_mylonitic_foliation'})
  ON CREATE SET n_gso_layered_mylonitic_foliation += {id: 'gso_layered_mylonitic_foliation', gso_class: 'layered_mylonitic_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/layered_mylonitic_foliation', pref_label_en: 'layered mylonitic foliation', definition_en_canonical: 'Compound foliation in which mylonitic foliation is present in rock that has continuous compositional layering. Continuous means individual layers can be traced more than 1 m.', parents: ['gsfo:compound_foliation', 'gsfo:generic_mylonitic_foliation', 'gsfo:layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_layered_mylonitic_foliation += {id: 'gso_layered_mylonitic_foliation', gso_class: 'layered_mylonitic_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/layered_mylonitic_foliation', pref_label_en: 'layered mylonitic foliation', definition_en_canonical: 'Compound foliation in which mylonitic foliation is present in rock that has continuous compositional layering. Continuous means individual layers can be traced more than 1 m.', parents: ['gsfo:compound_foliation', 'gsfo:generic_mylonitic_foliation', 'gsfo:layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_layering:GSOClass {id: 'gso_layering'})
  ON CREATE SET n_gso_layering += {id: 'gso_layering', gso_class: 'layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/layering', pref_label_en: 'layering', definition_en_canonical: 'Foliation defined by stacked, differentiable, sheet-like masses of material (layers), with no denotation of the nature (composition, grain size, grain shape...) or origin (igneous, sedimentary, metamorphic) of the layers.', parents: ['gsos:Foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_layering += {id: 'gso_layering', gso_class: 'layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/layering', pref_label_en: 'layering', definition_en_canonical: 'Foliation defined by stacked, differentiable, sheet-like masses of material (layers), with no denotation of the nature (composition, grain size, grain shape...) or origin (igneous, sedimentary, metamorphic) of the layers.', parents: ['gsos:Foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_low_temperature_flow_foliation:GSOClass {id: 'gso_low_temperature_flow_foliation'})
  ON CREATE SET n_gso_low_temperature_flow_foliation += {id: 'gso_low_temperature_flow_foliation', gso_class: 'low_temperature_flow_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/low_temperature_flow_foliation', pref_label_en: 'low temperature flow foliation', definition_en_canonical: 'Foliation interpreted to be due to flow in a body of rock (typically mudrock, salt, or anhydrite) under low-temperature (non-metamorphic) conditions, typically related to diapirism.', parents: ['gsos:Foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_low_temperature_flow_foliation += {id: 'gso_low_temperature_flow_foliation', gso_class: 'low_temperature_flow_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/low_temperature_flow_foliation', pref_label_en: 'low temperature flow foliation', definition_en_canonical: 'Foliation interpreted to be due to flow in a body of rock (typically mudrock, salt, or anhydrite) under low-temperature (non-metamorphic) conditions, typically related to diapirism.', parents: ['gsos:Foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_metamorphic_differentiation_layering:GSOClass {id: 'gso_metamorphic_differentiation_layering'})
  ON CREATE SET n_gso_metamorphic_differentiation_layering += {id: 'gso_metamorphic_differentiation_layering', gso_class: 'metamorphic_differentiation_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/metamorphic_differentiation_layering', pref_label_en: 'metamorphic differentiation layering', definition_en_canonical: 'Layering defined by mineralogical variations in a rock body interpreted to be result of solid-state reactions in rock body (metamorphic segregation).', parents: ['gsfo:compositional_layering', 'gsfo:metamorphic_layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_metamorphic_differentiation_layering += {id: 'gso_metamorphic_differentiation_layering', gso_class: 'metamorphic_differentiation_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/metamorphic_differentiation_layering', pref_label_en: 'metamorphic differentiation layering', definition_en_canonical: 'Layering defined by mineralogical variations in a rock body interpreted to be result of solid-state reactions in rock body (metamorphic segregation).', parents: ['gsfo:compositional_layering', 'gsfo:metamorphic_layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_metamorphic_layering:GSOClass {id: 'gso_metamorphic_layering'})
  ON CREATE SET n_gso_metamorphic_layering += {id: 'gso_metamorphic_layering', gso_class: 'metamorphic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/metamorphic_layering', pref_label_en: 'metamorphic layering', definition_en_canonical: 'Layering of unspecified origin in a metamorphic rock. Compositional or textural variations may be inherited from protolith, or result from metamorphic processes.', parents: ['gsfo:layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_metamorphic_layering += {id: 'gso_metamorphic_layering', gso_class: 'metamorphic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/metamorphic_layering', pref_label_en: 'metamorphic layering', definition_en_canonical: 'Layering of unspecified origin in a metamorphic rock. Compositional or textural variations may be inherited from protolith, or result from metamorphic processes.', parents: ['gsfo:layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_metamorphic_layering_inherited_from_protolith:GSOClass {id: 'gso_metamorphic_layering_inherited_from_protolith'})
  ON CREATE SET n_gso_metamorphic_layering_inherited_from_protolith += {id: 'gso_metamorphic_layering_inherited_from_protolith', gso_class: 'metamorphic_layering_inherited_from_protolith', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/metamorphic_layering_inherited_from_protolith', pref_label_en: 'metamorphic layering inherited from protolith', definition_en_canonical: 'Metamorphic layering in which layer differntiation is relict of compositional variations in the protolith, typically heterogeneous sedimentary or volcanic rock.', parents: ['gsfo:compositional_layering', 'gsfo:metamorphic_layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_metamorphic_layering_inherited_from_protolith += {id: 'gso_metamorphic_layering_inherited_from_protolith', gso_class: 'metamorphic_layering_inherited_from_protolith', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/metamorphic_layering_inherited_from_protolith', pref_label_en: 'metamorphic layering inherited from protolith', definition_en_canonical: 'Metamorphic layering in which layer differntiation is relict of compositional variations in the protolith, typically heterogeneous sedimentary or volcanic rock.', parents: ['gsfo:compositional_layering', 'gsfo:metamorphic_layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_mineralogical_layering:GSOClass {id: 'gso_mineralogical_layering'})
  ON CREATE SET n_gso_mineralogical_layering += {id: 'gso_mineralogical_layering', gso_class: 'mineralogical_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/mineralogical_layering', pref_label_en: 'mineralogical layering', definition_en_canonical: 'Generic layering defined by variations in mineralogy between individual sheets of material', parents: ['gsfo:compositional_layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_mineralogical_layering += {id: 'gso_mineralogical_layering', gso_class: 'mineralogical_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/mineralogical_layering', pref_label_en: 'mineralogical layering', definition_en_canonical: 'Generic layering defined by variations in mineralogy between individual sheets of material', parents: ['gsfo:compositional_layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_mylonite_foliation:GSOClass {id: 'gso_mylonite_foliation'})
  ON CREATE SET n_gso_mylonite_foliation += {id: 'gso_mylonite_foliation', gso_class: 'mylonite_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/mylonite_foliation', pref_label_en: 'mylonite foliation', definition_en_canonical: 'Generic mylonitic foliation in which 50-90 percent of rock is matrix due to tectonic grain size reduction processes. Planar fabric is very apparent due to flattening of mineral grains, development of shear surfaces, and alignment of tabular mineral grains. Lineation is typically present and easily observed.', parents: ['gsfo:generic_mylonitic_foliation'], sources: ['NADM metamorphic rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixB/appendixB.pdf) SLTTm1.0 2004,  Sibson 1977'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_mylonite_foliation += {id: 'gso_mylonite_foliation', gso_class: 'mylonite_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/mylonite_foliation', pref_label_en: 'mylonite foliation', definition_en_canonical: 'Generic mylonitic foliation in which 50-90 percent of rock is matrix due to tectonic grain size reduction processes. Planar fabric is very apparent due to flattening of mineral grains, development of shear surfaces, and alignment of tabular mineral grains. Lineation is typically present and easily observed.', parents: ['gsfo:generic_mylonitic_foliation'], sources: ['NADM metamorphic rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixB/appendixB.pdf) SLTTm1.0 2004,  Sibson 1977'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_parallel_bedding:GSOClass {id: 'gso_parallel_bedding'})
  ON CREATE SET n_gso_parallel_bedding += {id: 'gso_parallel_bedding', gso_class: 'parallel_bedding', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/parallel_bedding', pref_label_en: 'parallel bedding', definition_en_canonical: 'Bedding defined by parallel surfaces. Bedding structure may be lamination or layering.', parents: ['gsfo:bedding_fabric'], sources: ['NADM sedimentary rock vocabulary NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  SLTTs 2004'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_parallel_bedding += {id: 'gso_parallel_bedding', gso_class: 'parallel_bedding', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/parallel_bedding', pref_label_en: 'parallel bedding', definition_en_canonical: 'Bedding defined by parallel surfaces. Bedding structure may be lamination or layering.', parents: ['gsfo:bedding_fabric'], sources: ['NADM sedimentary rock vocabulary NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  SLTTs 2004'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_parallel_bedding_lamination:GSOClass {id: 'gso_parallel_bedding_lamination'})
  ON CREATE SET n_gso_parallel_bedding_lamination += {id: 'gso_parallel_bedding_lamination', gso_class: 'parallel_bedding_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/parallel_bedding_lamination', pref_label_en: 'parallel bedding lamination', definition_en_canonical: 'Bedding lamination structure in which all visible bedding surfaces are parallel.', parents: ['gsfo:bedding_lamination_structure'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_parallel_bedding_lamination += {id: 'gso_parallel_bedding_lamination', gso_class: 'parallel_bedding_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/parallel_bedding_lamination', pref_label_en: 'parallel bedding lamination', definition_en_canonical: 'Bedding lamination structure in which all visible bedding surfaces are parallel.', parents: ['gsfo:bedding_lamination_structure'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_phyllitic_cleavage:GSOClass {id: 'gso_phyllitic_cleavage'})
  ON CREATE SET n_gso_phyllitic_cleavage += {id: 'gso_phyllitic_cleavage', gso_class: 'phyllitic_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/phyllitic_cleavage', pref_label_en: 'phyllitic cleavage', definition_en_canonical: 'Continuous cleavage in phyllitic rock, phyllosilicate mineral grains just barely visible, grain size midway between slaty cleavage and schist, typically has a satiny lustre.', parents: ['gsfo:continuous_cleavage'], sources: ['NADM metamorphic rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixB/appendixB.pdf) SLTTm1.0 2004,  Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_phyllitic_cleavage += {id: 'gso_phyllitic_cleavage', gso_class: 'phyllitic_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/phyllitic_cleavage', pref_label_en: 'phyllitic cleavage', definition_en_canonical: 'Continuous cleavage in phyllitic rock, phyllosilicate mineral grains just barely visible, grain size midway between slaty cleavage and schist, typically has a satiny lustre.', parents: ['gsfo:continuous_cleavage'], sources: ['NADM metamorphic rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixB/appendixB.pdf) SLTTm1.0 2004,  Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_planar_lamination:GSOClass {id: 'gso_planar_lamination'})
  ON CREATE SET n_gso_planar_lamination += {id: 'gso_planar_lamination', gso_class: 'planar_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/planar_lamination', pref_label_en: 'planar lamination', definition_en_canonical: 'Lamination that is defined by planar bedding surfaces at the scale of description.', parents: ['gsfo:bedding_lamination_structure'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_planar_lamination += {id: 'gso_planar_lamination', gso_class: 'planar_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/planar_lamination', pref_label_en: 'planar lamination', definition_en_canonical: 'Lamination that is defined by planar bedding surfaces at the scale of description.', parents: ['gsfo:bedding_lamination_structure'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_primary_foliation:GSOClass {id: 'gso_primary_foliation'})
  ON CREATE SET n_gso_primary_foliation += {id: 'gso_primary_foliation', gso_class: 'primary_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/primary_foliation', pref_label_en: 'primary foliation', definition_en_canonical: 'Foliation formed during original process of deposition or crystallization of an igneous or sedimentary material.', parents: ['gsos:Foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_primary_foliation += {id: 'gso_primary_foliation', gso_class: 'primary_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/primary_foliation', pref_label_en: 'primary foliation', definition_en_canonical: 'Foliation formed during original process of deposition or crystallization of an igneous or sedimentary material.', parents: ['gsos:Foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_primary_igneous_foliation:GSOClass {id: 'gso_primary_igneous_foliation'})
  ON CREATE SET n_gso_primary_igneous_foliation += {id: 'gso_primary_igneous_foliation', gso_class: 'primary_igneous_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/primary_igneous_foliation', pref_label_en: 'primary igneous foliation', definition_en_canonical: 'Foliation interpreted to be the product of igneous processes, formed in the rock while melt was still present..', parents: ['gsfo:primary_foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
