MERGE (n_seismic_acquisition_survey:Entity:Instrument {id: 'seismic-acquisition-survey'})
  ON CREATE SET n_seismic_acquisition_survey += {id: 'seismic-acquisition-survey', label: 'Levantamento de Aquisição Sísmica', label_en: 'Seismic Acquisition Survey', type: 'instrument', definition: 'Projeto de aquisição sísmica que mobiliza recursos em campo para registrar dados — também chamado field survey ou programa de campo; difere da geometria dos equipamentos (nav), que é um WPC. (OSDU canonical: A seismic acquisition project is a type of business project that deploys resources to the field to record seismic data. It may be referred to as a field survey, acquisition survey, or field program.)', osdu_kind: 'opendes:osdu:master-data--SeismicAcquisitionSurvey:1.0.0', geocoverage: ['layer3'], sources: ['Accenture/OSDU OWL']}
