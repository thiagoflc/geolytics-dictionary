MERGE (n_seismic_processing_project:Entity:Instrument {id: 'seismic-processing-project'})
  ON CREATE SET n_seismic_processing_project += {id: 'seismic-processing-project', label: 'Projeto de Processamento Sísmico', label_en: 'Seismic Processing Project', type: 'instrument', definition: 'Projeto de negócio que gere a criação de produtos sísmicos processados; pode mesclar dados de múltiplos surveys de campo. Processamentos originais e reprocessamentos geram projetos separados. (OSDU canonical: A seismic processing project is a type of business project which manages the creation of processed seismic work products.)', osdu_kind: 'opendes:osdu:master-data--SeismicProcessingProject:1.0.0', geocoverage: ['layer3'], sources: ['Accenture/OSDU OWL']}
