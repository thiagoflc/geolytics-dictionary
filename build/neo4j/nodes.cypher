  ON MATCH SET n_gso_Impact_Structure_Boundary += {id: 'gso_Impact_Structure_Boundary', gso_class: 'Impact_Structure_Boundary', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Impact_Structure_Boundary', pref_label_en: 'impact structure boundary', definition_en_canonical: 'surface that bounds a body of rock affected by an extraterrestrial impact event', parents: ['gscn:Lithogenetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

