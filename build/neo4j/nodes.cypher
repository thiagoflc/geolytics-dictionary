MERGE (n_gso_protomylonite_foliation:GSOClass {id: 'gso_protomylonite_foliation'})
  ON CREATE SET n_gso_protomylonite_foliation += {id: 'gso_protomylonite_foliation', gso_class: 'protomylonite_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/protomylonite_foliation', pref_label_en: 'protomylonite foliation', definition_en_canonical: 'Generic mylonitic foliation in which 10-50 percent of rock is matrix due to tectonic grain size reduction processes. Planar aspect of fabric may be quite subtle in weakly deformed rocks.', parents: ['gsfo:generic_mylonitic_foliation'], sources: ['NADM metamorphic rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixB/appendixB.pdf) SLTTm1.0 2004,  Sibson 1977'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_protomylonite_foliation += {id: 'gso_protomylonite_foliation', gso_class: 'protomylonite_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/protomylonite_foliation', pref_label_en: 'protomylonite foliation', definition_en_canonical: 'Generic mylonitic foliation in which 10-50 percent of rock is matrix due to tectonic grain size reduction processes. Planar aspect of fabric may be quite subtle in weakly deformed rocks.', parents: ['gsfo:generic_mylonitic_foliation'], sources: ['NADM metamorphic rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixB/appendixB.pdf) SLTTm1.0 2004,  Sibson 1977'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_rhythmic_layering:GSOClass {id: 'gso_rhythmic_layering'})
  ON CREATE SET n_gso_rhythmic_layering += {id: 'gso_rhythmic_layering', gso_class: 'rhythmic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/rhythmic_layering', pref_label_en: 'rhythmic layering', definition_en_canonical: 'Layering in igneous rock defined by repeated gravity-stratified layers of typically mafic minerals at the base and plagioclase at the top, formed by crystal settling', parents: ['gsfo:igneous_layering'], sources: ['Jackson 1997'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_rhythmic_layering += {id: 'gso_rhythmic_layering', gso_class: 'rhythmic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/rhythmic_layering', pref_label_en: 'rhythmic layering', definition_en_canonical: 'Layering in igneous rock defined by repeated gravity-stratified layers of typically mafic minerals at the base and plagioclase at the top, formed by crystal settling', parents: ['gsfo:igneous_layering'], sources: ['Jackson 1997'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_rough_cleavage:GSOClass {id: 'gso_rough_cleavage'})
  ON CREATE SET n_gso_rough_cleavage += {id: 'gso_rough_cleavage', gso_class: 'rough_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/rough_cleavage', pref_label_en: 'rough cleavage', definition_en_canonical: 'Disjunct (Borradaile et al, 1990) cleavage characterized by short, discontinuous clavage surfaces, typically with concentrations of phyllosilicate minerals. Common in micaceous sandstone.', parents: ['gsfo:cleavage'], sources: ['Neuendorf et al. 2005, Borradaile et al, 1990'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_rough_cleavage += {id: 'gso_rough_cleavage', gso_class: 'rough_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/rough_cleavage', pref_label_en: 'rough cleavage', definition_en_canonical: 'Disjunct (Borradaile et al, 1990) cleavage characterized by short, discontinuous clavage surfaces, typically with concentrations of phyllosilicate minerals. Common in micaceous sandstone.', parents: ['gsfo:cleavage'], sources: ['Neuendorf et al. 2005, Borradaile et al, 1990'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_s_fabric:GSOClass {id: 'gso_s_fabric'})
  ON CREATE SET n_gso_s_fabric += {id: 'gso_s_fabric', gso_class: 's_fabric', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/s_fabric', pref_label_en: 's fabric', definition_en_canonical: 'Foliation in mylonite defined by alignment of tabular crystals or deformed mineral grains, often with sigmoid shape, typically curving into an associated ductile shear banding foliation (C fabric) with a consistent sense.', parents: ['gsfo:grain_shape_foliation', 'gsfo:tectonic_foliation'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_s_fabric += {id: 'gso_s_fabric', gso_class: 's_fabric', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/s_fabric', pref_label_en: 's fabric', definition_en_canonical: 'Foliation in mylonite defined by alignment of tabular crystals or deformed mineral grains, often with sigmoid shape, typically curving into an associated ductile shear banding foliation (C fabric) with a consistent sense.', parents: ['gsfo:grain_shape_foliation', 'gsfo:tectonic_foliation'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_scaly_cleavage:GSOClass {id: 'gso_scaly_cleavage'})
  ON CREATE SET n_gso_scaly_cleavage += {id: 'gso_scaly_cleavage', gso_class: 'scaly_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/scaly_cleavage', pref_label_en: 'scaly cleavage', definition_en_canonical: 'Discrete, anastomosing spaced cleavage characterized by smooth and highly polished/slickensided cleavage surfaces that intersect with one another to form lensoid flakes, scales or chips. Common in pelitic rocks in shear zones, melange, or deformed accretionary complexes.', parents: ['gsfo:spaced_cleavage'], sources: ['Based on Jackson 1997'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_scaly_cleavage += {id: 'gso_scaly_cleavage', gso_class: 'scaly_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/scaly_cleavage', pref_label_en: 'scaly cleavage', definition_en_canonical: 'Discrete, anastomosing spaced cleavage characterized by smooth and highly polished/slickensided cleavage surfaces that intersect with one another to form lensoid flakes, scales or chips. Common in pelitic rocks in shear zones, melange, or deformed accretionary complexes.', parents: ['gsfo:spaced_cleavage'], sources: ['Based on Jackson 1997'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_schistosity:GSOClass {id: 'gso_schistosity'})
  ON CREATE SET n_gso_schistosity += {id: 'gso_schistosity', gso_class: 'schistosity', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/schistosity', pref_label_en: 'schistosity', definition_en_canonical: 'A fabric defined the parallel, planar arrangement of mineral grains having a platy, lamellar, or tabular crystallographic habit that are oriented in a continuous planar or rarely a linear fabric. Schistosity is commonly, but not necessarily, a crystalloblastic foliation. Platy mineral grains typically 1 to 10 mm across (Jackson, 1997), at smaller grain size grades into phyllitic cleavage. Schistosity is typically associated with a continuous cleavage due to the tendency to part parallel to the aligned mineral grains.', parents: ['gsfo:tectonic_foliation'], sources: ['NADM metamorphic rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixB/appendixB.pdf) SLTTm1.0 2004'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_schistosity += {id: 'gso_schistosity', gso_class: 'schistosity', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/schistosity', pref_label_en: 'schistosity', definition_en_canonical: 'A fabric defined the parallel, planar arrangement of mineral grains having a platy, lamellar, or tabular crystallographic habit that are oriented in a continuous planar or rarely a linear fabric. Schistosity is commonly, but not necessarily, a crystalloblastic foliation. Platy mineral grains typically 1 to 10 mm across (Jackson, 1997), at smaller grain size grades into phyllitic cleavage. Schistosity is typically associated with a continuous cleavage due to the tendency to part parallel to the aligned mineral grains.', parents: ['gsfo:tectonic_foliation'], sources: ['NADM metamorphic rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixB/appendixB.pdf) SLTTm1.0 2004'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_sedimentary_layering:GSOClass {id: 'gso_sedimentary_layering'})
  ON CREATE SET n_gso_sedimentary_layering += {id: 'gso_sedimentary_layering', gso_class: 'sedimentary_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/sedimentary_layering', pref_label_en: 'sedimentary layering', definition_en_canonical: 'Layering resulting from primary sedimentary processes, in which the individual layers (beds) are bounded by discontinuities related to events in the depositional history.', parents: ['gsfo:bedding_fabric', 'gsfo:layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_sedimentary_layering += {id: 'gso_sedimentary_layering', gso_class: 'sedimentary_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/sedimentary_layering', pref_label_en: 'sedimentary layering', definition_en_canonical: 'Layering resulting from primary sedimentary processes, in which the individual layers (beds) are bounded by discontinuities related to events in the depositional history.', parents: ['gsfo:bedding_fabric', 'gsfo:layering'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_slaty_cleavage:GSOClass {id: 'gso_slaty_cleavage'})
  ON CREATE SET n_gso_slaty_cleavage += {id: 'gso_slaty_cleavage', gso_class: 'slaty_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/slaty_cleavage', pref_label_en: 'slaty cleavage', definition_en_canonical: 'Continuous cleavage defined by aligned fine to very-fine grained phylosilicate mineral grains. The individual grains defining the fabric are too small to be seen by the unaided eye. Grades into phyllitic cleavage as grain size increases. Cleavage domains typically less than 100 micrometres wide, rock easily splits into slabs and thin plates.', parents: ['gsfo:continuous_cleavage'], sources: ['Brodie, Kate, Fettes, Douglas, and Harte, Ben, 2007, Structural terms including fault rock terms, in Fettes, D., and Desmons, J., Metamorphic rocks-A classification and Glossary of Terms: Cambridge, UK, Cambridge University Press, p. 24-31., Jackson 1997'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_slaty_cleavage += {id: 'gso_slaty_cleavage', gso_class: 'slaty_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/slaty_cleavage', pref_label_en: 'slaty cleavage', definition_en_canonical: 'Continuous cleavage defined by aligned fine to very-fine grained phylosilicate mineral grains. The individual grains defining the fabric are too small to be seen by the unaided eye. Grades into phyllitic cleavage as grain size increases. Cleavage domains typically less than 100 micrometres wide, rock easily splits into slabs and thin plates.', parents: ['gsfo:continuous_cleavage'], sources: ['Brodie, Kate, Fettes, Douglas, and Harte, Ben, 2007, Structural terms including fault rock terms, in Fettes, D., and Desmons, J., Metamorphic rocks-A classification and Glossary of Terms: Cambridge, UK, Cambridge University Press, p. 24-31., Jackson 1997'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_solution_cleavage:GSOClass {id: 'gso_solution_cleavage'})
  ON CREATE SET n_gso_solution_cleavage += {id: 'gso_solution_cleavage', gso_class: 'solution_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/solution_cleavage', pref_label_en: 'solution cleavage', definition_en_canonical: 'Spaced cleavage forming an array of parallel to anastomosing, stylolitic to smooth, fracture-like partings formed by rock dissolution. Dissolution is indicated by discontinuity and offset of primary features that intersect cleavage surfaces, and typically by accumulation of insoluble residue along cleavage surface. Syn. stylolitic cleavage, pressure solution cleavage', parents: ['gsfo:spaced_cleavage'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_solution_cleavage += {id: 'gso_solution_cleavage', gso_class: 'solution_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/solution_cleavage', pref_label_en: 'solution cleavage', definition_en_canonical: 'Spaced cleavage forming an array of parallel to anastomosing, stylolitic to smooth, fracture-like partings formed by rock dissolution. Dissolution is indicated by discontinuity and offset of primary features that intersect cleavage surfaces, and typically by accumulation of insoluble residue along cleavage surface. Syn. stylolitic cleavage, pressure solution cleavage', parents: ['gsfo:spaced_cleavage'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_spaced_cleavage:GSOClass {id: 'gso_spaced_cleavage'})
  ON CREATE SET n_gso_spaced_cleavage += {id: 'gso_spaced_cleavage', gso_class: 'spaced_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/spaced_cleavage', pref_label_en: 'spaced cleavage', definition_en_canonical: 'Cleavage in which cleavage domains are spaced at finite intervals as the scale of description. Microlithons of uncleaved rock separate cleavage domains.', parents: ['gsfo:cleavage'], sources: ['Borradaile et al. 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_spaced_cleavage += {id: 'gso_spaced_cleavage', gso_class: 'spaced_cleavage', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/spaced_cleavage', pref_label_en: 'spaced cleavage', definition_en_canonical: 'Cleavage in which cleavage domains are spaced at finite intervals as the scale of description. Microlithons of uncleaved rock separate cleavage domains.', parents: ['gsfo:cleavage'], sources: ['Borradaile et al. 1982'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_stromatic_layering:GSOClass {id: 'gso_stromatic_layering'})
  ON CREATE SET n_gso_stromatic_layering += {id: 'gso_stromatic_layering', gso_class: 'stromatic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/stromatic_layering', pref_label_en: 'stromatic layering', definition_en_canonical: 'Tectonic layering in which variations that distinguish the layers are the result of melt segregation during high-grade metamorphism, some layers have magmatic/igneous mineralogy. Plates 143 and 144, Borradaile et al [1982] (page 344-347) Syn. Migmatitic layering, lit-par-lit layering', parents: ['gsfo:metamorphic_layering'], sources: ['Weiss 1972, Borradaile et al 1982, Neuendorf et al. 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_stromatic_layering += {id: 'gso_stromatic_layering', gso_class: 'stromatic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/stromatic_layering', pref_label_en: 'stromatic layering', definition_en_canonical: 'Tectonic layering in which variations that distinguish the layers are the result of melt segregation during high-grade metamorphism, some layers have magmatic/igneous mineralogy. Plates 143 and 144, Borradaile et al [1982] (page 344-347) Syn. Migmatitic layering, lit-par-lit layering', parents: ['gsfo:metamorphic_layering'], sources: ['Weiss 1972, Borradaile et al 1982, Neuendorf et al. 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_stromatolitic_lamination:GSOClass {id: 'gso_stromatolitic_lamination'})
  ON CREATE SET n_gso_stromatolitic_lamination += {id: 'gso_stromatolitic_lamination', gso_class: 'stromatolitic_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/stromatolitic_lamination', pref_label_en: 'stromatolitic lamination', definition_en_canonical: 'Lamination produced by sediment trapping, binding and or precipitation by cyanophytes (blue-green algae)', parents: ['gsfo:cryptomicrobial_lamination'], sources: ['Based on Neuendorf et al 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_stromatolitic_lamination += {id: 'gso_stromatolitic_lamination', gso_class: 'stromatolitic_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/stromatolitic_lamination', pref_label_en: 'stromatolitic lamination', definition_en_canonical: 'Lamination produced by sediment trapping, binding and or precipitation by cyanophytes (blue-green algae)', parents: ['gsfo:cryptomicrobial_lamination'], sources: ['Based on Neuendorf et al 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_tectonic_foliation:GSOClass {id: 'gso_tectonic_foliation'})
  ON CREATE SET n_gso_tectonic_foliation += {id: 'gso_tectonic_foliation', gso_class: 'tectonic_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/tectonic_foliation', pref_label_en: 'tectonic foliation', definition_en_canonical: 'Foliation in a rock body defined by physical components related to deformation subsequent to solidification of the rock.', parents: ['gsos:Foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_tectonic_foliation += {id: 'gso_tectonic_foliation', gso_class: 'tectonic_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/tectonic_foliation', pref_label_en: 'tectonic foliation', definition_en_canonical: 'Foliation in a rock body defined by physical components related to deformation subsequent to solidification of the rock.', parents: ['gsos:Foliation'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_tectonic_layering:GSOClass {id: 'gso_tectonic_layering'})
  ON CREATE SET n_gso_tectonic_layering += {id: 'gso_tectonic_layering', gso_class: 'tectonic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/tectonic_layering', pref_label_en: 'tectonic layering', definition_en_canonical: 'Layering defined by mineralogical or textural variations in a rock body that are interpreted to be related to deformation or metamorphism, commonly associated with layers that have sharp boundaries. Also known as gneissic foliation. See plates 142-145 (p. 342-349) in Borradaile et al [1982] and plate 46A to 49A in Weiss [1972].', parents: ['gsfo:layering', 'gsfo:tectonic_foliation'], sources: ['Weiss 1972, Borradaile et al 1982, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_tectonic_layering += {id: 'gso_tectonic_layering', gso_class: 'tectonic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/tectonic_layering', pref_label_en: 'tectonic layering', definition_en_canonical: 'Layering defined by mineralogical or textural variations in a rock body that are interpreted to be related to deformation or metamorphism, commonly associated with layers that have sharp boundaries. Also known as gneissic foliation. See plates 142-145 (p. 342-349) in Borradaile et al [1982] and plate 46A to 49A in Weiss [1972].', parents: ['gsfo:layering', 'gsfo:tectonic_foliation'], sources: ['Weiss 1972, Borradaile et al 1982, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_transposed_bedding_layering:GSOClass {id: 'gso_transposed_bedding_layering'})
  ON CREATE SET n_gso_transposed_bedding_layering += {id: 'gso_transposed_bedding_layering', gso_class: 'transposed_bedding_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/transposed_bedding_layering', pref_label_en: 'transposed bedding layering', definition_en_canonical: 'Layering interpreted to have originated as sedimentary bedding that has been transposed as a result of metamorphism and deformation.', parents: ['gsfo:metamorphic_layering_inherited_from_protolith'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_transposed_bedding_layering += {id: 'gso_transposed_bedding_layering', gso_class: 'transposed_bedding_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/transposed_bedding_layering', pref_label_en: 'transposed bedding layering', definition_en_canonical: 'Layering interpreted to have originated as sedimentary bedding that has been transposed as a result of metamorphism and deformation.', parents: ['gsfo:metamorphic_layering_inherited_from_protolith'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_ultramylonite_foliation:GSOClass {id: 'gso_ultramylonite_foliation'})
  ON CREATE SET n_gso_ultramylonite_foliation += {id: 'gso_ultramylonite_foliation', gso_class: 'ultramylonite_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/ultramylonite_foliation', pref_label_en: 'ultramylonite foliation', definition_en_canonical: 'Mylonitic foliation in which greater than 90 percent of rock is matrix due to tectonic grain size reduction processes. Typically rock is very-fine grained to aphanitic, with sparse porphyroclasts, and vague to prominent lamination on a mm scale.', parents: ['gsfo:generic_mylonitic_foliation'], sources: ['NADM metamorphic rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixB/appendixB.pdf) SLTTm1.0 2004,  Sibson 1977'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_ultramylonite_foliation += {id: 'gso_ultramylonite_foliation', gso_class: 'ultramylonite_foliation', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/ultramylonite_foliation', pref_label_en: 'ultramylonite foliation', definition_en_canonical: 'Mylonitic foliation in which greater than 90 percent of rock is matrix due to tectonic grain size reduction processes. Typically rock is very-fine grained to aphanitic, with sparse porphyroclasts, and vague to prominent lamination on a mm scale.', parents: ['gsfo:generic_mylonitic_foliation'], sources: ['NADM metamorphic rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixB/appendixB.pdf) SLTTm1.0 2004,  Sibson 1977'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_undulating_lamination:GSOClass {id: 'gso_undulating_lamination'})
  ON CREATE SET n_gso_undulating_lamination += {id: 'gso_undulating_lamination', gso_class: 'undulating_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/undulating_lamination', pref_label_en: 'undulating lamination', definition_en_canonical: 'Gently curviplanar or wavy bedding lamination structure', parents: ['gsfo:bedding_lamination_structure'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_undulating_lamination += {id: 'gso_undulating_lamination', gso_class: 'undulating_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/undulating_lamination', pref_label_en: 'undulating lamination', definition_en_canonical: 'Gently curviplanar or wavy bedding lamination structure', parents: ['gsfo:bedding_lamination_structure'], sources: ['CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_vague_metamorphic_layering:GSOClass {id: 'gso_vague_metamorphic_layering'})
  ON CREATE SET n_gso_vague_metamorphic_layering += {id: 'gso_vague_metamorphic_layering', gso_class: 'vague_metamorphic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/vague_metamorphic_layering', pref_label_en: 'vague metamorphic layering', definition_en_canonical: 'Metamorphic layering of uncertain origin, defined by subtle mineralogical or textural variations, with gradational layer boundaries. See plate 142 in Borradaile et al [1982].', parents: ['gsfo:metamorphic_layering'], sources: ['Weiss 1972,Borradaile et al 1982, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_vague_metamorphic_layering += {id: 'gso_vague_metamorphic_layering', gso_class: 'vague_metamorphic_layering', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/vague_metamorphic_layering', pref_label_en: 'vague metamorphic layering', definition_en_canonical: 'Metamorphic layering of uncertain origin, defined by subtle mineralogical or textural variations, with gradational layer boundaries. See plate 142 in Borradaile et al [1982].', parents: ['gsfo:metamorphic_layering'], sources: ['Weiss 1972,Borradaile et al 1982, CGI foliationtype SKOS vocabulary 2018-08-03'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

MERGE (n_gso_varve_lamination:GSOClass {id: 'gso_varve_lamination'})
  ON CREATE SET n_gso_varve_lamination += {id: 'gso_varve_lamination', gso_class: 'varve_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/varve_lamination', pref_label_en: 'varve lamination', definition_en_canonical: 'Bedding defined by distinct, parallel laminae (layers less than 1 cm thick), typically occurring in sequences of distinct couplets (e.g. dark and light color). Generally interpreted as deposited from suspension in still water, with each lamina thought to be an annual sedimentation unit. Typically consists of mud-size sediment.', parents: ['gsfo:bedding_lamination_structure'], sources: ['NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  SLTTs 2004, Jackson 1997'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}
  ON MATCH SET n_gso_varve_lamination += {id: 'gso_varve_lamination', gso_class: 'varve_lamination', owl_uri: 'https://w3id.org/gso/1.0/geologicfoliation/varve_lamination', pref_label_en: 'varve lamination', definition_en_canonical: 'Bedding defined by distinct, parallel laminae (layers less than 1 cm thick), typically occurring in sequences of distinct couplets (e.g. dark and light color). Generally interpreted as deposited from suspension in still water, with each lamina thought to be an annual sedimentation unit. Typically consists of mud-size sediment.', parents: ['gsfo:bedding_lamination_structure'], sources: ['NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  NADM sedimentary rock vocabulary (https://pubs.usgs.gov/of/2004/1451/sltt/appendixC/appendixC_pdf.zip)  SLTTs 2004, Jackson 1997'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-foliations'}

