  ON CREATE SET n_basin_type += {id: 'basin-type', label: 'Tipo de Bacia', label_en: 'Basin Type', type: 'geological', definition: 'Região geológica onde se acumularam sedimentos depositados, deprimida ou preservada na crosta — taxonomia para classificar bacias. (OSDU canonical: A geologic region where an accumulation of deposited sediments has depressed or is preserved within the crust.)', osdu_kind: 'opendes:osdu:reference-data--BasinType:1.0.0', geocoverage: ['layer1'], sources: ['Accenture/OSDU OWL']}
