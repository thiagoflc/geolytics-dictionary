MERGE (n_gso_bedding_cleavage_intersection_lineation:GSOClass {id: 'gso_bedding_cleavage_intersection_lineation'})
  ON CREATE SET n_gso_bedding_cleavage_intersection_lineation += {id: 'gso_bedding_cleavage_intersection_lineation', gso_class: 'bedding_cleavage_intersection_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/bedding_cleavage_intersection_lineation', pref_label_en: 'bedding cleavage intersection lineation', definition_en_canonical: 'Lineation defined by the intersection of bedding surfaces and cleavage surfaces.', parents: ['gsol:intersection_lineation', 'gsol:tectonic_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_bedding_cleavage_intersection_lineation += {id: 'gso_bedding_cleavage_intersection_lineation', gso_class: 'bedding_cleavage_intersection_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/bedding_cleavage_intersection_lineation', pref_label_en: 'bedding cleavage intersection lineation', definition_en_canonical: 'Lineation defined by the intersection of bedding surfaces and cleavage surfaces.', parents: ['gsol:intersection_lineation', 'gsol:tectonic_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_biotite_mineral_lineation:GSOClass {id: 'gso_biotite_mineral_lineation'})
  ON CREATE SET n_gso_biotite_mineral_lineation += {id: 'gso_biotite_mineral_lineation', gso_class: 'biotite_mineral_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/biotite_mineral_lineation', pref_label_en: 'biotite mineral lineation', definition_en_canonical: 'Mineral lineation defined by aligned elongate biotite aggregates in a foliation surface. Biotite does not have an elongate (prismatic, acicular) mineral habit, so production of lineation must reflect elongate aggregates of biotite crystals.', parents: ['gsol:mineral_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_biotite_mineral_lineation += {id: 'gso_biotite_mineral_lineation', gso_class: 'biotite_mineral_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/biotite_mineral_lineation', pref_label_en: 'biotite mineral lineation', definition_en_canonical: 'Mineral lineation defined by aligned elongate biotite aggregates in a foliation surface. Biotite does not have an elongate (prismatic, acicular) mineral habit, so production of lineation must reflect elongate aggregates of biotite crystals.', parents: ['gsol:mineral_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_cleavage_intersection_lineation:GSOClass {id: 'gso_cleavage_intersection_lineation'})
  ON CREATE SET n_gso_cleavage_intersection_lineation += {id: 'gso_cleavage_intersection_lineation', gso_class: 'cleavage_intersection_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/cleavage_intersection_lineation', pref_label_en: 'cleavage intersection lineation', definition_en_canonical: 'Lineation defined by the intersection of two cleavages.', parents: ['gsol:intersection_lineation', 'gsol:tectonic_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
