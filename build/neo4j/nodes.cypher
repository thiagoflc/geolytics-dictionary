MERGE (n_gso_particle_shape_lineation:GSOClass {id: 'gso_particle_shape_lineation'})
  ON CREATE SET n_gso_particle_shape_lineation += {id: 'gso_particle_shape_lineation', gso_class: 'particle_shape_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/particle_shape_lineation', pref_label_en: 'particle shape lineation', definition_en_canonical: 'Lineation defined by alignment of long axes of prolate-shaped particles such as clasts, fossils, crystals, or phenocrysts. Particles may be polycrystalline aggregates formed by deformation of pre-existing particles. General category does not specify genesis of particles or their alignment.', parents: ['gsos:Lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_particle_shape_lineation += {id: 'gso_particle_shape_lineation', gso_class: 'particle_shape_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/particle_shape_lineation', pref_label_en: 'particle shape lineation', definition_en_canonical: 'Lineation defined by alignment of long axes of prolate-shaped particles such as clasts, fossils, crystals, or phenocrysts. Particles may be polycrystalline aggregates formed by deformation of pre-existing particles. General category does not specify genesis of particles or their alignment.', parents: ['gsos:Lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_pencil_lineation:GSOClass {id: 'gso_pencil_lineation'})
  ON CREATE SET n_gso_pencil_lineation += {id: 'gso_pencil_lineation', gso_class: 'pencil_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/pencil_lineation', pref_label_en: 'pencil lineation', definition_en_canonical: 'Lineation defined by tendency of rock to break into long, slender pieces resembling pencils. Typically produced by intesection of bedding and cleavage or intersection of two cleavages. Fabric is generally only observed in weakly metamorphosed rocks.', parents: ['gsos:Lineation'], sources: ['based on Neuendorf et al 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_pencil_lineation += {id: 'gso_pencil_lineation', gso_class: 'pencil_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/pencil_lineation', pref_label_en: 'pencil lineation', definition_en_canonical: 'Lineation defined by tendency of rock to break into long, slender pieces resembling pencils. Typically produced by intesection of bedding and cleavage or intersection of two cleavages. Fabric is generally only observed in weakly metamorphosed rocks.', parents: ['gsos:Lineation'], sources: ['based on Neuendorf et al 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_quartz_fibre_lineation:GSOClass {id: 'gso_quartz_fibre_lineation'})
  ON CREATE SET n_gso_quartz_fibre_lineation += {id: 'gso_quartz_fibre_lineation', gso_class: 'quartz_fibre_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/quartz_fibre_lineation', pref_label_en: 'quartz fibre lineation', definition_en_canonical: 'Aligned quartz fibres that define a measurable lineation', parents: ['gsol:particle_shape_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_quartz_fibre_lineation += {id: 'gso_quartz_fibre_lineation', gso_class: 'quartz_fibre_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/quartz_fibre_lineation', pref_label_en: 'quartz fibre lineation', definition_en_canonical: 'Aligned quartz fibres that define a measurable lineation', parents: ['gsol:particle_shape_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_rodding_lineation:GSOClass {id: 'gso_rodding_lineation'})
  ON CREATE SET n_gso_rodding_lineation += {id: 'gso_rodding_lineation', gso_class: 'rodding_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/rodding_lineation', pref_label_en: 'rodding lineation', definition_en_canonical: 'Linear structure in metamorphic rocks in which the stronger parts have been shaped into parallel rods (eg. vein quartz)', parents: ['gsol:tectonic_lineation'], sources: ['Jackson 1997'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_rodding_lineation += {id: 'gso_rodding_lineation', gso_class: 'rodding_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/rodding_lineation', pref_label_en: 'rodding lineation', definition_en_canonical: 'Linear structure in metamorphic rocks in which the stronger parts have been shaped into parallel rods (eg. vein quartz)', parents: ['gsol:tectonic_lineation'], sources: ['Jackson 1997'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_sillimanite_mineral_lineation:GSOClass {id: 'gso_sillimanite_mineral_lineation'})
  ON CREATE SET n_gso_sillimanite_mineral_lineation += {id: 'gso_sillimanite_mineral_lineation', gso_class: 'sillimanite_mineral_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/sillimanite_mineral_lineation', pref_label_en: 'sillimanite mineral lineation', definition_en_canonical: 'Mineral lineation defined by aligned sillimanite crystals.', parents: ['gsol:mineral_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_sillimanite_mineral_lineation += {id: 'gso_sillimanite_mineral_lineation', gso_class: 'sillimanite_mineral_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/sillimanite_mineral_lineation', pref_label_en: 'sillimanite mineral lineation', definition_en_canonical: 'Mineral lineation defined by aligned sillimanite crystals.', parents: ['gsol:mineral_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_slickenline:GSOClass {id: 'gso_slickenline'})
  ON CREATE SET n_gso_slickenline += {id: 'gso_slickenline', gso_class: 'slickenline', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/slickenline', pref_label_en: 'slickenline', definition_en_canonical: 'Lineation on a brittle slip surface defined by grooves, ridges, or striations', parents: ['gsol:tectonic_lineation'], sources: ['based on Neuendorf et al 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_slickenline += {id: 'gso_slickenline', gso_class: 'slickenline', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/slickenline', pref_label_en: 'slickenline', definition_en_canonical: 'Lineation on a brittle slip surface defined by grooves, ridges, or striations', parents: ['gsol:tectonic_lineation'], sources: ['based on Neuendorf et al 2005'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_stretching_lineation:GSOClass {id: 'gso_stretching_lineation'})
  ON CREATE SET n_gso_stretching_lineation += {id: 'gso_stretching_lineation', gso_class: 'stretching_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/stretching_lineation', pref_label_en: 'stretching lineation', definition_en_canonical: 'Lineation defined by elongate (prolate) fabric elements in which the alignment of the fabric elements, and the formation of prolate fabric elements is interpreted to be the product of crystal plastic deformation processes. Associated with mylontic foliation.', parents: ['gsol:particle_shape_lineation', 'gsol:tectonic_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_stretching_lineation += {id: 'gso_stretching_lineation', gso_class: 'stretching_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/stretching_lineation', pref_label_en: 'stretching lineation', definition_en_canonical: 'Lineation defined by elongate (prolate) fabric elements in which the alignment of the fabric elements, and the formation of prolate fabric elements is interpreted to be the product of crystal plastic deformation processes. Associated with mylontic foliation.', parents: ['gsol:particle_shape_lineation', 'gsol:tectonic_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_tectonic_lineation:GSOClass {id: 'gso_tectonic_lineation'})
  ON CREATE SET n_gso_tectonic_lineation += {id: 'gso_tectonic_lineation', gso_class: 'tectonic_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/tectonic_lineation', pref_label_en: 'tectonic lineation', definition_en_canonical: 'Penetrative linear structure in a rock body defined by fabric elements that are the product of tectonic processes. Linear is used in the sense that the orientation of the structure can be represented as a line in some sufficiently small neighborhood of any point in the material containig the fabric. Penetrative denotes that the fabric elements defining the structure are repeated at distances so small, compared with the scale of the whole that they can be considered to pervade it uniformly and be present at every point (paraphrase of Turner and Weiss, 1963, p. 21).', parents: ['gsos:Lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_tectonic_lineation += {id: 'gso_tectonic_lineation', gso_class: 'tectonic_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/tectonic_lineation', pref_label_en: 'tectonic lineation', definition_en_canonical: 'Penetrative linear structure in a rock body defined by fabric elements that are the product of tectonic processes. Linear is used in the sense that the orientation of the structure can be represented as a line in some sufficiently small neighborhood of any point in the material containig the fabric. Penetrative denotes that the fabric elements defining the structure are repeated at distances so small, compared with the scale of the whole that they can be considered to pervade it uniformly and be present at every point (paraphrase of Turner and Weiss, 1963, p. 21).', parents: ['gsos:Lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_Alteration_Facies_Contact:GSOClass {id: 'gso_Alteration_Facies_Contact'})
  ON CREATE SET n_gso_Alteration_Facies_Contact += {id: 'gso_Alteration_Facies_Contact', gso_class: 'Alteration_Facies_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Alteration_Facies_Contact', pref_label_en: 'alteration facies contact', definition_en_canonical: 'A metasomatic facies contact separating rocks that have undergone alteration of a particular facies from those that have undergone metasomatism of another facies. Alteration is a kind of metasomatism that does not introduce economically important minerals.', parents: ['gscn:Metamorphic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Alteration_Facies_Contact += {id: 'gso_Alteration_Facies_Contact', gso_class: 'Alteration_Facies_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Alteration_Facies_Contact', pref_label_en: 'alteration facies contact', definition_en_canonical: 'A metasomatic facies contact separating rocks that have undergone alteration of a particular facies from those that have undergone metasomatism of another facies. Alteration is a kind of metasomatism that does not introduce economically important minerals.', parents: ['gscn:Metamorphic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Angular_Unconformable_Contact:GSOClass {id: 'gso_Angular_Unconformable_Contact'})
  ON CREATE SET n_gso_Angular_Unconformable_Contact += {id: 'gso_Angular_Unconformable_Contact', gso_class: 'Angular_Unconformable_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Angular_Unconformable_Contact', pref_label_en: 'angular unconformable contact', definition_en_canonical: 'An unconformable contact between two geological units in which the older, underlying rocks dip at an angle different from the younger, overlying strata, usually in which younger sediments rest upon the eroded surface of tilted or folded older rocks.', parents: ['gscn:Unconformable_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Angular_Unconformable_Contact += {id: 'gso_Angular_Unconformable_Contact', gso_class: 'Angular_Unconformable_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Angular_Unconformable_Contact', pref_label_en: 'angular unconformable contact', definition_en_canonical: 'An unconformable contact between two geological units in which the older, underlying rocks dip at an angle different from the younger, overlying strata, usually in which younger sediments rest upon the eroded surface of tilted or folded older rocks.', parents: ['gscn:Unconformable_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Buttress_Unconformity:GSOClass {id: 'gso_Buttress_Unconformity'})
  ON CREATE SET n_gso_Buttress_Unconformity += {id: 'gso_Buttress_Unconformity', gso_class: 'Buttress_Unconformity', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Buttress_Unconformity', pref_label_en: 'buttress unconformity', definition_en_canonical: 'An unconformity in which onlapping strata are truncated against a steep topographic scarp.', parents: ['gscn:Unconformable_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Buttress_Unconformity += {id: 'gso_Buttress_Unconformity', gso_class: 'Buttress_Unconformity', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Buttress_Unconformity', pref_label_en: 'buttress unconformity', definition_en_canonical: 'An unconformity in which onlapping strata are truncated against a steep topographic scarp.', parents: ['gscn:Unconformable_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Chronostratigraphic_Contact:GSOClass {id: 'gso_Chronostratigraphic_Contact'})
  ON CREATE SET n_gso_Chronostratigraphic_Contact += {id: 'gso_Chronostratigraphic_Contact', gso_class: 'Chronostratigraphic_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Chronostratigraphic_Contact', pref_label_en: 'Chronostratigraphic-zone contact', definition_en_canonical: 'A contact between bodies of material having different ages of origin. The temporal boundary represented by the zone contact is typically associated with some \'guide\' event, such as a magnetic field reversal or fossil first appearance datum. If the event instance is implemented, link with Chronostratigraphic_Contact gsoc:isOutputOf ..event....', parents: ['gscn:Contact'], sources: ['Federal Geographic Data Committee, 2006, FGDC Digital Cartographic Standard for Geologic Map Symbolization: Reston, Va., Federal Geographic Data Committee Document Number FGDC-STD-013-2006, 290 p., 2 plates;  p. A-31-1, ref. 31.23.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Chronostratigraphic_Contact += {id: 'gso_Chronostratigraphic_Contact', gso_class: 'Chronostratigraphic_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Chronostratigraphic_Contact', pref_label_en: 'Chronostratigraphic-zone contact', definition_en_canonical: 'A contact between bodies of material having different ages of origin. The temporal boundary represented by the zone contact is typically associated with some \'guide\' event, such as a magnetic field reversal or fossil first appearance datum. If the event instance is implemented, link with Chronostratigraphic_Contact gsoc:isOutputOf ..event....', parents: ['gscn:Contact'], sources: ['Federal Geographic Data Committee, 2006, FGDC Digital Cartographic Standard for Geologic Map Symbolization: Reston, Va., Federal Geographic Data Committee Document Number FGDC-STD-013-2006, 290 p., 2 plates;  p. A-31-1, ref. 31.23.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Conductivity_Contact:GSOClass {id: 'gso_Conductivity_Contact'})
  ON CREATE SET n_gso_Conductivity_Contact += {id: 'gso_Conductivity_Contact', gso_class: 'Conductivity_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Conductivity_Contact', pref_label_en: 'conductivity contact', definition_en_canonical: 'A geophysical contact between bodies of material distinguished based on electrical conductivity characteristics', parents: ['gscn:Geophysical_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Conductivity_Contact += {id: 'gso_Conductivity_Contact', gso_class: 'Conductivity_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Conductivity_Contact', pref_label_en: 'conductivity contact', definition_en_canonical: 'A geophysical contact between bodies of material distinguished based on electrical conductivity characteristics', parents: ['gscn:Geophysical_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Conformable_Contact:GSOClass {id: 'gso_Conformable_Contact'})
  ON CREATE SET n_gso_Conformable_Contact += {id: 'gso_Conformable_Contact', gso_class: 'Conformable_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Conformable_Contact', pref_label_en: 'conformable contact', definition_en_canonical: 'A contact separating two geological units in which the layers are formed one above the other in order by regular, uninterrupted deposition under the same general conditions.', parents: ['gscn:Depositional_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Conformable_Contact += {id: 'gso_Conformable_Contact', gso_class: 'Conformable_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Conformable_Contact', pref_label_en: 'conformable contact', definition_en_canonical: 'A contact separating two geological units in which the layers are formed one above the other in order by regular, uninterrupted deposition under the same general conditions.', parents: ['gscn:Depositional_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Contact:GSOClass {id: 'gso_Contact'})
  ON CREATE SET n_gso_Contact += {id: 'gso_Contact', gso_class: 'Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Contact', pref_label_en: 'Contact', definition_en_canonical: 'A surface that separates geologic units. Very general concept representing any kind of surface separating two geologic units, including primary boundaries such as depositional contacts, all kinds of unconformities, intrusive contacts, and gradational contacts, as well as faults that separate geologic units. (CGI ContactType vocabulary, adapted from Jackson, 1997, page 137, NADM C1 2004)', parents: ['gsoc:Low_Dimension_Feature', 'gsog:Geologic_Structure'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Contact += {id: 'gso_Contact', gso_class: 'Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Contact', pref_label_en: 'Contact', definition_en_canonical: 'A surface that separates geologic units. Very general concept representing any kind of surface separating two geologic units, including primary boundaries such as depositional contacts, all kinds of unconformities, intrusive contacts, and gradational contacts, as well as faults that separate geologic units. (CGI ContactType vocabulary, adapted from Jackson, 1997, page 137, NADM C1 2004)', parents: ['gsoc:Low_Dimension_Feature', 'gsog:Geologic_Structure'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Deformation_Zone_Contact:GSOClass {id: 'gso_Deformation_Zone_Contact'})
  ON CREATE SET n_gso_Deformation_Zone_Contact += {id: 'gso_Deformation_Zone_Contact', gso_class: 'Deformation_Zone_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Deformation_Zone_Contact', pref_label_en: 'deformation zone contact', definition_en_canonical: 'A lithogenetic bundary separating rock masses that have different deformation structure, e.g. sheared rock against non sheared rock, brecciated rock against non-brecciated rock.', parents: ['gscn:Lithogenetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Deformation_Zone_Contact += {id: 'gso_Deformation_Zone_Contact', gso_class: 'Deformation_Zone_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Deformation_Zone_Contact', pref_label_en: 'deformation zone contact', definition_en_canonical: 'A lithogenetic bundary separating rock masses that have different deformation structure, e.g. sheared rock against non sheared rock, brecciated rock against non-brecciated rock.', parents: ['gscn:Lithogenetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Density_Contact:GSOClass {id: 'gso_Density_Contact'})
  ON CREATE SET n_gso_Density_Contact += {id: 'gso_Density_Contact', gso_class: 'Density_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Density_Contact', pref_label_en: 'density contact', definition_en_canonical: 'A geophysical contact separating bodies of material with different density characteristics, generally determined through measurement and modelling of gravity variations.', parents: ['gscn:Geophysical_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Density_Contact += {id: 'gso_Density_Contact', gso_class: 'Density_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Density_Contact', pref_label_en: 'density contact', definition_en_canonical: 'A geophysical contact separating bodies of material with different density characteristics, generally determined through measurement and modelling of gravity variations.', parents: ['gscn:Geophysical_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Depositional_Contact:GSOClass {id: 'gso_Depositional_Contact'})
  ON CREATE SET n_gso_Depositional_Contact += {id: 'gso_Depositional_Contact', gso_class: 'Depositional_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Depositional_Contact', pref_label_en: 'depositional contact', definition_en_canonical: 'Lithogenetic contact at which a sedimentary or volcanic rock has been deposited on (or against) another rock body. The relationship between the older underlying rocks and younger overlying rocks is unknown or not specfied.', parents: ['gscn:Lithogenetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Depositional_Contact += {id: 'gso_Depositional_Contact', gso_class: 'Depositional_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Depositional_Contact', pref_label_en: 'depositional contact', definition_en_canonical: 'Lithogenetic contact at which a sedimentary or volcanic rock has been deposited on (or against) another rock body. The relationship between the older underlying rocks and younger overlying rocks is unknown or not specfied.', parents: ['gscn:Lithogenetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Disconformable_Contact:GSOClass {id: 'gso_Disconformable_Contact'})
  ON CREATE SET n_gso_Disconformable_Contact += {id: 'gso_Disconformable_Contact', gso_class: 'Disconformable_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Disconformable_Contact', pref_label_en: 'disconformable contact', definition_en_canonical: 'An unconformable contact between two geological units in which the bedding of the older, underlying unit is parallel to the bedding of the younger, overlying unit, but in which the contact between the two units is marked by an irregular or uneven surface of appreciable relief.', parents: ['gscn:Unconformable_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Disconformable_Contact += {id: 'gso_Disconformable_Contact', gso_class: 'Disconformable_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Disconformable_Contact', pref_label_en: 'disconformable contact', definition_en_canonical: 'An unconformable contact between two geological units in which the bedding of the older, underlying unit is parallel to the bedding of the younger, overlying unit, but in which the contact between the two units is marked by an irregular or uneven surface of appreciable relief.', parents: ['gscn:Unconformable_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Faulted_Contact:GSOClass {id: 'gso_Faulted_Contact'})
  ON CREATE SET n_gso_Faulted_Contact += {id: 'gso_Faulted_Contact', gso_class: 'Faulted_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Faulted_Contact', pref_label_en: 'faulted contact', definition_en_canonical: 'A contact separating two bodies of material across which one body has slid past the other.', parents: ['gscn:Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Faulted_Contact += {id: 'gso_Faulted_Contact', gso_class: 'Faulted_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Faulted_Contact', pref_label_en: 'faulted contact', definition_en_canonical: 'A contact separating two bodies of material across which one body has slid past the other.', parents: ['gscn:Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_GSSP:GSOClass {id: 'gso_GSSP'})
  ON CREATE SET n_gso_GSSP += {id: 'gso_GSSP', gso_class: 'GSSP', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/GSSP', pref_label_en: 'GSSP ', definition_en_canonical: 'GSSP is dependent on some particular geologic event that is manifested globally in the stratigraphic record.  At least one of the host Rock_Body_Boundary objects must be a participant in the host Geologic_Event', parents: ['gscn:Stratigraphic_Point'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_GSSP += {id: 'gso_GSSP', gso_class: 'GSSP', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/GSSP', pref_label_en: 'GSSP ', definition_en_canonical: 'GSSP is dependent on some particular geologic event that is manifested globally in the stratigraphic record.  At least one of the host Rock_Body_Boundary objects must be a participant in the host Geologic_Event', parents: ['gscn:Stratigraphic_Point'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Geologic_Province_Contact:GSOClass {id: 'gso_Geologic_Province_Contact'})
  ON CREATE SET n_gso_Geologic_Province_Contact += {id: 'gso_Geologic_Province_Contact', gso_class: 'Geologic_Province_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Geologic_Province_Contact', pref_label_en: 'geologic province contact', definition_en_canonical: 'A contact between regions characterised by their geological history or by similar structural, petrographic or stratigraphic features', parents: ['gscn:Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Geologic_Province_Contact += {id: 'gso_Geologic_Province_Contact', gso_class: 'Geologic_Province_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Geologic_Province_Contact', pref_label_en: 'geologic province contact', definition_en_canonical: 'A contact between regions characterised by their geological history or by similar structural, petrographic or stratigraphic features', parents: ['gscn:Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Geophysical_Contact:GSOClass {id: 'gso_Geophysical_Contact'})
  ON CREATE SET n_gso_Geophysical_Contact += {id: 'gso_Geophysical_Contact', gso_class: 'Geophysical_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Geophysical_Contact', pref_label_en: 'geophysical contact', definition_en_canonical: 'A contact separating bodies of material in the earth that have different geophysical properties. Use for boundaries that are detected by geophysical sensor techniques as opposed to direct lithologic observation.', parents: ['gscn:Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Geophysical_Contact += {id: 'gso_Geophysical_Contact', gso_class: 'Geophysical_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Geophysical_Contact', pref_label_en: 'geophysical contact', definition_en_canonical: 'A contact separating bodies of material in the earth that have different geophysical properties. Use for boundaries that are detected by geophysical sensor techniques as opposed to direct lithologic observation.', parents: ['gscn:Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Glacial_Stationary_Line:GSOClass {id: 'gso_Glacial_Stationary_Line'})
  ON CREATE SET n_gso_Glacial_Stationary_Line += {id: 'gso_Glacial_Stationary_Line', gso_class: 'Glacial_Stationary_Line', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Glacial_Stationary_Line', pref_label_en: 'glacial stationary line', definition_en_canonical: 'A boundary between a subglacial geomorphic unit and a periglacial geomorphic unit, marking the maximum extent of glacial cover. This can be thought of as the outcrop of the contact between a glacier and its substrate at some time at each point along the boundary. This contact type is included as an interim concept, assuming that in the future, there will be extensions to account better for geomorphic units and line types.', parents: ['gscn:Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Glacial_Stationary_Line += {id: 'gso_Glacial_Stationary_Line', gso_class: 'Glacial_Stationary_Line', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Glacial_Stationary_Line', pref_label_en: 'glacial stationary line', definition_en_canonical: 'A boundary between a subglacial geomorphic unit and a periglacial geomorphic unit, marking the maximum extent of glacial cover. This can be thought of as the outcrop of the contact between a glacier and its substrate at some time at each point along the boundary. This contact type is included as an interim concept, assuming that in the future, there will be extensions to account better for geomorphic units and line types.', parents: ['gscn:Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

