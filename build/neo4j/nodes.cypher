  ON CREATE SET n_annular_fluid_type += {id: 'annular-fluid-type', label: 'Tipo de Fluido no Anular', label_en: 'Annular Fluid Type', type: 'analytical', definition: 'Tipo de fluido presente no anular do poço no momento de uma operação de canhoneio. (OSDU canonical: Type of fluid in wellbore at time of perforation job.)', osdu_kind: 'opendes:osdu:reference-data--AnnularFluidType:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}
