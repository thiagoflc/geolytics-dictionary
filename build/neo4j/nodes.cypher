MERGE (n_gso_crenulation_lineation:GSOClass {id: 'gso_crenulation_lineation'})
  ON CREATE SET n_gso_crenulation_lineation += {id: 'gso_crenulation_lineation', gso_class: 'crenulation_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/crenulation_lineation', pref_label_en: 'crenulation lineation', definition_en_canonical: 'Lineation defined by small-scale wrinkles, typically of phylosillicate minerals, on another surface, typically a cleavage or schistosity. Use instead of intersection lineation if the wrinkles are the measured feature and the intersecting planar feature is not apparent.', parents: ['gsol:tectonic_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_crenulation_lineation += {id: 'gso_crenulation_lineation', gso_class: 'crenulation_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/crenulation_lineation', pref_label_en: 'crenulation lineation', definition_en_canonical: 'Lineation defined by small-scale wrinkles, typically of phylosillicate minerals, on another surface, typically a cleavage or schistosity. Use instead of intersection lineation if the wrinkles are the measured feature and the intersecting planar feature is not apparent.', parents: ['gsol:tectonic_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_flow_lineation:GSOClass {id: 'gso_flow_lineation'})
  ON CREATE SET n_gso_flow_lineation += {id: 'gso_flow_lineation', gso_class: 'flow_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/flow_lineation', pref_label_en: 'flow lineation', definition_en_canonical: 'A linear alignment of fabric elements, especially elongate or rod-shaped minerals, interpreted to have been aligned by flow of magma, lava, pyroclastic material, or diapiric flow of sedimentary rock.', parents: ['gsos:Lineation'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_flow_lineation += {id: 'gso_flow_lineation', gso_class: 'flow_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/flow_lineation', pref_label_en: 'flow lineation', definition_en_canonical: 'A linear alignment of fabric elements, especially elongate or rod-shaped minerals, interpreted to have been aligned by flow of magma, lava, pyroclastic material, or diapiric flow of sedimentary rock.', parents: ['gsos:Lineation'], sources: ['Geoscience Victoria, Australia'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

