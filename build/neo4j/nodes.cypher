  ON MATCH SET n_gso_hornblende_mineral_lineation += {id: 'gso_hornblende_mineral_lineation', gso_class: 'hornblende_mineral_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/hornblende_mineral_lineation', pref_label_en: 'hornblende mineral lineation', definition_en_canonical: 'Mineral lineation defined by aligned hornblende crystals.', parents: ['gsol:mineral_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_igneous_lineation:GSOClass {id: 'gso_igneous_lineation'})
  ON CREATE SET n_gso_igneous_lineation += {id: 'gso_igneous_lineation', gso_class: 'igneous_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/igneous_lineation', pref_label_en: 'igneous lineation', definition_en_canonical: 'Lineation defined by alignment of elongate fabric elements formed in lava or magma before complete crystallization. Some typical fabric elements are elongate phenocrysts and vesicles.', parents: ['gsos:Lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_igneous_lineation += {id: 'gso_igneous_lineation', gso_class: 'igneous_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/igneous_lineation', pref_label_en: 'igneous lineation', definition_en_canonical: 'Lineation defined by alignment of elongate fabric elements formed in lava or magma before complete crystallization. Some typical fabric elements are elongate phenocrysts and vesicles.', parents: ['gsos:Lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_igneous_mineral_lineation:GSOClass {id: 'gso_igneous_mineral_lineation'})
  ON CREATE SET n_gso_igneous_mineral_lineation += {id: 'gso_igneous_mineral_lineation', gso_class: 'igneous_mineral_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/igneous_mineral_lineation', pref_label_en: 'igneous mineral lineation', definition_en_canonical: 'Lineation in igneous rock defined by aligned crystals where there is evidence that the crystal alignment is related to process occurring before the rock was solidified.', parents: ['gsol:igneous_lineation', 'gsol:mineral_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_igneous_mineral_lineation += {id: 'gso_igneous_mineral_lineation', gso_class: 'igneous_mineral_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/igneous_mineral_lineation', pref_label_en: 'igneous mineral lineation', definition_en_canonical: 'Lineation in igneous rock defined by aligned crystals where there is evidence that the crystal alignment is related to process occurring before the rock was solidified.', parents: ['gsol:igneous_lineation', 'gsol:mineral_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_igneous_particle_shape_lineation:GSOClass {id: 'gso_igneous_particle_shape_lineation'})
  ON CREATE SET n_gso_igneous_particle_shape_lineation += {id: 'gso_igneous_particle_shape_lineation', gso_class: 'igneous_particle_shape_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/igneous_particle_shape_lineation', pref_label_en: 'igneous particle shape lineation', definition_en_canonical: 'Lineation in an igneous rock, usually welded tuff, defined by elongate objects in the rock (usually pumice pads, also elongate crystals). Descriptive--elogation may be due to deformation or to rotation/alignment of originally elongate (prolate ellipsoid) objects in the rock.', parents: ['gsol:igneous_lineation', 'gsol:particle_shape_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
  ON MATCH SET n_gso_igneous_particle_shape_lineation += {id: 'gso_igneous_particle_shape_lineation', gso_class: 'igneous_particle_shape_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/igneous_particle_shape_lineation', pref_label_en: 'igneous particle shape lineation', definition_en_canonical: 'Lineation in an igneous rock, usually welded tuff, defined by elongate objects in the rock (usually pumice pads, also elongate crystals). Descriptive--elogation may be due to deformation or to rotation/alignment of originally elongate (prolate ellipsoid) objects in the rock.', parents: ['gsol:igneous_lineation', 'gsol:particle_shape_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}

MERGE (n_gso_igneous_vesicle_lineation:GSOClass {id: 'gso_igneous_vesicle_lineation'})
  ON CREATE SET n_gso_igneous_vesicle_lineation += {id: 'gso_igneous_vesicle_lineation', gso_class: 'igneous_vesicle_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/igneous_vesicle_lineation', pref_label_en: 'igneous vesicle lineation', definition_en_canonical: 'lineation defined in a volcanic rock by aligned elongation direction of vesicles.', parents: ['gsol:igneous_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
