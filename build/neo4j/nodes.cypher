MERGE (n_gso_Thrust_Fault:GSOClass {id: 'gso_Thrust_Fault'})
  ON CREATE SET n_gso_Thrust_Fault += {id: 'gso_Thrust_Fault', gso_class: 'Thrust_Fault', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/Thrust_Fault', pref_label_en: 'thrust fault', definition_en_canonical: 'Fault that dips less than 45 degrees over more than half of the recognized extent of the fault, with a hanging wall displaced from a structurally deeper position relative to footwall rocks.', parents: ['gsfa:Low_Angle_Fault', 'gsfa:Reverse_Fault'], sources: ['CGI faulttype SKOS vocabulary 2016-10-19'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
