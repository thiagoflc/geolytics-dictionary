MERGE (n_wellbore_architecture:Entity:Equipment {id: 'wellbore-architecture'})
  ON CREATE SET n_wellbore_architecture += {id: 'wellbore-architecture', label: 'Arquitetura do Poço', label_en: 'Wellbore Architecture', type: 'equipment', definition: 'Descreve as estruturas físicas de um poço — revestimentos, cimentações, completação e equipamentos permanentes do poço. (OSDU canonical: Describes the physical structures for a borehole.)', osdu_kind: 'opendes:osdu:work-product-component--WellboreArchitecture:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}
