MERGE (n_wellbore_trajectory:Entity:Instrument {id: 'wellbore-trajectory'})
  ON CREATE SET n_wellbore_trajectory += {id: 'wellbore-trajectory', label: 'Trajetória do Poço (WPC)', label_en: 'Wellbore Trajectory', type: 'instrument', definition: 'Componente de Produto de Trabalho descrevendo uma trajetória individual de poço — também chamada deviation survey, usada para calcular posição e incerteza espacial em 2D/3D do poço planejado ou real. (OSDU canonical: Work Product Component describing an individual instance of a wellbore trajectory data object. Also called a deviation survey.)', osdu_kind: 'opendes:osdu:work-product-component--WellboreTrajectory:1.0.0', owl_uri: 'https://w3id.org/osdu#WellboreTrajectory', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}
  ON MATCH SET n_wellbore_trajectory += {id: 'wellbore-trajectory', label: 'Trajetória do Poço (WPC)', label_en: 'Wellbore Trajectory', type: 'instrument', definition: 'Componente de Produto de Trabalho descrevendo uma trajetória individual de poço — também chamada deviation survey, usada para calcular posição e incerteza espacial em 2D/3D do poço planejado ou real. (OSDU canonical: Work Product Component describing an individual instance of a wellbore trajectory data object. Also called a deviation survey.)', osdu_kind: 'opendes:osdu:work-product-component--WellboreTrajectory:1.0.0', owl_uri: 'https://w3id.org/osdu#WellboreTrajectory', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}

MERGE (n_wellbore_marker_set:Entity:Geological {id: 'wellbore-marker-set'})
  ON CREATE SET n_wellbore_marker_set += {id: 'wellbore-marker-set', label: 'Conjunto de Marcadores de Poço', label_en: 'Wellbore Marker Set', type: 'geological', definition: 'Marcadores que identificam profundidades em um poço — abaixo de uma referência — onde alguém ou um processo automatizado registra observação relevante (geralmente mudança de rocha). Conhecidos como picks ou tops de formação. (OSDU canonical: Wellbore Markers identify the depth in a wellbore, measured below a reference elevation, at which a person or an automated process identifies a noteworthy observation.)', osdu_kind: 'opendes:osdu:work-product-component--WellboreMarkerSet:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}
  ON MATCH SET n_wellbore_marker_set += {id: 'wellbore-marker-set', label: 'Conjunto de Marcadores de Poço', label_en: 'Wellbore Marker Set', type: 'geological', definition: 'Marcadores que identificam profundidades em um poço — abaixo de uma referência — onde alguém ou um processo automatizado registra observação relevante (geralmente mudança de rocha). Conhecidos como picks ou tops de formação. (OSDU canonical: Wellbore Markers identify the depth in a wellbore, measured below a reference elevation, at which a person or an automated process identifies a noteworthy observation.)', osdu_kind: 'opendes:osdu:work-product-component--WellboreMarkerSet:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}

