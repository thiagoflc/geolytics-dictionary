  ON CREATE SET n_seismic_horizon += {id: 'seismic-horizon', label: 'Horizonte Sísmico', label_en: 'Seismic Horizon', type: 'geological', definition: 'Conjunto de picks relacionados à geometria de processamento sísmico que define uma superfície interpretada; a geometria utilizada é referenciada pelo Interpretation Project. (OSDU canonical: A set of picks related to seismic processing geometry which define a surface.)', osdu_kind: 'opendes:osdu:work-product-component--SeismicHorizon:1.0.0', geocoverage: ['layer3'], sources: ['Accenture/OSDU OWL']}
  ON MATCH SET n_seismic_horizon += {id: 'seismic-horizon', label: 'Horizonte Sísmico', label_en: 'Seismic Horizon', type: 'geological', definition: 'Conjunto de picks relacionados à geometria de processamento sísmico que define uma superfície interpretada; a geometria utilizada é referenciada pelo Interpretation Project. (OSDU canonical: A set of picks related to seismic processing geometry which define a surface.)', osdu_kind: 'opendes:osdu:work-product-component--SeismicHorizon:1.0.0', geocoverage: ['layer3'], sources: ['Accenture/OSDU OWL']}

