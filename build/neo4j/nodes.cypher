MERGE (n_gso_Metamorphic_Contact:GSOClass {id: 'gso_Metamorphic_Contact'})
  ON CREATE SET n_gso_Metamorphic_Contact += {id: 'gso_Metamorphic_Contact', gso_class: 'Metamorphic_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Metamorphic_Contact', pref_label_en: 'metamorphic contact', definition_en_canonical: 'Lithogenetic contact separating rocks that have different lithologic properties related to metamorphism, metasomatism, alteration, or mineralization. Generally separates metamorphic rock bodies, but may separate metamorphosed (broadly speaking) and non-metamorphosed rock.', parents: ['gscn:Lithogenetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Metamorphic_Contact += {id: 'gso_Metamorphic_Contact', gso_class: 'Metamorphic_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Metamorphic_Contact', pref_label_en: 'metamorphic contact', definition_en_canonical: 'Lithogenetic contact separating rocks that have different lithologic properties related to metamorphism, metasomatism, alteration, or mineralization. Generally separates metamorphic rock bodies, but may separate metamorphosed (broadly speaking) and non-metamorphosed rock.', parents: ['gscn:Lithogenetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Metamorphic_Facies_Contact:GSOClass {id: 'gso_Metamorphic_Facies_Contact'})
  ON CREATE SET n_gso_Metamorphic_Facies_Contact += {id: 'gso_Metamorphic_Facies_Contact', gso_class: 'Metamorphic_Facies_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Metamorphic_Facies_Contact', pref_label_en: 'metamorphic facies contact', definition_en_canonical: 'A metamorphic contact separating rocks that have undergone metamorphism of a particular facies from those that have undergone metamorphism of another facies.', parents: ['gscn:Metamorphic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Metamorphic_Facies_Contact += {id: 'gso_Metamorphic_Facies_Contact', gso_class: 'Metamorphic_Facies_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Metamorphic_Facies_Contact', pref_label_en: 'metamorphic facies contact', definition_en_canonical: 'A metamorphic contact separating rocks that have undergone metamorphism of a particular facies from those that have undergone metamorphism of another facies.', parents: ['gscn:Metamorphic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Metasomatic_Facies_Contact:GSOClass {id: 'gso_Metasomatic_Facies_Contact'})
  ON CREATE SET n_gso_Metasomatic_Facies_Contact += {id: 'gso_Metasomatic_Facies_Contact', gso_class: 'Metasomatic_Facies_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Metasomatic_Facies_Contact', pref_label_en: 'metasomatic facies contact', definition_en_canonical: 'A metamorphic contact separating rocks that have undergone metasomatism of a particular facies from those that have undergone metasomatism of another facies. Metasomatism is distinguished from metamorphism by significant changes in bulk chemistry of the affected rock.', parents: ['gscn:Metamorphic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Metasomatic_Facies_Contact += {id: 'gso_Metasomatic_Facies_Contact', gso_class: 'Metasomatic_Facies_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Metasomatic_Facies_Contact', pref_label_en: 'metasomatic facies contact', definition_en_canonical: 'A metamorphic contact separating rocks that have undergone metasomatism of a particular facies from those that have undergone metasomatism of another facies. Metasomatism is distinguished from metamorphism by significant changes in bulk chemistry of the affected rock.', parents: ['gscn:Metamorphic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Mineralisation_Assemblage_Contact:GSOClass {id: 'gso_Mineralisation_Assemblage_Contact'})
  ON CREATE SET n_gso_Mineralisation_Assemblage_Contact += {id: 'gso_Mineralisation_Assemblage_Contact', gso_class: 'Mineralisation_Assemblage_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Mineralisation_Assemblage_Contact', pref_label_en: 'mineralisation assemblage contact', definition_en_canonical: 'A metasomatic facies contact separating rocks which have been mineralised and contain a particular mineral assemblage from those which contain a different assemblage. Mineralization is a kind of metasomatism that introduces ecomomically important minerals.', parents: ['gscn:Metamorphic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Mineralisation_Assemblage_Contact += {id: 'gso_Mineralisation_Assemblage_Contact', gso_class: 'Mineralisation_Assemblage_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Mineralisation_Assemblage_Contact', pref_label_en: 'mineralisation assemblage contact', definition_en_canonical: 'A metasomatic facies contact separating rocks which have been mineralised and contain a particular mineral assemblage from those which contain a different assemblage. Mineralization is a kind of metasomatism that introduces ecomomically important minerals.', parents: ['gscn:Metamorphic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Nonconformable_Contact:GSOClass {id: 'gso_Nonconformable_Contact'})
  ON CREATE SET n_gso_Nonconformable_Contact += {id: 'gso_Nonconformable_Contact', gso_class: 'Nonconformable_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Nonconformable_Contact', pref_label_en: 'nonconformable contact', definition_en_canonical: 'An unconformable contact between an underlying, older nonstratified geological unit (usually intrusive igneous rocks or metamorphics) and an overlying, younger stratified geological unit.', parents: ['gscn:Unconformable_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Nonconformable_Contact += {id: 'gso_Nonconformable_Contact', gso_class: 'Nonconformable_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Nonconformable_Contact', pref_label_en: 'nonconformable contact', definition_en_canonical: 'An unconformable contact between an underlying, older nonstratified geological unit (usually intrusive igneous rocks or metamorphics) and an overlying, younger stratified geological unit.', parents: ['gscn:Unconformable_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Paraconformable_Contact:GSOClass {id: 'gso_Paraconformable_Contact'})
  ON CREATE SET n_gso_Paraconformable_Contact += {id: 'gso_Paraconformable_Contact', gso_class: 'Paraconformable_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Paraconformable_Contact', pref_label_en: 'paraconformable contact', definition_en_canonical: 'An unconformable contact between two geological units in which the bedding of the older, underlying unit is parallel to the bedding of the younger, overlying unit, in which the contact between the two units is planar, and may be coincident with a bedding plane.', parents: ['gscn:Unconformable_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Paraconformable_Contact += {id: 'gso_Paraconformable_Contact', gso_class: 'Paraconformable_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Paraconformable_Contact', pref_label_en: 'paraconformable contact', definition_en_canonical: 'An unconformable contact between two geological units in which the bedding of the older, underlying unit is parallel to the bedding of the younger, overlying unit, in which the contact between the two units is planar, and may be coincident with a bedding plane.', parents: ['gscn:Unconformable_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Radiometric_Contact:GSOClass {id: 'gso_Radiometric_Contact'})
  ON CREATE SET n_gso_Radiometric_Contact += {id: 'gso_Radiometric_Contact', gso_class: 'Radiometric_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Radiometric_Contact', pref_label_en: 'radiometric contact', definition_en_canonical: 'A geophysical contact separating bodies of material distinguished based on the characteristics of emitted of radiant energy related to radioactivity (e.g. gamma rays).', parents: ['gscn:Geophysical_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Radiometric_Contact += {id: 'gso_Radiometric_Contact', gso_class: 'Radiometric_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Radiometric_Contact', pref_label_en: 'radiometric contact', definition_en_canonical: 'A geophysical contact separating bodies of material distinguished based on the characteristics of emitted of radiant energy related to radioactivity (e.g. gamma rays).', parents: ['gscn:Geophysical_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Sedimentary_Facies_Contact:GSOClass {id: 'gso_Sedimentary_Facies_Contact'})
  ON CREATE SET n_gso_Sedimentary_Facies_Contact += {id: 'gso_Sedimentary_Facies_Contact', gso_class: 'Sedimentary_Facies_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Sedimentary_Facies_Contact', pref_label_en: 'sedimentary facies contact', definition_en_canonical: 'A lithogenetic contact separating essentially coeval sedimentary material bodies distinguished by characteristics reflecting different physical or chemical processes active at the time of deposition of the sediment.', parents: ['gscn:Lithogenetic_Contact'], sources: ['base on Nichols, Gary, 1999, Sedimentology and stratigraphy, Blackwell, p. 62-63.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Sedimentary_Facies_Contact += {id: 'gso_Sedimentary_Facies_Contact', gso_class: 'Sedimentary_Facies_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Sedimentary_Facies_Contact', pref_label_en: 'sedimentary facies contact', definition_en_canonical: 'A lithogenetic contact separating essentially coeval sedimentary material bodies distinguished by characteristics reflecting different physical or chemical processes active at the time of deposition of the sediment.', parents: ['gscn:Lithogenetic_Contact'], sources: ['base on Nichols, Gary, 1999, Sedimentology and stratigraphy, Blackwell, p. 62-63.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Sedimentary_Intrusive_Contact:GSOClass {id: 'gso_Sedimentary_Intrusive_Contact'})
  ON CREATE SET n_gso_Sedimentary_Intrusive_Contact += {id: 'gso_Sedimentary_Intrusive_Contact', gso_class: 'Sedimentary_Intrusive_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Sedimentary_Intrusive_Contact', pref_label_en: 'sedimentary intrusive contact', definition_en_canonical: 'An intrusive contact between a sedimentary rock unit and plastic sediment (e.g., clay, chalk, salt, gypsum, etc.), forced upward into it from underlying sediment', parents: ['gscn:Lithogenetic_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Sedimentary_Intrusive_Contact += {id: 'gso_Sedimentary_Intrusive_Contact', gso_class: 'Sedimentary_Intrusive_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Sedimentary_Intrusive_Contact', pref_label_en: 'sedimentary intrusive contact', definition_en_canonical: 'An intrusive contact between a sedimentary rock unit and plastic sediment (e.g., clay, chalk, salt, gypsum, etc.), forced upward into it from underlying sediment', parents: ['gscn:Lithogenetic_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Seismic_Contact:GSOClass {id: 'gso_Seismic_Contact'})
  ON CREATE SET n_gso_Seismic_Contact += {id: 'gso_Seismic_Contact', gso_class: 'Seismic_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Seismic_Contact', pref_label_en: 'seismic contact', definition_en_canonical: 'A geophysical contact separating bodies of material defined based on their seismic character. Seismic character is based on transmission of vibrations (seismic waves) through a rock body, and relates to the velocity of transmission, and the nature of reflection, refraction, or transformation of seismic waves by inhomogeneities in the rock body.', parents: ['gscn:Geophysical_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Seismic_Contact += {id: 'gso_Seismic_Contact', gso_class: 'Seismic_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Seismic_Contact', pref_label_en: 'seismic contact', definition_en_canonical: 'A geophysical contact separating bodies of material defined based on their seismic character. Seismic character is based on transmission of vibrations (seismic waves) through a rock body, and relates to the velocity of transmission, and the nature of reflection, refraction, or transformation of seismic waves by inhomogeneities in the rock body.', parents: ['gscn:Geophysical_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Stratigraphic_Point:GSOClass {id: 'gso_Stratigraphic_Point'})
  ON CREATE SET n_gso_Stratigraphic_Point += {id: 'gso_Stratigraphic_Point', gso_class: 'Stratigraphic_Point', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Stratigraphic_Point', pref_label_en: 'Stratigraphic Point', definition_en_canonical: 'A spatially restricted part of a Contact feature in a particular stratigraphic section, typically located by a point location.', parents: ['gscn:Contact'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Stratigraphic_Point += {id: 'gso_Stratigraphic_Point', gso_class: 'Stratigraphic_Point', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Stratigraphic_Point', pref_label_en: 'Stratigraphic Point', definition_en_canonical: 'A spatially restricted part of a Contact feature in a particular stratigraphic section, typically located by a point location.', parents: ['gscn:Contact'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Unconformable_Contact:GSOClass {id: 'gso_Unconformable_Contact'})
  ON CREATE SET n_gso_Unconformable_Contact += {id: 'gso_Unconformable_Contact', gso_class: 'Unconformable_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Unconformable_Contact', pref_label_en: 'unconformable contact', definition_en_canonical: 'A contact separating two geological units in which the younger unit succeeds the older after a substantial hiatus in deposition.', parents: ['gscn:Depositional_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Unconformable_Contact += {id: 'gso_Unconformable_Contact', gso_class: 'Unconformable_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Unconformable_Contact', pref_label_en: 'unconformable contact', definition_en_canonical: 'A contact separating two geological units in which the younger unit succeeds the older after a substantial hiatus in deposition.', parents: ['gscn:Depositional_Contact'], sources: ['Neuendorf, K.K.E, Mehl, J.P. & Jackson, J.A. (eds), 2005. Glossary of geology, 5th Edition. American Geological Institute, Alexandria, 779 p.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Volcanic_Subsidence_Zone_Boundary:GSOClass {id: 'gso_Volcanic_Subsidence_Zone_Boundary'})
  ON CREATE SET n_gso_Volcanic_Subsidence_Zone_Boundary += {id: 'gso_Volcanic_Subsidence_Zone_Boundary', gso_class: 'Volcanic_Subsidence_Zone_Boundary', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Volcanic_Subsidence_Zone_Boundary', pref_label_en: 'volcanic subsidence zone boundary', definition_en_canonical: 'boundary around a body of rock that is within a zone of subsidence or cratering produced by volcanic activity.', parents: ['gscn:Lithogenetic_Contact'], sources: ['this vocabulary, concept to encompass boundary of caldron, caldera, or crater.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Volcanic_Subsidence_Zone_Boundary += {id: 'gso_Volcanic_Subsidence_Zone_Boundary', gso_class: 'Volcanic_Subsidence_Zone_Boundary', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Volcanic_Subsidence_Zone_Boundary', pref_label_en: 'volcanic subsidence zone boundary', definition_en_canonical: 'boundary around a body of rock that is within a zone of subsidence or cratering produced by volcanic activity.', parents: ['gscn:Lithogenetic_Contact'], sources: ['this vocabulary, concept to encompass boundary of caldron, caldera, or crater.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Weathering_Contact:GSOClass {id: 'gso_Weathering_Contact'})
  ON CREATE SET n_gso_Weathering_Contact += {id: 'gso_Weathering_Contact', gso_class: 'Weathering_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Weathering_Contact', pref_label_en: 'weathering contact', definition_en_canonical: 'A lithogenetic contact separating bodies of material differentiated based on lithologic properties related to weathering.', parents: ['gscn:Lithogenetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Weathering_Contact += {id: 'gso_Weathering_Contact', gso_class: 'Weathering_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Weathering_Contact', pref_label_en: 'weathering contact', definition_en_canonical: 'A lithogenetic contact separating bodies of material differentiated based on lithologic properties related to weathering.', parents: ['gscn:Lithogenetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

MERGE (n_gso_Boundary_Stratotype:GSOClass {id: 'gso_Boundary_Stratotype'})
  ON CREATE SET n_gso_Boundary_Stratotype += {id: 'gso_Boundary_Stratotype', gso_class: 'Boundary_Stratotype', owl_uri: 'https://w3id.org/gso/1.0/geologicfeature/Boundary_Stratotype', attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
  ON MATCH SET n_gso_Boundary_Stratotype += {id: 'gso_Boundary_Stratotype', gso_class: 'Boundary_Stratotype', owl_uri: 'https://w3id.org/gso/1.0/geologicfeature/Boundary_Stratotype', attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
