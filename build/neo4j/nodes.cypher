// Geolytics Dictionary — Neo4j node import
// Generated: 2026-05-01T12:08:19.615Z
// Run with: cypher-shell -u neo4j -p <password> --file build/neo4j/nodes.cypher
MERGE (n_poco:Entity:Operational {id: 'poco'})
  ON CREATE SET n_poco += {id: 'poco', label: 'Poço', label_en: 'Well', type: 'operational', definition: 'Identificador padronizado atribuído a um poço de petróleo ou gás no Brasil, conforme as regras da Agência Nacional do Petróleo, Gás Natural e Biocombustíveis (ANP). Permite a identificação única em documentos técnicos, sistemas oficiais e comunicações regulatórias.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Well', osdu_kind: 'opendes:osdu:master-data--Well:1.0.0', geosciml_uri: 'http://geosciml.org/def/gsmlbh#Borehole', owl_uri: 'https://w3id.org/osdu#Well', geocoverage: ['layer1', 'layer1b', 'layer2', 'layer3', 'layer4', 'layer5'], sources: ['ANP/SEP']}
  ON MATCH SET n_poco += {id: 'poco', label: 'Poço', label_en: 'Well', type: 'operational', definition: 'Identificador padronizado atribuído a um poço de petróleo ou gás no Brasil, conforme as regras da Agência Nacional do Petróleo, Gás Natural e Biocombustíveis (ANP). Permite a identificação única em documentos técnicos, sistemas oficiais e comunicações regulatórias.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Well', osdu_kind: 'opendes:osdu:master-data--Well:1.0.0', geosciml_uri: 'http://geosciml.org/def/gsmlbh#Borehole', owl_uri: 'https://w3id.org/osdu#Well', geocoverage: ['layer1', 'layer1b', 'layer2', 'layer3', 'layer4', 'layer5'], sources: ['ANP/SEP']}

MERGE (n_bloco:Entity:Operational {id: 'bloco'})
  ON CREATE SET n_bloco += {id: 'bloco', label: 'Bloco', label_en: 'Block', type: 'operational', definition: 'Parte de uma bacia sedimentar, formada por um prisma vertical de profundidade indeterminada, com superfície poligonal definida pelas coordenadas geográficas de seus vértices, onde são desenvolvidas atividades de exploração ou produção de petróleo e gás natural.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#ExplorationBlock', osdu_kind: 'opendes:osdu:master-data--AcquisitionSurvey:1.0.0', geocoverage: ['layer4', 'layer5'], sources: ['Lei nº 9478, de 06/08/1997']}
  ON MATCH SET n_bloco += {id: 'bloco', label: 'Bloco', label_en: 'Block', type: 'operational', definition: 'Parte de uma bacia sedimentar, formada por um prisma vertical de profundidade indeterminada, com superfície poligonal definida pelas coordenadas geográficas de seus vértices, onde são desenvolvidas atividades de exploração ou produção de petróleo e gás natural.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#ExplorationBlock', osdu_kind: 'opendes:osdu:master-data--AcquisitionSurvey:1.0.0', geocoverage: ['layer4', 'layer5'], sources: ['Lei nº 9478, de 06/08/1997']}

MERGE (n_campo:Entity:Operational {id: 'campo'})
  ON CREATE SET n_campo += {id: 'campo', label: 'Campo', label_en: 'Field', type: 'operational', definition: 'Área produtora de petróleo ou gás natural a partir de um ou mais reservatórios contínuos. No regime ANP, um campo é declarado a partir da Declaração de Comercialidade que confirma a viabilidade econômica da descoberta.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Field', osdu_kind: 'opendes:osdu:master-data--Field:1.0.0', owl_uri: 'https://w3id.org/osdu#Field', geocoverage: ['layer4', 'layer5'], sources: ['ANP/SEP']}
  ON MATCH SET n_campo += {id: 'campo', label: 'Campo', label_en: 'Field', type: 'operational', definition: 'Área produtora de petróleo ou gás natural a partir de um ou mais reservatórios contínuos. No regime ANP, um campo é declarado a partir da Declaração de Comercialidade que confirma a viabilidade econômica da descoberta.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Field', osdu_kind: 'opendes:osdu:master-data--Field:1.0.0', owl_uri: 'https://w3id.org/osdu#Field', geocoverage: ['layer4', 'layer5'], sources: ['ANP/SEP']}

MERGE (n_bacia_sedimentar:Entity:Operational {id: 'bacia-sedimentar'})
  ON CREATE SET n_bacia_sedimentar += {id: 'bacia-sedimentar', label: 'Bacia Sedimentar', label_en: 'Sedimentary Basin', type: 'operational', definition: 'Depressão da crosta terrestre onde se acumulam rochas sedimentares que podem ser portadoras de petróleo ou gás, associados ou não.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#SedimentaryBasin', osdu_kind: 'opendes:osdu:master-data--Basin:1.0.0', geosciml_uri: 'http://geosciml.org/def/gsmlb#GeologicUnit', owl_uri: 'https://w3id.org/osdu#Basin', geocoverage: ['layer1', 'layer1b', 'layer2', 'layer3', 'layer4', 'layer5'], sources: ['Lei nº 9478, de 06/08/1997']}
  ON MATCH SET n_bacia_sedimentar += {id: 'bacia-sedimentar', label: 'Bacia Sedimentar', label_en: 'Sedimentary Basin', type: 'operational', definition: 'Depressão da crosta terrestre onde se acumulam rochas sedimentares que podem ser portadoras de petróleo ou gás, associados ou não.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#SedimentaryBasin', osdu_kind: 'opendes:osdu:master-data--Basin:1.0.0', geosciml_uri: 'http://geosciml.org/def/gsmlb#GeologicUnit', owl_uri: 'https://w3id.org/osdu#Basin', geocoverage: ['layer1', 'layer1b', 'layer2', 'layer3', 'layer4', 'layer5'], sources: ['Lei nº 9478, de 06/08/1997']}

MERGE (n_reservatorio:Entity:Operational {id: 'reservatorio'})
  ON CREATE SET n_reservatorio += {id: 'reservatorio', label: 'Reservatório', label_en: 'Reservoir', type: 'operational', definition: 'Corpo rochoso poroso e permeável capaz de armazenar e produzir hidrocarbonetos sob condições de pressão e temperatura adequadas. Equivale ao GeologicalBody do GeoCore com propriedades de porosidade e permeabilidade. O reservatório é a unidade econômica fundamental da exploração de petróleo.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Reservoir', osdu_kind: 'opendes:osdu:master-data--Reservoir:1.0.0', geosciml_uri: 'http://geosciml.org/def/gsmlb#GeologicUnit', geocoverage: ['layer1', 'layer1b', 'layer2', 'layer3', 'layer4'], sources: ['GeoCore + GeoReservoir (UFRGS)']}
  ON MATCH SET n_reservatorio += {id: 'reservatorio', label: 'Reservatório', label_en: 'Reservoir', type: 'operational', definition: 'Corpo rochoso poroso e permeável capaz de armazenar e produzir hidrocarbonetos sob condições de pressão e temperatura adequadas. Equivale ao GeologicalBody do GeoCore com propriedades de porosidade e permeabilidade. O reservatório é a unidade econômica fundamental da exploração de petróleo.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Reservoir', osdu_kind: 'opendes:osdu:master-data--Reservoir:1.0.0', geosciml_uri: 'http://geosciml.org/def/gsmlb#GeologicUnit', geocoverage: ['layer1', 'layer1b', 'layer2', 'layer3', 'layer4'], sources: ['GeoCore + GeoReservoir (UFRGS)']}

MERGE (n_formacao:Entity:Geological {id: 'formacao'})
  ON CREATE SET n_formacao += {id: 'formacao', label: 'Formação', label_en: 'Geological Formation', type: 'geological', definition: 'Unidade litoestratigráfica formal com características rochosas homogêneas, definida por suas propriedades litológicas e posição estratigráfica. É a unidade fundamental de mapeamento geológico e equivale ao conceito de GeologicalUnit do GeoCore.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#GeologicalFormation', osdu_kind: 'opendes:osdu:master-data--GeologicalFormation:1.0.0', geosciml_uri: 'http://geosciml.org/def/gsmlb#GeologicUnit', owl_uri: 'https://w3id.org/osdu#GeologicalFormation', geocoverage: ['layer1', 'layer1b', 'layer2', 'layer3', 'layer4'], sources: ['GeoCore (UFRGS/Geosiris)']}
  ON MATCH SET n_formacao += {id: 'formacao', label: 'Formação', label_en: 'Geological Formation', type: 'geological', definition: 'Unidade litoestratigráfica formal com características rochosas homogêneas, definida por suas propriedades litológicas e posição estratigráfica. É a unidade fundamental de mapeamento geológico e equivale ao conceito de GeologicalUnit do GeoCore.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#GeologicalFormation', osdu_kind: 'opendes:osdu:master-data--GeologicalFormation:1.0.0', geosciml_uri: 'http://geosciml.org/def/gsmlb#GeologicUnit', owl_uri: 'https://w3id.org/osdu#GeologicalFormation', geocoverage: ['layer1', 'layer1b', 'layer2', 'layer3', 'layer4'], sources: ['GeoCore (UFRGS/Geosiris)']}

MERGE (n_sistema_deposicional:Entity:Geological {id: 'sistema-deposicional'})
  ON CREATE SET n_sistema_deposicional += {id: 'sistema-deposicional', label: 'Sistema Deposicional', label_en: 'Depositional System', type: 'geological', definition: 'Conjunto de ambientes deposicionais geneticamente relacionados que depositaram sedimentos durante um evento ou época geológica. É a base da classificação de reservatórios de águas profundas brasileiros, especialmente os turbidíticos da Bacia de Campos e os carbonáticos do pré-sal de Santos.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#DepositionalSystem', geocoverage: ['layer1', 'layer2'], sources: ['GeoReservoir (UFRGS)']}
  ON MATCH SET n_sistema_deposicional += {id: 'sistema-deposicional', label: 'Sistema Deposicional', label_en: 'Depositional System', type: 'geological', definition: 'Conjunto de ambientes deposicionais geneticamente relacionados que depositaram sedimentos durante um evento ou época geológica. É a base da classificação de reservatórios de águas profundas brasileiros, especialmente os turbidíticos da Bacia de Campos e os carbonáticos do pré-sal de Santos.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#DepositionalSystem', geocoverage: ['layer1', 'layer2'], sources: ['GeoReservoir (UFRGS)']}

MERGE (n_contrato_ep:Entity:Contractual {id: 'contrato-ep'})
  ON CREATE SET n_contrato_ep += {id: 'contrato-ep', label: 'Contrato E&P', label_en: 'E&P Contract', type: 'contractual', definition: 'Contrato de Exploração e Produção assinado entre o agente econômico e a ANP. Estabelece os direitos e obrigações das partes para exploração de petróleo e gás natural em um bloco específico, incluindo o Programa Exploratório Mínimo (PEM) e as condições de produção.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#ExplorationProductionContract', geocoverage: ['layer5'], sources: ['ANP/SEP']}
  ON MATCH SET n_contrato_ep += {id: 'contrato-ep', label: 'Contrato E&P', label_en: 'E&P Contract', type: 'contractual', definition: 'Contrato de Exploração e Produção assinado entre o agente econômico e a ANP. Estabelece os direitos e obrigações das partes para exploração de petróleo e gás natural em um bloco específico, incluindo o Programa Exploratório Mínimo (PEM) e as condições de produção.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#ExplorationProductionContract', geocoverage: ['layer5'], sources: ['ANP/SEP']}

MERGE (n_pad:Entity:Contractual {id: 'pad'})
  ON CREATE SET n_pad += {id: 'pad', label: 'PAD', label_en: 'Discovery Evaluation Plan', type: 'contractual', definition: 'Instrumento pelo qual o concessionário avalia tecnicamente uma descoberta de hidrocarbonetos para determinar sua viabilidade comercial. O código do PAD corresponde ao nome da acumulação principal da área avaliada. Após a conclusão, o PAD resulta em declaração de comercialidade ou encerramento sem sucesso.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#DiscoveryEvaluationPlan', geocoverage: ['layer5'], sources: ['ANP/SEP — SIGEP']}
  ON MATCH SET n_pad += {id: 'pad', label: 'PAD', label_en: 'Discovery Evaluation Plan', type: 'contractual', definition: 'Instrumento pelo qual o concessionário avalia tecnicamente uma descoberta de hidrocarbonetos para determinar sua viabilidade comercial. O código do PAD corresponde ao nome da acumulação principal da área avaliada. Após a conclusão, o PAD resulta em declaração de comercialidade ou encerramento sem sucesso.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#DiscoveryEvaluationPlan', geocoverage: ['layer5'], sources: ['ANP/SEP — SIGEP']}

MERGE (n_rodada_licitacao:Entity:Contractual {id: 'rodada-licitacao'})
  ON CREATE SET n_rodada_licitacao += {id: 'rodada-licitacao', label: 'Rodada de Licitação', label_en: 'Bid Round', type: 'contractual', definition: 'Ato pelo qual o governo leiloa áreas específicas do seu território para fins de exploração mineral. Identifica em qual rodada o bloco exploratório foi arrematado, permitindo rastrear o histórico de concessões e partilhas no Brasil.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#BiddingRound', geocoverage: ['layer5'], sources: ['Dicionário enciclopédico inglês-português de geofísica e geologia']}
  ON MATCH SET n_rodada_licitacao += {id: 'rodada-licitacao', label: 'Rodada de Licitação', label_en: 'Bid Round', type: 'contractual', definition: 'Ato pelo qual o governo leiloa áreas específicas do seu território para fins de exploração mineral. Identifica em qual rodada o bloco exploratório foi arrematado, permitindo rastrear o histórico de concessões e partilhas no Brasil.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#BiddingRound', geocoverage: ['layer5'], sources: ['Dicionário enciclopédico inglês-português de geofísica e geologia']}

MERGE (n_declaracao_comercialidade:Entity:Contractual {id: 'declaracao-comercialidade'})
  ON CREATE SET n_declaracao_comercialidade += {id: 'declaracao-comercialidade', label: 'Declaração de Comercialidade', label_en: 'Commerciality Declaration', type: 'contractual', definition: 'Declaração formal do concessionário à ANP de que uma descoberta de hidrocarbonetos possui viabilidade econômica para produção. Encerra o PAD com resultado positivo e dá início ao planejamento da área de desenvolvimento.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#CommercialityDeclaration', geocoverage: ['layer5'], sources: ['ANP/SEP — SIGEP']}
  ON MATCH SET n_declaracao_comercialidade += {id: 'declaracao-comercialidade', label: 'Declaração de Comercialidade', label_en: 'Commerciality Declaration', type: 'contractual', definition: 'Declaração formal do concessionário à ANP de que uma descoberta de hidrocarbonetos possui viabilidade econômica para produção. Encerra o PAD com resultado positivo e dá início ao planejamento da área de desenvolvimento.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#CommercialityDeclaration', geocoverage: ['layer5'], sources: ['ANP/SEP — SIGEP']}

MERGE (n_operador:Entity:Actor {id: 'operador'})
  ON CREATE SET n_operador += {id: 'operador', label: 'Operador', label_en: 'Operator', type: 'actor', definition: 'Empresa legalmente designada pelos consorciados para conduzir e executar todas as operações e atividades na área sob contrato, de acordo com o estabelecido no contrato de E&P celebrado entre a contratante e o contratado.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#PetroleumOperator', osdu_kind: 'opendes:osdu:master-data--Organisation:1.0.0', owl_uri: 'https://w3id.org/osdu#Organisation', geocoverage: ['layer3', 'layer4', 'layer5'], sources: ['ANP/SEP']}
  ON MATCH SET n_operador += {id: 'operador', label: 'Operador', label_en: 'Operator', type: 'actor', definition: 'Empresa legalmente designada pelos consorciados para conduzir e executar todas as operações e atividades na área sob contrato, de acordo com o estabelecido no contrato de E&P celebrado entre a contratante e o contratado.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#PetroleumOperator', osdu_kind: 'opendes:osdu:master-data--Organisation:1.0.0', owl_uri: 'https://w3id.org/osdu#Organisation', geocoverage: ['layer3', 'layer4', 'layer5'], sources: ['ANP/SEP']}

MERGE (n_anp:Entity:Actor {id: 'anp'})
  ON CREATE SET n_anp += {id: 'anp', label: 'ANP', label_en: 'ANP (Brazilian Oil & Gas Regulator)', type: 'actor', definition: 'Agência Nacional do Petróleo, Gás Natural e Biocombustíveis. Autarquia federal vinculada ao Ministério de Minas e Energia, responsável pela regulação, contratação e fiscalização das atividades da indústria de petróleo, gás natural e biocombustíveis no Brasil.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#RegulatoryAgency', geocoverage: ['layer5'], sources: ['Lei nº 9478/1997']}
  ON MATCH SET n_anp += {id: 'anp', label: 'ANP', label_en: 'ANP (Brazilian Oil & Gas Regulator)', type: 'actor', definition: 'Agência Nacional do Petróleo, Gás Natural e Biocombustíveis. Autarquia federal vinculada ao Ministério de Minas e Energia, responsável pela regulação, contratação e fiscalização das atividades da indústria de petróleo, gás natural e biocombustíveis no Brasil.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#RegulatoryAgency', geocoverage: ['layer5'], sources: ['Lei nº 9478/1997']}

MERGE (n_sigep:Entity:Instrument {id: 'sigep'})
  ON CREATE SET n_sigep += {id: 'sigep', label: 'SIGEP', label_en: 'SIGEP (E&P Information System)', type: 'instrument', definition: 'Sistema de Informações Gerenciais de Exploração e Produção. Sistema oficial da ANP que concentra e disponibiliza dados sobre poços, PADs, blocos e contratos de exploração e produção de petróleo e gás natural no Brasil.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#InformationSystem', geocoverage: ['layer5'], sources: ['ANP/SEP']}
  ON MATCH SET n_sigep += {id: 'sigep', label: 'SIGEP', label_en: 'SIGEP (E&P Information System)', type: 'instrument', definition: 'Sistema de Informações Gerenciais de Exploração e Produção. Sistema oficial da ANP que concentra e disponibiliza dados sobre poços, PADs, blocos e contratos de exploração e produção de petróleo e gás natural no Brasil.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#InformationSystem', geocoverage: ['layer5'], sources: ['ANP/SEP']}

MERGE (n_sep:Entity:Instrument {id: 'sep'})
  ON CREATE SET n_sep += {id: 'sep', label: 'SEP', label_en: 'SEP (ANP Exploration Office)', type: 'instrument', definition: 'Superintendência de Exploração da ANP. Unidade organizacional responsável pelo gerenciamento e fiscalização das atividades exploratórias de petróleo e gás natural no Brasil, incluindo o acompanhamento de blocos, poços e PADs.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#RegulatoryUnit', geocoverage: ['layer5'], sources: ['ANP']}
  ON MATCH SET n_sep += {id: 'sep', label: 'SEP', label_en: 'SEP (ANP Exploration Office)', type: 'instrument', definition: 'Superintendência de Exploração da ANP. Unidade organizacional responsável pelo gerenciamento e fiscalização das atividades exploratórias de petróleo e gás natural no Brasil, incluindo o acompanhamento de blocos, poços e PADs.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#RegulatoryUnit', geocoverage: ['layer5'], sources: ['ANP']}

MERGE (n_uts:Entity:Instrument {id: 'uts'})
  ON CREATE SET n_uts += {id: 'uts', label: 'UTS', label_en: 'Work Units', type: 'instrument', definition: 'Unidade de conversão para diferentes trabalhos exploratórios, utilizada para fins de aferição da execução do Programa Exploratório Mínimo (PEM) de cada contrato. Permite comparar diferentes tipos de atividades exploratórias — como perfuração de poços, aquisição sísmica e estudos técnicos — em uma unidade comum.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#WorkUnit', geocoverage: ['layer5'], sources: ['ANP/SEP']}
  ON MATCH SET n_uts += {id: 'uts', label: 'UTS', label_en: 'Work Units', type: 'instrument', definition: 'Unidade de conversão para diferentes trabalhos exploratórios, utilizada para fins de aferição da execução do Programa Exploratório Mínimo (PEM) de cada contrato. Permite comparar diferentes tipos de atividades exploratórias — como perfuração de poços, aquisição sísmica e estudos técnicos — em uma unidade comum.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#WorkUnit', geocoverage: ['layer5'], sources: ['ANP/SEP']}

MERGE (n_regime_contratual:Entity:Instrument {id: 'regime-contratual'})
  ON CREATE SET n_regime_contratual += {id: 'regime-contratual', label: 'Regime Contratual', label_en: 'Contract Regime', type: 'instrument', definition: 'Modalidade contratual do bloco exploratório. Concessão: o concessionário assume todos os riscos e detém o petróleo produzido mediante pagamento de tributos. Partilha de produção: o petróleo produzido é dividido entre o contratado e a União, sendo a Petrobras operadora obrigatória nos blocos do pré-sal.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#ContractualRegime', geocoverage: ['layer5'], sources: ['ANP/SEP']}
  ON MATCH SET n_regime_contratual += {id: 'regime-contratual', label: 'Regime Contratual', label_en: 'Contract Regime', type: 'instrument', definition: 'Modalidade contratual do bloco exploratório. Concessão: o concessionário assume todos os riscos e detém o petróleo produzido mediante pagamento de tributos. Partilha de produção: o petróleo produzido é dividido entre o contratado e a União, sendo a Petrobras operadora obrigatória nos blocos do pré-sal.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#ContractualRegime', geocoverage: ['layer5'], sources: ['ANP/SEP']}

MERGE (n_periodo_exploratorio:Entity:Instrument {id: 'periodo-exploratorio'})
  ON CREATE SET n_periodo_exploratorio += {id: 'periodo-exploratorio', label: 'Período Exploratório', label_en: 'Exploratory Period', type: 'instrument', definition: 'Identificação do período exploratório dos blocos sob contrato: 1º, 2º ou 3º período exploratório, período único ou prorrogado por PAD. Cada período tem prazo definido e obrigações exploratórias mínimas que o contratado deve cumprir.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#ExploratoryPeriod', geocoverage: ['layer5'], sources: ['ANP/SEP']}
  ON MATCH SET n_periodo_exploratorio += {id: 'periodo-exploratorio', label: 'Período Exploratório', label_en: 'Exploratory Period', type: 'instrument', definition: 'Identificação do período exploratório dos blocos sob contrato: 1º, 2º ou 3º período exploratório, período único ou prorrogado por PAD. Cada período tem prazo definido e obrigações exploratórias mínimas que o contratado deve cumprir.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#ExploratoryPeriod', geocoverage: ['layer5'], sources: ['ANP/SEP']}

MERGE (n_processo_sancionador:Entity:Instrument {id: 'processo-sancionador'})
  ON CREATE SET n_processo_sancionador += {id: 'processo-sancionador', label: 'Processo Sancionador', label_en: 'Sanctioning Proceeding', type: 'instrument', definition: 'Processo administrativo resultante da consolidação das autuações relativas à exploração de petróleo e gás natural em trâmite na Superintendência de Exploração (SEP). Registra o auto de infração, o motivo da autuação, a multa aplicada e a situação processual.', geocoverage: ['layer5'], sources: ['ANP/SEP']}
  ON MATCH SET n_processo_sancionador += {id: 'processo-sancionador', label: 'Processo Sancionador', label_en: 'Sanctioning Proceeding', type: 'instrument', definition: 'Processo administrativo resultante da consolidação das autuações relativas à exploração de petróleo e gás natural em trâmite na Superintendência de Exploração (SEP). Registra o auto de infração, o motivo da autuação, a multa aplicada e a situação processual.', geocoverage: ['layer5'], sources: ['ANP/SEP']}

MERGE (n_notificacao_descoberta:Entity:Instrument {id: 'notificacao-descoberta'})
  ON CREATE SET n_notificacao_descoberta += {id: 'notificacao-descoberta', label: 'Notificação Descoberta', label_en: 'Discovery Notification', type: 'instrument', definition: 'Registro que identifica se ocorreu ou não indícios de hidrocarbonetos durante a perfuração de um poço exploratório. A data da primeira descoberta registra quando foi notificada à ANP a primeira detecção de hidrocarbonetos no poço.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#DiscoveryNotification', geocoverage: ['layer4', 'layer5'], sources: ['ANP/SEP — SIGEP']}
  ON MATCH SET n_notificacao_descoberta += {id: 'notificacao-descoberta', label: 'Notificação Descoberta', label_en: 'Discovery Notification', type: 'instrument', definition: 'Registro que identifica se ocorreu ou não indícios de hidrocarbonetos durante a perfuração de um poço exploratório. A data da primeira descoberta registra quando foi notificada à ANP a primeira detecção de hidrocarbonetos no poço.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#DiscoveryNotification', geocoverage: ['layer4', 'layer5'], sources: ['ANP/SEP — SIGEP']}

MERGE (n_area_desenvolvimento:Entity:Contractual {id: 'area-desenvolvimento'})
  ON CREATE SET n_area_desenvolvimento += {id: 'area-desenvolvimento', label: 'Área de Desenvolvimento da Produção', label_en: 'Production Development Phase', type: 'contractual', definition: 'Fase intermediária do ciclo de E&P entre a Declaração de Comercialidade e o Primeiro Óleo. Durante essa etapa, o concessionário executa o Plano de Desenvolvimento (PD) aprovado pela ANP: contratação de plataformas, perfuração de poços produtores, instalação de sistemas submarinos e gasodutos. O campo é considerado "em desenvolvimento" enquanto a produção comercial ainda não se iniciou.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#DevelopmentArea', osdu_kind: 'opendes:osdu:master-data--Field:1.0.0', owl_uri: 'https://w3id.org/osdu#Field', geocoverage: ['layer4', 'layer5'], sources: ['Lei nº 9.478/1997; RANP 810/2020']}
  ON MATCH SET n_area_desenvolvimento += {id: 'area-desenvolvimento', label: 'Área de Desenvolvimento da Produção', label_en: 'Production Development Phase', type: 'contractual', definition: 'Fase intermediária do ciclo de E&P entre a Declaração de Comercialidade e o Primeiro Óleo. Durante essa etapa, o concessionário executa o Plano de Desenvolvimento (PD) aprovado pela ANP: contratação de plataformas, perfuração de poços produtores, instalação de sistemas submarinos e gasodutos. O campo é considerado "em desenvolvimento" enquanto a produção comercial ainda não se iniciou.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#DevelopmentArea', osdu_kind: 'opendes:osdu:master-data--Field:1.0.0', owl_uri: 'https://w3id.org/osdu#Field', geocoverage: ['layer4', 'layer5'], sources: ['Lei nº 9.478/1997; RANP 810/2020']}

MERGE (n_plano_desenvolvimento:Entity:Contractual {id: 'plano-desenvolvimento'})
  ON CREATE SET n_plano_desenvolvimento += {id: 'plano-desenvolvimento', label: 'Plano de Desenvolvimento', label_en: 'Development Plan', type: 'contractual', definition: 'Documento técnico-econômico obrigatório que o concessionário deve submeter à ANP após a Declaração de Comercialidade. Detalha o número e tipo de poços a perfurar, sistemas de produção (FPSO, plataforma fixa, etc.), infraestrutura de escoamento, cronograma e estimativa de investimentos. Sua aprovação pela ANP autoriza o início formal da Fase de Desenvolvimento da Produção.', sources: ['RANP 810/2020']}
  ON MATCH SET n_plano_desenvolvimento += {id: 'plano-desenvolvimento', label: 'Plano de Desenvolvimento', label_en: 'Development Plan', type: 'contractual', definition: 'Documento técnico-econômico obrigatório que o concessionário deve submeter à ANP após a Declaração de Comercialidade. Detalha o número e tipo de poços a perfurar, sistemas de produção (FPSO, plataforma fixa, etc.), infraestrutura de escoamento, cronograma e estimativa de investimentos. Sua aprovação pela ANP autoriza o início formal da Fase de Desenvolvimento da Produção.', sources: ['RANP 810/2020']}

MERGE (n_primeiro_oleo:Entity:Operational {id: 'primeiro-oleo'})
  ON CREATE SET n_primeiro_oleo += {id: 'primeiro-oleo', label: 'Primeiro Óleo', label_en: 'First Oil', type: 'operational', definition: 'Marco que sinaliza o início da produção comercial em um campo. Para a ANP, é o evento que encerra formalmente a Fase de Desenvolvimento da Produção e inaugura o Campo de Produção. A partir desse ponto, o operador passa a submeter o Programa Anual de Produção (PAP) e a pagar royalties sobre a produção.', sources: ['ANP/SEP']}
  ON MATCH SET n_primeiro_oleo += {id: 'primeiro-oleo', label: 'Primeiro Óleo', label_en: 'First Oil', type: 'operational', definition: 'Marco que sinaliza o início da produção comercial em um campo. Para a ANP, é o evento que encerra formalmente a Fase de Desenvolvimento da Produção e inaugura o Campo de Produção. A partir desse ponto, o operador passa a submeter o Programa Anual de Produção (PAP) e a pagar royalties sobre a produção.', sources: ['ANP/SEP']}

MERGE (n_presal:Entity:Geological {id: 'presal'})
  ON CREATE SET n_presal += {id: 'presal', label: 'Pré-sal', label_en: 'Pre-salt', type: 'geological', definition: 'Camada geológica localizada abaixo de uma extensa camada de sal no subsolo marítimo e terrestre. Identificar se um poço atingiu o pré-sal é informação estratégica para avaliar o potencial exploratório e enquadrar o regime contratual aplicável.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#PresaltLayer', geocoverage: ['layer1', 'layer2', 'layer3', 'layer5'], sources: ['ANP/SEP']}
  ON MATCH SET n_presal += {id: 'presal', label: 'Pré-sal', label_en: 'Pre-salt', type: 'geological', definition: 'Camada geológica localizada abaixo de uma extensa camada de sal no subsolo marítimo e terrestre. Identificar se um poço atingiu o pré-sal é informação estratégica para avaliar o potencial exploratório e enquadrar o regime contratual aplicável.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#PresaltLayer', geocoverage: ['layer1', 'layer2', 'layer3', 'layer5'], sources: ['ANP/SEP']}

MERGE (n_bacias_agrupadas:Entity:Geological {id: 'bacias-agrupadas'})
  ON CREATE SET n_bacias_agrupadas += {id: 'bacias-agrupadas', label: 'Bacias Agrupadas', label_en: 'Grouped Basins', type: 'geological', definition: 'Agrupamento regional das bacias sedimentares em quatro grupos: Mar — Margem Equatorial (Foz do Amazonas, Pará-Maranhão, Barreirinhas, Ceará, Potiguar marítimo); Mar — Margem Leste (Pernambuco-Paraíba, Sergipe-Alagoas, Jacuípe, Camamu-Almada, Jequitinhonha, Cumuruxatiba, Mucuri, Espírito Santo, Campos, Santos, Pelotas); Terra — Bacias Maduras (Potiguar, Sergipe, Alagoas, Recôncavo, Espírito Santo terrestre); Terra — Bacias de Nova Fronteira (Amazonas, Paraná, Parnaíba, São Francisco, Solimões, Tucano Sul).', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#BasinGroup', osdu_kind: 'opendes:osdu:master-data--Basin:1.0.0', owl_uri: 'https://w3id.org/osdu#Basin', geocoverage: ['layer3', 'layer5'], sources: ['ANP/SEP']}
  ON MATCH SET n_bacias_agrupadas += {id: 'bacias-agrupadas', label: 'Bacias Agrupadas', label_en: 'Grouped Basins', type: 'geological', definition: 'Agrupamento regional das bacias sedimentares em quatro grupos: Mar — Margem Equatorial (Foz do Amazonas, Pará-Maranhão, Barreirinhas, Ceará, Potiguar marítimo); Mar — Margem Leste (Pernambuco-Paraíba, Sergipe-Alagoas, Jacuípe, Camamu-Almada, Jequitinhonha, Cumuruxatiba, Mucuri, Espírito Santo, Campos, Santos, Pelotas); Terra — Bacias Maduras (Potiguar, Sergipe, Alagoas, Recôncavo, Espírito Santo terrestre); Terra — Bacias de Nova Fronteira (Amazonas, Paraná, Parnaíba, São Francisco, Solimões, Tucano Sul).', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#BasinGroup', osdu_kind: 'opendes:osdu:master-data--Basin:1.0.0', owl_uri: 'https://w3id.org/osdu#Basin', geocoverage: ['layer3', 'layer5'], sources: ['ANP/SEP']}

MERGE (n_ambiente:Entity:Geological {id: 'ambiente'})
  ON CREATE SET n_ambiente += {id: 'ambiente', label: 'Ambiente', label_en: 'Environment', type: 'geological', definition: 'Localização por ambiente dos blocos exploratórios sob contrato: terra (onshore) ou mar (offshore). Distingue operações terrestres e marítimas para fins de classificação e monitoramento regulatório.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#OperationalEnvironment', geocoverage: ['layer3', 'layer5'], sources: ['ANP/SEP']}
  ON MATCH SET n_ambiente += {id: 'ambiente', label: 'Ambiente', label_en: 'Environment', type: 'geological', definition: 'Localização por ambiente dos blocos exploratórios sob contrato: terra (onshore) ou mar (offshore). Distingue operações terrestres e marítimas para fins de classificação e monitoramento regulatório.', petrokgraph_uri: 'https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#OperationalEnvironment', geocoverage: ['layer3', 'layer5'], sources: ['ANP/SEP']}

MERGE (n_bop:Entity:Equipment {id: 'bop'})
  ON CREATE SET n_bop += {id: 'bop', label: 'BOP', label_en: 'Blowout Preventer', type: 'equipment', definition: 'Preventor de erupção (Blowout Preventer). Conjunto de válvulas instalado na cabeça do poço durante a perfuração para conter pressão descontrolada e evitar blowout. Equipamento crítico de segurança.', geocoverage: ['layer4'], sources: ['Siglário O&G / API']}
  ON MATCH SET n_bop += {id: 'bop', label: 'BOP', label_en: 'Blowout Preventer', type: 'equipment', definition: 'Preventor de erupção (Blowout Preventer). Conjunto de válvulas instalado na cabeça do poço durante a perfuração para conter pressão descontrolada e evitar blowout. Equipamento crítico de segurança.', geocoverage: ['layer4'], sources: ['Siglário O&G / API']}

MERGE (n_fpso:Entity:Equipment {id: 'fpso'})
  ON CREATE SET n_fpso += {id: 'fpso', label: 'FPSO', label_en: 'Floating Production, Storage and Offloading', type: 'equipment', definition: 'Unidade Flutuante de Produção, Estocagem e Transferência de Óleo. Navio adaptado que processa, armazena e transfere óleo produzido em campos offshore. Padrão dominante em águas profundas no Brasil.', geocoverage: ['layer4'], sources: ['Siglário O&G']}
  ON MATCH SET n_fpso += {id: 'fpso', label: 'FPSO', label_en: 'Floating Production, Storage and Offloading', type: 'equipment', definition: 'Unidade Flutuante de Produção, Estocagem e Transferência de Óleo. Navio adaptado que processa, armazena e transfere óleo produzido em campos offshore. Padrão dominante em águas profundas no Brasil.', geocoverage: ['layer4'], sources: ['Siglário O&G']}

MERGE (n_anm_eq:Entity:Equipment {id: 'anm-eq'})
  ON CREATE SET n_anm_eq += {id: 'anm-eq', label: 'ANM', label_en: 'Wet Christmas Tree (Árvore de Natal Molhada)', type: 'equipment', definition: 'Árvore de Natal Molhada — conjunto de válvulas e equipamentos de controle de fluxo instalado sobre a cabeça de um poço submarino. Permite produção, intervenção e segurança da poço subsea.', geocoverage: ['layer4'], sources: ['Siglário O&G']}
  ON MATCH SET n_anm_eq += {id: 'anm-eq', label: 'ANM', label_en: 'Wet Christmas Tree (Árvore de Natal Molhada)', type: 'equipment', definition: 'Árvore de Natal Molhada — conjunto de válvulas e equipamentos de controle de fluxo instalado sobre a cabeça de um poço submarino. Permite produção, intervenção e segurança da poço subsea.', geocoverage: ['layer4'], sources: ['Siglário O&G']}

MERGE (n_riser:Entity:Equipment {id: 'riser'})
  ON CREATE SET n_riser += {id: 'riser', label: 'Riser', label_en: 'Riser', type: 'equipment', definition: 'Tubulação que conecta o equipamento submarino (poço/ANM) à unidade flutuante de superfície (FPSO/sonda). Pode ser rígido (SCR), flexível ou híbrido (RHAS).', geocoverage: ['layer4'], sources: ['Siglário O&G']}
  ON MATCH SET n_riser += {id: 'riser', label: 'Riser', label_en: 'Riser', type: 'equipment', definition: 'Tubulação que conecta o equipamento submarino (poço/ANM) à unidade flutuante de superfície (FPSO/sonda). Pode ser rígido (SCR), flexível ou híbrido (RHAS).', geocoverage: ['layer4'], sources: ['Siglário O&G']}

MERGE (n_rov:Entity:Equipment {id: 'rov'})
  ON CREATE SET n_rov += {id: 'rov', label: 'ROV', label_en: 'Remotely Operated Vehicle', type: 'equipment', definition: 'Veículo Operado Remotamente. Robô submarino conectado por umbilical ao navio de apoio, usado para inspeção, intervenção e operação de equipamentos no leito marinho.', geocoverage: ['layer4'], sources: ['Siglário O&G']}
  ON MATCH SET n_rov += {id: 'rov', label: 'ROV', label_en: 'Remotely Operated Vehicle', type: 'equipment', definition: 'Veículo Operado Remotamente. Robô submarino conectado por umbilical ao navio de apoio, usado para inspeção, intervenção e operação de equipamentos no leito marinho.', geocoverage: ['layer4'], sources: ['Siglário O&G']}

MERGE (n_dhsv:Entity:Equipment {id: 'dhsv'})
  ON CREATE SET n_dhsv += {id: 'dhsv', label: 'DHSV', label_en: 'Downhole Safety Valve', type: 'equipment', definition: 'Válvula de Segurança de Subsuperfície (Downhole Safety Valve / SSSV / SCSSV). Instalada na coluna de produção dentro do poço; fecha automaticamente em caso de falha catastrófica na superfície.', geocoverage: ['layer4'], sources: ['Siglário O&G']}
  ON MATCH SET n_dhsv += {id: 'dhsv', label: 'DHSV', label_en: 'Downhole Safety Valve', type: 'equipment', definition: 'Válvula de Segurança de Subsuperfície (Downhole Safety Valve / SSSV / SCSSV). Instalada na coluna de produção dentro do poço; fecha automaticamente em caso de falha catastrófica na superfície.', geocoverage: ['layer4'], sources: ['Siglário O&G']}

MERGE (n_bha:Entity:Equipment {id: 'bha'})
  ON CREATE SET n_bha += {id: 'bha', label: 'BHA', label_en: 'Bottom-Hole Assembly', type: 'equipment', definition: 'Composição de Fundo de Poço — porção inferior da coluna de perfuração que inclui broca, comandos, estabilizadores, motor de fundo e ferramentas de medição (MWD/LWD).', geocoverage: ['layer4'], sources: ['Siglário O&G']}
  ON MATCH SET n_bha += {id: 'bha', label: 'BHA', label_en: 'Bottom-Hole Assembly', type: 'equipment', definition: 'Composição de Fundo de Poço — porção inferior da coluna de perfuração que inclui broca, comandos, estabilizadores, motor de fundo e ferramentas de medição (MWD/LWD).', geocoverage: ['layer4'], sources: ['Siglário O&G']}

MERGE (n_esp_eq:Entity:Equipment {id: 'esp-eq'})
  ON CREATE SET n_esp_eq += {id: 'esp-eq', label: 'ESP/BCS', label_en: 'Electrical Submersible Pump', type: 'equipment', definition: 'Bomba Centrífuga Submersa elétrica. Método de elevação artificial em que uma bomba multi-estágio é instalada no fundo do poço para impulsionar fluidos à superfície.', geocoverage: ['layer4'], sources: ['Siglário O&G']}
  ON MATCH SET n_esp_eq += {id: 'esp-eq', label: 'ESP/BCS', label_en: 'Electrical Submersible Pump', type: 'equipment', definition: 'Bomba Centrífuga Submersa elétrica. Método de elevação artificial em que uma bomba multi-estágio é instalada no fundo do poço para impulsionar fluidos à superfície.', geocoverage: ['layer4'], sources: ['Siglário O&G']}

MERGE (n_mwd:Entity:Equipment {id: 'mwd'})
  ON CREATE SET n_mwd += {id: 'mwd', label: 'MWD', label_en: 'Measure While Drilling', type: 'equipment', definition: 'Medição Durante a Perfuração. Conjunto de sensores no BHA que transmitem em tempo real dados direcionais (azimute, inclinação) e parâmetros operacionais durante a perfuração.', geocoverage: ['layer4'], sources: ['Siglário O&G']}
  ON MATCH SET n_mwd += {id: 'mwd', label: 'MWD', label_en: 'Measure While Drilling', type: 'equipment', definition: 'Medição Durante a Perfuração. Conjunto de sensores no BHA que transmitem em tempo real dados direcionais (azimute, inclinação) e parâmetros operacionais durante a perfuração.', geocoverage: ['layer4'], sources: ['Siglário O&G']}

MERGE (n_lwd:Entity:Equipment {id: 'lwd'})
  ON CREATE SET n_lwd += {id: 'lwd', label: 'LWD', label_en: 'Logging While Drilling', type: 'equipment', definition: 'Perfilagem Durante a Perfuração. Sensores petrofísicos (raio gama, resistividade, densidade, neutron) integrados ao BHA que registram propriedades da formação enquanto se perfura.', geocoverage: ['layer4'], sources: ['Siglário O&G']}
  ON MATCH SET n_lwd += {id: 'lwd', label: 'LWD', label_en: 'Logging While Drilling', type: 'equipment', definition: 'Perfilagem Durante a Perfuração. Sensores petrofísicos (raio gama, resistividade, densidade, neutron) integrados ao BHA que registram propriedades da formação enquanto se perfura.', geocoverage: ['layer4'], sources: ['Siglário O&G']}

MERGE (n_manifold_submarino:Entity:Equipment {id: 'manifold-submarino'})
  ON CREATE SET n_manifold_submarino += {id: 'manifold-submarino', label: 'Manifold Submarino', label_en: 'Subsea Manifold', type: 'equipment', definition: 'Equipamento submarino de coleta/distribuição que agrega o fluxo de múltiplos poços para uma única linha que vai até a UEP, ou distribui injeção entre poços.', geocoverage: ['layer4'], sources: ['Siglário O&G']}
  ON MATCH SET n_manifold_submarino += {id: 'manifold-submarino', label: 'Manifold Submarino', label_en: 'Subsea Manifold', type: 'equipment', definition: 'Equipamento submarino de coleta/distribuição que agrega o fluxo de múltiplos poços para uma única linha que vai até a UEP, ou distribui injeção entre poços.', geocoverage: ['layer4'], sources: ['Siglário O&G']}

MERGE (n_ibama:Entity:Actor {id: 'ibama'})
  ON CREATE SET n_ibama += {id: 'ibama', label: 'IBAMA', label_en: 'Brazilian Institute of Environment', type: 'actor', definition: 'Instituto Brasileiro do Meio Ambiente e dos Recursos Naturais Renováveis. Autarquia federal responsável pelo licenciamento ambiental de atividades de E&P offshore — atua em paralelo com a ANP no aspecto ambiental.', geocoverage: ['layer5'], sources: ['Siglário O&G / Lei 7.735/1989']}
  ON MATCH SET n_ibama += {id: 'ibama', label: 'IBAMA', label_en: 'Brazilian Institute of Environment', type: 'actor', definition: 'Instituto Brasileiro do Meio Ambiente e dos Recursos Naturais Renováveis. Autarquia federal responsável pelo licenciamento ambiental de atividades de E&P offshore — atua em paralelo com a ANP no aspecto ambiental.', geocoverage: ['layer5'], sources: ['Siglário O&G / Lei 7.735/1989']}

MERGE (n_conama:Entity:Actor {id: 'conama'})
  ON CREATE SET n_conama += {id: 'conama', label: 'CONAMA', label_en: 'National Environmental Council', type: 'actor', definition: 'Conselho Nacional do Meio Ambiente. Órgão consultivo e deliberativo do SISNAMA que estabelece normas e padrões ambientais aplicáveis à indústria de petróleo.', geocoverage: ['layer5'], sources: ['Siglário O&G / Lei 6.938/1981']}
  ON MATCH SET n_conama += {id: 'conama', label: 'CONAMA', label_en: 'National Environmental Council', type: 'actor', definition: 'Conselho Nacional do Meio Ambiente. Órgão consultivo e deliberativo do SISNAMA que estabelece normas e padrões ambientais aplicáveis à indústria de petróleo.', geocoverage: ['layer5'], sources: ['Siglário O&G / Lei 6.938/1981']}

MERGE (n_ana_agencia:Entity:Actor {id: 'ana-agencia'})
  ON CREATE SET n_ana_agencia += {id: 'ana-agencia', label: 'ANA', label_en: 'National Water Agency', type: 'actor', definition: 'Agência Nacional de Águas e Saneamento Básico. Regula o uso de recursos hídricos em operações onshore (descarte, captação, água produzida).', geocoverage: ['layer5'], sources: ['Siglário O&G']}
  ON MATCH SET n_ana_agencia += {id: 'ana-agencia', label: 'ANA', label_en: 'National Water Agency', type: 'actor', definition: 'Agência Nacional de Águas e Saneamento Básico. Regula o uso de recursos hídricos em operações onshore (descarte, captação, água produzida).', geocoverage: ['layer5'], sources: ['Siglário O&G']}

