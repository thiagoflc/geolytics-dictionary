  ON CREATE SET n_gso_Magnetization_Contact += {id: 'gso_Magnetization_Contact', gso_class: 'Magnetization_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Magnetization_Contact', pref_label_en: 'magnetization contact', definition_en_canonical: 'A magnetic contact between bodies of material distinguished based on any aspect of magnetization of material in the units.', parents: ['gscn:Magnetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}
