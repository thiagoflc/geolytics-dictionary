  ON CREATE SET n_gso_augen_lineation += {id: 'gso_augen_lineation', gso_class: 'augen_lineation', owl_uri: 'https://w3id.org/gso/1.0/geologiclineation/augen_lineation', pref_label_en: 'augen lineation', definition_en_canonical: 'A shape lineation defined by elongate augen.', parents: ['gsol:particle_shape_lineation', 'gsol:tectonic_lineation'], sources: ['CGI lineationtype SKOS vocabulary 2016-11-21'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-lineations'}
