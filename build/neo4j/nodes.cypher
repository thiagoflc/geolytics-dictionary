  ON MATCH SET n_gso_Magnetic_Susceptiblity_Contact += {id: 'gso_Magnetic_Susceptiblity_Contact', gso_class: 'Magnetic_Susceptiblity_Contact', owl_uri: 'https://w3id.org/gso/1.0/geologiccontact/Magnetic_Susceptiblity_Contact', pref_label_en: 'magnetic susceptiblity contact', definition_en_canonical: 'A magnetic contact between bodies of material distinguished based on magnetic susceptibility characteristics.', parents: ['gscn:Magnetic_Contact'], sources: ['CGI contacttype SKOS vocabulary 2012-11-24'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-contacts'}

