MERGE (n_gso_No_Movement_Sense:GSOClass {id: 'gso_No_Movement_Sense'})
  ON CREATE SET n_gso_No_Movement_Sense += {id: 'gso_No_Movement_Sense', gso_class: 'No_Movement_Sense', owl_uri: 'https://w3id.org/gso/1.0/geologicfault/No_Movement_Sense', pref_label_en: 'no movement sense', definition_en_canonical: 'The fault-parallel displacement is effectively zero, as in an extraction fault.', parents: ['gsfa:Fault_Movement_Sense'], sources: ['Froitzheim, N., Pleuger, J. & Nagel, T.J., 2006. Extraction faults. Journal of Structural Geology v28, pp. 1388-1395.'], attribution: 'GSO v1.0 (Brodaric & Richard 2021), GSC OF 8796, CC BY 4.0, DOI 10.4095/328296', gso_module: 'gso-faults'}
