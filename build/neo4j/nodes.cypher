MERGE (n_log_curve_type:Entity:Instrument {id: 'log-curve-type'})
  ON CREATE SET n_log_curve_type += {id: 'log-curve-type', label: 'Tipo de Curva de Perfil', label_en: 'Log Curve Type', type: 'instrument', definition: 'Mnemônico padrão escolhido pela companhia para curvas de perfilagem — OSDU disponibiliza uma lista inicial (ex.: GR, RHOB, NPHI, DTC). (OSDU canonical: LogCurveType is the standard mnemonic chosen by the company - OSDU provides an initial list.)', osdu_kind: 'opendes:osdu:reference-data--LogCurveType:1.0.0', geocoverage: ['layer4'], sources: ['Accenture/OSDU OWL']}
