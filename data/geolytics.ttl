#
# Edges (instance-level relation triples)
#

geo:poco geo:drilled_in geo:bloco .
geo:poco geo:located_in geo:bacia-sedimentar .
geo:poco geo:operated_by geo:operador .
geo:poco geo:may_register geo:notificacao-descoberta .
geo:poco geo:may_reach geo:presal .
geo:poco geo:traverses geo:formacao .
geo:bloco geo:delimited_in geo:bacia-sedimentar .
geo:bloco geo:governed_by geo:contrato-ep .
geo:bloco geo:operated_by geo:operador .
geo:bloco geo:may_have geo:pad .
geo:bloco geo:originated_in geo:rodada-licitacao .
geo:contrato-ep geo:signed_with geo:anp .
geo:contrato-ep geo:defines geo:regime-contratual .
geo:contrato-ep geo:organized_in geo:periodo-exploratorio .
geo:contrato-ep geo:measured_via geo:uts .
geo:pad geo:evaluates geo:bloco .
geo:pad geo:may_yield geo:declaracao-comercialidade .
geo:declaracao-comercialidade geo:originates geo:campo .
geo:campo geo:located_in geo:bacia-sedimentar .
geo:campo geo:sustained_by geo:reservatorio .
geo:reservatorio geo:contained_in geo:bacia-sedimentar .
geo:reservatorio geo:characterized_by geo:sistema-deposicional .
geo:reservatorio geo:hosted_in geo:formacao .
geo:operador geo:may_have geo:processo-sancionador .
geo:anp geo:manages_via geo:sigep .
geo:anp geo:oversees_via geo:sep .
geo:bop geo:installed_on geo:poco .
geo:dhsv geo:installed_in geo:poco .
geo:anm-eq geo:controls geo:poco .
geo:bha geo:composes geo:poco .
geo:esp-eq geo:lifts_from geo:poco .
geo:mwd geo:measures geo:poco .
geo:lwd geo:logs geo:poco .
geo:fpso geo:produces_at geo:campo .
geo:riser geo:connects geo:anm-eq .
