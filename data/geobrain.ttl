geo:anp a owl:Class ;
    skos:prefLabel "ANP"@pt ;
    skos:prefLabel "ANP (Brazilian Oil & Gas Regulator)"@en ;
    geo:entityType "actor" ;
    skos:definition """Agência Nacional do Petróleo, Gás Natural e Biocombustíveis. Autarquia federal vinculada ao Ministério de Minas e Energia, responsável pela regulação, contratação e fiscalização das atividades da indústria de petróleo, gás natural e biocombustíveis no Brasil."""@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#RegulatoryAgency> ;
    geo:geocoverage "layer5" .

geo:sigep a owl:Class ;
    skos:prefLabel "SIGEP"@pt ;
    skos:prefLabel "SIGEP (E&P Information System)"@en ;
    geo:entityType "instrument" ;
    skos:definition """Sistema de Informações Gerenciais de Exploração e Produção. Sistema oficial da ANP que concentra e disponibiliza dados sobre poços, PADs, blocos e contratos de exploração e produção de petróleo e gás natural no Brasil."""@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#InformationSystem> ;
    geo:geocoverage "layer5" .

geo:sep a owl:Class ;
    skos:prefLabel "SEP"@pt ;
    skos:prefLabel "SEP (ANP Exploration Office)"@en ;
    geo:entityType "instrument" ;
    skos:definition """Superintendência de Exploração da ANP. Unidade organizacional responsável pelo gerenciamento e fiscalização das atividades exploratórias de petróleo e gás natural no Brasil, incluindo o acompanhamento de blocos, poços e PADs."""@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#RegulatoryUnit> ;
    geo:geocoverage "layer5" .

geo:uts a owl:Class ;
    skos:prefLabel "UTS"@pt ;
    skos:prefLabel "Work Units"@en ;
    geo:entityType "instrument" ;
    skos:definition """Unidade de conversão para diferentes trabalhos exploratórios, utilizada para fins de aferição da execução do Programa Exploratório Mínimo (PEM) de cada contrato. Permite comparar diferentes tipos de atividades exploratórias — como perfuração de poços, aquisição sísmica e estudos técnicos — em uma unidade comum."""@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#WorkUnit> ;
    geo:geocoverage "layer5" .

geo:regime-contratual a owl:Class ;
    skos:prefLabel "Regime Contratual"@pt ;
    skos:prefLabel "Contract Regime"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "regime"@pt ;
    skos:altLabel "modalidade contratual"@pt ;
    skos:altLabel "regime de exploração"@pt ;
    skos:altLabel "contract regime"@en ;
    skos:altLabel "contract model"@en ;
    skos:altLabel "fiscal regime"@en ;
    skos:definition """Modalidade contratual do bloco exploratório. Concessão: o concessionário assume todos os riscos e detém o petróleo produzido mediante pagamento de tributos. Partilha de produção: o petróleo produzido é dividido entre o contratado e a União, sendo a Petrobras operadora obrigatória nos blocos do pré-sal."""@pt ;
    skos:example "Concessão (Lei 9.478/1997)" ;
    skos:example "Partilha de Produção (Lei 12.351/2010)" ;
    skos:example "Cessão Onerosa" ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#ContractualRegime> ;
    geo:geocoverage "layer5" .

geo:periodo-exploratorio a owl:Class ;
    skos:prefLabel "Período Exploratório"@pt ;
    skos:prefLabel "Exploratory Period"@en ;
    geo:entityType "instrument" ;
    skos:definition """Identificação do período exploratório dos blocos sob contrato: 1º, 2º ou 3º período exploratório, período único ou prorrogado por PAD. Cada período tem prazo definido e obrigações exploratórias mínimas que o contratado deve cumprir."""@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#ExploratoryPeriod> ;
    geo:geocoverage "layer5" .

geo:processo-sancionador a owl:Class ;
    skos:prefLabel "Processo Sancionador"@pt ;
    skos:prefLabel "Sanctioning Proceeding"@en ;
    geo:entityType "instrument" ;
    skos:definition """Processo administrativo resultante da consolidação das autuações relativas à exploração de petróleo e gás natural em trâmite na Superintendência de Exploração (SEP). Registra o auto de infração, o motivo da autuação, a multa aplicada e a situação processual."""@pt ;
    geo:geocoverage "layer5" .

geo:notificacao-descoberta a owl:Class ;
    skos:prefLabel "Notificação Descoberta"@pt ;
    skos:prefLabel "Discovery Notification"@en ;
    geo:entityType "instrument" ;
    skos:definition """Registro que identifica se ocorreu ou não indícios de hidrocarbonetos durante a perfuração de um poço exploratório. A data da primeira descoberta registra quando foi notificada à ANP a primeira detecção de hidrocarbonetos no poço."""@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#DiscoveryNotification> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer5" .

geo:area-desenvolvimento a owl:Class ;
    skos:prefLabel "Área de Desenvolvimento da Produção"@pt ;
    skos:prefLabel "Production Development Phase"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "área de desenvolvimento"@pt ;
    skos:altLabel "campo"@pt ;
    skos:altLabel "development area"@en ;
    skos:altLabel "field"@en ;
    skos:altLabel "producing field"@en ;
    skos:definition """Fase intermediária do ciclo de E&P entre a Declaração de Comercialidade e o Primeiro Óleo. Durante essa etapa, o concessionário executa o Plano de Desenvolvimento (PD) aprovado pela ANP: contratação de plataformas, perfuração de poços produtores, instalação de sistemas submarinos e gasodutos. O campo é considerado "em desenvolvimento" enquanto a produção comercial ainda não se iniciou."""@pt ;
    skos:example "Tupi" ;
    skos:example "Búzios" ;
    skos:example "Mero" ;
    skos:example "Sapinhoá" ;
    skos:example "Lula" ;
    skos:example "Sépia" ;
    skos:example "Atapu" ;
    owl:sameAs <https://w3id.org/osdu#Field> ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#DevelopmentArea> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer5" .

geo:plano-desenvolvimento a owl:Class ;
    skos:prefLabel "Plano de Desenvolvimento"@pt ;
    skos:prefLabel "Development Plan"@en ;
    geo:entityType "contractual" ;
    skos:definition """Documento técnico-econômico obrigatório entregue pelo concessionário à ANP em até 180 dias após a Declaração de Comercialidade. Agrupa informações técnicas, operacionais, econômicas e ambientais da explotação do campo, incluindo abandono. A ANP analisa o PD em até 180 dias; se solicitar modificações, o contratado tem 60 dias para apresentar o PD modificado. Após aprovação, o PD passa a vincular a atuação do concessionário. Em casos de jazidas compartilhadas, deve ser acompanhado do AIP ou do CIP."""@pt .

geo:aip a owl:Class ;
    skos:prefLabel "AIP"@pt ;
    skos:prefLabel "Production Individualization Agreement"@en ;
    geo:entityType "contractual" ;
    skos:definition """Acordo celebrado entre concessionários de blocos distintos que compartilham a mesma jazida de hidrocarbonetos, estabelecendo os termos para a produção individualizada de cada parte. Deve ser submetido à ANP juntamente com o Plano de Desenvolvimento quando houver descoberta em jazida compartilhada. Em situações em que o AIP ainda não está concluído, o CIP pode ser apresentado em substituição provisória."""@pt .

geo:cip a owl:Class ;
    skos:prefLabel "CIP"@pt ;
    skos:prefLabel "Production Individualization Commitment"@en ;
    geo:entityType "contractual" ;
    skos:definition """Instrumento provisório apresentado pelos concessionários à ANP quando o Acordo de Individualização da Produção (AIP) ainda não foi concluído, comprometendo-se a celebrá-lo em prazo definido. Acompanha o Plano de Desenvolvimento em casos de jazida compartilhada nos quais o AIP definitivo não está disponível."""@pt .

geo:primeiro-oleo a owl:Class ;
    skos:prefLabel "Primeiro Óleo"@pt ;
    skos:prefLabel "First Oil"@en ;
    geo:entityType "operational" ;
    skos:definition """Marco que sinaliza o início da produção comercial em um campo. Para a ANP, é o evento que encerra formalmente a Fase de Desenvolvimento da Produção e inaugura o Campo de Produção. A partir desse ponto, o operador passa a submeter o Programa Anual de Produção (PAP) e a pagar royalties sobre a produção."""@pt .

geo:teste-formacao a owl:Class ;
    skos:prefLabel "Teste de Formação"@pt ;
    skos:prefLabel "Formation Test (TF/TFR/TFRE)"@en ;
    geo:entityType "contractual" ;
    skos:definition """Teste realizado por tubulação com fluxo em superfície para avaliação do reservatório e coleta de amostras de fluido. Abrange os tipos: TIF (identificação de fluidos), TF (poço aberto), TFS (seletivo a poço aberto), TFR (poço revestido) e TFRE (TFR estendido > 72 h). Não exige autorização prévia da ANP, exceto quando realizado no âmbito de PAD ou PD ainda não aprovado. Exige envio do RFTP via DPP em até 60 dias após conclusão. Durante a execução, o operador reporta diariamente via SOP no i-Engine."""@pt .

geo:tld a owl:Class ;
    skos:prefLabel "TLD"@pt ;
    skos:prefLabel "Extended Well Test (EWT)"@en ;
    geo:entityType "contractual" ;
    skos:definition """Teste de Longa Duração. Realizado dentro de um PAD, com duração total superior a 72 horas de fluxo. Exige autorização prévia específica da ANP, mesmo em PAD aprovado. Sujeito ao pagamento de royalties e participações governamentais. Requer aprovação do sistema de medição fiscal e destino da produção. Documentação obrigatória: TLDI (em até 1 dia após abertura do poço), TLDS (semanal) e TLDF (em até 7 dias após conclusão), todos enviados via i-Engine; além do BMP mensal e RFTP. Internacionalmente corresponde ao Extended Well Test (EWT)."""@pt .

geo:rftp a owl:Class ;
    skos:prefLabel "RFTP"@pt ;
    skos:prefLabel "Well Test Final Report"@en ;
    geo:entityType "instrument" ;
    skos:definition """Relatório Final de Teste de Poço. Documento obrigatório enviado à ANP via DPP em até 60 dias após a conclusão de qualquer teste de formação (TIF, TF, TFS, TFR, TFRE, TLD). Contém: relatório operacional (sequência de eventos), planilhas de medições de superfície, relatório de estimulação, esquema de coluna de teste e dados de registradores de fundo."""@pt .

geo:i-engine a owl:Class ;
    skos:prefLabel "i-Engine"@pt ;
    skos:prefLabel "ANP i-Engine System"@en ;
    geo:entityType "instrument" ;
    skos:definition """Sistema de webservices da ANP para envio e recebimento de dados técnicos de E&P. Utilizado para: SOP (Situação Operacional de Poços) durante testes de formação, TLDI/TLDS/TLDF durante TLD e BMP mensal na fase de produção. Utiliza formato XML padronizado com tags semânticas para amostra, fase e componente conforme Resolução ANP nº 880/2022."""@pt .

geo:dpp a owl:Class ;
    skos:prefLabel "DPP"@pt ;
    skos:prefLabel "ANP Data Portal (DPP)"@en ;
    geo:entityType "instrument" ;
    skos:definition """Portal de Dados e Projetos da ANP. Sistema utilizado para envio do RFTP e respectivos anexos após a conclusão de testes de formação e TLD. Complementa o i-Engine no fluxo regulatório de entrega de dados técnicos de poço."""@pt .

geo:bmp a owl:Class ;
    skos:prefLabel "BMP"@pt ;
    skos:prefLabel "Monthly Production Report"@en ;
    geo:entityType "instrument" ;
    skos:definition """Boletim Mensal de Produção. Documento enviado mensalmente à ANP via i-Engine durante a realização de TLD e na fase de produção regular do campo. Informa volumes de óleo, gás e outros fluidos produzidos para efeito de cálculo de royalties e participações governamentais."""@pt .

geo:presal a owl:Class ;
    skos:prefLabel "Pré-sal"@pt ;
    skos:prefLabel "Pre-salt"@en ;
    geo:entityType "geological" ;
    skos:altLabel "pré-sal"@pt ;
    skos:altLabel "camada do pré-sal"@pt ;
    skos:altLabel "reservatórios do pré-sal"@pt ;
    skos:altLabel "pre-salt"@en ;
    skos:altLabel "sub-salt"@en ;
    skos:altLabel "subsalt"@en ;
    skos:definition """Camada geológica localizada abaixo de uma extensa camada de sal no subsolo marítimo e terrestre. Identificar se um poço atingiu o pré-sal é informação estratégica para avaliar o potencial exploratório e enquadrar o regime contratual aplicável."""@pt ;
    skos:example "Reservatórios de Tupi" ;
    skos:example "Reservatórios de Búzios" ;
    skos:example "Polígono do Pré-sal (Lei 12.351/2010)" ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#PresaltLayer> ;
    skos:relatedMatch <http://sweetontology.net/realmGeol/GeologicFeature> ;
    skos:relatedMatch <http://sweetontology.net/matrRockSedimentary/SaltRock> ;
    geo:geocoverage "layer1" ;
    geo:geocoverage "layer2" ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer5" .

geo:bacias-agrupadas a owl:Class ;
    skos:prefLabel "Bacias Agrupadas"@pt ;
    skos:prefLabel "Grouped Basins"@en ;
    geo:entityType "geological" ;
    skos:definition """Agrupamento regional das bacias sedimentares em quatro grupos: Mar — Margem Equatorial (Foz do Amazonas, Pará-Maranhão, Barreirinhas, Ceará, Potiguar marítimo); Mar — Margem Leste (Pernambuco-Paraíba, Sergipe-Alagoas, Jacuípe, Camamu-Almada, Jequitinhonha, Cumuruxatiba, Mucuri, Espírito Santo, Campos, Santos, Pelotas); Terra — Bacias Maduras (Potiguar, Sergipe, Alagoas, Recôncavo, Espírito Santo terrestre); Terra — Bacias de Nova Fronteira (Amazonas, Paraná, Parnaíba, São Francisco, Solimões, Tucano Sul)."""@pt ;
    owl:sameAs <https://w3id.org/osdu#Basin> ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#BasinGroup> ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer5" .

geo:ambiente a owl:Class ;
    skos:prefLabel "Ambiente"@pt ;
    skos:prefLabel "Environment"@en ;
    geo:entityType "geological" ;
    skos:definition """Localização por ambiente dos blocos exploratórios sob contrato: terra (onshore) ou mar (offshore). Distingue operações terrestres e marítimas para fins de classificação e monitoramento regulatório."""@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#OperationalEnvironment> ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer5" .

geo:bop a owl:Class ;
    skos:prefLabel "BOP"@pt ;
    skos:prefLabel "Blowout Preventer"@en ;
    geo:entityType "equipment" ;
    skos:definition """Preventor de erupção (Blowout Preventer). Conjunto de válvulas instalado na cabeça do poço durante a perfuração para conter pressão descontrolada e evitar blowout. Equipamento crítico de segurança."""@pt ;
    geo:geocoverage "layer4" .

geo:fpso a owl:Class ;
    skos:prefLabel "FPSO"@pt ;
    skos:prefLabel "Floating Production, Storage and Offloading"@en ;
    geo:entityType "equipment" ;
    skos:definition """Unidade Flutuante de Produção, Estocagem e Transferência de Óleo. Navio adaptado que processa, armazena e transfere óleo produzido em campos offshore. Padrão dominante em águas profundas no Brasil."""@pt ;
    geo:geocoverage "layer4" .

geo:anm-eq a owl:Class ;
    skos:prefLabel "ANM"@pt ;
    skos:prefLabel "Wet Christmas Tree (Árvore de Natal Molhada)"@en ;
    geo:entityType "equipment" ;
    skos:definition """Árvore de Natal Molhada — conjunto de válvulas e equipamentos de controle de fluxo instalado sobre a cabeça de um poço submarino. Permite produção, intervenção e segurança da poço subsea."""@pt ;
    geo:geocoverage "layer4" .

geo:riser a owl:Class ;
    skos:prefLabel "Riser"@pt ;
    skos:prefLabel "Riser"@en ;
    geo:entityType "equipment" ;
    skos:definition """Tubulação que conecta o equipamento submarino (poço/ANM) à unidade flutuante de superfície (FPSO/sonda). Pode ser rígido (SCR), flexível ou híbrido (RHAS)."""@pt ;
    geo:geocoverage "layer4" .

geo:rov a owl:Class ;
    skos:prefLabel "ROV"@pt ;
    skos:prefLabel "Remotely Operated Vehicle"@en ;
    geo:entityType "equipment" ;
    skos:definition """Veículo Operado Remotamente. Robô submarino conectado por umbilical ao navio de apoio, usado para inspeção, intervenção e operação de equipamentos no leito marinho."""@pt ;
    geo:geocoverage "layer4" .

geo:dhsv a owl:Class ;
    skos:prefLabel "DHSV"@pt ;
    skos:prefLabel "Downhole Safety Valve"@en ;
    geo:entityType "equipment" ;
    skos:altLabel "válvula de segurança de subsuperfície"@pt ;
    skos:altLabel "SSSV"@pt ;
    skos:altLabel "SCSSV"@pt ;
    skos:altLabel "downhole safety valve"@en ;
    skos:altLabel "subsurface safety valve"@en ;
    skos:altLabel "surface-controlled subsurface safety valve"@en ;
    skos:altLabel "SSSV"@en ;
    skos:altLabel "SCSSV"@en ;
    skos:definition """Válvula de Segurança de Subsuperfície (Downhole Safety Valve / SSSV / SCSSV). Instalada na coluna de produção dentro do poço; fecha automaticamente em caso de falha catastrófica na superfície."""@pt ;
    skos:example "DHSV fecha automaticamente quando a pressão de controle hidráulico cai" ;
    skos:example "Fechamento espúrio da DHSV (classe 2 do 3W) causa queda de P-PDG" ;
    owl:sameAs <https://w3id.org/osdu#EquipmentType> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:bha a owl:Class ;
    skos:prefLabel "BHA"@pt ;
    skos:prefLabel "Bottom-Hole Assembly"@en ;
    geo:entityType "equipment" ;
    skos:definition """Composição de Fundo de Poço — porção inferior da coluna de perfuração que inclui broca, comandos, estabilizadores, motor de fundo e ferramentas de medição (MWD/LWD)."""@pt ;
    geo:geocoverage "layer4" .

geo:esp-eq a owl:Class ;
    skos:prefLabel "ESP/BCS"@pt ;
    skos:prefLabel "Electrical Submersible Pump"@en ;
    geo:entityType "equipment" ;
    skos:definition """Bomba Centrífuga Submersa elétrica. Método de elevação artificial em que uma bomba multi-estágio é instalada no fundo do poço para impulsionar fluidos à superfície."""@pt ;
    geo:geocoverage "layer4" .

geo:mwd a owl:Class ;
    skos:prefLabel "MWD"@pt ;
    skos:prefLabel "Measure While Drilling"@en ;
    geo:entityType "equipment" ;
    skos:definition """Medição Durante a Perfuração. Conjunto de sensores no BHA que transmitem em tempo real dados direcionais (azimute, inclinação) e parâmetros operacionais durante a perfuração."""@pt ;
    geo:geocoverage "layer4" .

geo:lwd a owl:Class ;
    skos:prefLabel "LWD"@pt ;
    skos:prefLabel "Logging While Drilling"@en ;
    geo:entityType "equipment" ;
    skos:definition """Perfilagem Durante a Perfuração. Sensores petrofísicos (raio gama, resistividade, densidade, neutron) integrados ao BHA que registram propriedades da formação enquanto se perfura."""@pt ;
    geo:geocoverage "layer4" .

geo:manifold-submarino a owl:Class ;
    skos:prefLabel "Manifold Submarino"@pt ;
    skos:prefLabel "Subsea Manifold"@en ;
    geo:entityType "equipment" ;
    skos:definition """Equipamento submarino de coleta/distribuição que agrega o fluxo de múltiplos poços para uma única linha que vai até a UEP, ou distribui injeção entre poços."""@pt ;
    geo:geocoverage "layer4" .

geo:ibama a owl:Class ;
    skos:prefLabel "IBAMA"@pt ;
    skos:prefLabel "Brazilian Institute of Environment"@en ;
    geo:entityType "actor" ;
    skos:definition """Instituto Brasileiro do Meio Ambiente e dos Recursos Naturais Renováveis. Autarquia federal responsável pelo licenciamento ambiental de atividades de E&P offshore — atua em paralelo com a ANP no aspecto ambiental."""@pt ;
    geo:geocoverage "layer5" .

geo:conama a owl:Class ;
    skos:prefLabel "CONAMA"@pt ;
    skos:prefLabel "National Environmental Council"@en ;
    geo:entityType "actor" ;
    skos:definition """Conselho Nacional do Meio Ambiente. Órgão consultivo e deliberativo do SISNAMA que estabelece normas e padrões ambientais aplicáveis à indústria de petróleo."""@pt ;
    geo:geocoverage "layer5" .

geo:ana-agencia a owl:Class ;
    skos:prefLabel "ANA"@pt ;
    skos:prefLabel "National Water Agency"@en ;
    geo:entityType "actor" ;
    skos:definition """Agência Nacional de Águas e Saneamento Básico. Regula o uso de recursos hídricos em operações onshore (descarte, captação, água produzida)."""@pt ;
    geo:geocoverage "layer5" .

geo:ibp a owl:Class ;
    skos:prefLabel "IBP"@pt ;
    skos:prefLabel "Brazilian Petroleum Institute"@en ;
    geo:entityType "actor" ;
    skos:definition """Instituto Brasileiro de Petróleo, Gás e Biocombustíveis. Associação de classe que representa operadoras e fornecedores; promove normas técnicas e diálogo regulatório."""@pt ;
    geo:geocoverage "layer5" .

geo:bndes a owl:Class ;
    skos:prefLabel "BNDES"@pt ;
    skos:prefLabel "National Development Bank"@en ;
    geo:entityType "actor" ;
    skos:definition """Banco Nacional de Desenvolvimento Econômico e Social. Financia projetos de E&P (FINEM, debêntures), conteúdo local e desenvolvimento da cadeia de fornecedores."""@pt ;
    geo:geocoverage "layer5" .

geo:eia a owl:Class ;
    skos:prefLabel "EIA"@pt ;
    skos:prefLabel "Environmental Impact Study"@en ;
    geo:entityType "instrument" ;
    skos:definition """Estudo de Impacto Ambiental. Documento técnico exigido pelo IBAMA para licenciamento de atividades com potencial degradador (perfuração offshore, sísmica, produção)."""@pt ;
    geo:geocoverage "layer5" .

geo:rima a owl:Class ;
    skos:prefLabel "RIMA"@pt ;
    skos:prefLabel "Environmental Impact Report"@en ;
    geo:entityType "instrument" ;
    skos:definition """Relatório de Impacto Ambiental. Síntese técnica do EIA em linguagem acessível, destinada à consulta pública no processo de licenciamento."""@pt ;
    geo:geocoverage "layer5" .

geo:afe a owl:Class ;
    skos:prefLabel "AFE"@pt ;
    skos:prefLabel "Approval for Expenditure"@en ;
    geo:entityType "instrument" ;
    skos:definition """Approval for Expenditure (Aprovação de Gastos / Autorização de Dispêndio). Mecanismo formal de aprovação prévia de gasto entre operadores e parceiros do consórcio antes de comprometer capital em poço ou instalação."""@pt ;
    geo:geocoverage "layer5" .

geo:joa a owl:Class ;
    skos:prefLabel "JOA"@pt ;
    skos:prefLabel "Joint Operating Agreement"@en ;
    geo:entityType "instrument" ;
    skos:definition """Joint Operating Agreement (Acordo de Operações Conjuntas). Acordo entre os consorciados de um Contrato de E&P que rege governança, votação, distribuição de custos e operação cotidiana do bloco."""@pt ;
    geo:geocoverage "layer5" .

geo:epc a owl:Class ;
    skos:prefLabel "EPC"@pt ;
    skos:prefLabel "Engineering, Procurement, Construction"@en ;
    geo:entityType "instrument" ;
    skos:definition """Engineering, Procurement and Construction (Engenharia, Suprimento, Construção e Montagem). Modalidade contratual em que um único contratado executa engenharia, compra de materiais e construção de uma instalação (FPSO, plataforma, gasoduto)."""@pt ;
    geo:geocoverage "layer5" .

geo:rocha-geradora a owl:Class ;
    skos:prefLabel "Rocha Geradora"@pt ;
    skos:prefLabel "Source Rock"@en ;
    geo:entityType "geological" ;
    skos:definition """Rocha rica em matéria orgânica (COT > 1%) capaz de gerar HC quando submetida à temperatura adequada. Equivale a C005 em ontopetro."""@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#SourceRock> ;
    geo:geocoverage "layer1" ;
    geo:geocoverage "layer2" ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer6" .

geo:rocha-capacitante a owl:Class ;
    skos:prefLabel "Rocha Capacitante"@pt ;
    skos:prefLabel "Cap Rock"@en ;
    geo:entityType "geological" ;
    skos:definition """Rocha de baixa permeabilidade que sela o reservatório, impedindo migração de HC para fora da trapa. Equivale a C004 em ontopetro."""@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#CapRock> ;
    geo:geocoverage "layer1" ;
    geo:geocoverage "layer2" ;
    geo:geocoverage "layer3" .

geo:trapa a owl:Class ;
    skos:prefLabel "Trapa"@pt ;
    skos:prefLabel "Petroleum Trap"@en ;
    geo:entityType "geological" ;
    skos:definition "Configuração geológica (estrutural, estratigráfica ou combinada) que permite acúmulo de HC. C006 em ontopetro."@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#PetroleumTrap> ;
    geo:geocoverage "layer1" ;
    geo:geocoverage "layer3" .

geo:sistema-petrolifero a owl:Class ;
    skos:prefLabel "Sistema Petrolífero"@pt ;
    skos:prefLabel "Petroleum System"@en ;
    geo:entityType "geological" ;
    skos:definition "Conjunto integrado de rocha geradora, migração, reservatório, capa e trapa. C007 em ontopetro."@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#PetroleumSystem> ;
    geo:geocoverage "layer1" ;
    geo:geocoverage "layer3" .

geo:acumulacao a owl:Class ;
    skos:prefLabel "Acumulação"@pt ;
    skos:prefLabel "Hydrocarbon Accumulation"@en ;
    geo:entityType "operational" ;
    skos:definition "Volume de HC contido em armadilha com dimensões definidas. Precede a Declaração de Comercialidade. C008 em ontopetro."@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#HydrocarbonAccumulation> ;
    skos:relatedMatch <http://sweetontology.net/realmGeol/GeologicFeature> ;
    skos:relatedMatch <http://sweetontology.net/matrOrganics/Hydrocarbon> ;
    geo:geocoverage "layer2" ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer4" .

geo:play a owl:Class ;
    skos:prefLabel "Play"@pt ;
    skos:prefLabel "Play"@en ;
    geo:entityType "operational" ;
    skos:definition "Combinação de elementos petrolíferos com potencial exploratório regional. C017 em ontopetro."@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Play> ;
    geo:geocoverage "layer3" .

geo:prospecto a owl:Class ;
    skos:prefLabel "Prospecto"@pt ;
    skos:prefLabel "Prospect"@en ;
    geo:entityType "operational" ;
    skos:definition "Área específica com potencial para acumulação, dentro de um play. C018 em ontopetro."@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Prospect> ;
    geo:geocoverage "layer3" .

geo:recurso a owl:Class ;
    skos:prefLabel "Recurso"@pt ;
    skos:prefLabel "Resource"@en ;
    geo:entityType "contractual" ;
    skos:definition "Volume de HC com grau variável de certeza geológica. Categorizado por SPE-PRMS. C019 em ontopetro."@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Resource> ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer5" .

geo:reserva a owl:Class ;
    skos:prefLabel "Reserva"@pt ;
    skos:prefLabel "Reserve"@en ;
    geo:entityType "contractual" ;
    skos:definition """Volume de HC tecnicamente recuperável e economicamente viável. Categorias 1P/2P/3P. C020 em ontopetro. NÃO confundir com Reserva Ambiental."""@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Reserve> ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer5" .

geo:falha a owl:Class ;
    skos:prefLabel "Falha Geológica"@pt ;
    skos:prefLabel "Geological Fault"@en ;
    geo:entityType "geological" ;
    skos:definition "Descontinuidade tectônica com deslocamento relativo das camadas. C016 em ontopetro."@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#GeologicalFault> ;
    geo:geocoverage "layer1" ;
    geo:geocoverage "layer3" .

geo:idade-geologica a owl:Class ;
    skos:prefLabel "Idade Geológica"@pt ;
    skos:prefLabel "Geological Age"@en ;
    geo:entityType "geological" ;
    skos:definition "Período/época formal segundo ICS GTS2020. Ex.: Aptiano, Albiano, Cretáceo Superior. Tipo NER PetroGold IDA."@pt ;
    geo:geocoverage "layer1" ;
    geo:geocoverage "layer3" .

