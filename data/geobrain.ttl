    skos:altLabel "RFT"@pt ;
    skos:altLabel "MDT"@pt ;
    skos:altLabel "MiniDST"@pt ;
    skos:altLabel "RFT point"@en ;
    skos:altLabel "MDT pretest"@en ;
    skos:definition """Medida única de pressão de formação (pretest) — RFT/MDT/XPT/FMT/MiniDST. Inclui pressão estática/fluxo, mobilidade, qualidade do pretest e coleta de amostra."""@pt .

geo:dst-interval a owl:Class ;
    skos:prefLabel "Intervalo de Teste de Formação (DST)"@pt ;
    skos:prefLabel "DST Interval"@en ;
    geo:entityType "analytical" ;
    skos:altLabel "DST"@pt ;
    skos:altLabel "Drill Stem Test"@en ;
    skos:definition """Intervalo de DST conforme PE-2E&P-00773. Interpretação definitiva da produtividade do poço. CRÍTICO: dados DST armazenados no SIRR (NÃO BDIEP). Gestor é RES/TR/AR (Reservatórios), NÃO EXP/OGP/AQG. Arquivos (FT1/2/5, Saphir, PanSystem) ficam em BDOC."""@pt .

geo:geostopping-event a owl:Class ;
    skos:prefLabel "Evento de Geostopping"@pt ;
    skos:prefLabel "Geostopping Event"@en ;
    geo:entityType "analytical" ;
    skos:definition """Evento de decisão de geostopping — decisão em tempo real de parar a perfuração em profundidade precisa, baseada em curvas LWD, indícios de gás, tendência de MSE, mudança de fácies. Conforme definição PE-2EXP-00061. KPIs (decision_time_h, npt_avoided_h) são métricas operacionais inferidas."""@pt .

geo:sirr a owl:Class ;
    skos:prefLabel "Sistema de Informações de Reservas e Reservatórios"@pt ;
    skos:prefLabel "Reserves & Reservoirs Information System (SIRR)"@en ;
    geo:entityType "instrument" ;
