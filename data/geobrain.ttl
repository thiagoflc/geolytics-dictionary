    skos:altLabel "plug de testemunho"@pt ;
    skos:altLabel "core plug"@en ;
    skos:definition "Plugue cilíndrico extraído de uma CoreRun para análise laboratorial."@pt .

geo:sidewall-core-sample a owl:Class ;
    skos:prefLabel "Amostra Lateral (SWC)"@pt ;
    skos:prefLabel "Sidewall Core Sample"@en ;
