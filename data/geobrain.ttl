geo:fluid-sample a owl:Class ;
    skos:prefLabel "Amostra de Fluido"@pt ;
    skos:prefLabel "Fluid Sample"@en ;
    geo:entityType "analytical" ;
    skos:altLabel "amostra de fluido"@pt ;
    skos:altLabel "fluid sample"@en ;
