geo:mudlogging a owl:Class ;
    skos:prefLabel "Mudlogging"@pt ;
    skos:prefLabel "Mudlogging"@en ;
    geo:entityType "analytical" ;
    skos:definition """Linha de serviço de Operações Geológicas: monitoramento contínuo de parâmetros de perfuração e análise de gás em tempo real, transmitidos da sonda ao EXATA. Documento primário são os dados em tempo real (não o BDP). Normado por PE-2EXP-00059 e PE-2EXP-00061."""@pt .

geo:cuttings-sampling a owl:Class ;
    skos:prefLabel "Coleta de Calha"@pt ;
    skos:prefLabel "Cuttings Sampling"@en ;
    geo:entityType "analytical" ;
    skos:altLabel "amostragem de calha"@pt ;
    skos:altLabel "amostras de calha"@pt ;
    skos:altLabel "cuttings sample collection"@en ;
    skos:definition """Linha de serviço de Operações Geológicas: coleta, descrição e classificação litológica dos cascalhos trazidos pelo fluido de perfuração. Insumo para classificação litológica e correlação. Normado por PE-2EXP-00059 e PE-2EXP-00061."""@pt .

geo:coring a owl:Class ;
    skos:prefLabel "Testemunhagem"@pt ;
    skos:prefLabel "Coring"@en ;
    geo:entityType "analytical" ;
    skos:definition """Linha de serviço de Operações Geológicas: extração de cilindros de rocha (testemunhos) para análise laboratorial detalhada. Alinhada ao GeoSciML (specimentype/core). Insumo direto para IGP e caracterização de reservatório."""@pt .

geo:sidewall-sampling a owl:Class ;
    skos:prefLabel "Amostragem Lateral (SWC)"@pt ;
    skos:prefLabel "Sidewall Sampling"@en ;
    geo:entityType "analytical" ;
    skos:altLabel "SWC"@pt ;
    skos:altLabel "sidewall core"@en ;
    skos:altLabel "SWC"@en ;
    skos:definition """Linha de serviço de Operações Geológicas: coleta de plugues laterais de rocha por ferramentas de wireline após a perfuração de uma seção. Normado por PE-2EXP-00065."""@pt .

geo:mwd-lwd a owl:Class ;
    skos:prefLabel "MWD/LWD"@pt ;
    skos:prefLabel "MWD/LWD"@en ;
    geo:entityType "analytical" ;
    skos:definition """Linha de serviço de Operações Geológicas: medição e perfilagem durante a perfuração — dados petrofísicos e direcionais em tempo real. Registro primário são as curvas transmitidas ao EXATA, não o BDP. Normado por PE-2EXP-00061."""@pt .

geo:wireline-logging a owl:Class ;
    skos:prefLabel "Perfilagem a Cabo"@pt ;
    skos:prefLabel "Wireline Logging"@en ;
    geo:entityType "analytical" ;
    skos:definition """Linha de serviço de Operações Geológicas: aquisição de perfis de poço descidos a cabo após a perfuração de cada fase. Alinhada ao OSDU (work-product-component--WellLog). Normado por PE-2EXP-00065."""@pt .

geo:formation-testing a owl:Class ;
    skos:prefLabel "Teste de Formação"@pt ;
    skos:prefLabel "Formation Testing"@en ;
    geo:entityType "analytical" ;
    skos:altLabel "RFT"@pt ;
    skos:altLabel "MDT"@pt ;
    skos:altLabel "DST"@pt ;
    skos:altLabel "formation test"@en ;
    skos:altLabel "RFT"@en ;
    skos:altLabel "MDT"@en ;
    skos:altLabel "DST"@en ;
    skos:definition """Linha de serviço de Operações Geológicas: amostragem de fluidos e medição de pressões em reservatórios (RFT/MDT/DST). DST normado por PE-2E&P-00773. Calibra modelos de pressão de poros (geomechanics:GM004)."""@pt .

geo:geostopping a owl:Class ;
    skos:prefLabel "Geostopping"@pt ;
    skos:prefLabel "Geostopping"@en ;
    geo:entityType "analytical" ;
    skos:definition """Linha de serviço de Operações Geológicas: monitoramento em tempo real para parada precisa em alvos geológicos, especialmente no pré-sal. Decisões baseadas em curvas LWD, indícios de gás, MSE e mudanças de fácies. Normado por PE-2EXP-00061."""@pt .

geo:ogeomec a owl:Class ;
    skos:prefLabel "Ocorrências Geomecânicas"@pt ;
    skos:prefLabel "Geomechanical Occurrences (OGEOMEC)"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "OGEOMEC"@pt ;
    skos:altLabel "Planilha de Ocorrências Geomecânicas"@pt ;
    skos:altLabel "OGEOMEC"@en ;
    skos:altLabel "Geomechanical Occurrences Table"@en ;
    skos:definition """Tabela relacional de ocorrências geomecânicas durante a perfuração, persistida na BDIEP. Cada linha representa um evento (kick, perda, prisão, arraste, topamento) com intervalo, ECD, peso de lama, procedimento, diâmetro e BHA. Fonte estruturada primária para retroanálise e busca de análogos (898 ocorrências; 544 poços)."""@pt .

geo:rcsd a owl:Class ;
    skos:prefLabel "Relatório do CSD de Operações"@pt ;
    skos:prefLabel "CSD Operations Report (RCSD)"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "RCSD"@pt ;
    skos:altLabel "Relatório CSD"@pt ;
    skos:altLabel "RCSD"@en ;
    skos:altLabel "CSD Report"@en ;
    skos:definition """Relatório do CSD (Centro de Suporte à Decisão) de Operações — documento PPT semi-estruturado armazenado em SharePoint / Drive Científico CSD. Consolida o status operacional emitido pelo CSD."""@pt .

geo:qpg a owl:Class ;
    skos:prefLabel "Quadro de Previsão Geológica"@pt ;
    skos:prefLabel "Geological Prognosis Chart (QPG)"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "Quadro de Previsão Geológica"@pt ;
    skos:altLabel "Prognóstico Geológico"@pt ;
    skos:altLabel "QPG"@pt ;
    skos:altLabel "geological prognosis"@en ;
    skos:altLabel "predicted geology chart"@en ;
    skos:altLabel "QPG"@en ;
    skos:definition """Quadro de Previsão Geológica — publicado no SIGEO/BDIEP, consolida a representação visual das possíveis características geológicas do poço: previsão litológica, marcadores, falhas, tempo sísmico, objetivos e previsões de ferramentas/técnicas de aquisição. Principal insumo de planejamento consumido pelas atividades de aquisição. Raiz da linhagem de documentos do poço."""@pt .

geo:bdp a owl:Class ;
    skos:prefLabel "Boletim Diário de Perfuração"@pt ;
    skos:prefLabel "Daily Drilling Bulletin (BDP)"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "BDP"@pt ;
    skos:altLabel "Boletim Diário de Perfuração"@pt ;
    skos:altLabel "BDP"@en ;
    skos:altLabel "daily drilling bulletin"@en ;
    skos:definition """Boletim Diário de Perfuração — boletim estruturado (CSV) disponível via API POÇOS. Registra a execução diária contra o prognóstico do QPG. Gestor: POÇOS. Insumo de retroanálise e upstream do IGP e OGEOMEC."""@pt .

geo:igp a owl:Class ;
    skos:prefLabel "Informativo Geológico de Poço"@pt ;
    skos:prefLabel "Well Geological Information (IGP)"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "IGP"@pt ;
    skos:altLabel "Informativo Geológico de Poço"@pt ;
    skos:altLabel "IGP"@en ;
    skos:altLabel "well geological information"@en ;
    skos:definition """Informativo Geológico de Poço — relatório não estruturado (PDF/Word) consolidando a informação geológica do poço após a perfuração de cada fase. Integra BDP, QPG e PAG. Gestor: EXP/OGP/AQG. Insumo do Perfil Composto."""@pt .

geo:perfil-composto a owl:Class ;
    skos:prefLabel "Perfil Composto"@pt ;
    skos:prefLabel "Composite Log"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "Perfil Composto"@pt ;
    skos:altLabel "perfil consolidado de poço"@pt ;
    skos:altLabel "composite log"@en ;
    skos:altLabel "well composite log"@en ;
    skos:definition """Perfil Composto — produto canônico pós-perfuração que integra, para um único poço, curvas de perfis (wireline e MWD/LWD), descrições litológicas, indícios, testes de formação, registros direcionais e demais dados adquiridos — recuperados da BDIEP via SIGEO. Produto da disciplina de Consolidação de Dados de Poço."""@pt .

geo:rmg a owl:Class ;
    skos:prefLabel "Relatório de Monitoramento Geomecânico"@pt ;
    skos:prefLabel "Geomechanical Monitoring Report (RMG)"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "RMG"@pt ;
    skos:altLabel "Relatório de Monitoramento Geomecânico"@pt ;
    skos:altLabel "RMG"@en ;
    skos:altLabel "geomechanical monitoring report"@en ;
    skos:definition """Relatório de Monitoramento Geomecânico — PDF não estruturado armazenado em VGE / Pasta de Poço. Sintetiza ocorrências geomecânicas (OGEOMEC) e operações diárias (BDP) para retroanálise e lessons learned. Gestor: EXP/OGP/AQG/AIP-OGEO."""@pt .

geo:lessons-learned a owl:Class ;
    skos:prefLabel "Lições Aprendidas"@pt ;
    skos:prefLabel "Lessons Learned"@en ;
    geo:entityType "operational" ;
    skos:altLabel "Lições Aprendidas"@pt ;
    skos:altLabel "Lessons Learned"@pt ;
    skos:altLabel "lessons learned"@en ;
    skos:definition """Fase de lições aprendidas ao fim da jornada do poço — agrega RCSD, OGEOMEC e RMG para alimentar a RetroAnálise do próximo poço. Fase final do ciclo da jornada do poço (WellJourneyPhase). Gestor: EXP/OGP."""@pt .

geo:retro-analysis a owl:Class ;
    skos:prefLabel "Retroanálise"@pt ;
    skos:prefLabel "Retro Analysis"@en ;
    geo:entityType "operational" ;
    skos:altLabel "retroanálise"@pt ;
    skos:altLabel "análise retrospectiva"@pt ;
    skos:altLabel "retro analysis"@en ;
    skos:altLabel "retrospective analysis"@en ;
    skos:definition """Fase inicial da jornada do poço — análise dos dados históricos de poços análogos (OGEOMEC, RMG) para subsidiar o planejamento. Consumes lessons-learned de poços anteriores."""@pt .

geo:input-elaboration a owl:Class ;
    skos:prefLabel "Elaboração de Insumos"@pt ;
    skos:prefLabel "Input Elaboration"@en ;
    geo:entityType "operational" ;
    skos:altLabel "elaboração de insumos"@pt ;
    skos:altLabel "planejamento de aquisição"@pt ;
    skos:altLabel "input elaboration"@en ;
    skos:altLabel "acquisition planning"@en ;
    skos:definition """Fase de planejamento detalhado — elaboração do QPG e demais insumos técnicos (programas de aquisição, seleção de linhas de serviço). Upstream de todas as atividades de campo."""@pt .

geo:operational-monitoring a owl:Class ;
    skos:prefLabel "Acompanhamento Operacional"@pt ;
    skos:prefLabel "Operational Monitoring"@en ;
    geo:entityType "operational" ;
    skos:altLabel "acompanhamento operacional"@pt ;
    skos:altLabel "monitoramento de poço"@pt ;
    skos:altLabel "operational monitoring"@en ;
    skos:altLabel "well monitoring"@en ;
    skos:definition """Fase de execução — acompanhamento em tempo real das linhas de serviço (mudlogging, MWD/LWD, geostopping) via EXATA. Produz BDP, PAG e eventos discretos (kick, gas show)."""@pt .

geo:formation-evaluation a owl:Class ;
    skos:prefLabel "Avaliação de Formações"@pt ;
    skos:prefLabel "Formation Evaluation"@en ;
    geo:entityType "operational" ;
    skos:altLabel "avaliação de formações"@pt ;
    skos:altLabel "avaliação petrofísica"@pt ;
    skos:altLabel "formation evaluation"@en ;
    skos:altLabel "petrophysical evaluation"@en ;
    skos:definition """Fase pós-perfuração — interpretação integrada de wireline, LWD, FRX/DRX, testes e amostras para gerar IGP e Perfil Composto. Alimenta a consolidação de dados do poço."""@pt .

geo:exata a owl:Class ;
    skos:prefLabel "EXATA"@pt ;
    skos:prefLabel "EXATA (Real-time Acquisition System)"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "EXATA"@pt ;
    skos:altLabel "sistema de aquisição em tempo real"@pt ;
    skos:altLabel "EXATA"@en ;
    skos:altLabel "real-time well data acquisition system"@en ;
    skos:definition """Sistema Petrobras de aquisição e transmissão de dados em tempo real de poço — integra dados de mudlogging, MWD/LWD e geostopping via streaming. Backend Oracle (hot data) + Cassandra (séries temporais). Centro operacional: CGOR."""@pt .

geo:sigeo a owl:Class ;
    skos:prefLabel "SIGEO"@pt ;
    skos:prefLabel "SIGEO (Geological Information System)"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "SIGEO"@pt ;
    skos:altLabel "SIGEO"@en ;
    skos:altLabel "geological information system"@en ;
    skos:definition """Sistema de Informações Geológicas Petrobras — repositório canônico de QPG, Perfil Composto, FRX e dados geológicos de poço. Acesso via VGE (BDIEP). Principal sistema de gestão de dados geológicos pós-perfuração."""@pt .

geo:bdiep a owl:Class ;
    skos:prefLabel "BDIEP"@pt ;
    skos:prefLabel "BDIEP (Exploration and Production Well Database)"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "BDIEP"@pt ;
    skos:altLabel "BDIEP"@en ;
    skos:altLabel "E&P well information database"@en ;
    skos:definition """Banco de Dados de Informações de Exploração e Produção — repositório primário de dados de poço Petrobras. Armazena OGEOMEC, QPG, dados de wireline/LWD e demais dados de aquisição. Acessado via VGE."""@pt .

geo:bdiap a owl:Class ;
    skos:prefLabel "BDIAP"@pt ;
    skos:prefLabel "BDIAP (Production Well Database)"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "BDIAP"@pt ;
    skos:altLabel "BDIAP"@en ;
    skos:definition """Banco de Dados de Informações de Avaliação e Produção — repositório de dados de poços em produção. Complementar ao BDIEP para fase de desenvolvimento e produção."""@pt .

geo:aida a owl:Class ;
    skos:prefLabel "AIDA"@pt ;
    skos:prefLabel "AIDA (Analytical Platform / Databricks)"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "AIDA"@pt ;
    skos:altLabel "plataforma analítica"@pt ;
    skos:altLabel "Databricks"@pt ;
    skos:altLabel "AIDA"@en ;
    skos:altLabel "analytical platform"@en ;
    skos:altLabel "Databricks"@en ;
    skos:definition """Plataforma analítica Petrobras baseada em Databricks/Delta Lake — destino downstream dos dados de operações geológicas (DRX, FRX, OGEOMEC) para análise exploratória, ML e GraphRAG. Pipeline de ingestão BDIEP → AIDA não totalmente documentado (gap conhecido)."""@pt .

geo:geodo a owl:Class ;
    skos:prefLabel "GeoDO"@pt ;
    skos:prefLabel "GeoDO (Geological Operations Data Orchestrator)"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "GeoDO"@pt ;
    skos:altLabel "GeoDO"@en ;
    skos:definition """Sistema de orquestração de dados de operações geológicas — inclui pipeline text-to-SQL para consultas em linguagem natural sobre dados de poço. Integração com DRX/FRX pendente (gap de documentação)."""@pt .

geo:gda a owl:Class ;
    skos:prefLabel "GDA"@pt ;
    skos:prefLabel "GDA (Geological Data Access)"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "GDA"@pt ;
    skos:altLabel "GDA"@en ;
    skos:definition """Camada de acesso a dados geológicos — interface de consulta para dados de operações geológicas (mudlogging, EXATA). Referenciado em fontes de mudlogging (GDA SharePoint)."""@pt .

geo:laudo-geomecanico a owl:Class ;
    skos:prefLabel "Laudo Geomecânico"@pt ;
    skos:prefLabel "Geomechanical Report (Laudo Geomecânico)"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "Laudo Geomecânico"@pt ;
    skos:altLabel "Laudo de Geomecânica"@pt ;
    skos:altLabel "Laudo Geomecânico de locação"@pt ;
    skos:altLabel "Laudo Geomecânico de poço"@pt ;
    skos:altLabel "Relatório Geomecânico"@pt ;
    skos:altLabel "Relatório Geomecânico de Poço"@pt ;
    skos:altLabel "Análise de Estabilidade de Poço"@pt ;
    skos:altLabel "geomechanical report"@en ;
    skos:altLabel "wellbore stability report"@en ;
    skos:altLabel "geomechanical assessment"@en ;
    skos:altLabel "geomechanical prognosis"@en ;
    skos:altLabel "Geomechanical Report"@en ;
    skos:definition """Documento técnico que consolida a análise geomecânica associada a uma locação ou poço, reunindo informações de contexto geológico, estrutural, sísmico e operacional, além de riscos geomecânicos, curvas/modelos de geopressões e tensões quando disponíveis. Serve como evidência técnica formal para subsidiar o projeto e o acompanhamento do poço. Produzido pelo CSD Geomecânica (RES/GMR ou área responsável). Distinto do QPG (prognóstico geológico) — não inferir existência para todos os poços."""@pt .

geo:sensor_aber_ckgl a owl:Class ;
    skos:prefLabel "ABER-CKGL"@pt ;
    skos:prefLabel "Gas-Lift Choke Opening"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "abertura GLCK"@pt ;
    skos:altLabel "abertura choke gas-lift"@pt ;
    skos:altLabel "GLCK opening"@en ;
    skos:altLabel "gas-lift choke opening"@en ;
    skos:definition """Abertura do GLCK (gas-lift choke), variável 3W em percentual. Indica o grau de abertura da válvula de estrangulamento da linha de gas-lift."""@pt ;
    skos:example "ABER-CKGL=0 indica GLCK fechado" ;
    skos:example "ABER-CKGL=100 indica GLCK totalmente aberto" ;
    owl:sameAs <https://w3id.org/osdu#TimeSeriesData> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:sensor_aber_ckp a owl:Class ;
    skos:prefLabel "ABER-CKP"@pt ;
    skos:prefLabel "Production Choke Opening"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "abertura PCK"@pt ;
    skos:altLabel "abertura choke produção"@pt ;
    skos:altLabel "PCK opening"@en ;
    skos:altLabel "production choke opening"@en ;
    skos:definition """Abertura do PCK (production choke), variável 3W em percentual. Queda brusca de ABER-CKP pode indicar restrição rápida (classe 6) ou incrustação (classe 7)."""@pt ;
    skos:example "ABER-CKP caindo rapidamente indica classe 6 ou 7" ;
    owl:sameAs <https://w3id.org/osdu#TimeSeriesData> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:sensor_estado_dhsv a owl:Class ;
    skos:prefLabel "ESTADO-DHSV"@pt ;
    skos:prefLabel "DHSV State"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "estado DHSV"@pt ;
    skos:altLabel "estado válvula de segurança"@pt ;
    skos:altLabel "DHSV state"@en ;
    skos:altLabel "safety valve state"@en ;
    skos:definition """Estado da DHSV (válvula de segurança de subsuperfície): 0=fechada, 0.5=parcial, 1=aberta. Fechamento espúrio (classe 2) é detectado por queda abrupta de ESTADO-DHSV."""@pt ;
    skos:example "ESTADO-DHSV=0 confirma fechamento da DHSV" ;
    owl:sameAs <https://w3id.org/osdu#TimeSeriesData> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:sensor_estado_m1 a owl:Class ;
    skos:prefLabel "ESTADO-M1"@pt ;
    skos:prefLabel "PMV State"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "estado PMV"@pt ;
    skos:altLabel "estado válvula mestra produção"@pt ;
    skos:altLabel "PMV state"@en ;
    skos:altLabel "production master valve state"@en ;
    skos:definition "Estado da PMV (production master valve / válvula mestra de produção): 0=fechada, 0.5=parcial, 1=aberta. Variável 3W."@pt ;
    owl:sameAs <https://w3id.org/osdu#TimeSeriesData> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:sensor_estado_m2 a owl:Class ;
    skos:prefLabel "ESTADO-M2"@pt ;
    skos:prefLabel "AMV State"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "estado AMV"@pt ;
    skos:altLabel "estado válvula mestra anular"@pt ;
    skos:altLabel "AMV state"@en ;
    skos:altLabel "annulus master valve state"@en ;
    skos:definition "Estado da AMV (annulus master valve / válvula mestra de anular): 0=fechada, 0.5=parcial, 1=aberta. Variável 3W."@pt ;
    owl:sameAs <https://w3id.org/osdu#TimeSeriesData> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:sensor_estado_pxo a owl:Class ;
    skos:prefLabel "ESTADO-PXO"@pt ;
    skos:prefLabel "PXO Valve State"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "estado PXO"@pt ;
    skos:altLabel "estado válvula pig-crossover"@pt ;
    skos:altLabel "PXO state"@en ;
    skos:altLabel "pig-crossover valve state"@en ;
    skos:definition "Estado da PXO (pig-crossover valve): 0=fechada, 0.5=parcial, 1=aberta. Variável 3W."@pt ;
    owl:sameAs <https://w3id.org/osdu#TimeSeriesData> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:sensor_estado_sdv_gl a owl:Class ;
    skos:prefLabel "ESTADO-SDV-GL"@pt ;
    skos:prefLabel "Gas-Lift SDV State"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "estado SDV-GL"@pt ;
    skos:altLabel "estado válvula bloqueio gas-lift"@pt ;
    skos:altLabel "SDV-GL state"@en ;
    skos:altLabel "gas-lift shutdown valve state"@en ;
    skos:definition "Estado da SDV-GL (válvula de bloqueio de gas-lift): 0=fechada, 0.5=parcial, 1=aberta. Variável 3W."@pt ;
    owl:sameAs <https://w3id.org/osdu#TimeSeriesData> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:sensor_estado_sdv_p a owl:Class ;
    skos:prefLabel "ESTADO-SDV-P"@pt ;
    skos:prefLabel "Production SDV State"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "estado SDV-P"@pt ;
    skos:altLabel "estado válvula bloqueio produção"@pt ;
    skos:altLabel "SDV-P state"@en ;
    skos:altLabel "production shutdown valve state"@en ;
    skos:definition "Estado da SDV-P (válvula de bloqueio de produção): 0=fechada, 0.5=parcial, 1=aberta. Variável 3W."@pt ;
    owl:sameAs <https://w3id.org/osdu#TimeSeriesData> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:sensor_estado_w1 a owl:Class ;
    skos:prefLabel "ESTADO-W1"@pt ;
    skos:prefLabel "PWV State"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "estado PWV"@pt ;
    skos:altLabel "estado válvula asa produção"@pt ;
    skos:altLabel "PWV state"@en ;
