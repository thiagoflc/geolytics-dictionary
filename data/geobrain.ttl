geo:sigep a owl:Class ;
    skos:prefLabel "SIGEP"@pt ;
    skos:prefLabel "SIGEP (E&P Information System)"@en ;
    geo:entityType "instrument" ;
    skos:definition """Sistema de Informações Gerenciais de Exploração e Produção. Sistema oficial da ANP que concentra e disponibiliza dados sobre poços, PADs, blocos e contratos de exploração e produção de petróleo e gás natural no Brasil."""@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#InformationSystem> ;
