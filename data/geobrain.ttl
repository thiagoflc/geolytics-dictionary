    skos:altLabel "Fluorescência de Raios-X"@pt ;
    skos:altLabel "Análise de FRX"@pt ;
    skos:altLabel "XRF"@en ;
    skos:altLabel "X-Ray Fluorescence"@en ;
    skos:definition """Técnica analítica de determinação da composição elementar de amostras de rocha por fluorescência de raios X. Gera assinatura geoquímica usada na caracterização e correlação de formações. Detalhada em data/operacoes-geologicas.json (OG013b)."""@pt ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:dna-geoquimico a owl:Class ;
