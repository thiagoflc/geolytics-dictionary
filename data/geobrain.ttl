geo:cassandra-exata-curva-tempo a owl:Class ;
    skos:prefLabel "Camada Cassandra — mdae.exata_curva_tempo"@pt ;
    skos:prefLabel "Cassandra mdae.exata_curva_tempo Layer"@en ;
