geo:pck a owl:Class ;
    skos:prefLabel "PCK"@pt ;
    skos:prefLabel "Production Choke"@en ;
    geo:entityType "equipment" ;
    skos:altLabel "choke produção"@pt ;
    skos:altLabel "PCK"@pt ;
    skos:altLabel "estrangulador produção"@pt ;
    skos:altLabel "production choke"@en ;
    skos:altLabel "PCK"@en ;
    skos:definition """Choke de produção (PCK) da ANM subsea. Controla a vazão da linha de produção do poço; principal ponto de incrustação (scaling, classe 7) e restrição rápida (classe 6). Parte da árvore de natal (ANM). ATENÇÃO: PCK no contexto 3W é o Production Choke — não confundir com "pilot-operated check valve" em contextos genéricos de tubulação."""@pt ;
    skos:example "Incrustação no PCK detectada por queda de ABER-CKP com diferencial crescente de pressão" ;
    owl:sameAs <https://w3id.org/osdu#EquipmentType> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:tpt a owl:Class ;
    skos:prefLabel "TPT"@pt ;
    skos:prefLabel "Temperature and Pressure Transducer"@en ;
    geo:entityType "equipment" ;
    skos:altLabel "transdutor temperatura pressão"@pt ;
    skos:altLabel "TPT"@pt ;
    skos:altLabel "transdutor ANM"@pt ;
    skos:altLabel "temperature pressure transducer"@en ;
    skos:altLabel "TPT"@en ;
    skos:definition """Transdutor de temperatura e pressão (TPT) instalado na ANM subsea. Fornece as variáveis P-TPT e T-TPT. Parte da árvore de natal (ANM)."""@pt ;
    owl:sameAs <https://w3id.org/osdu#EquipmentType> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:pdg a owl:Class ;
    skos:prefLabel "PDG"@pt ;
    skos:prefLabel "Permanent Downhole Gauge"@en ;
    geo:entityType "equipment" ;
    skos:altLabel "medidor downhole"@pt ;
    skos:altLabel "PDG"@pt ;
    skos:altLabel "medidor permanente fundo"@pt ;
    skos:altLabel "permanent downhole gauge"@en ;
    skos:altLabel "PDG"@en ;
    skos:altLabel "downhole gauge"@en ;
    skos:definition """Medidor permanente de fundo de poço (Permanent Downhole Gauge, PDG). Instalado na coluna de produção dentro do poço (downhole). Fornece P-PDG e T-PDG. Sensor crítico para detecção de golfadas severas e perda de produtividade."""@pt ;
    skos:example "PDG mede pressão e temperatura na coluna de produção em profundidade" ;
    owl:sameAs <https://w3id.org/osdu#EquipmentType> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:sp_pump a owl:Class ;
    skos:prefLabel "SP"@pt ;
    skos:prefLabel "Service Pump"@en ;
    geo:entityType "equipment" ;
    skos:altLabel "bomba serviço"@pt ;
    skos:altLabel "SP"@pt ;
    skos:altLabel "service pump"@en ;
    skos:altLabel "SP"@en ;
    skos:definition """Bomba de serviço (SP) usada em operações de intervenção ou injeção de fluidos no poço. Fornece as variáveis QBS (vazão) e P-JUS-BS (pressão a jusante). Relevante para detecção de hidrato em linha de serviço (classe 9)."""@pt ;
    skos:example "QBS + P-JUS-BS monitoram hidrato na linha de serviço" ;
    owl:sameAs <https://w3id.org/osdu#EquipmentType> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:anm a owl:Class ;
    skos:prefLabel "ANM"@pt ;
    skos:prefLabel "Subsea Xmas-Tree"@en ;
    geo:entityType "equipment" ;
    skos:altLabel "árvore de natal molhada"@pt ;
    skos:altLabel "ANM"@pt ;
    skos:altLabel "árvore de natal subsea"@pt ;
    skos:altLabel "Christmas tree subsea"@pt ;
    skos:altLabel "subsea Xmas-tree"@en ;
    skos:altLabel "ANM"@en ;
    skos:altLabel "wet Christmas tree"@en ;
    skos:altLabel "subsea tree"@en ;
    skos:definition """Árvore de natal molhada (ANM) — conjunto de válvulas e equipamentos instalado no leito marinho no topo do poço offshore. Inclui PMV, AMV, PWV, AWV, PXO, XO, SDV-P, SDV-GL, GLCK, PCK e TPT. Componente central da completação subsea."""@pt ;
    skos:example "A ANM é o principal conjunto de controle de fluxo em poços offshore" ;
    owl:sameAs <https://w3id.org/osdu#EquipmentType> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

