geo:vge a owl:Class ;
    skos:prefLabel "Visualizador de Geo-dados (acesso BDIEP)"@pt ;
    skos:prefLabel "Geo-data Visualizer (VGE/BDIEP)"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "BDIEP"@pt ;
