    skos:altLabel "Geological Operations"@en ;
    skos:altLabel "Geological Data Acquisition"@en ;
    skos:definition """Disciplina que agrupa técnicas analíticas e operacionais de aquisição de dados geológicos (DRX, FRX, geoquímica) aplicadas a amostras de poço e formação. Detalhada no módulo data/operacoes-geologicas.json (OG001)."""@pt ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:drx a owl:Class ;
    skos:prefLabel "Difração de Raios X"@pt ;
    skos:prefLabel "X-Ray Diffraction"@en ;
    geo:entityType "analytical" ;
