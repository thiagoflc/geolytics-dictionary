geo:poco a owl:Class ;
    skos:prefLabel "Poço"@pt ;
    skos:prefLabel "Well"@en ;
    geo:entityType "operational" ;
    skos:altLabel "poço"@pt ;
    skos:altLabel "poço exploratório"@pt ;
    skos:altLabel "poço de petróleo"@pt ;
    skos:altLabel "well"@en ;
    skos:altLabel "borehole"@en ;
    skos:altLabel "exploratory well"@en ;
    skos:altLabel "oil well"@en ;
    skos:definition """Identificador padronizado atribuído a um poço de petróleo ou gás no Brasil, conforme as regras da Agência Nacional do Petróleo, Gás Natural e Biocombustíveis (ANP). Permite a identificação única em documentos técnicos, sistemas oficiais e comunicações regulatórias."""@pt ;
    skos:example "1-RJS-702-RJ (Tupi)" ;
    skos:example "1-BRSA-1135-RJS" ;
    skos:example "3-BRSA-944-RJS (Búzios)" ;
    skos:example "1-ANP-2-AL" ;
    owl:sameAs <https://w3id.org/osdu#Well> ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Well> ;
    geo:geocoverage "layer1" ;
    geo:geocoverage "layer1b" ;
    geo:geocoverage "layer2" ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer5" ;
    geo:ontologicalRole "well_anchor" .

geo:bloco a owl:Class ;
    skos:prefLabel "Bloco"@pt ;
    skos:prefLabel "Block"@en ;
    geo:entityType "operational" ;
    skos:altLabel "bloco exploratório"@pt ;
    skos:altLabel "área concedida"@pt ;
    skos:altLabel "block"@en ;
    skos:altLabel "exploration block"@en ;
    skos:altLabel "lease block"@en ;
    skos:altLabel "concession block"@en ;
    skos:definition """Parte de uma bacia sedimentar, formada por um prisma vertical de profundidade indeterminada, com superfície poligonal definida pelas coordenadas geográficas de seus vértices, onde são desenvolvidas atividades de exploração ou produção de petróleo e gás natural."""@pt ;
    skos:example "BM-S-11 (Lula)" ;
    skos:example "BCAM-40 (Búzios)" ;
    skos:example "BS-4 (Atlanta)" ;
    skos:example "BM-C-33" ;
    owl:sameAs <https://w3id.org/osdu#AcquisitionSurvey> ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#ExplorationBlock> ;
    skos:relatedMatch <http://sweetontology.net/realmGeol/GeologicFeature> ;
    skos:relatedMatch <http://sweetontology.net/realmGeolBasin/SedimentaryBasin> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer5" ;
    geo:ontologicalRole "regulatory_anchor" .

geo:campo a owl:Class ;
    skos:prefLabel "Campo"@pt ;
    skos:prefLabel "Field"@en ;
    geo:entityType "operational" ;
    skos:definition """Área produtora de petróleo ou gás natural a partir de um ou mais reservatórios contínuos. No regime ANP, um campo é declarado a partir da Declaração de Comercialidade que confirma a viabilidade econômica da descoberta."""@pt ;
    owl:sameAs <https://w3id.org/osdu#Field> ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Field> ;
    skos:relatedMatch <http://sweetontology.net/realmGeol/GeologicFeature> ;
