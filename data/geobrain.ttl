geo:sistema-deposicional a owl:Class ;
    skos:prefLabel "Sistema Deposicional"@pt ;
    skos:prefLabel "Depositional System"@en ;
    geo:entityType "geological" ;
    skos:altLabel "sistema deposicional"@pt ;
    skos:altLabel "sistema sedimentar"@pt ;
    skos:altLabel "ambiente deposicional"@pt ;
    skos:altLabel "depositional system"@en ;
    skos:altLabel "sedimentary system"@en ;
    skos:definition """Conjunto de ambientes deposicionais geneticamente relacionados que depositaram sedimentos durante um evento ou época geológica. É a base da classificação de reservatórios de águas profundas brasileiros, especialmente os turbidíticos da Bacia de Campos e os carbonáticos do pré-sal de Santos."""@pt ;
    skos:example "Sistema turbidítico de águas profundas" ;
    skos:example "Sistema lacustre carbonático (pré-sal)" ;
    skos:example "Sistema deltaico" ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#DepositionalSystem> ;
    skos:relatedMatch <http://sweetontology.net/procGeo/Sedimentation> ;
    skos:relatedMatch <http://sweetontology.net/realmGeolBasin/SedimentaryBasin> ;
    geo:geocoverage "layer1" ;
    geo:geocoverage "layer1b" ;
    geo:geocoverage "layer2" ;
    geo:ontologicalRole "feature_observation" .

geo:contrato-ep a owl:Class ;
    skos:prefLabel "Contrato E&P"@pt ;
    skos:prefLabel "E&P Contract"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "contrato de E&P"@pt ;
    skos:altLabel "contrato de concessão"@pt ;
    skos:altLabel "contrato de partilha"@pt ;
    skos:altLabel "E&P contract"@en ;
    skos:altLabel "exploration and production contract"@en ;
    skos:altLabel "upstream contract"@en ;
    skos:definition """Contrato de Exploração e Produção assinado entre o agente econômico e a ANP. Estabelece os direitos e obrigações das partes para exploração de petróleo e gás natural em um bloco específico, incluindo o Programa Exploratório Mínimo (PEM) e as condições de produção."""@pt ;
    skos:example "Concessão BM-S-11" ;
    skos:example "Partilha de Libra" ;
    skos:example "Cessão Onerosa de Búzios" ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#ExplorationProductionContract> ;
    geo:geocoverage "layer5" ;
    geo:ontologicalRole "regulatory_anchor" .

geo:pem a owl:Class ;
    skos:prefLabel "PEM"@pt ;
    skos:prefLabel "Minimum Exploratory Programme"@en ;
    geo:entityType "contractual" ;
    skos:definition """Conjunto mínimo de atividades exploratórias que o contratado se compromete a realizar como parte do contrato de concessão ou partilha de produção. A partir da 5ª Rodada (2003), o PEM do 1º período exploratório é expresso em Unidades de Trabalho (UTs) — parâmetro de oferta na licitação — e o do 2º período corresponde obrigatoriamente à perfuração de um poço exploratório. O cumprimento de cada período é garantido por garantia financeira prestada à ANP, devolvida após a entrega dos dados conforme padrões regulatórios."""@pt ;
    geo:geocoverage "layer5" ;
    geo:ontologicalRole "governance_artifact" .

geo:pte a owl:Class ;
    skos:prefLabel "PTE"@pt ;
    skos:prefLabel "Exploratory Work Plan"@en ;
    geo:entityType "contractual" ;
    skos:definition """Instrumento de acompanhamento e fiscalização das atividades exploratórias de cada bloco sob contrato de E&P, substituto do Programa Anual de Trabalho e Orçamento e do Plano de Exploração. Deve ser apresentado em até 90 dias da assinatura do contrato de concessão (ou 180 dias no caso de partilha de produção). Ao longo da vigência, o operador envia anualmente: o PTE previsto (outubro) e o PTE realizado (março). Revisões são permitidas conforme condições da Resolução ANP nº 876/2022. A ANP analisa e aprova cada remessa em até 30 dias. O envio é realizado pelo sistema DPP."""@pt ;
    geo:geocoverage "layer5" ;
    geo:ontologicalRole "governance_artifact" .

geo:pad a owl:Class ;
    skos:prefLabel "PAD"@pt ;
    skos:prefLabel "Discovery Evaluation Plan"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "Plano de Avaliação de Descobertas"@pt ;
    skos:altLabel "PAD"@pt ;
    skos:altLabel "Discovery Evaluation Plan"@en ;
    skos:altLabel "Appraisal Plan"@en ;
    skos:altLabel "DEP"@en ;
    skos:definition """Instrumento pelo qual o concessionário avalia tecnicamente uma descoberta de hidrocarbonetos para determinar sua viabilidade comercial. Elaborado e entregue à ANP conforme a Resolução ANP nº 845/2021, descreve a descoberta e apresenta programa de trabalho com atividades, prazos e investimentos para avaliação. O código do PAD corresponde ao nome da acumulação principal da área avaliada. Após a conclusão, o PAD resulta em RFAD; se a descoberta for comercial, o RFAD fundamenta a Declaração de Comercialidade."""@pt ;
    skos:example "PAD Búzios" ;
    skos:example "PAD Mero" ;
    skos:example "PAD Sépia" ;
    skos:example "PAD Atapu" ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#DiscoveryEvaluationPlan> ;
    geo:geocoverage "layer5" ;
    geo:ontologicalRole "governance_artifact" .

geo:rfad a owl:Class ;
    skos:prefLabel "RFAD"@pt ;
    skos:prefLabel "Discovery Evaluation Final Report"@en ;
    geo:entityType "contractual" ;
    skos:definition """Documento de encerramento do PAD que consolida as atividades de avaliação realizadas e os resultados da interpretação dos dados. A aprovação do RFAD pela ANP é condição necessária para conferir efetividade a uma eventual Declaração de Comercialidade. Em caso de resultado negativo, encerra o PAD sem declaração."""@pt ;
    geo:geocoverage "layer5" ;
    geo:ontologicalRole "governance_artifact" .

geo:rodada-licitacao a owl:Class ;
    skos:prefLabel "Rodada de Licitação"@pt ;
    skos:prefLabel "Bid Round"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "rodada"@pt ;
    skos:altLabel "leilão de blocos"@pt ;
    skos:altLabel "rodada da ANP"@pt ;
    skos:altLabel "bidding round"@en ;
    skos:altLabel "oil auction"@en ;
    skos:altLabel "licensing round"@en ;
    skos:definition """Ato pelo qual o governo leiloa áreas específicas do seu território para fins de exploração mineral. Identifica em qual rodada o bloco exploratório foi arrematado, permitindo rastrear o histórico de concessões e partilhas no Brasil."""@pt ;
    skos:example "1ª Rodada (1999)" ;
    skos:example "17ª Rodada (2022)" ;
    skos:example "1ª Rodada de Partilha (2013, Libra)" ;
    skos:example "Cessão Onerosa (2019)" ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#BiddingRound> ;
    geo:geocoverage "layer5" ;
    geo:ontologicalRole "regulatory_anchor" .

geo:declaracao-comercialidade a owl:Class ;
    skos:prefLabel "Declaração de Comercialidade"@pt ;
    skos:prefLabel "Commerciality Declaration"@en ;
    geo:entityType "contractual" ;
    skos:definition """Declaração formal do concessionário à ANP de que uma descoberta de hidrocarbonetos possui viabilidade econômica para produção. Encerra o PAD com resultado positivo e dá início ao planejamento da área de desenvolvimento."""@pt ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#CommercialityDeclaration> ;
    geo:geocoverage "layer5" ;
