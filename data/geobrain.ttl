geo:wellbore a owl:Class ;
    skos:prefLabel "Trecho Perfurado"@pt ;
    skos:prefLabel "Wellbore"@en ;
    geo:entityType "operational" ;
    skos:altLabel "trecho perfurado"@pt ;
    skos:altLabel "furo"@pt ;
    skos:altLabel "wellbore"@pt ;
    skos:altLabel "poço físico"@pt ;
    skos:altLabel "wellbore"@en ;
    skos:altLabel "borehole"@en ;
    skos:altLabel "drilled hole"@en ;
    skos:definition """Trecho físico perfurado de um poço. Um poço ANP (registro superficial + legal) pode ter múltiplos wellbores em caso de sidetrack ou completação multilateral. Na prática, 1 poço ANP sem sidetrack = 1 wellbore. OSDU separa formalmente Well (registro de superfície) de Wellbore (trecho perfurado físico). O número ANP POCO_NUM corresponde ao Well.WellID no OSDU; o wellbore é gerado automaticamente."""@pt ;
    skos:example "1-RJS-702-RJ (wellbore único)" ;
    skos:example "3-NA-0001-RN-ST1 (sidetrack = segundo wellbore)" ;
    owl:sameAs <https://w3id.org/osdu#Wellbore> ;
    geo:geocoverage "layer1b" ;
    geo:geocoverage "layer2" ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer4" ;
    geo:ontologicalRole "well_anchor" .

geo:topo-formacional a owl:Class ;
    skos:prefLabel "Topo Formacional"@pt ;
    skos:prefLabel "Formation Top / Wellbore Marker"@en ;
    geo:entityType "analytical" ;
    skos:altLabel "topo de formação"@pt ;
    skos:altLabel "marco estratigráfico"@pt ;
    skos:altLabel "pick estratigráfico"@pt ;
    skos:altLabel "marker"@pt ;
    skos:altLabel "formation top"@en ;
    skos:altLabel "wellbore marker"@en ;
    skos:altLabel "stratigraphic pick"@en ;
    skos:altLabel "formation pick"@en ;
    skos:definition """Pick da profundidade (em MD — Measured Depth — e TVD — True Vertical Depth) em que o wellbore intercepta o topo de uma formação geológica. Dado fundamental em correlações estratigráficas entre poços e na construção de modelos de reservatórios 3D. Exemplo: Topo da Formação Barra Velha no poço 1-RJS-702-RJ a MD=4220m / TVD=4105m."""@pt ;
    skos:example "Topo Fm. Barra Velha a 4220m MD" ;
    skos:example "Topo Fm. Macaé a 2890m MD" ;
    skos:example "Base do Sal a 3410m TVD" ;
    owl:sameAs <https://w3id.org/osdu#WellboreMarker> ;
    geo:geocoverage "layer1b" ;
    geo:geocoverage "layer2" ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer4" ;
    geo:ontologicalRole "feature_observation" .

geo:trajetoria-poco a owl:Class ;
    skos:prefLabel "Trajetória do Poço"@pt ;
    skos:prefLabel "Wellbore Trajectory"@en ;
    geo:entityType "analytical" ;
    skos:altLabel "trajetória direcional"@pt ;
    skos:altLabel "survey direcional"@pt ;
    skos:altLabel "desvio do poço"@pt ;
    skos:altLabel "perfil direcional"@pt ;
    skos:altLabel "wellbore trajectory"@en ;
    skos:altLabel "directional survey"@en ;
    skos:altLabel "deviation survey"@en ;
    skos:altLabel "trajectory survey"@en ;
    skos:definition """Survey direcional do wellbore: sequência de medições de profundidade (MD), inclinação e azimute ao longo do trecho perfurado. Permite calcular a posição 3D real do poço (TVD, offsets Norte/Sul/Leste/Oeste). Diferencia poços verticais (inclinação ≈ 0°) de poços direcionais (inclinação > 30°) e poços horizontais (inclinação ≈ 90°). Essencial para visualização 3D de poços offshore e para o cálculo correto de pressão hidrostática."""@pt ;
    skos:example "Poço horizontal pré-sal: 60° inclinação em 2800m TVD" ;
    skos:example "Poço vertical 1-RJS-702-RJ: inclinação < 3°" ;
    owl:sameAs <https://w3id.org/osdu#WellboreTrajectory> ;
    geo:geocoverage "layer1b" ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer4" ;
    geo:ontologicalRole "feature_observation" .

geo:completacao a owl:Class ;
    skos:prefLabel "Completação"@pt ;
    skos:prefLabel "Well Completion"@en ;
    geo:entityType "operational" ;
    skos:altLabel "completação"@pt ;
    skos:altLabel "acabamento de poço"@pt ;
    skos:altLabel "completion"@pt ;
    skos:altLabel "well completion"@en ;
    skos:altLabel "completion"@en ;
    skos:definition """Conjunto de operações e equipamentos instalados no poço após a perfuração para viabilizar a produção segura: revestimento de produção, tubing (coluna de produção), packers, válvulas de subsuperfície (DHSV), perforações (canhoneio) das zonas produtoras e árvore de natal. No OSDU corresponde a master-data--WellboreCompletion, vinculado ao Wellbore. Tipos: completação seca (dry tree, plataforma fixa), molhada (subsea com ANM) ou inteligente (smart well — múltiplas zonas controladas)."""@pt ;
    skos:example "Completação seca (dry tree)" ;
    skos:example "Completação molhada subsea com ANM" ;
    skos:example "Completação inteligente (smart well)" ;
    owl:sameAs <https://w3id.org/osdu#WellboreCompletion> ;
    geo:geocoverage "layer2" ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer4" ;
    geo:ontologicalRole "well_operation" .

geo:unidade-medida a owl:Class ;
    skos:prefLabel "Unidade de Medida"@pt ;
    skos:prefLabel "Unit of Measure"@en ;
    geo:entityType "instrument" ;
    skos:altLabel "unidade"@pt ;
    skos:altLabel "unidade SI"@pt ;
    skos:altLabel "unidade imperial"@pt ;
    skos:altLabel "UOM"@pt ;
    skos:altLabel "unit of measure"@en ;
    skos:altLabel "UOM"@en ;
    skos:altLabel "unit"@en ;
    skos:altLabel "measurement unit"@en ;
    skos:definition """Vocabulário controlado de unidades de medida usadas nos dados de subsuperfície. Crítico para interoperabilidade entre sistemas: ANP/Petrobras usa SI (metros, MPa, m³/d) enquanto dados legados e internacionais frequentemente usam sistema imperial (ft, psi, bbl/d). O mD (miliDarcy) é um caso especial — unidade do sistema CGS-Gaussian amplamente usada em petrofísica. A conversão de unidades sem referência ao vocabulário OSDU é fonte frequente de erros em integração de dados."""@pt ;
    skos:example "mD (miliDarcy) — permeabilidade" ;
    skos:example "ºAPI (API gravity) — densidade óleo" ;
    skos:example "GAPI (Gamma Ray API) — argilosidade" ;
    owl:sameAs <https://w3id.org/osdu#UnitOfMeasure> ;
    geo:geocoverage "layer2" ;
    geo:geocoverage "layer3" ;
    geo:geocoverage "layer4" ;
    geo:ontologicalRole "well_attribute_concept" .

