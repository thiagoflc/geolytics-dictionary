    skos:altLabel "MWD"@pt ;
    skos:altLabel "Corrida MWD/LWD"@pt ;
    skos:altLabel "LWD"@en ;
    skos:altLabel "MWD"@en ;
    skos:altLabel "Logging While Drilling"@en ;
    skos:altLabel "Measurement While Drilling"@en ;
    skos:definition """Corrida única LWD/MWD — fase, BHA, prestadora, stack de ferramentas, curvas em tempo real vs memória, versão WITSML, taxas de amostragem e ID do log no EXATA. Distinção MWD (medidas direcionais/perfuração) vs LWD (avaliação de formação durante perfuração) per PE-2EXP-00061."""@pt .

geo:wireline-run a owl:Class ;
    skos:prefLabel "Corrida de Perfilagem a Cabo"@pt ;
    skos:prefLabel "Wireline Logging Run"@en ;
    geo:entityType "analytical" ;
