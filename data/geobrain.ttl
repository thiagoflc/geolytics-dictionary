#
# Layer1 (GeoCore) ↔ Layer1b (GeoSciML + CGI Simple Lithology) equivalences
# Source: data/layer1-layer1b-equivalence.json — Semantic equivalences between layer1 (BFO+GeoCore) and layer1b (GeoSciML+CGI Simple Lithology)
# Generated: 2026-05-03
#

<http://loop3d.org/GKO/geocore#GeologicUnit> skos:exactMatch <http://geosciml.org/def/gsmlb#GeologicUnit> .
<http://loop3d.org/GKO/geocore#GeologicBody> owl:equivalentClass <http://geosciml.org/def/gsmlb#GeologicUnit> .
<http://loop3d.org/GKO/geocore#Borehole> owl:equivalentClass <http://geosciml.org/def/gsmlbh#Borehole> .
<http://loop3d.org/GKO/geocore#GeologicStructure> skos:exactMatch <http://geosciml.org/def/gsmlb#GeologicStructure> .
<http://loop3d.org/GKO/geocore#FaultZone> skos:broadMatch <http://geosciml.org/def/gsmlb#ShearDisplacementStructure> .
<http://loop3d.org/GKO/geocore#Contact> skos:exactMatch <http://geosciml.org/def/gsmlb#Contact> .
<http://loop3d.org/GKO/geocore#Fold> skos:exactMatch <http://geosciml.org/def/gsmlb#Fold> .
<http://loop3d.org/GKO/geocore#Foliation> skos:exactMatch <http://geosciml.org/def/gsmlb#Foliation> .
<http://loop3d.org/GKO/geocore#Lineation> skos:exactMatch <http://geosciml.org/def/gsmlb#Lineation> .
<http://loop3d.org/GKO/geocore#RockMaterial> skos:exactMatch <http://geosciml.org/def/gsmlb#RockMaterial> .
<http://loop3d.org/GKO/geocore#RockMaterial> skos:narrowMatch <http://resource.geosciml.org/classifier/cgi/lithOntology/sedimentary_material> .
<http://loop3d.org/GKO/geocore#GeologicFeature> skos:broadMatch <http://geosciml.org/def/gsmlb#MappedFeature> .
<http://loop3d.org/GKO/geocore#GeologicEvent> skos:exactMatch <http://geosciml.org/def/gsmlb#GeologicEvent> .
<http://loop3d.org/GKO/geocore#EarthMaterial> skos:exactMatch <http://geosciml.org/def/gsmlb#EarthMaterial> .

#
# SHACL property shapes — geo:Poco (gsmlbh borehole properties, layer1b)
# Source: GeoSciML Borehole (gsmlbh) Module
#

@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix gsmlbh: <http://geosciml.org/def/gsmlbh#> .

geo:PocoShape a sh:NodeShape ;
    sh:targetClass geo:Poco ;
    rdfs:label "Forma de Poço — Propriedades gsmlbh"@pt ;
    rdfs:label "Well Shape — gsmlbh borehole properties"@en ;
    sh:property [
        sh:path gsmlbh:boreholeDiameter ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        rdfs:label "Diâmetro do Poço"@pt ;
    ] ;
    sh:property [
        sh:path gsmlbh:dateOfDrilling ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
        rdfs:label "Data de Perfuração"@pt ;
    ] ;
    sh:property [
        sh:path gsmlbh:drillingMethod ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        rdfs:label "Método de Perfuração"@pt ;
    ] ;
    sh:property [
        sh:path gsmlbh:inclinationType ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:in ( "vertical" "deviated" "horizontal" ) ;
        rdfs:label "Tipo de Inclinação"@pt ;
    ] .

#
# W3C SOSA/SSN + QUDT minimal alignment
# Source: data/sosa-qudt-alignment.json
#

geo:WellLog rdfs:subClassOf sosa:ObservationCollection .
geo:WellLog rdfs:comment "A well log is a collection of SOSA observations on a geological formation." .

geo:PorePressureObservation rdfs:subClassOf sosa:Observation .
geo:PorePressureObservation rdfs:comment "A formation pore pressure measurement; direct SOSA observation with qudt:Pressure result." .

geo:CoreSample rdfs:subClassOf ssn:Sample .
geo:CoreSample rdfs:comment "A physical core plug retrieved from the borehole; maps to ssn:Sample per W3C SSN." .

geo:poco rdfs:subClassOf sosa:FeatureOfInterest .
geo:formacao rdfs:subClassOf sosa:FeatureOfInterest .

geo:lwd-run rdfs:subClassOf sosa:Sampling .
geo:wireline-run rdfs:subClassOf sosa:Sampling .
