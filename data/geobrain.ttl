geo:reservatorio a owl:Class ;
    skos:prefLabel "Reservatório"@pt ;
    skos:prefLabel "Reservoir"@en ;
    geo:entityType "operational" ;
    skos:altLabel "reservatório"@pt ;
    skos:altLabel "rocha-reservatório"@pt ;
    skos:altLabel "corpo reservatório"@pt ;
    skos:altLabel "reservoir"@en ;
    skos:altLabel "reservoir rock"@en ;
    skos:altLabel "pay zone"@en ;
    skos:definition """Corpo rochoso poroso e permeável capaz de armazenar e produzir hidrocarbonetos sob condições de pressão e temperatura adequadas. Equivale ao GeologicalBody do GeoCore com propriedades de porosidade e permeabilidade. O reservatório é a unidade econômica fundamental da exploração de petróleo."""@pt ;
    skos:example "Reservatórios carbonáticos do pré-sal (Coquinas)" ;
    skos:example "Reservatórios turbidíticos de Campos" ;
    skos:example "Reservatório Barra Velha" ;
    owl:sameAs <https://w3id.org/osdu#Reservoir> ;
    rdfs:seeAlso <https://raw.githubusercontent.com/Petroles/PetroNLP/main/Petro%20KGraph%20public.owl#Reservoir> ;
