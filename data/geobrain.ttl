    skos:altLabel "estado normal"@pt ;
    skos:altLabel "normal operation"@en ;
    skos:altLabel "normal state"@en ;
    skos:definition """Estado de referência do poço: produção estável, todas as variáveis dentro da faixa operacional nominal. Rótulo 3W classe 0."""@pt ;
    skos:example "Classe 0 é o baseline para treinamento de modelos de detecção de anomalias" ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" ;
    geo:ontologicalRole "feature_observation" .

geo:event_bsw_increase a owl:Class ;
    skos:prefLabel "Aumento Abrupto de BSW"@pt ;
    skos:prefLabel "Abrupt Increase of BSW"@en ;
    geo:entityType "operational" ;
    skos:altLabel "aumento BSW"@pt ;
    skos:altLabel "surgência de água"@pt ;
    skos:altLabel "irrupção de água"@pt ;
    skos:altLabel "BSW increase"@en ;
    skos:altLabel "water breakthrough"@en ;
    skos:altLabel "water influx"@en ;
    skos:definition """Aumento súbito do BSW (Basic Sediment and Water — fração de água e sedimentos na produção). Indica influxo de água de formação ou quebra de barreira de óleo/água. Rótulo 3W classe 1 (transiente: 101)."""@pt ;
    skos:example "BSW abrupto indica comunicação com aquífero ou falha de barreira" ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" ;
    geo:ontologicalRole "feature_observation" .

geo:event_spurious_dhsv a owl:Class ;
    skos:prefLabel "Fechamento Espúrio de DHSV"@pt ;
    skos:prefLabel "Spurious Closure of DHSV"@en ;
    geo:entityType "operational" ;
    skos:altLabel "fechamento espúrio DHSV"@pt ;
    skos:altLabel "fechamento não-intencional DHSV"@pt ;
    skos:altLabel "spurious DHSV closure"@en ;
    skos:altLabel "unintended DHSV closure"@en ;
    skos:definition """Fechamento não-intencional da DHSV (válvula de segurança de subsuperfície) sem causa operacional justificada. Causa queda abrupta de P-PDG e P-TPT. Rótulo 3W classe 2 (transiente: 102). Janela de análise: 180 s, passo: 15 s."""@pt ;
    skos:example "ESTADO-DHSV=0 com queda de P-PDG confirma fechamento espúrio" ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" ;
    geo:ontologicalRole "feature_observation" .

geo:event_severe_slugging a owl:Class ;
    skos:prefLabel "Golfadas Severas"@pt ;
    skos:prefLabel "Severe Slugging"@en ;
    geo:entityType "operational" ;
    skos:altLabel "golfadas severas"@pt ;
    skos:altLabel "slugging severo"@pt ;
    skos:altLabel "padrão de golfadas"@pt ;
    skos:altLabel "severe slugging"@en ;
    skos:altLabel "riser slugging"@en ;
    skos:altLabel "terrain slugging"@en ;
    skos:definition """Padrão de fluxo bifásico instável caracterizado por golfadas longas de líquido alternadas com bolsões de gás na linha de produção riser. Causa oscilações cíclicas em P-TPT e P-PDG. Rótulo 3W classe 3 (sem transiente)."""@pt ;
    skos:example "Ciclo de golfada severa: bloqueio de gás → acúmulo de líquido → irrupção → blow-out" ;
    skos:example "P-TPT e P-PDG oscilatórios são assinatura de severe slugging" ;
    skos:relatedMatch <http://sweetontology.net/phenFluidDynamics/FlowInstability> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" ;
    geo:ontologicalRole "feature_observation" .

geo:event_flow_instability a owl:Class ;
    skos:prefLabel "Instabilidade de Fluxo"@pt ;
    skos:prefLabel "Flow Instability"@en ;
    geo:entityType "operational" ;
    skos:altLabel "instabilidade de fluxo"@pt ;
    skos:altLabel "fluxo instável"@pt ;
    skos:altLabel "oscilação de fluxo"@pt ;
    skos:altLabel "flow instability"@en ;
    skos:altLabel "flow oscillation"@en ;
    skos:altLabel "unstable flow"@en ;
    skos:definition """Instabilidade de fluxo multifásico no poço, com oscilações irregulares de pressão e vazão. Diferencia-se de golfadas severas por padrão menos periódico. Rótulo 3W classe 4 (sem transiente)."""@pt ;
    skos:example "Instabilidade de fluxo pode anteceder golfadas severas" ;
    skos:relatedMatch <http://sweetontology.net/phenFluidDynamics/FlowInstability> ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" ;
    geo:ontologicalRole "feature_observation" .

geo:event_rapid_prod_loss a owl:Class ;
    skos:prefLabel "Perda Rápida de Produtividade"@pt ;
    skos:prefLabel "Rapid Productivity Loss"@en ;
    geo:entityType "operational" ;
    skos:altLabel "perda produtividade"@pt ;
    skos:altLabel "declínio rápido"@pt ;
    skos:altLabel "queda de produção"@pt ;
    skos:altLabel "rapid productivity loss"@en ;
    skos:altLabel "productivity decline"@en ;
    skos:altLabel "production drop"@en ;
    skos:definition """Queda rápida e persistente da produtividade do poço, indicada por redução de P-PDG e QGL sem ação operacional. Pode ser causada por dano à formação, incrustação de fundo ou mudança na permeabilidade efetiva. Rótulo 3W classe 5 (transiente: 105)."""@pt ;
    skos:example "P-PDG declining faster than expected pode indicar skin damage" ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" ;
    geo:ontologicalRole "feature_observation" .

geo:event_quick_pck_restriction a owl:Class ;
    skos:prefLabel "Restrição Rápida no PCK"@pt ;
    skos:prefLabel "Quick Restriction in PCK"@en ;
    geo:entityType "operational" ;
    skos:altLabel "restrição rápida PCK"@pt ;
    skos:altLabel "obstrução rápida choke"@pt ;
    skos:altLabel "quick PCK restriction"@en ;
    skos:altLabel "rapid choke restriction"@en ;
    skos:altLabel "choke obstruction"@en ;
    skos:definition """Redução rápida e abrupta da abertura do PCK (production choke) ou da seção de passagem, causando aumento do diferencial de pressão. Pode ser causada por objeto sólido, wax ou hidrato parcial. Rótulo 3W classe 6 (transiente: 106)."""@pt ;
    skos:example "ABER-CKP caindo abruptamente com diferencial de pressão crescente é assinatura de classe 6" ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" ;
    geo:ontologicalRole "feature_observation" .

geo:event_scaling_pck a owl:Class ;
    skos:prefLabel "Incrustação no PCK"@pt ;
    skos:prefLabel "Scaling in PCK"@en ;
    geo:entityType "operational" ;
    skos:altLabel "incrustação PCK"@pt ;
    skos:altLabel "scaling choke"@pt ;
    skos:altLabel "deposição mineral choke"@pt ;
    skos:altLabel "PCK scaling"@en ;
    skos:altLabel "choke scaling"@en ;
    skos:altLabel "mineral deposition in choke"@en ;
    skos:definition """Deposição progressiva de incrustações minerais (carbonato de cálcio, barita, etc.) no PCK (production choke), causando redução gradual da abertura efetiva. Distingue-se de restrição rápida pelo ritmo de crescimento do diferencial de pressão. Rótulo 3W classe 7 (transiente: 107)."""@pt ;
    skos:example "T-MON-CKP elevada com diferencial crescente ao longo do tempo é assinatura de scaling" ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" ;
    geo:ontologicalRole "feature_observation" .

