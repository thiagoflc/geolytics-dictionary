    skos:altLabel "XRD"@en ;
    skos:altLabel "X-Ray Diffraction"@en ;
    skos:definition """Técnica analítica de identificação mineralógica baseada na difração de raios X em amostras de rocha. Permite caracterizar mineralogia e auxiliar a classificação litológica. Detalhada em data/operacoes-geologicas.json (OG013)."""@pt ;
    geo:geocoverage "layer4" ;
    geo:geocoverage "layer6" .

geo:frx a owl:Class ;
    skos:prefLabel "Fluorescência de Raios X"@pt ;
    skos:prefLabel "X-Ray Fluorescence"@en ;
