geo:roa a owl:Class ;
    skos:prefLabel "Relatório de Ocorrências Anômalas"@pt ;
    skos:prefLabel "Anomalous Occurrences Report (ROA)"@en ;
    geo:entityType "contractual" ;
    skos:altLabel "relatório de ocorrências anômalas"@pt ;
