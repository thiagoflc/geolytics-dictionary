    skos:altLabel "indício de hidrocarboneto"@pt ;
    skos:altLabel "gas show"@en ;
    skos:altLabel "hydrocarbon show"@en ;
    skos:definition """Evento discreto de indício de gás/óleo detectado durante o mudlogging. Complementa a série temporal contínua com valores de pico, análise de razões (wetness/balance/character) e metadados de coleta em vacutainer."""@pt .

geo:kick-event a owl:Class ;
    skos:prefLabel "Evento Discreto de Kick"@pt ;
    skos:prefLabel "Kick Event"@en ;
    geo:entityType "analytical" ;
    skos:altLabel "kick"@pt ;
    skos:altLabel "well kick"@en ;
    skos:altLabel "influx event"@en ;
    skos:definition """Evento discreto de kick (influxo de formação). Mesma entidade conceitual do registro OGEOMEC com TipoOcorrencia='Kick' no módulo pai — este esquema é a visão geológica resolvida no tempo; OGEOMEC é o registro de ocorrência geomecânica."""@pt .

geo:cuttings-sample-detailed a owl:Class ;
