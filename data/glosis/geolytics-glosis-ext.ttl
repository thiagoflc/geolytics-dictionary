# ============================================================================
# 5. SOSA Property/Value hints — módulos M7/M8/M9/M10 (modules-extended.json)
# ============================================================================
# Pattern declaration only — classes individuais ficam em arquivo geolytics-modules.ttl separado.
#

# Geoquímica Orgânica e Inorgânica (M7_geochem)
geox:m7-geochem-pattern a owl:NamedIndividual ;
    rdfs:label "Geoquímica Orgânica e Inorgânica"@pt ;
    geox:quantityKindDefault <http://qudt.org/vocab/quantitykind/MassFraction> ;
    rdfs:comment """Geochemistry: mass fractions, %, ppm, mg/g — use cmol/L (glosis_u:CentiMOL-PER-L) for cation exchange."""@pt .

# Rocha e Petrofísica (M8_rock)
geox:m8-rock-pattern a owl:NamedIndividual ;
    rdfs:label "Rocha e Petrofísica"@pt ;
    geox:quantityKindDefault <http://qudt.org/vocab/quantitykind/Porosity> ;
    rdfs:comment """Rock physics: bulk density (g/cm3 or kg/m3), porosity (fraction), permeability (mD = milliDarcy)."""@pt .

# Geomecânica de Reservatório (M9_geomec)
geox:m9-geomec-pattern a owl:NamedIndividual ;
    rdfs:label "Geomecânica de Reservatório"@pt ;
    geox:quantityKindDefault <http://qudt.org/vocab/quantitykind/Pressure> ;
    rdfs:comment """Geomechanics: stress (psi/MPa), Young modulus (GPa), Poisson ratio (dimensionless)."""@pt .

# Fluidos — Geoquímica e PVT (M10_fluidos)
geox:m10-fluidos-pattern a owl:NamedIndividual ;
    rdfs:label "Fluidos — Geoquímica e PVT"@pt ;
    geox:quantityKindDefault <http://qudt.org/vocab/quantitykind/Density> ;
    rdfs:comment """PVT/fluids: pressure (psi), temperature (°C), density (g/cm3), GOR (scf/stb), Bo (rbbl/stb)."""@pt .


# ============================================================================
# 6. Sample SHACL-style hints (informational — full shapes em arquivo .shapes.ttl)
# ============================================================================
# Validações implícitas pelo padrão GLOSIS:
#   - Cada qudt:Quantity DEVE ter qudt:numericValue + qudt:unit
#   - Cada glosis_ob:GL_Observation DEVE ter sosa:hasResult + sosa:observedProperty
#   - Cada iso28258:ProfileElement DEVE ter upperDepth ≤ lowerDepth (xsd:decimal, em metros)

# === EOF ===
