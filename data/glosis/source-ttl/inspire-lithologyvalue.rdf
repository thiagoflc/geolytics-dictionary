      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:05 PM UTC</dct:created>
      <dct:title xml:lang="en">schist</dct:title>
      <skos:prefLabel xml:lang="en">schist</skos:prefLabel>
      <dct:description xml:lang="en">Foliated phaneritic metamorphic rock with well developed, continuous schistosity, meaning that greater than 50 percent of the rock by volume is mineral grains with a thin tabular, lamellar, or acicular prismatic crystallographic habit that are oriented in a continuous planar or linear fabric.</dct:description>
      <skos:definition xml:lang="en">Foliated phaneritic metamorphic rock with well developed, continuous schistosity, meaning that greater than 50 percent of the rock by volume is mineral grains with a thin tabular, lamellar, or acicular prismatic crystallographic habit that are oriented in a continuous planar or linear fabric.</skos:definition>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/micaSchist"/>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/foliatedMetamorphicRock"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/applicationschema/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/theme/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/registry/governance-level/eu-technical"/>
      <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
   </rdf:Description>
   <rdf:Description rdf:about="http://inspire.ec.europa.eu/codelist/LithologyValue/micaSchist">
      <dct:identifier rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">http://inspire.ec.europa.eu/codelist/LithologyValue/micaSchist</dct:identifier>
      <dcat:isPartOf>
         <dcat:Catalog rdf:about="http://inspire.ec.europa.eu/registry"/>
      </dcat:isPartOf>
      <dcat:isPartOf>
         <dcat:Catalog rdf:about="http://inspire.ec.europa.eu/codelist"/>
      </dcat:isPartOf>
      <owl:sameAs rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/micaSchist:1"/>
