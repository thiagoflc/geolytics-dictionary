      <dct:title xml:lang="en">sedimentary material</dct:title>
      <skos:prefLabel xml:lang="en">sedimentary material</skos:prefLabel>
      <dct:description xml:lang="en">Material formed by accumulation of solid fragmental material deposited by air, water or ice, or material that accumulated by other natural agents such as chemical precipitation from solution or secretion by organisms.</dct:description>
      <skos:definition xml:lang="en">Material formed by accumulation of solid fragmental material deposited by air, water or ice, or material that accumulated by other natural agents such as chemical precipitation from solution or secretion by organisms.</skos:definition>
