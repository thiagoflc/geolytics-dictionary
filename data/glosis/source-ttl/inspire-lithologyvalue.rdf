      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 17:31 PM UTC</dct:created>
      <dct:title xml:lang="en">tuffite</dct:title>
      <skos:prefLabel xml:lang="en">tuffite</skos:prefLabel>
      <dct:description xml:lang="en">Rock consists of more than 50 percent particles of indeterminate pyroclastic or epiclastic origin and less than 75 percent particles of clearly pyroclastic origin.</dct:description>
      <skos:definition xml:lang="en">Rock consists of more than 50 percent particles of indeterminate pyroclastic or epiclastic origin and less than 75 percent particles of clearly pyroclastic origin.</skos:definition>
