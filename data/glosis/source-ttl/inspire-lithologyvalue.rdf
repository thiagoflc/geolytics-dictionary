      <skos:inScheme rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue"/>
      <skos:topConceptOf rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue"/>
      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 17:30 PM UTC</dct:created>
      <dct:title xml:lang="en">sedimentary rock</dct:title>
      <skos:prefLabel xml:lang="en">sedimentary rock</skos:prefLabel>
      <dct:description xml:lang="en">Rock formed by accumulation and cementation of solid fragmental material deposited by air, water or ice, or as a result of other natural agents, such as precipitation from solution, the accumulation of organicMaterial, or from biogenic processes, including secretion by organisms.</dct:description>
      <skos:definition xml:lang="en">Rock formed by accumulation and cementation of solid fragmental material deposited by air, water or ice, or as a result of other natural agents, such as precipitation from solution, the accumulation of organicMaterial, or from biogenic processes, including secretion by organisms.</skos:definition>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/genericConglomerate"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/genericMudstone"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/genericSandstone"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/hybridSedimentaryRock"/>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/rock"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/applicationschema/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/theme/ge"/>
