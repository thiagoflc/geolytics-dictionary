      <skos:prefLabel xml:lang="en">composite genesis rock</skos:prefLabel>
      <dct:description xml:lang="en">Rock formed by geological modification of pre-existing rocks outside the realm of igneous and sedimentary processes.</dct:description>
      <skos:definition xml:lang="en">Rock formed by geological modification of pre-existing rocks outside the realm of igneous and sedimentary processes.</skos:definition>
