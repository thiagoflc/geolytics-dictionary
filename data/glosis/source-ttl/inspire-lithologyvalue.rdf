      <dct:title xml:lang="en">organic bearing mudstone</dct:title>
      <skos:prefLabel xml:lang="en">organic bearing mudstone</skos:prefLabel>
      <dct:description xml:lang="en">Mudstone that contains a significant amount of organic carbon, typically kerogen. Commonly finely laminated, brown or black in color.</dct:description>
      <skos:definition xml:lang="en">Mudstone that contains a significant amount of organic carbon, typically kerogen. Commonly finely laminated, brown or black in color.</skos:definition>
