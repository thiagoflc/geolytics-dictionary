      <skos:prefLabel xml:lang="en">phonolitic foidite</skos:prefLabel>
      <dct:description xml:lang="en">Foiditoid that contains less than 90 percent feldspathoid minerals in the QAPF fraction, and has a plagioclase to total feldspar ratio that is less than 0.5</dct:description>
