      <adms:last rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/grainstone"/>
      <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
      <skos:inScheme rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue"/>
      <skos:topConceptOf rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue"/>
      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:03 PM UTC</dct:created>
      <dct:title xml:lang="en">grainstone</dct:title>
      <skos:prefLabel xml:lang="en">grainstone</skos:prefLabel>
      <dct:description xml:lang="en">Carbonate sedimentary rock with recognizable depositional fabric that is grain-supported, and constituent particles are of intrabasinal origin; contains little or no mud matrix. Distinction from sandstone is based on interpretation of intrabasinal origin of clasts and grain-supported fabric, but grainstone definition does not include a grain size criteria.</dct:description>
      <skos:definition xml:lang="en">Carbonate sedimentary rock with recognizable depositional fabric that is grain-supported, and constituent particles are of intrabasinal origin; contains little or no mud matrix. Distinction from sandstone is based on interpretation of intrabasinal origin of clasts and grain-supported fabric, but grainstone definition does not include a grain size criteria.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/carbonateSedimentaryRock"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/applicationschema/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/theme/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/registry/governance-level/eu-technical"/>
      <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
   </rdf:Description>
