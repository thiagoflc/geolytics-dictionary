      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:02 PM UTC</dct:created>
      <dct:title xml:lang="en">duricrust</dct:title>
      <skos:prefLabel xml:lang="en">duricrust</skos:prefLabel>
      <dct:description xml:lang="en">Rock forming a hard crust or layer at or near the Earth's surface at the time of formation, e.g. in the upper horizons of a soil, characterized by structures indicative of pedogenic origin.</dct:description>
      <skos:definition xml:lang="en">Rock forming a hard crust or layer at or near the Earth's surface at the time of formation, e.g. in the upper horizons of a soil, characterized by structures indicative of pedogenic origin.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/compositeGenesisRock"/>
