      <dct:title xml:lang="en">evaporite</dct:title>
      <skos:prefLabel xml:lang="en">evaporite</skos:prefLabel>
      <dct:description xml:lang="en">Nonclastic sedimentary rock composed of at least 50 percent non-carbonate salts, including chloride, sulfate or borate minerals; formed through precipitation of mineral salts from a saline solution (non-carbonate salt rock).</dct:description>
      <skos:definition xml:lang="en">Nonclastic sedimentary rock composed of at least 50 percent non-carbonate salts, including chloride, sulfate or borate minerals; formed through precipitation of mineral salts from a saline solution (non-carbonate salt rock).</skos:definition>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/exoticEvaporite"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/gypsumOrAnhydrite"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/rockSalt"/>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/chemicalSedimentaryMaterial"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/applicationschema/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/theme/ge"/>
