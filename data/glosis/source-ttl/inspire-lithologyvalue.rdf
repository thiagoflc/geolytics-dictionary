   <rdf:Description rdf:about="http://inspire.ec.europa.eu/codelist/LithologyValue/dioritoid">
      <dct:identifier rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">http://inspire.ec.europa.eu/codelist/LithologyValue/dioritoid</dct:identifier>
      <dcat:isPartOf>
         <dcat:Catalog rdf:about="http://inspire.ec.europa.eu/registry"/>
      </dcat:isPartOf>
      <dcat:isPartOf>
         <dcat:Catalog rdf:about="http://inspire.ec.europa.eu/codelist"/>
