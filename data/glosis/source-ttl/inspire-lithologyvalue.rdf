      <dct:title xml:lang="en">shale</dct:title>
      <skos:prefLabel xml:lang="en">shale</skos:prefLabel>
      <dct:description xml:lang="en">Laminated mudstone that will part or break along thin, closely spaced layers parallel to stratification.</dct:description>
      <skos:definition xml:lang="en">Laminated mudstone that will part or break along thin, closely spaced layers parallel to stratification.</skos:definition>
