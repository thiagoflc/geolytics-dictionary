      <dct:title xml:lang="en">exotic evaporite</dct:title>
      <skos:prefLabel xml:lang="en">exotic evaporite</skos:prefLabel>
      <dct:description xml:lang="en">Evaporite that is not 50 percent halite or 50 percent gypsum or anhydrite.</dct:description>
      <skos:definition xml:lang="en">Evaporite that is not 50 percent halite or 50 percent gypsum or anhydrite.</skos:definition>
