      <dct:title xml:lang="en">chlorite actinolite epidote metamorphic rock</dct:title>
      <skos:prefLabel xml:lang="en">chlorite actinolite epidote metamorphic rock</skos:prefLabel>
      <dct:description xml:lang="en">Metamorphic rock characterized by 50 percent or more of combined chlorite, actinolite and epidote. Category for rocks generally named greenschist or greenstone.</dct:description>
      <skos:definition xml:lang="en">Metamorphic rock characterized by 50 percent or more of combined chlorite, actinolite and epidote. Category for rocks generally named greenschist or greenstone.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/metamorphicRock"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/applicationschema/ge"/>
