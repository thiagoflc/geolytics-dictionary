         <dcat:Catalog rdf:about="http://inspire.ec.europa.eu/codelist"/>
      </dcat:isPartOf>
      <owl:sameAs rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/granitoid:1"/>
      <adms:last rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/granitoid"/>
