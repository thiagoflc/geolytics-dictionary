      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:01 PM UTC</dct:created>
      <dct:title xml:lang="en">boninite</dct:title>
      <skos:prefLabel xml:lang="en">boninite</skos:prefLabel>
      <dct:description xml:lang="en">andesitic rock that contains more than 8 percent MgO. Typically consists of phenocrysts of protoenstatite, orthopyroxene, clinopyroxene, and olivine in a glassy base full of crystallites, and exhibits textures characterisitc of rapid crystal growth.</dct:description>
      <skos:definition xml:lang="en">andesitic rock that contains more than 8 percent MgO. Typically consists of phenocrysts of protoenstatite, orthopyroxene, clinopyroxene, and olivine in a glassy base full of crystallites, and exhibits textures characterisitc of rapid crystal growth.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/andesite"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/applicationschema/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/theme/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/registry/governance-level/eu-technical"/>
      <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
   </rdf:Description>
