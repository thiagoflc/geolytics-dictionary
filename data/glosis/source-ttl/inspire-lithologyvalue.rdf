      <dct:title xml:lang="en">phosphate rich sedimentary material</dct:title>
      <skos:prefLabel xml:lang="en">phosphate rich sedimentary material</skos:prefLabel>
      <dct:description xml:lang="en">Sedimentary material in which at least 50 percent of the primary and/or recrystallized constituents are phosphate minerals.</dct:description>
      <skos:definition xml:lang="en">Sedimentary material in which at least 50 percent of the primary and/or recrystallized constituents are phosphate minerals.</skos:definition>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/phosphorite"/>
