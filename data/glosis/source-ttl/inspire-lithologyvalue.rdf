      <skos:prefLabel xml:lang="en">igneous material</skos:prefLabel>
      <dct:description xml:lang="en">Earth material formed as a result of igneous processes, e.g. intrusion and cooling of magma in the crust, volcanic eruption.</dct:description>
      <skos:definition xml:lang="en">Earth material formed as a result of igneous processes, e.g. intrusion and cooling of magma in the crust, volcanic eruption.</skos:definition>
