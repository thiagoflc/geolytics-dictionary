      <skos:prefLabel xml:lang="en">marble</skos:prefLabel>
      <dct:description xml:lang="en">Metamorphic rock consisting of greater than 75 percent fine- to coarse-grained recrystallized calcite and/or dolomite; usually with a granoblastic, saccharoidal texture.</dct:description>
      <skos:definition xml:lang="en">Metamorphic rock consisting of greater than 75 percent fine- to coarse-grained recrystallized calcite and/or dolomite; usually with a granoblastic, saccharoidal texture.</skos:definition>
