      <dct:title xml:lang="en">generic mudstone</dct:title>
      <skos:prefLabel xml:lang="en">generic mudstone</skos:prefLabel>
      <dct:description xml:lang="en">Sedimentary rock consisting of less than 30 percent gravel-size (2 mm) particles and with a mud to sand ratio greater than 1. Clasts may be of any composition or origin.</dct:description>
      <skos:definition xml:lang="en">Sedimentary rock consisting of less than 30 percent gravel-size (2 mm) particles and with a mud to sand ratio greater than 1. Clasts may be of any composition or origin.</skos:definition>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/organicBearingMudstone"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/silicateMudstone"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/carbonateRichMudstone"/>
