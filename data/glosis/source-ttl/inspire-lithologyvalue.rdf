      <dct:title xml:lang="en">dolomitic or magnesian sedimentary rock</dct:title>
      <skos:prefLabel xml:lang="en">dolomitic or magnesian sedimentary rock</skos:prefLabel>
      <dct:description xml:lang="en">Carbonate sedimentary rock with a ratio of magnesium carbonate to calcite (plus aragonite) greater than 1 to 1. Includes dolostone, lime dolostone and magnesite-stone.</dct:description>
      <skos:definition xml:lang="en">Carbonate sedimentary rock with a ratio of magnesium carbonate to calcite (plus aragonite) greater than 1 to 1. Includes dolostone, lime dolostone and magnesite-stone.</skos:definition>
