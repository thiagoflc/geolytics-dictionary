      <dct:title xml:lang="en">biogenic silica sedimentary rock</dct:title>
      <skos:prefLabel xml:lang="en">biogenic silica sedimentary rock</skos:prefLabel>
      <dct:description xml:lang="en">Sedimentary rock that consists of at least 50 percent silicate mineral material, deposited directly by biological processes at the depositional surface, or in particles formed by biological processes within the basin of deposition.</dct:description>
      <skos:definition xml:lang="en">Sedimentary rock that consists of at least 50 percent silicate mineral material, deposited directly by biological processes at the depositional surface, or in particles formed by biological processes within the basin of deposition.</skos:definition>
