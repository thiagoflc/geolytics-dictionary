      <dct:title xml:lang="en">quartzite</dct:title>
      <skos:prefLabel xml:lang="en">quartzite</skos:prefLabel>
      <dct:description xml:lang="en">Metamorphic rock consisting of greater than or equal to 75 percent quartz; typically granoblastic texture.</dct:description>
      <skos:definition xml:lang="en">Metamorphic rock consisting of greater than or equal to 75 percent quartz; typically granoblastic texture.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/metamorphicRock"/>
