      <dct:title xml:lang="en">calcareous carbonate sedimentary material</dct:title>
      <skos:prefLabel xml:lang="en">calcareous carbonate sedimentary material</skos:prefLabel>
      <dct:description xml:lang="en">Carbonate sedimentary material of unspecified consolidation state with a calcite (plus aragonite) to dolomite ratio greater than 1 to 1. Includes lime-sediments, limestone and dolomitic limestone.</dct:description>
      <skos:definition xml:lang="en">Carbonate sedimentary material of unspecified consolidation state with a calcite (plus aragonite) to dolomite ratio greater than 1 to 1. Includes lime-sediments, limestone and dolomitic limestone.</skos:definition>
