      <skos:prefLabel xml:lang="en">limestone</skos:prefLabel>
      <dct:description xml:lang="en">Pure carbonate sedimentary rock with a calcite (plus aragonite) to dolomite ratio greater than 1 to 1. Includes limestone and dolomitic limestone.</dct:description>
      <skos:definition xml:lang="en">Pure carbonate sedimentary rock with a calcite (plus aragonite) to dolomite ratio greater than 1 to 1. Includes limestone and dolomitic limestone.</skos:definition>
