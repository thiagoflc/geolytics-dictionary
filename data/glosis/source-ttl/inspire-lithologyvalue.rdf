      <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
      <skos:inScheme rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue"/>
      <skos:topConceptOf rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue"/>
      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:01 PM UTC</dct:created>
      <dct:title xml:lang="en">anorthositic rock</dct:title>
      <skos:prefLabel xml:lang="en">anorthositic rock</skos:prefLabel>
      <dct:description xml:lang="en">Leucocratic phaneritic crystalline igneous rock consisting essentially of plagioclase, often with small amounts of pyroxene. By definition, colour index M is less than 10, and plagiclase to total feldspar ratio is greater than 0.9. Less than 20 percent quartz and less than 10 percent feldspathoid in the QAPF fraction. QAPF field 10, 10*, and 10'.</dct:description>
      <skos:definition xml:lang="en">Leucocratic phaneritic crystalline igneous rock consisting essentially of plagioclase, often with small amounts of pyroxene. By definition, colour index M is less than 10, and plagiclase to total feldspar ratio is greater than 0.9. Less than 20 percent quartz and less than 10 percent feldspathoid in the QAPF fraction. QAPF field 10, 10*, and 10'.</skos:definition>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/foidBearingAnorthosite"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/quartzAnorthosite"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/anorthosite"/>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/phaneriticIgneousRock"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/applicationschema/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/theme/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/registry/governance-level/eu-technical"/>
      <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
   </rdf:Description>
