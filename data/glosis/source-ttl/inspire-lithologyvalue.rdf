      <dct:title xml:lang="en">crystalline carbonate</dct:title>
      <skos:prefLabel xml:lang="en">crystalline carbonate</skos:prefLabel>
      <dct:description xml:lang="en">Carbonate rock of indeterminate mineralogy in which diagenetic processes have obliterated any original depositional texture.</dct:description>
      <skos:definition xml:lang="en">Carbonate rock of indeterminate mineralogy in which diagenetic processes have obliterated any original depositional texture.</skos:definition>
