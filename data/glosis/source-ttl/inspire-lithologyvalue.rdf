      <dct:title xml:lang="en">carbonate mud</dct:title>
      <skos:prefLabel xml:lang="en">carbonate mud</skos:prefLabel>
      <dct:description xml:lang="en">Carbonate sediment composed of less than 25 percent clasts that have a maximum diameter more than 2 mm, and the ratio of sand size to mud size clasts is less than one.</dct:description>
      <skos:definition xml:lang="en">Carbonate sediment composed of less than 25 percent clasts that have a maximum diameter more than 2 mm, and the ratio of sand size to mud size clasts is less than one.</skos:definition>
