      <dct:title xml:lang="en">organic rich sediment</dct:title>
      <skos:prefLabel xml:lang="en">organic rich sediment</skos:prefLabel>
      <dct:description xml:lang="en">Sediment with color, composition, texture and apparent density indicating greater than 50 percent organic content by weight on a moisture-free basis.</dct:description>
      <skos:definition xml:lang="en">Sediment with color, composition, texture and apparent density indicating greater than 50 percent organic content by weight on a moisture-free basis.</skos:definition>
