      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/trachytoid"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/andesite"/>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/igneousRock"/>
