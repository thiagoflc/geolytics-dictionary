      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 17:30 PM UTC</dct:created>
      <dct:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-24 10:48 AM UTC</dct:issued>
      <dct:title xml:lang="en">impact generated material</dct:title>
      <skos:prefLabel xml:lang="en">impact generated material</skos:prefLabel>
      <dct:description xml:lang="en">Material that contains features indicative of shock metamorphism, such as microscopic planar deformation features within grains or shatter cones, interpreted to be the result of extraterrestrial bolide impact. Includes breccias and melt rocks.</dct:description>
      <skos:definition xml:lang="en">Material that contains features indicative of shock metamorphism, such as microscopic planar deformation features within grains or shatter cones, interpreted to be the result of extraterrestrial bolide impact. Includes breccias and melt rocks.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/compositeGenesisMaterial"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/applicationschema/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/theme/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/registry/governance-level/eu-legal"/>
      <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/invalid"/>
   </rdf:Description>
   <rdf:Description rdf:about="http://inspire.ec.europa.eu/codelist/LithologyValue/materialFormedInSurficialEnvironment">
      <dct:identifier rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">http://inspire.ec.europa.eu/codelist/LithologyValue/materialFormedInSurficialEnvironment</dct:identifier>
