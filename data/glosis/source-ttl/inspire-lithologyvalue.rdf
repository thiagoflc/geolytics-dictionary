      <dct:description xml:lang="en">Pyroclastic rock in which less than 25 percent of rock by volume are more than 64 mm in longest diameter. Includes tuff, lapilli tuff, and lapillistone.</dct:description>
      <skos:definition xml:lang="en">Pyroclastic rock in which less than 25 percent of rock by volume are more than 64 mm in longest diameter. Includes tuff, lapilli tuff, and lapillistone.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/pyroclasticRock"/>
