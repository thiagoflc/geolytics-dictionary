      <dct:title xml:lang="en">packstone</dct:title>
      <skos:prefLabel xml:lang="en">packstone</skos:prefLabel>
      <dct:description xml:lang="en">Carbonate sedimentary rock with discernible grain supported depositional texture, containing greater than 10 percent grains, and constituent particles are of intrabasinal origin; intergranular spaces are filled by matrix.</dct:description>
      <skos:definition xml:lang="en">Carbonate sedimentary rock with discernible grain supported depositional texture, containing greater than 10 percent grains, and constituent particles are of intrabasinal origin; intergranular spaces are filled by matrix.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/carbonateSedimentaryRock"/>
