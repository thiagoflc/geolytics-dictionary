      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:03 PM UTC</dct:created>
      <dct:title xml:lang="en">granitoid</dct:title>
      <skos:prefLabel xml:lang="en">granitoid</skos:prefLabel>
      <dct:description xml:lang="en">Phaneritic crystalline igneous rock consisting of quartz, alkali feldspar and/or plagioclase. Includes rocks defined modally in QAPF fields 2, 3, 4 and 5 as alkali feldspar granite, granite, granodiorite or tonalite.</dct:description>
      <skos:definition xml:lang="en">Phaneritic crystalline igneous rock consisting of quartz, alkali feldspar and/or plagioclase. Includes rocks defined modally in QAPF fields 2, 3, 4 and 5 as alkali feldspar granite, granite, granodiorite or tonalite.</skos:definition>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/granodiorite"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/tonalite"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/alkaliFeldsparGranite"/>
