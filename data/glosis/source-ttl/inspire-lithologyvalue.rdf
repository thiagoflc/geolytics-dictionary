      <skos:prefLabel xml:lang="en">sandstone</skos:prefLabel>
      <dct:description xml:lang="en">Clastic sedimentary rock in which less than 30 percent of particles are greater than 2 mm in diameter (gravel) and the sand to mud ratio is at least 1.</dct:description>
      <skos:definition xml:lang="en">Clastic sedimentary rock in which less than 30 percent of particles are greater than 2 mm in diameter (gravel) and the sand to mud ratio is at least 1.</skos:definition>
