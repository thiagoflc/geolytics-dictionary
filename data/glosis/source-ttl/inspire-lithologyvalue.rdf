      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 17:31 PM UTC</dct:created>
      <dct:title xml:lang="en">fragmental igneous material</dct:title>
      <skos:prefLabel xml:lang="en">fragmental igneous material</skos:prefLabel>
      <dct:description xml:lang="en">Igneous material of unspecified consolidation state in which greater than 75 percent of the rock consists of fragments produced as a result of igneous rock-forming process.</dct:description>
      <skos:definition xml:lang="en">Igneous material of unspecified consolidation state in which greater than 75 percent of the rock consists of fragments produced as a result of igneous rock-forming process.</skos:definition>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/fragmentalIgneousRock"/>
