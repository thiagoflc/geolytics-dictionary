      <dct:title xml:lang="en">impure carbonate sedimentary rock</dct:title>
      <skos:prefLabel xml:lang="en">impure carbonate sedimentary rock</skos:prefLabel>
      <dct:description xml:lang="en">Sedimentary rock in which between 50 and 90 percent of the primary and/or recrystallized constituents are composed of carbonate minerals.</dct:description>
      <skos:definition xml:lang="en">Sedimentary rock in which between 50 and 90 percent of the primary and/or recrystallized constituents are composed of carbonate minerals.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/carbonateSedimentaryRock"/>
