      <dct:title xml:lang="en">granofels</dct:title>
      <skos:prefLabel xml:lang="en">granofels</skos:prefLabel>
      <dct:description xml:lang="en">Metamorphic rock with granoblastic fabric and very little or no foliation (less than 10 percent of the mineral grains in the rock are elements in a planar or linear fabric). Grainsize not specified.</dct:description>
      <skos:definition xml:lang="en">Metamorphic rock with granoblastic fabric and very little or no foliation (less than 10 percent of the mineral grains in the rock are elements in a planar or linear fabric). Grainsize not specified.</skos:definition>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/hornfels"/>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/metamorphicRock"/>
