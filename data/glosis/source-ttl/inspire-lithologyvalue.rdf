      <dct:description xml:lang="en">Granite that has a plagiolcase to total feldspar ratio between 0.35 and 0.65. QAPF field 3b.</dct:description>
      <skos:definition xml:lang="en">Granite that has a plagiolcase to total feldspar ratio between 0.35 and 0.65. QAPF field 3b.</skos:definition>
