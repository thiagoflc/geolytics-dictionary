   </rdf:Description>
   <rdf:Description rdf:about="http://inspire.ec.europa.eu/codelist/LithologyValue/siltstone">
      <dct:identifier rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">http://inspire.ec.europa.eu/codelist/LithologyValue/siltstone</dct:identifier>
      <dcat:isPartOf>
         <dcat:Catalog rdf:about="http://inspire.ec.europa.eu/registry"/>
