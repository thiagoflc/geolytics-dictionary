      <dct:title xml:lang="en">composite genesis material</dct:title>
      <skos:prefLabel xml:lang="en">composite genesis material</skos:prefLabel>
      <dct:description xml:lang="en">Material of unspecified consolidation state formed by geological modification of pre-existing materials outside the realm of igneous and sedimentary processes.</dct:description>
      <skos:definition xml:lang="en">Material of unspecified consolidation state formed by geological modification of pre-existing materials outside the realm of igneous and sedimentary processes.</skos:definition>
