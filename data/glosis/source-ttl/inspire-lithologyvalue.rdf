      <dct:title xml:lang="en">exotic alkaline rock</dct:title>
      <skos:prefLabel xml:lang="en">exotic alkaline rock</skos:prefLabel>
      <dct:description xml:lang="en">Kimberlite, lamproite, or lamprophyre. Generally are potassic, mafic or ultramafic rocks. Olivine (commonly serpentinized in kimberlite), and phlogopite are significant constituents.</dct:description>
      <skos:definition xml:lang="en">Kimberlite, lamproite, or lamprophyre. Generally are potassic, mafic or ultramafic rocks. Olivine (commonly serpentinized in kimberlite), and phlogopite are significant constituents.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/exoticCompositionIgneousRock"/>
