      <dct:title xml:lang="en">biogenic sediment</dct:title>
      <skos:prefLabel xml:lang="en">biogenic sediment</skos:prefLabel>
      <dct:description xml:lang="en">Sediment composed of greater than 50 percent material of biogenic origin. Because the biogenic material may be skeletal remains that are not organic, all biogenic sediment is not necessarily organic-rich.</dct:description>
      <skos:definition xml:lang="en">Sediment composed of greater than 50 percent material of biogenic origin. Because the biogenic material may be skeletal remains that are not organic, all biogenic sediment is not necessarily organic-rich.</skos:definition>
