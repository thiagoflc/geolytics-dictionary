      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:02 PM UTC</dct:created>
      <dct:title xml:lang="en">carbonate sedimentary rock</dct:title>
      <skos:prefLabel xml:lang="en">carbonate sedimentary rock</skos:prefLabel>
      <dct:description xml:lang="en">Sedimentary rock in which at least 50 percent of the primary and/or recrystallized constituents are composed of one (or more) of the carbonate minerals calcite, aragonite, magnesite or dolomite.</dct:description>
      <skos:definition xml:lang="en">Sedimentary rock in which at least 50 percent of the primary and/or recrystallized constituents are composed of one (or more) of the carbonate minerals calcite, aragonite, magnesite or dolomite.</skos:definition>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/carbonateWackestone"/>
