      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:03 PM UTC</dct:created>
      <dct:title xml:lang="en">metamorphic rock</dct:title>
      <skos:prefLabel xml:lang="en">metamorphic rock</skos:prefLabel>
      <dct:description xml:lang="en">Rock formed by solid-state mineralogical, chemical and/or structural changes to a pre-existing rock, in response to marked changes in temperature, pressure, shearing stress and chemical environment.</dct:description>
      <skos:definition xml:lang="en">Rock formed by solid-state mineralogical, chemical and/or structural changes to a pre-existing rock, in response to marked changes in temperature, pressure, shearing stress and chemical environment.</skos:definition>
