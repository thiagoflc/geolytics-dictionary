      <dct:title xml:lang="en">sand</dct:title>
      <skos:prefLabel xml:lang="en">sand</skos:prefLabel>
      <dct:description xml:lang="en">Clastic sediment in which less than 30 percent of particles are gravel (greater than 2 mm in diameter) and the sand to mud ratio is at least 1. More than half of the particles are of epiclastic origin.</dct:description>
      <skos:definition xml:lang="en">Clastic sediment in which less than 30 percent of particles are gravel (greater than 2 mm in diameter) and the sand to mud ratio is at least 1. More than half of the particles are of epiclastic origin.</skos:definition>
