      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2016-06-07 09:21 AM UTC</dct:created>
      <dct:title xml:lang="en">kalsilitic and melilitic rock</dct:title>
      <skos:prefLabel xml:lang="en">kalsilitic and melilitic rock</skos:prefLabel>
      <dct:description xml:lang="en">Igneous rock containing greater than 10 percent melilite or kalsilite. Typically undersaturated, ultrapotassic (kalsilitic rocks) or calcium-rich (melilitic rocks) mafic or ultramafic rocks.</dct:description>
      <skos:definition xml:lang="en">Igneous rock containing greater than 10 percent melilite or kalsilite. Typically undersaturated, ultrapotassic (kalsilitic rocks) or calcium-rich (melilitic rocks) mafic or ultramafic rocks.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/exoticCompositionIgneousRock"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/applicationschema/ge"/>
