      <dct:title xml:lang="en">mudstone</dct:title>
      <skos:prefLabel xml:lang="en">mudstone</skos:prefLabel>
      <dct:description xml:lang="en">Clastic sedimentary rock consisting of less than 30 percent gravel-size (2 mm) particles and with a mud to sand ratio greater than 1.</dct:description>
      <skos:definition xml:lang="en">Clastic sedimentary rock consisting of less than 30 percent gravel-size (2 mm) particles and with a mud to sand ratio greater than 1.</skos:definition>
