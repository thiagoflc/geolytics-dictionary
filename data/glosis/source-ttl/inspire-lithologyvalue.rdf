      <dct:title xml:lang="en">mud size sediment</dct:title>
      <skos:prefLabel xml:lang="en">mud size sediment</skos:prefLabel>
      <dct:description xml:lang="en">Sediment consisting of less than 30 percent gravel-size (2 mm) particles and with a mud-size to sand-size particle ratio greater than 1. Clasts may be of any composition or origin.</dct:description>
      <skos:definition xml:lang="en">Sediment consisting of less than 30 percent gravel-size (2 mm) particles and with a mud-size to sand-size particle ratio greater than 1. Clasts may be of any composition or origin.</skos:definition>
