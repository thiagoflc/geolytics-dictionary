      <skos:prefLabel xml:lang="en">quartz rich igneous rock</skos:prefLabel>
      <dct:description xml:lang="en">Phaneritic crystalline igneous rock that contains less than 90 percent mafic minerals and contains greater than 60 percent quartz in the QAPF fraction.</dct:description>
