      <dct:title xml:lang="en">carbonate rich mud</dct:title>
      <skos:prefLabel xml:lang="en">carbonate rich mud</skos:prefLabel>
      <dct:description xml:lang="en">Mud size sediment that contains between 10 and 50 percent carbonate minerals in any size fraction. Carbonate origin is not specified.</dct:description>
