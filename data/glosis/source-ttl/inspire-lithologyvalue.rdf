      <dct:title xml:lang="en">impact generated material</dct:title>
      <skos:prefLabel xml:lang="en">impact generated material</skos:prefLabel>
      <dct:description xml:lang="en">Material that contains features indicative of shock metamorphism, such as microscopic planar deformation features within grains or shatter cones, interpreted to be the result of extraterrestrial bolide impact. Includes breccias and melt rocks.</dct:description>
      <skos:definition xml:lang="en">Material that contains features indicative of shock metamorphism, such as microscopic planar deformation features within grains or shatter cones, interpreted to be the result of extraterrestrial bolide impact. Includes breccias and melt rocks.</skos:definition>
