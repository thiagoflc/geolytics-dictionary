      </dcat:isPartOf>
      <dcat:isPartOf>
         <dcat:Catalog rdf:about="http://inspire.ec.europa.eu/codelist"/>
      </dcat:isPartOf>
      <owl:sameAs rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/anthrazit:1"/>
      <adms:last rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/anthrazit"/>
      <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
      <skos:inScheme rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue"/>
      <skos:topConceptOf rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue"/>
      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:01 PM UTC</dct:created>
      <dct:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2016-06-07 09:21 AM UTC</dct:issued>
      <dct:title xml:lang="en">anthrazit</dct:title>
      <skos:prefLabel xml:lang="en">anthrazit</skos:prefLabel>
      <dct:description xml:lang="en">Coal that has vitrinite mean random reflectance greater than 2.0% (determined in conformance with ISO 7404-5). Less than 12-14 percent volatiles (dry, ash free), greater than 91 percent fixed carbon (dry, ash free basis). The highest rank coal; very hard, glossy, black, with semimetallic luster, semi conchoidal fracture.</dct:description>
      <skos:definition xml:lang="en">Coal that has vitrinite mean random reflectance greater than 2.0% (determined in conformance with ISO 7404-5). Less than 12-14 percent volatiles (dry, ash free), greater than 91 percent fixed carbon (dry, ash free basis). The highest rank coal; very hard, glossy, black, with semimetallic luster, semi conchoidal fracture.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/coal"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/applicationschema/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/theme/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/registry/governance-level/eu-technical"/>
      <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/superseded"/>
   </rdf:Description>
   <rdf:Description rdf:about="http://inspire.ec.europa.eu/codelist/LithologyValue/bituminousCoal">
      <dct:identifier rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">http://inspire.ec.europa.eu/codelist/LithologyValue/bituminousCoal</dct:identifier>
