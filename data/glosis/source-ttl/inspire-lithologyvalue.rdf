      <skos:prefLabel xml:lang="en">ooze</skos:prefLabel>
      <dct:description xml:lang="en">Biogenic sediment consisting of less than 1 percent gravel-size (greater than or equal to 2 mm) particles, with a sand to mud ratio less than 1 to 9, and less than 50 percent carbonate minerals.</dct:description>
      <skos:definition xml:lang="en">Biogenic sediment consisting of less than 1 percent gravel-size (greater than or equal to 2 mm) particles, with a sand to mud ratio less than 1 to 9, and less than 50 percent carbonate minerals.</skos:definition>
