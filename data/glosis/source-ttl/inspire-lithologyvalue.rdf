      <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
   </rdf:Description>
   <rdf:Description rdf:about="http://inspire.ec.europa.eu/codelist/LithologyValue/granulite">
      <dct:identifier rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">http://inspire.ec.europa.eu/codelist/LithologyValue/granulite</dct:identifier>
      <dcat:isPartOf>
         <dcat:Catalog rdf:about="http://inspire.ec.europa.eu/registry"/>
      </dcat:isPartOf>
      <dcat:isPartOf>
         <dcat:Catalog rdf:about="http://inspire.ec.europa.eu/codelist"/>
      </dcat:isPartOf>
      <owl:sameAs rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/granulite:1"/>
      <adms:last rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/granulite"/>
      <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
      <skos:inScheme rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue"/>
      <skos:topConceptOf rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue"/>
      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:03 PM UTC</dct:created>
      <dct:title xml:lang="en">granulite</dct:title>
      <skos:prefLabel xml:lang="en">granulite</skos:prefLabel>
      <dct:description xml:lang="en">Metamorphic rock of high metamorphic grade in which Fe-Mg silicate minerals are dominantly hydroxl-free; feldspar must be present, and muscovite is absent; rock contains less than 90 percent mafic minerals, less than 75 percent calcite and/or dolomite, less than 75 percent quartz, less than 50 percent iron-bearing minerals (hematite, magnetite, limonite-group, siderite, iron-sulfides), and less than 50 percent calc-silicate minerals.</dct:description>
      <skos:definition xml:lang="en">Metamorphic rock of high metamorphic grade in which Fe-Mg silicate minerals are dominantly hydroxl-free; feldspar must be present, and muscovite is absent; rock contains less than 90 percent mafic minerals, less than 75 percent calcite and/or dolomite, less than 75 percent quartz, less than 50 percent iron-bearing minerals (hematite, magnetite, limonite-group, siderite, iron-sulfides), and less than 50 percent calc-silicate minerals.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/metamorphicRock"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/applicationschema/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/theme/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/registry/governance-level/eu-technical"/>
      <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
   </rdf:Description>
