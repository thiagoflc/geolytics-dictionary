      <dct:title xml:lang="en">syenogranite</dct:title>
      <skos:prefLabel xml:lang="en">syenogranite</skos:prefLabel>
      <dct:description xml:lang="en">Granite that has a plagiolcase to total feldspar ratio between 0.10 and 0.35. QAPF field 3a.</dct:description>
