      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 17:31 PM UTC</dct:created>
      <dct:title xml:lang="en">clastic sedimentary material</dct:title>
      <skos:prefLabel xml:lang="en">clastic sedimentary material</skos:prefLabel>
      <dct:description xml:lang="en">Sedimentary material of unspecified consolidation state in which at least 50 percent of the constituent particles were derived from erosion, weathering, or mass-wasting of pre-existing earth materials, and transported to the place of deposition by mechanical agents such as water, wind, ice and gravity.</dct:description>
      <skos:definition xml:lang="en">Sedimentary material of unspecified consolidation state in which at least 50 percent of the constituent particles were derived from erosion, weathering, or mass-wasting of pre-existing earth materials, and transported to the place of deposition by mechanical agents such as water, wind, ice and gravity.</skos:definition>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/clasticSediment"/>
      <skos:narrower rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/clasticSedimentaryRock"/>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/sedimentaryMaterial"/>
