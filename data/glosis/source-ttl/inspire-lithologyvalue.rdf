      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:02 PM UTC</dct:created>
      <dct:title xml:lang="en">calcareous carbonate sediment</dct:title>
      <skos:prefLabel xml:lang="en">calcareous carbonate sediment</skos:prefLabel>
      <dct:description xml:lang="en">Carbonate sediment with a calcite (plus aragonite) to dolomite ratio greater than 1 to 1. Includes lime-sediments.</dct:description>
