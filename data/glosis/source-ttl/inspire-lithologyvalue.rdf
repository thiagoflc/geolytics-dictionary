      <adms:last rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/diamicton"/>
      <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
      <skos:inScheme rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue"/>
      <skos:topConceptOf rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue"/>
      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:02 PM UTC</dct:created>
      <dct:title xml:lang="en">diamicton</dct:title>
      <skos:prefLabel xml:lang="en">diamicton</skos:prefLabel>
      <dct:description xml:lang="en">Unsorted or poorly sorted, clastic sediment with a wide range of particle sizes, including a muddy matrix. Biogenic materials that have such texture are excluded. Distinguished from conglomerate, sandstone, mudstone based on polymodality and lack of structures related to transport and deposition of sediment by moving air or water. Assignment to an other size class can be used in conjunction to indicate the dominant grain size.</dct:description>
      <skos:definition xml:lang="en">Unsorted or poorly sorted, clastic sediment with a wide range of particle sizes, including a muddy matrix. Biogenic materials that have such texture are excluded. Distinguished from conglomerate, sandstone, mudstone based on polymodality and lack of structures related to transport and deposition of sediment by moving air or water. Assignment to an other size class can be used in conjunction to indicate the dominant grain size.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/clasticSediment"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/applicationschema/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/theme/ge"/>
      <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/registry/governance-level/eu-technical"/>
      <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
   </rdf:Description>
