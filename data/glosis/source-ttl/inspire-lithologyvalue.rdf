      <dct:title xml:lang="en">tephritic phonolite</dct:title>
      <skos:prefLabel xml:lang="en">tephritic phonolite</skos:prefLabel>
      <dct:description xml:lang="en">Phonolitoid that has a plagioclase to total feldspar ratio between 0.1 and 0.5. Broadly corresponds to TAS tephriphonolite of TAS field U3.</dct:description>
      <skos:definition xml:lang="en">Phonolitoid that has a plagioclase to total feldspar ratio between 0.1 and 0.5. Broadly corresponds to TAS tephriphonolite of TAS field U3.</skos:definition>
