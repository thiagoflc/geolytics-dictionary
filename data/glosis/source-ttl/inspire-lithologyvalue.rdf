      <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-08-18 18:03 PM UTC</dct:created>
      <dct:title xml:lang="en">hornfels</dct:title>
      <skos:prefLabel xml:lang="en">hornfels</skos:prefLabel>
      <dct:description xml:lang="en">Granofels formed by contact metamorphism, composed of a mosaic of equidimensional grains in a characteristically granoblastic or decussate matrix; porphyroblasts or relict phenocrysts may be present. Typically fine grained.</dct:description>
      <skos:definition xml:lang="en">Granofels formed by contact metamorphism, composed of a mosaic of equidimensional grains in a characteristically granoblastic or decussate matrix; porphyroblasts or relict phenocrysts may be present. Typically fine grained.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/granofels"/>
