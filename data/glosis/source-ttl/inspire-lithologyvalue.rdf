      <dct:title xml:lang="en">gabbro</dct:title>
      <skos:prefLabel xml:lang="en">gabbro</skos:prefLabel>
      <dct:description xml:lang="en">Gabbroic rock that contains between 0 and 5 percent quartz and no feldspathoid mineral in the QAPF fraction. Includes rocks defined modally in QAPF Field 10 as gabbro.</dct:description>
      <skos:definition xml:lang="en">Gabbroic rock that contains between 0 and 5 percent quartz and no feldspathoid mineral in the QAPF fraction. Includes rocks defined modally in QAPF Field 10 as gabbro.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/gabbroicRock"/>
