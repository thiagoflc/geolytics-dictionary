      <dct:title xml:lang="en">aplite</dct:title>
      <skos:prefLabel xml:lang="en">aplite</skos:prefLabel>
      <dct:description xml:lang="en">Light coloured crystalline rock, characterized by a fine grained allotriomorphic-granular (aplitic, saccharoidal or xenomorphic) texture; typically granitic composition, consisting of quartz, alkali feldspar and sodic plagioclase.</dct:description>
      <skos:definition xml:lang="en">Light coloured crystalline rock, characterized by a fine grained allotriomorphic-granular (aplitic, saccharoidal or xenomorphic) texture; typically granitic composition, consisting of quartz, alkali feldspar and sodic plagioclase.</skos:definition>
      <skos:broader rdf:resource="http://inspire.ec.europa.eu/codelist/LithologyValue/phaneriticIgneousRock"/>
