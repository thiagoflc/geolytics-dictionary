# ── Geoquímica Orgânica e Inorgânica (M7_geochem) ──────────────────────────────────────
# System origin: GEOQWIN, Rock-Eval, GC
# Quantity-kind default: http://qudt.org/vocab/quantitykind/MassFraction

m7:analiseGeoquimica a owl:Class ;
    skos:prefLabel "AnaliseGeoquimica"@pt ;
    rdfs:subClassOf geox:analyticalObject ;
    skos:definition """Conjunto de análises sobre amostras para caracterização geoquímica"""@pt ;
    geox:moduleId "M7_geochem" ;
    geox:internalId "C101" ;
    rdfs:isDefinedBy <https://geolytics.petrobras.com.br/dict/modules> .

m7:rochaGeneradora a owl:Class ;
    skos:prefLabel "RochaGeneradora"@pt ;
    rdfs:subClassOf geox:formacaoGeologica ;
    skos:definition """Rocha rica em matéria orgânica capaz de gerar HC (source rock)"""@pt ;
    geox:moduleId "M7_geochem" ;
    geox:internalId "C102" ;
    rdfs:isDefinedBy <https://geolytics.petrobras.com.br/dict/modules> .

m7:rochaGeneradoraProperty a sosa:ObservableProperty ;
    skos:prefLabel "RochaGeneradora (property)"@pt ;
    qudt:hasQuantityKind <http://qudt.org/vocab/quantitykind/MassFraction> ;
    rdfs:isDefinedBy <https://geolytics.petrobras.com.br/dict/modules> .

m7:rochaGeneradoraValue a owl:Class ; rdfs:subClassOf qudt:Quantity ;
    skos:prefLabel "RochaGeneradora value"@pt ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty qudt:hasQuantityKind ; owl:hasValue <http://qudt.org/vocab/quantitykind/MassFraction> ] ;
    rdfs:isDefinedBy <https://geolytics.petrobras.com.br/dict/modules> .

m7:materiaOrganica a owl:Class ;
    skos:prefLabel "MateriaOrganica"@pt ;
    rdfs:subClassOf geox:geochemicalObject ;
    skos:definition """Substância orgânica preservada na rocha com potencial gerador"""@pt ;
    geox:moduleId "M7_geochem" ;
    geox:internalId "C103" ;
    rdfs:isDefinedBy <https://geolytics.petrobras.com.br/dict/modules> .

m7:maturidadeTermal a owl:Class ;
    skos:prefLabel "MaturidadeTermal"@pt ;
    rdfs:subClassOf geox:geochemicalProperty ;
    skos:definition """Estado de evolução termal da matéria orgânica (Ro% e Tmax)"""@pt ;
    geox:moduleId "M7_geochem" ;
