# ── Object properties for service-line relations ──

geo:executesServico a owl:ObjectProperty ;
    rdfs:label "executa serviço"@pt ;
    rdfs:label "executesServico"@en ;
    rdfs:comment "Service line parent executes a detailed acquisition record."@en ;
    rdfs:domain geo:GeologicalOperationsDocument ;
    rdfs:range geo:WellsiteAcquisitionRecord .

geo:acquiredDuring a owl:ObjectProperty ;
    rdfs:label "adquirido durante"@pt ;
    rdfs:label "acquiredDuring"@en ;
    rdfs:comment "A sidewall core sample is acquired during a wireline run."@en ;
    rdfs:domain geo:SidewallCoreSample ;
    rdfs:range geo:WirelineRun .

geo:hasPlug a owl:ObjectProperty ;
    rdfs:label "tem plugue"@pt ;
    rdfs:label "hasPlug"@en ;
    rdfs:comment "A core run yields one or more core plugs."@en ;
    rdfs:domain geo:CoreRun ;
    rdfs:range geo:CorePlug .

geo:feedsGeostoppingDecision a owl:ObjectProperty ;
    rdfs:label "alimenta decisão de geostopping"@pt ;
    rdfs:label "feedsGeostoppingDecision"@en ;
    rdfs:comment "An LWD run or gas show event feeds a geostopping decision."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range geo:GeostoppingEvent .

geo:storedInSirr a owl:ObjectProperty ;
    rdfs:label "armazenado no SIRR"@pt ;
    rdfs:label "storedInSirr"@en ;
    rdfs:comment "Definitive DST interpretation is stored in SIRR."@en ;
    rdfs:domain geo:DSTInterval ;
    rdfs:range geo:SIRR .

geo:storedInBdoc a owl:ObjectProperty ;
    rdfs:label "armazenado no BDOC"@pt ;
    rdfs:label "storedInBdoc"@en ;
    rdfs:comment "Raw acquisition files are stored in BDOC."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range geo:BDOC .

geo:documentsAnomaly a owl:ObjectProperty ;
    rdfs:label "documenta anomalia"@pt ;
    rdfs:label "documentsAnomaly"@en ;
    rdfs:comment "ROA documents anomalies of a wireline or LWD run."@en ;
    rdfs:domain geo:ROA ;
    rdfs:range owl:Thing .

geo:configures a owl:ObjectProperty ;
    rdfs:label "configura"@pt ;
    rdfs:label "configures"@en ;
    rdfs:comment "FRAME configures an LWD or wireline run."@en ;
    rdfs:domain geo:FRAME ;
    rdfs:range owl:Thing .

geo:extendsParent a owl:ObjectProperty ;
    rdfs:label "estende classe pai"@pt ;
    rdfs:label "extendsParent"@en ;
    rdfs:comment "A detailed-schema class extends a parent class in operacoes-geologicas.json."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing .

