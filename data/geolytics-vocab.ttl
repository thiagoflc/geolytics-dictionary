# ─────────────────────────────────────────────────────────────────────────────
# Service Line Detailed Schemas (operacoes-geologicas-servicos.json)
# 21 classes: 12 wellsite acquisition records + 9 supporting systems/documents
# ─────────────────────────────────────────────────────────────────────────────

# Abstract parent for the 12 detailed wellsite acquisition records
geo:WellsiteAcquisitionRecord a owl:Class ;
    rdfs:label "Registro de Aquisição em Poço"@pt ;
    rdfs:label "Wellsite Acquisition Record"@en ;
    skos:prefLabel "Registro de Aquisição em Poço"@pt ;
    skos:prefLabel "Wellsite Acquisition Record"@en ;
    skos:definition "Classe abstrata para registros detalhados produzidos pelas linhas de serviço de aquisição em poço (mudlogging, cuttings, coring, sidewall, LWD, wireline, formation testing, geostopping)."@pt ;
    skos:definition "Abstract class for detailed records produced by wellsite acquisition service lines (mudlogging, cuttings, coring, sidewall, LWD, wireline, formation testing, geostopping)."@en .

# Abstract parent for laboratory specimens (CorePlug, FluidSample)
geo:Specimen a owl:Class ;
    rdfs:label "Amostra"@pt ;
    rdfs:label "Specimen"@en ;
    skos:prefLabel "Amostra"@pt ;
    skos:prefLabel "Specimen"@en ;
    skos:definition "Classe abstrata para amostras físicas (plugues de testemunho, amostras de fluido) coletadas em poço para análise laboratorial."@pt ;
    rdfs:seeAlso <http://resource.geosciml.org/classifier/cgi/specimentype> .

geo:MudloggingTimeSeries a owl:Class ;
    rdfs:subClassOf geo:WellsiteAcquisitionRecord ;
    rdfs:label "Curvas de Tempo de Mudlogging"@pt ;
    rdfs:label "MudloggingTimeSeries"@en ;
    skos:prefLabel "Curvas de Tempo de Mudlogging"@pt ;
    skos:prefLabel "MudloggingTimeSeries"@en ;
    skos:altLabel "MudloggingSerieTemporal"@pt ;
    skos:definition "Fluxo contínuo de parâmetros de perfuração e análise de gás transmitido da sonda ao EXATA."@pt ;
    skos:definition "Continuous time-series stream of drilling parameters and gas analysis transmitted from the rig to EXATA."@en .

geo:GasShowEvent a owl:Class ;
    rdfs:subClassOf geo:WellsiteAcquisitionRecord ;
    rdfs:label "Evento Discreto de Indício de Hidrocarboneto"@pt ;
    rdfs:label "GasShowEvent"@en ;
    skos:prefLabel "Evento Discreto de Indício de Hidrocarboneto"@pt ;
    skos:prefLabel "GasShowEvent"@en ;
    skos:altLabel "EventoIndicioGas"@pt ;
    skos:definition "Evento discreto de indício de gás/óleo detectado durante o mudlogging."@pt ;
    skos:definition "Discrete gas/oil show event detected during mudlogging."@en .

geo:KickEvent a owl:Class ;
    rdfs:subClassOf geo:WellsiteAcquisitionRecord ;
    rdfs:label "Evento Discreto de Kick"@pt ;
    rdfs:label "KickEvent"@en ;
    skos:prefLabel "Evento Discreto de Kick"@pt ;
    skos:prefLabel "KickEvent"@en ;
    skos:altLabel "EventoKick"@pt ;
    skos:definition "Evento discreto de kick (influxo de formação)."@pt ;
    skos:definition "Discrete kick (formation influx) event."@en .

geo:CuttingsSampleDetailed a owl:Class ;
    rdfs:subClassOf geo:WellsiteAcquisitionRecord ;
    rdfs:label "Amostra de Calha (Esquema Detalhado)"@pt ;
    rdfs:label "CuttingsSampleDetailed"@en ;
    skos:prefLabel "Amostra de Calha (Esquema Detalhado)"@pt ;
    skos:prefLabel "CuttingsSampleDetailed"@en ;
    skos:altLabel "AmostraCalhaDetalhada"@pt ;
    skos:definition "Esquema detalhado de amostra de calha conforme PE-2EXP-00059, superando o stub leve do módulo pai."@pt ;
    skos:definition "Detailed cuttings sample schema per PE-2EXP-00059, superseding the lightweight CuttingsSampling stub in the parent module."@en .

geo:CoreRun a owl:Class ;
    rdfs:subClassOf geo:WellsiteAcquisitionRecord ;
    rdfs:label "Corrida de Testemunho"@pt ;
    rdfs:label "CoreRun"@en ;
    skos:prefLabel "Corrida de Testemunho"@pt ;
    skos:prefLabel "CoreRun"@en ;
    skos:altLabel "CorridaTestemunho"@pt ;
    skos:definition "Corrida única de testemunhagem em um wellbore — intervalos programado e recuperado, percentual de recuperação, tipo de tubo, contagens de plugues e FKs para OSDU/GeoSciML/BDIEP/SIGEO/QPG."@pt ;
    skos:definition "Single coring run on a wellbore — programmed and recovered intervals, recovery percentage, barrel type, plug counts and FKs to OSDU RockSample, GeoSciML Specimen and Petrobras BDIEP/SIGEO/QPG references."@en .

geo:CorePlug a owl:Class ;
    rdfs:subClassOf geo:Specimen ;
    rdfs:label "Plugue de Testemunho"@pt ;
    rdfs:label "CorePlug"@en ;
    skos:prefLabel "Plugue de Testemunho"@pt ;
    skos:prefLabel "CorePlug"@en ;
    skos:altLabel "PlugueTestemunho"@pt ;
    skos:definition "Plugue cilíndrico extraído de uma CoreRun para análise laboratorial."@pt ;
    skos:definition "Cylindrical plug extracted from a CoreRun for laboratory analysis (petrography, petrophysics, geomechanics, geochemistry)."@en .

geo:SidewallCoreSample a owl:Class ;
    rdfs:subClassOf geo:WellsiteAcquisitionRecord ;
    rdfs:label "Amostra Lateral (SWC)"@pt ;
    rdfs:label "SidewallCoreSample"@en ;
    skos:prefLabel "Amostra Lateral (SWC)"@pt ;
    skos:prefLabel "SidewallCoreSample"@en ;
    skos:altLabel "AmostraSidewallCore"@pt ;
    skos:definition "Amostra lateral (SWC) adquirida durante corrida wireline — ferramentas rotativas (RSCT), de percussão (CST) ou mecânicas."@pt ;
    skos:definition "Sidewall core sample (SWC) acquired during a wireline run — rotary (RSCT), percussion (CST) or mechanical tools."@en .

geo:LWDRun a owl:Class ;
    rdfs:subClassOf geo:WellsiteAcquisitionRecord ;
    rdfs:label "Corrida LWD/MWD"@pt ;
    rdfs:label "LWDRun"@en ;
    skos:prefLabel "Corrida LWD/MWD"@pt ;
    skos:prefLabel "LWDRun"@en ;
    skos:altLabel "CorridaLWD"@pt ;
    skos:definition "Corrida única LWD/MWD — fase, BHA, prestadora, stack de ferramentas, curvas em tempo real vs memória, versão WITSML, taxas de amostragem e ID do log no EXATA."@pt ;
    skos:definition "Single LWD/MWD run on a wellbore — phase, BHA, vendor, tool stack, real-time vs memory curves, WITSML version, sample rates and EXATA log id."@en .

geo:WirelineRun a owl:Class ;
    rdfs:subClassOf geo:WellsiteAcquisitionRecord ;
    rdfs:label "Corrida de Perfilagem a Cabo"@pt ;
    rdfs:label "WirelineRun"@en ;
    skos:prefLabel "Corrida de Perfilagem a Cabo"@pt ;
    skos:prefLabel "WirelineRun"@en ;
    skos:altLabel "CorridaWireline"@pt ;
    skos:definition "Corrida única de perfilagem a cabo conforme PE-2EXP-00065."@pt ;
    skos:definition "Single wireline run per PE-2EXP-00065."@en .

geo:FormationPressurePoint a owl:Class ;
    rdfs:subClassOf geo:WellsiteAcquisitionRecord ;
    rdfs:label "Ponto de Pressão de Formação (RFT/MDT/MiniDST)"@pt ;
    rdfs:label "FormationPressurePoint"@en ;
    skos:prefLabel "Ponto de Pressão de Formação (RFT/MDT/MiniDST)"@pt ;
    skos:prefLabel "FormationPressurePoint"@en ;
    skos:altLabel "PontoPressaoFormacao"@pt ;
    skos:definition "Medida única de pressão de formação (pretest) — RFT/MDT/XPT/FMT/MiniDST."@pt ;
    skos:definition "Single formation pressure measurement (pretest) — RFT, MDT, XPT, FMT or MiniDST."@en .

geo:DSTInterval a owl:Class ;
    rdfs:subClassOf geo:WellsiteAcquisitionRecord ;
    rdfs:label "Intervalo de Teste de Formação (DST)"@pt ;
    rdfs:label "DSTInterval"@en ;
    skos:prefLabel "Intervalo de Teste de Formação (DST)"@pt ;
    skos:prefLabel "DSTInterval"@en ;
    skos:altLabel "IntervaloDST"@pt ;
    skos:definition "Intervalo de DST conforme PE-2E&P-00773."@pt ;
    skos:definition "Drill Stem Test interval per PE-2E&P-00773."@en .

geo:GeostoppingEvent a owl:Class ;
    rdfs:subClassOf geo:WellsiteAcquisitionRecord ;
    rdfs:label "Evento de Geostopping"@pt ;
    rdfs:label "GeostoppingEvent"@en ;
    skos:prefLabel "Evento de Geostopping"@pt ;
    skos:prefLabel "GeostoppingEvent"@en ;
    skos:altLabel "EventoGeostopping"@pt ;
    skos:definition "Evento de decisão de geostopping — decisão em tempo real de parar a perfuração em profundidade precisa, baseada em curvas LWD, indícios de gás, tendência de MSE, mudança de fácies."@pt ;
    skos:definition "Geostopping decision event — real-time decision to stop drilling at a precise depth based on LWD curves, gas shows, MSE trend, facies change."@en .

geo:SIRR a owl:Class ;
    rdfs:subClassOf geo:GeologicalOperationsSystem ;
    rdfs:label "Sistema de Informações de Reservas e Reservatórios"@pt ;
    rdfs:label "SIRR"@en ;
    skos:prefLabel "Sistema de Informações de Reservas e Reservatórios"@pt ;
    skos:prefLabel "SIRR"@en ;
    skos:definition "Sistema canônico Petrobras para interpretações definitivas de DST e informações de reservas/reservatórios."@pt ;
    skos:definition "Petrobras canonical system for definitive DST interpretations and reservoir/reserve information."@en .

geo:BDOC a owl:Class ;
    rdfs:subClassOf geo:GeologicalOperationsSystem ;
    rdfs:label "Repositório Documental BDOC"@pt ;
    rdfs:label "BDOC"@en ;
    skos:prefLabel "Repositório Documental BDOC"@pt ;
    skos:prefLabel "BDOC"@en ;
    skos:definition "Repositório documental para arquivos brutos: LAS/DLIS (wireline/LWD), fotos de testemunho, FT1/FT2/FT5 (DST), projetos Saphir/PanSystem."@pt ;
    skos:definition "Document repository for raw acquisition files: LAS/DLIS (wireline/LWD), core photos, FT1/FT2/FT5 DST data files, Saphir/PanSystem interpretation projects."@en .

geo:VGE a owl:Class ;
    rdfs:subClassOf geo:GeologicalOperationsSystem ;
    rdfs:label "Visualizador de Geo-dados (acesso BDIEP)"@pt ;
    rdfs:label "VGE"@en ;
    skos:prefLabel "Visualizador de Geo-dados (acesso BDIEP)"@pt ;
    skos:prefLabel "VGE"@en ;
    skos:definition "Camada de visualização de geo-dados que provê acesso ao BDIEP."@pt ;
    skos:definition "Geo-data visualization layer providing user access to BDIEP."@en .

geo:ROA a owl:Class ;
    rdfs:subClassOf geo:GeologicalOperationsDocument ;
    rdfs:label "Relatório de Ocorrências Anômalas"@pt ;
    rdfs:label "ROA"@en ;
    skos:prefLabel "Relatório de Ocorrências Anômalas"@pt ;
    skos:prefLabel "ROA"@en ;
    skos:definition "Sub-documento do ROP registrando anomalias durante uma corrida wireline ou LWD."@pt ;
    skos:definition "Sub-document of ROP recording anomalies during a wireline or LWD run (tool failures, signal loss, BHA stuck, hole conditions)."@en .

geo:CassandraExataCurvaTempo a owl:Class ;
    rdfs:subClassOf geo:GeologicalOperationsSystem ;
    rdfs:label "Camada Cassandra — mdae.exata_curva_tempo"@pt ;
    rdfs:label "Cassandra_ExataCurvaTempo"@en ;
    skos:prefLabel "Camada Cassandra — mdae.exata_curva_tempo"@pt ;
    skos:prefLabel "Cassandra_ExataCurvaTempo"@en ;
    skos:definition "Camada de storage para séries temporais do EXATA."@pt ;
    skos:definition "Storage layer for EXATA time-series."@en .

geo:PAG a owl:Class ;
    rdfs:subClassOf geo:GeologicalOperationsDocument ;
    rdfs:label "Perfil de Acompanhamento Geológico"@pt ;
    rdfs:label "PAG"@en ;
    skos:prefLabel "Perfil de Acompanhamento Geológico"@pt ;
    skos:prefLabel "PAG"@en ;
    skos:definition "Documento operacional do mudlogging contendo parâmetros de perfuração, percentuais de litologia, interpretação litológica, indícios de hidrocarboneto e dados de fluidos."@pt ;
    skos:definition "Operational document from mudlogging containing drilling parameters, lithology percentages, lithology interpretation, hydrocarbon shows and fluid data."@en .

geo:FRAME a owl:Class ;
    rdfs:subClassOf geo:GeologicalOperationsDocument ;
    rdfs:label "Frame de Configuração de Aquisição"@pt ;
    rdfs:label "FRAME"@en ;
    skos:prefLabel "Frame de Configuração de Aquisição"@pt ;
    skos:prefLabel "FRAME"@en ;
    skos:definition "Documento de configuração da prestadora especificando curvas em tempo real, curvas em memória, offsets de ferramenta, números de série, ROP máximo, taxa de amostragem e taxa de transmissão para uma corrida LWD ou wireline."@pt ;
    skos:definition "Service company configuration document specifying realtime curves, memory curves, tool offsets, serial numbers, max ROP, sample rate and transmission rate for an LWD or wireline run."@en .

geo:FluidSample a owl:Class ;
    rdfs:subClassOf geo:Specimen ;
    rdfs:label "Amostra de Fluido"@pt ;
    rdfs:label "FluidSample"@en ;
    skos:prefLabel "Amostra de Fluido"@pt ;
    skos:prefLabel "FluidSample"@en ;
    skos:altLabel "AmostraFluido"@pt ;
    skos:definition "Amostra de fluido de reservatório coletada via ponto de pressão de formação (RFT/MDT/MiniDST) ou DST."@pt ;
    skos:definition "Reservoir fluid sample collected via formation pressure point (RFT/MDT/MiniDST) or DST."@en .

geo:BHA a owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "Bottom Hole Assembly"@pt ;
    rdfs:label "BHA"@en ;
    skos:prefLabel "Bottom Hole Assembly"@pt ;
    skos:prefLabel "BHA"@en ;
    skos:definition "Configuração da Bottom Hole Assembly — stack de componentes, comprimento total, peso, última atualização."@pt ;
    skos:definition "Bottom Hole Assembly configuration entity — components stack, total length, weight, last update."@en .

