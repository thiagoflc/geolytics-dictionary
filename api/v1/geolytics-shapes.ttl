        sh:message "CoreRun.geosciml_sample_id constraint."@en ;
    ] ;
    sh:property [
        sh:path geo:coreRunBdiepId ;
        sh:datatype xsd:string ;
        sh:message "CoreRun.bdiep_id constraint."@en ;
    ] ;
    sh:property [
        sh:path geo:coreRunSigeoId ;
        sh:datatype xsd:string ;
        sh:message "CoreRun.sigeo_id constraint."@en ;
    ] ;
    sh:property [
        sh:path geo:coreRunQpgReference ;
        sh:datatype xsd:string ;
        sh:message "CoreRun.qpg_reference constraint."@en ;
    ] ;
    sh:property [
        sh:path geo:coreRunRecordedAt ;
        sh:datatype xsd:dateTime ;
        sh:message "CoreRun.recorded_at constraint."@en ;
    ] ;
    sh:sparql [
        sh:message "CoreRun: depth_top_md must be <= depth_base_md."@en ;
        sh:select """
            PREFIX geo: <https://geolytics.petrobras.com.br/dict/>
            SELECT $this WHERE {
                $this geo:coreRunDepthTopMd ?t . $this geo:coreRunDepthBaseMd ?b . FILTER(?t > ?b)
            }
        """ ;
    ] ;
    sh:sparql [
        sh:message "CoreRun: depth_top_md_actual must be <= depth_base_md_actual."@en ;
        sh:select """
            PREFIX geo: <https://geolytics.petrobras.com.br/dict/>
            SELECT $this WHERE {
                $this geo:coreRunDepthTopMdActual ?t . $this geo:coreRunDepthBaseMdActual ?b . FILTER(?t > ?b)
            }
        """ ;
    ] .

