        sh:datatype xsd:double ;
        sh:minInclusive 0 ;
        sh:maxInclusive 100 ;
        sh:message "DSTInterval.watercut_pct constraint."@en ;
    ] ;
    sh:property [
        sh:path geo:dSTIntervalProductivityIndex ;
        sh:datatype xsd:double ;
        sh:message "DSTInterval.productivity_index constraint."@en ;
    ] ;
    sh:property [
        sh:path geo:dSTIntervalSkinFactor ;
        sh:datatype xsd:double ;
        sh:message "DSTInterval.skin_factor constraint."@en ;
    ] ;
    sh:property [
        sh:path geo:dSTIntervalTransmissibility ;
        sh:datatype xsd:double ;
        sh:message "DSTInterval.transmissibility constraint."@en ;
    ] ;
    sh:property [
        sh:path geo:dSTIntervalPermeabilityMd ;
        sh:datatype xsd:double ;
        sh:minInclusive 0 ;
        sh:message "DSTInterval.permeability_md constraint."@en ;
    ] ;
    sh:property [
        sh:path geo:dSTIntervalFt1FileUrl ;
        sh:datatype xsd:anyURI ;
        sh:message "DSTInterval.ft1_file_url constraint."@en ;
    ] ;
    sh:property [
        sh:path geo:dSTIntervalFt2FileUrl ;
        sh:datatype xsd:anyURI ;
        sh:message "DSTInterval.ft2_file_url constraint."@en ;
    ] ;
    sh:property [
        sh:path geo:dSTIntervalFt5FileUrl ;
        sh:datatype xsd:anyURI ;
        sh:message "DSTInterval.ft5_file_url constraint."@en ;
    ] ;
    sh:property [
        sh:path geo:dSTIntervalSaphirFileUrl ;
        sh:datatype xsd:anyURI ;
        sh:message "DSTInterval.saphir_file_url constraint."@en ;
    ] ;
    sh:sparql [
        sh:message "DSTInterval: depth_top_md must be <= depth_base_md."@en ;
        sh:select """
            PREFIX geo: <https://geolytics.petrobras.com.br/dict/>
            SELECT $this WHERE {
                $this geo:dSTIntervalDepthTopMd ?t . $this geo:dSTIntervalDepthBaseMd ?b . FILTER(?t > ?b)
            }
        """ ;
    ] .

geo:GeostoppingEventShape a sh:NodeShape ;
